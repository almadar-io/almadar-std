app std-project-manager "1.0.0"
"std-project-manager as a Function"

orbital TaskOrbital {
  entity Task [persistent: tasks] {
    id : string!
    title : string!
    description : string
    assignee : string
    priority : "low" | "medium" | "high" | "critical" = "medium"
    status : "todo" | "in-progress" | "review" | "done" = "todo"
    storyPoints : number = 0
    dueDate : datetime
    pendingId : string = ""
  }

  type TaskLoaded     = Event { data : [Task] }                  "Fired when Task finishes loading"
  type TaskLoadFailed = Event { error : string, code : string } "Fired when Task fails to load"
  type TaskSaved = Event { id : string }
  type TaskSaveFailed = Event { error : string, code : string }
  type TaskUpdated = Event { id : string }
  type TaskUpdateFailed = Event { error : string, code : string }
  type TaskDeleted = Event { id : string }
  type TaskDeleteFailed = Event { error : string, code : string }
  type SprintSaved = Event { id : string }
  type SprintSaveFailed = Event { error : string, code : string }
  type SprintUpdated = Event { id : string }
  type SprintUpdateFailed = Event { error : string, code : string }
  type SprintDeleted = Event { id : string }
  type SprintDeleteFailed = Event { error : string, code : string }
  trait TaskBrowse -> Task [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      TaskLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "ProjectManagerApp", navItems: [{ label: "Tasks", href: "/tasks", icon: "check-square" }, { label: "Sprints", href: "/sprints", icon: "zap" }, { label: "Burndown", href: "/burndown", icon: "layout-list" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-square" }, { type: "typography", content: "Tasks", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Task", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 1, children: [{ type: "stat-display", label: "Total Tasks", value: "@payload.data.length", icon: "check-square" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "title", variant: "h3", icon: "check-square" }, { name: "priority", variant: "badge" }, { name: "status", variant: "badge" }, { name: "assignee", variant: "body" }, { name: "storyPoints", label: "Points", variant: "body", format: "number" }, { name: "dueDate", label: "Due", variant: "caption", format: "date" }], cols: 2, gap: "md" }] }] })
      TaskLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load task" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    listens {
      TaskCreate TASK_CREATED -> INIT
      TaskEdit TASK_UPDATED -> INIT
      TaskDelete TASK_DELETED -> INIT
      * ASSIGN_TASK -> INIT
      VIEW { id : string!, row : Task }
      EDIT { id : string!, row : Task }
      DELETE { id : string!, row : Task }
          TaskLoadFailed { error : string, code : string }
    
      TaskSaveFailed { error : string, code : string }
      TaskUpdateFailed { error : string, code : string }
      TaskDeleteFailed { error : string, code : string }
      SprintSaveFailed { error : string, code : string }
      SprintUpdateFailed { error : string, code : string }
      SprintDeleteFailed { error : string, code : string }
    }
    emits: [TaskLoaded, TaskLoadFailed, TaskSaved, TaskSaveFailed, TaskUpdated, TaskUpdateFailed, TaskDeleted, TaskDeleteFailed, SprintSaved, SprintSaveFailed, SprintUpdated, SprintUpdateFailed, SprintDeleted, SprintDeleteFailed]
  }
  trait TaskCreate -> Task [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
      CREATE -> open
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Task", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "description", "assignee", "priority", "status", "storyPoints", "dueDate"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Task @payload.data { emit: { success: "TaskSaved", failure: "TaskSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit TASK_CREATED)
    }
    emits {
      TASK_CREATED external { id: string }
    }
    listens {
      SAVE { data : object! }
          TaskLoadFailed { error : string, code : string }
    }
    emits: [TaskLoadFailed, TaskLoaded, TaskSaveFailed, TaskSaved]
  }
  trait TaskEdit -> Task [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
      EDIT -> open
        (fetch Task {id: "@payload.id" , emit: { success: "TaskLoaded", failure: "TaskLoadFailed" }, emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Task", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "description", "assignee", "priority", "status", "storyPoints", "dueDate"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Task @payload.data { emit: { success: "TaskUpdated", failure: "TaskUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit TASK_UPDATED)
    }
    emits {
      TASK_UPDATED external { id: string }
    }
    listens {
      EDIT { id : string!, row : Task }
      SAVE { data : object! }
          TaskLoadFailed { error : string, code : string }
    }
    emits: [TaskLoadFailed, TaskLoaded, TaskUpdateFailed, TaskUpdated]
  }
  trait TaskView -> Task [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
      VIEW -> open
        (fetch Task {id: "@payload.id" , emit: { success: "TaskLoaded", failure: "TaskLoadFailed" }, emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.title" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Title" }, { type: "typography", variant: "body", content: "@entity.title" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Assignee" }, { type: "typography", variant: "body", content: "@entity.assignee" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Priority" }, { type: "typography", variant: "body", content: "@entity.priority" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Story Points" }, { type: "typography", variant: "body", content: "@entity.storyPoints" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Due Date" }, { type: "typography", variant: "body", content: "@entity.dueDate" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          TaskLoadFailed { error : string, code : string }
    }
    emits: [TaskLoaded, TaskLoadFailed]
  }
  trait TaskDelete -> Task [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Task {id: "@payload.id" , emit: { success: "TaskLoaded", failure: "TaskLoadFailed" }, emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Task", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Task @entity.pendingId { emit: { success: "TaskDeleted", failure: "TaskDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
        (emit TASK_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Task { emit: { success: "TaskLoaded", failure: "TaskLoadFailed" } })
    }
    emits {
      TASK_DELETED external { id: string }
    }
    listens {
      DELETE { id : string! }
          TaskLoadFailed { error : string, code : string }
    }
    emits: [TaskDeleteFailed, TaskDeleted, TaskLoadFailed, TaskLoaded]
  }
  page "/tasks" as TasksPage -> TaskBrowse, TaskCreate, TaskEdit, TaskView, TaskDelete
}
orbital SprintOrbital {
  entity Sprint [persistent: sprints] {
    id : string!
    name : string!
    startDate : datetime!
    endDate : datetime!
    goal : string
    status : "todo" | "in-progress" | "review" | "done" = "todo"
    taskCount : number
    pendingId : string = ""
  }

  type SprintLoaded     = Event { data : [Sprint] }                  "Fired when Sprint finishes loading"
  type SprintLoadFailed = Event { error : string, code : string } "Fired when Sprint fails to load"
  type SprintDeleteFailed = Event { error : string, code : string }
  type SprintDeleted = Event { id : string }
  type SprintSaveFailed = Event { error : string, code : string }
  type SprintSaved = Event { id : string }
  type SprintUpdateFailed = Event { error : string, code : string }
  type SprintUpdated = Event { id : string }
  trait SprintBrowse -> Sprint [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      SprintLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "ProjectManagerApp", navItems: [{ label: "Tasks", href: "/tasks", icon: "check-square" }, { label: "Sprints", href: "/sprints", icon: "zap" }, { label: "Burndown", href: "/burndown", icon: "layout-list" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "zap" }, { type: "typography", content: "Sprints", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Sprint", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "name", variant: "h3", icon: "zap" }, { name: "status", variant: "badge" }, { name: "goal", variant: "body" }, { name: "startDate", label: "Start", variant: "caption", format: "date" }, { name: "endDate", label: "End", variant: "caption", format: "date" }, { name: "taskCount", label: "Tasks", variant: "body", format: "number" }], cols: 2, gap: "md" }] }] })
      SprintLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load sprint" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      ASSIGN_TASK external { id: string }
      COMPLETE_SPRINT external { id: string }
    }
    listens {
      SprintCreate SPRINT_CREATED -> INIT
      SprintEdit SPRINT_UPDATED -> INIT
      SprintDelete SPRINT_DELETED -> INIT
          SprintLoadFailed { error : string, code : string }
    }
    emits: [SprintLoaded, SprintLoadFailed]
  }
  trait SprintCreate -> Sprint [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
      CREATE -> open
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Sprint", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "startDate", "endDate", "goal", "status", "taskCount"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Sprint @payload.data { emit: { success: "SprintSaved", failure: "SprintSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit SPRINT_CREATED)
    }
    emits {
      SPRINT_CREATED
    }
    emits: [SprintLoadFailed, SprintLoaded, SprintSaveFailed, SprintSaved]
    listens {
      SprintLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait SprintEdit -> Sprint [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
      EDIT -> open
        (fetch Sprint {id: "@payload.id" , emit: { success: "SprintLoaded", failure: "SprintLoadFailed" }, emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Sprint", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "startDate", "endDate", "goal", "status", "taskCount"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Sprint @payload.data { emit: { success: "SprintUpdated", failure: "SprintUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit SPRINT_UPDATED)
    }
    emits {
      SPRINT_UPDATED
    }
    emits: [SprintLoadFailed, SprintLoaded, SprintUpdateFailed, SprintUpdated]
    listens {
      SprintLoadFailed { error : string, code : string }
      EDIT { id : string, row : Sprint }
      SAVE { data : string }
    }
  }
  trait SprintView -> Sprint [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
      VIEW -> open
        (fetch Sprint {id: "@payload.id" , emit: { success: "SprintLoaded", failure: "SprintLoadFailed" }, emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Start Date" }, { type: "typography", variant: "body", content: "@entity.startDate" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "End Date" }, { type: "typography", variant: "body", content: "@entity.endDate" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Goal" }, { type: "typography", variant: "body", content: "@entity.goal" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Task Count" }, { type: "typography", variant: "body", content: "@entity.taskCount" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    emits: [SprintLoaded, SprintLoadFailed]
    listens {
      SprintLoadFailed { error : string, code : string }
      VIEW { id : string }
    }
  }
  trait SprintDelete -> Sprint [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Sprint {id: "@payload.id" , emit: { success: "SprintLoaded", failure: "SprintLoadFailed" }, emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Sprint", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Sprint @entity.pendingId { emit: { success: "SprintDeleted", failure: "SprintDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
        (emit SPRINT_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Sprint { emit: { success: "SprintLoaded", failure: "SprintLoadFailed" } })
    }
    emits {
      SPRINT_DELETED
    }
    emits: [SprintDeleteFailed, SprintDeleted, SprintLoadFailed, SprintLoaded]
    listens {
      SprintLoadFailed { error : string, code : string }
      DELETE { id : string }
    }
  }
  page "/sprints" -> SprintBrowse, SprintCreate, SprintEdit, SprintView, SprintDelete
}
orbital BurndownOrbital {
  entity Burndown [singleton] {
    id : string!
    totalPoints : number
    completedPoints : number
    remainingPoints : number
    velocity : number
    daysRemaining : number
  }

  type BurndownLoaded     = Event { data : [Burndown] }                  "Fired when Burndown finishes loading"
  type BurndownLoadFailed = Event { error : string, code : string } "Fired when Burndown fails to load"
  trait BurndownDisplay -> Burndown [interaction, collection] {
    initial: loading
    state loading {
      INIT -> displaying
        (fetch Burndown { emit: { success: "BurndownLoaded", failure: "BurndownLoadFailed" } })
