app std-marketing-campaign "1.0.0"
"Marketing campaigns: email/SMS broadcasts, audience segments, drip sequences, and message templates. Pick for marketing & advertising apps."

orbital CampaignOrbital {
  uses AppShell         from "std/behaviors/std-app-layout"
  uses Modal            from "std/behaviors/std-modal"
  uses Confirmation     from "std/behaviors/std-confirmation"
  uses Search           from "std/behaviors/std-search"
  uses Filter           from "std/behaviors/std-filter"
  uses Stats            from "std/behaviors/std-stats"
  uses Graphs           from "std/behaviors/std-graphs"
  uses BroadcastBuilder from "std/behaviors/std-broadcast-builder"
  uses Segment          from "std/behaviors/std-segment"
  uses DripSequence     from "std/behaviors/std-drip-sequence"
  uses TemplateEditor   from "std/behaviors/std-template-editor"

  entity Campaign [persistent: campaigns] {
    id          : string!
    name        : string!
    description : string = ""
    channel     : "email" | "sms" | "push" | "mixed" = "email"
    status      : "draft" | "scheduled" | "sending" | "sent" | "paused" = "draft"
    audience    : string = ""
    sendCount   : number = 0
    openRate    : number = 0
    clickRate   : number = 0
    scheduledAt : string = ""
    pendingId   : string = ""
  }

  type CampaignLoaded     = Event { data : [Campaign], totalCount : number } "Fired when Campaign collection finishes loading"
  type CampaignLoadFailed = Event { error : string, code : string }          "Fired when Campaign collection fails to load"

  trait CampaignAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.CampaignCatalog",
      appName: "Marketing",
      navItems: [
        { label: "Campaigns",  href: "/campaigns",  icon: "megaphone" },
        { label: "Broadcasts", href: "/broadcasts", icon: "send" },
        { label: "Segments",   href: "/segments",   icon: "users" },
        { label: "Sequences",  href: "/sequences",  icon: "mail" },
        { label: "Templates",  href: "/templates",  icon: "file-text" }
      ],
      searchEvent: "CAMPAIGN_SEARCH",
      notifications: [],
      notificationClickEvent: "CAMPAIGN_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: CAMPAIGN_SEARCH
      NOTIFY_CLICK: CAMPAIGN_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait. Owns the header (icon + Campaigns + New Campaign button)
  ;; + toolbar (search/filter) + stat row + graphs + embedded list. The
  ;; AppLayout's `contentTrait` points here.
  trait CampaignCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "megaphone" },
              { type: "typography", content: "Campaigns", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Campaign", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.CampaignSearch",
            "@trait.CampaignFilter"
          ]},
          "@trait.CampaignStats",
          "@trait.CampaignGraphs",
          { type: "divider" },
          "@trait.CampaignBrowseList"
        ]})
      CAMPAIGN_SEARCH -> composing
      CAMPAIGN_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to campaigns", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      CampaignAppLayout.CAMPAIGN_SEARCH -> CAMPAIGN_SEARCH
      CampaignAppLayout.CAMPAIGN_NOTIFICATIONS_OPEN -> CAMPAIGN_NOTIFICATIONS_OPEN
      CAMPAIGN_SEARCH { value : string }
      CAMPAIGN_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait CampaignSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search campaigns…",
      event: "CAMPAIGN_SEARCH"
    }
  }

  trait CampaignFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "channel", label: "Channel", filterType: "select", options: ["email", "sms", "push", "mixed"] },
        { field: "status",  label: "Status",  filterType: "select", options: ["draft", "scheduled", "sending", "sent", "paused"] }
      ],
      event: "CAMPAIGN_FILTER"
    }
  }

  trait CampaignStats = Stats.traits.StatsItemStats {
    config: {
      title: "Campaigns",
      metrics: [
        { aggregation: "count", label: "Total",     icon: "megaphone",    variant: "primary", format: "number" },
        { aggregation: "count", label: "Scheduled", icon: "clock",        variant: "info",    format: "number", filter: ["fn", "row", ["=", "@row.status", "scheduled"]] },
        { aggregation: "count", label: "Sent",      icon: "check-circle", variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "sent"]] },
        { aggregation: "avg",   label: "Open Rate", field: "openRate",    icon: "eye",        variant: "warning", format: "number", suffix: "%" }
      ]
    }
    listens {
      CampaignBrowseList.CampaignLoaded -> ITEMS_LOADED
    }
  }

  trait CampaignGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Campaigns by Channel",
      subtitle: "Volume across channels",
      chartType: "bar",
      categoryField: "channel",
      aggregation: "count",
      height: 240,
      showLegend: false
    }
    listens {
      CampaignBrowseList.CampaignLoaded -> ITEMS_LOADED
    }
  }

  ;; Custom browse trait for the Campaign collection — hand-authored because
  ;; std-browse isn't in this organism's import set. Emits CampaignLoaded for
  ;; Stats/Graphs and CREATE/EDIT/VIEW/DELETE for Modal/Confirmation refs.
  trait CampaignBrowseList -> Campaign [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch Campaign { emit: { success: "CampaignLoaded", failure: "CampaignLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading campaigns…" }] })
      CampaignLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [
          { type: "data-grid", entity: "@payload.data", fields: [
            { name: "name",        label: "Name",       variant: "h4",      icon: "megaphone" },
            { name: "channel",     label: "Channel",    variant: "badge" },
            { name: "status",      label: "Status",     variant: "badge" },
            { name: "audience",    label: "Audience",   variant: "caption" },
            { name: "sendCount",   label: "Sends",      variant: "body" },
            { name: "openRate",    label: "Opens %",    variant: "body" },
            { name: "clickRate",   label: "Clicks %",   variant: "body" },
            { name: "scheduledAt", label: "Scheduled",  variant: "caption", format: "date" }
          ], itemActions: [
            { label: "View",   event: "VIEW",   variant: "ghost" },
            { label: "Edit",   event: "EDIT",   variant: "ghost" },
            { label: "Delete", event: "DELETE", variant: "danger" }
          ], cols: 1, gap: "sm" }
        ]})
      CampaignLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load campaigns" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch Campaign { emit: { success: "CampaignLoaded", failure: "CampaignLoadFailed" } })
        (render-ui main { type: "spinner" })
      VIEW -> browsing
      EDIT -> browsing
      DELETE -> browsing
    }
    state error {
      INIT -> loading
        (fetch Campaign { emit: { success: "CampaignLoaded", failure: "CampaignLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      VIEW   -> external { id : string!, row : Campaign }
      EDIT   -> external { id : string!, row : Campaign }
      DELETE -> external { id : string!, row : Campaign }
      CampaignLoaded
      CampaignLoadFailed
    }
    listens {
      CampaignLoaded     { data : [Campaign], totalCount : number }
      CampaignLoadFailed { error : string, code : string }
      CampaignSearch.SEARCH               -> INIT
      CampaignFilter.FILTER               -> INIT
      CampaignPersistor.CAMPAIGN_CREATED  -> INIT
      CampaignPersistor.CAMPAIGN_UPDATED  -> INIT
      CampaignPersistor.CAMPAIGN_DELETED  -> INIT
    }
  }

  trait CampaignCreate = Modal.traits.ModalRecordModal -> Campaign {
    config: {
      icon: "plus-circle",
      title: "New Campaign",
      mode: "create",
      fields: ["name", "description", "channel", "audience", "scheduledAt"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      CampaignCatalog.CREATE -> CREATE
      CREATE { id : string, row : Campaign }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CampaignEdit = Modal.traits.ModalRecordModal -> Campaign {
    config: {
      icon: "edit",
      title: "Edit Campaign",
      mode: "edit",
      fields: ["name", "description", "channel", "status", "audience", "scheduledAt"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      CampaignBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Campaign }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CampaignView = Modal.traits.ModalRecordModal -> Campaign {
    config: {
      icon: "eye",
      title: "View Campaign",
      mode: "edit",
      fields: ["name", "description", "channel", "status", "audience", "sendCount", "openRate", "clickRate", "scheduledAt"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      CampaignBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Campaign }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CampaignDelete = Confirmation.traits.ConfirmActionConfirmation -> Campaign {
    config: {
      icon: "alert-triangle",
      title: "Delete Campaign",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      CampaignBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Campaign }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  ;; Coordinator: owns the persist side-effects triggered by Modal/Confirm
  ;; trait emits. Mirrors std-helpdesk's TicketPersistor.
  trait CampaignPersistor -> Campaign [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Campaign @payload.data { emit: { success: "CAMPAIGN_CREATED" } })
      DO_UPDATE -> idle
        (persist update Campaign @payload.data { emit: { success: "CAMPAIGN_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Campaign @payload.id { emit: { success: "CAMPAIGN_DELETED" } })
    }
    emits {
      CAMPAIGN_CREATED -> external { id : string }
      CAMPAIGN_UPDATED -> external { id : string }
      CAMPAIGN_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      CampaignCreate.SAVE          -> DO_CREATE
      CampaignEdit.SAVE            -> DO_UPDATE
      CampaignDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  ;; Sub-page bindings: each marketing primitive gets its own route, linked
  ;; from the AppShell navItems above. BroadcastBuilder is a molecule, so all
  ;; four of its internal traits are pulled together as a unit; Segment,
  ;; DripSequence and TemplateEditor are single-trait atoms.
  trait CampaignBroadcastBrowse    = BroadcastBuilder.traits.BroadcastDraftBrowse {}
  trait CampaignBroadcastCreate    = BroadcastBuilder.traits.BroadcastDraftCreate {
    listens {
      CampaignBroadcastBrowse.CREATE -> CREATE
      CREATE { id : string, row : object }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }
  trait CampaignBroadcastDelete    = BroadcastBuilder.traits.BroadcastDraftDelete {
    listens {
      CampaignBroadcastBrowse.REQUEST_DELETE -> DELETE
      DELETE { id : string, row : object }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }
  trait CampaignBroadcastPersistor = BroadcastBuilder.traits.BroadcastDraftPersistor {
    listens {
      DO_CREATE { data : object! }
      DO_DELETE { id : string }
      CampaignBroadcastCreate.SAVE           -> DO_CREATE
      CampaignBroadcastDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  trait CampaignSegment      = Segment.traits.SegmentSegment {
    config: { title: "Audience Segments" }
  }

  trait CampaignDripSequence = DripSequence.traits.DripSequenceSequence {
    config: { title: "Drip Sequences" }
  }

  trait CampaignTemplateEditor = TemplateEditor.traits.MessageTemplateEditor {
    config: { title: "Message Templates" }
  }

  page "/campaigns"  as CampaignsPage  -> CampaignAppLayout, CampaignCatalog, CampaignSearch, CampaignFilter, CampaignStats, CampaignGraphs, CampaignBrowseList, CampaignCreate, CampaignEdit, CampaignView, CampaignDelete, CampaignPersistor
  page "/broadcasts" as BroadcastsPage -> CampaignBroadcastBrowse, CampaignBroadcastCreate, CampaignBroadcastDelete, CampaignBroadcastPersistor
  page "/segments"   as SegmentsPage   -> CampaignSegment
  page "/sequences"  as SequencesPage  -> CampaignDripSequence
  page "/templates"  as TemplatesPage  -> CampaignTemplateEditor
}
