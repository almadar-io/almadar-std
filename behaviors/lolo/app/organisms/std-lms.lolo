app std-lms "1.0.0"
"LMS: courses, student enrollments, and lesson progress tracking."

orbital CourseOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  entity Course [runtime] {
    id : string!
    title : string = ""
    description : string = ""
    instructor : string = ""
    duration : string = ""
    level : "Beginner" | "Intermediate" | "Advanced" = "Beginner"
    pendingId : string = ""
  }

  trait CourseAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.CourseBrowse",
      appName: "LMS",
      navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }],
      searchEvent: "COURSE_SEARCH",
      notifications: [],
      notificationClickEvent: "COURSE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: COURSE_SEARCH
      NOTIFY_CLICK: COURSE_NOTIFICATIONS_OPEN
    }
  }

  type CourseLoaded     = Event { data : [Course] }                  "Fired when Course finishes loading"
  type CourseLoadFailed = Event { error : string, code : string } "Fired when Course fails to load"
  type CourseSaved = Event { id : string }
  type CourseSaveFailed = Event { error : string, code : string }
  type CourseUpdated = Event { id : string }
  type CourseUpdateFailed = Event { error : string, code : string }
  type CourseDeleted = Event { id : string }
  type CourseDeleteFailed = Event { error : string, code : string }
  type EnrollmentSaved = Event { id : string }
  type EnrollmentSaveFailed = Event { error : string, code : string }
  trait CourseBrowse -> Course [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      COURSE_SEARCH -> browsing
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Searching…" }] })
      COURSE_NOTIFICATIONS_OPEN -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [{ type: "icon", name: "bell" }, { type: "typography", variant: "h3", content: "No notifications" }, { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." }, { type: "button", label: "Back to courses", action: "INIT", variant: "ghost" }] })
      CourseLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "book-open" }, { type: "typography", content: "Courses", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Add Course", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "title", variant: "h3", icon: "book-open" }, { name: "level", variant: "badge" }, { name: "instructor", variant: "body" }, { name: "duration", variant: "body" }, { name: "description", variant: "caption" }], cols: 2, gap: "md" }] })
      CourseLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load course" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
ENROLL -> external { id: string }
CREATE
      VIEW { id : string!, row : Course }
EDIT { id : string!, row : Course }
DELETE { id : string!, row : Course }
CourseLoaded
      CourseLoadFailed
CourseSaved
      CourseSaveFailed
CourseUpdated
      CourseUpdateFailed
CourseDeleted
      CourseDeleteFailed
EnrollmentSaved
      EnrollmentSaveFailed
    }
    listens {
      CourseCreate.COURSE_CREATED -> INIT
      CourseEdit.COURSE_UPDATED -> INIT
      CourseDelete.COURSE_DELETED -> INIT
      CourseAppLayout.COURSE_SEARCH -> COURSE_SEARCH
      CourseAppLayout.COURSE_NOTIFICATIONS_OPEN -> COURSE_NOTIFICATIONS_OPEN
      VIEW { id : string!, row : Course }
      EDIT { id : string!, row : Course }
      DELETE { id : string!, row : Course }
      COURSE_SEARCH { value : string }
      COURSE_NOTIFICATIONS_OPEN { id : string }
          CourseLoadFailed { error : string, code : string }

      CourseSaveFailed { error : string, code : string }
      CourseUpdateFailed { error : string, code : string }
      CourseDeleteFailed { error : string, code : string }
      EnrollmentSaveFailed { error : string, code : string }
    }
  }
  trait CourseCreate -> Course [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
      CREATE -> open
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "New Course", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "description", "instructor", "duration", "level"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Course @payload.data { emit: { success: "CourseSaved", failure: "CourseSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit COURSE_CREATED)
    }
    emits {
COURSE_CREATED -> external { id: string }
CourseLoadFailed
      CourseLoaded
CourseSaveFailed
      CourseSaved
    }
    listens {
      SAVE { data : object! }
          CourseLoadFailed { error : string, code : string }
      CourseBrowse.CREATE -> CREATE
    }
  }
  trait CourseEdit -> Course [interaction, collection] {
    listens {
      CourseView.EDIT -> EDIT
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
      EDIT -> open
        (fetch Course {id: "@payload.id" , emit: { success: "CourseLoaded", failure: "CourseLoadFailed" }, emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Course", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "description", "instructor", "duration", "level"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Course @payload.data { emit: { success: "CourseUpdated", failure: "CourseUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit COURSE_UPDATED)
    }
    emits {
COURSE_UPDATED -> external { id: string }
CourseLoadFailed
      CourseLoaded
CourseUpdateFailed
      CourseUpdated
    }
    listens {
      EDIT { id : string!, row : Course }
      SAVE { data : object! }
          CourseLoadFailed { error : string, code : string }
      CourseBrowse.EDIT -> EDIT
    }
  }
  trait CourseView -> Course [interaction, collection] {
    emits {
EDIT { id : string }
CourseLoaded
      CourseLoadFailed
    }
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.description "")
        (set @entity.duration "")
        (set @entity.instructor "")
        (set @entity.level "Beginner")
        (set @entity.title "")
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
      VIEW -> open
        (fetch Course {id: "@payload.id" , emit: { success: "CourseLoaded", failure: "CourseLoadFailed" }, emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.title" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Title" }, { type: "typography", variant: "body", content: "@entity.title" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Instructor" }, { type: "typography", variant: "body", content: "@entity.instructor" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Duration" }, { type: "typography", variant: "body", content: "@entity.duration" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Level" }, { type: "typography", variant: "body", content: "@entity.level" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          CourseLoadFailed { error : string, code : string }
      CourseBrowse.VIEW -> VIEW
    }
  }
  trait CourseDelete -> Course [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Course {id: "@payload.id" , emit: { success: "CourseLoaded", failure: "CourseLoadFailed" }, emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Course", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Course @entity.pendingId { emit: { success: "CourseDeleted", failure: "CourseDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
        (emit COURSE_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Course { emit: { success: "CourseLoaded", failure: "CourseLoadFailed" } })
    }
    emits {
COURSE_DELETED -> external { id: string }
CourseDeleteFailed
      CourseDeleted
CourseLoadFailed
      CourseLoaded
    }
    listens {
      DELETE { id : string! }
          CourseLoadFailed { error : string, code : string }
      CourseBrowse.DELETE -> DELETE
    }
  }
  page "/courses" as CoursesPage -> CourseAppLayout, CourseBrowse, CourseCreate, CourseEdit, CourseView, CourseDelete
}
orbital EnrollmentOrbital {
  entity Enrollment [runtime] {
    id : string!
    studentName : string
    email : string
    courseId : string
    enrolledAt : datetime
    status : string
  }

  type EnrollmentLoaded     = Event { data : [Enrollment] }                  "Fired when Enrollment finishes loading"
  type EnrollmentLoadFailed = Event { error : string, code : string } "Fired when Enrollment fails to load"
  type EnrollmentSaveFailed = Event { error : string, code : string }
  type EnrollmentSaved = Event { id : string }
  trait EnrollmentWizard -> Enrollment [interaction, collection] {
    initial: step1
    state step1 {
      INIT -> step1
        (set @entity.courseId "")
        (set @entity.email "")
        (set @entity.enrolledAt "")
        (set @entity.status "")
        (set @entity.studentName "")
        (fetch Enrollment { emit: { success: "EnrollmentLoaded", failure: "EnrollmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Course Enrollment", variant: "h2" }] }, { type: "progress-dots", count: 2, currentIndex: 0 }, { type: "wizard-progress", steps: ["Student Info", "Course Selection"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Student Info", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["studentName", "email"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      NEXT -> step2
        (fetch Enrollment { emit: { success: "EnrollmentLoaded", failure: "EnrollmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Course Enrollment", variant: "h2" }] }, { type: "progress-dots", count: 2, currentIndex: 1 }, { type: "wizard-progress", steps: ["Student Info", "Course Selection"], currentStep: 1 }, { type: "divider" }, { type: "typography", content: "Course Selection", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["courseId"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
    state step2 {
      NEXT -> review
        (fetch Enrollment { emit: { success: "EnrollmentLoaded", failure: "EnrollmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Course Enrollment", variant: "h2" }] }, { type: "badge", label: "Review" }, { type: "wizard-progress", steps: ["Student Info", "Course Selection"], currentStep: 2 }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Student Name" }, { type: "typography", variant: "body", content: "@entity.studentName" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Course Id" }, { type: "typography", variant: "body", content: "@entity.courseId" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Enrolled At" }, { type: "typography", variant: "body", content: "@entity.enrolledAt" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }] }, { type: "wizard-navigation", currentStep: 2, totalSteps: 3, showBack: true, showComplete: true, showNext: false }] }] })
      PREV -> step1
        (fetch Enrollment { emit: { success: "EnrollmentLoaded", failure: "EnrollmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Course Enrollment", variant: "h2" }] }, { type: "progress-dots", count: 2, currentIndex: 0 }, { type: "wizard-progress", steps: ["Student Info", "Course Selection"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Student Info", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["studentName", "email"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
    state review {
      PREV -> step2
        (fetch Enrollment { emit: { success: "EnrollmentLoaded", failure: "EnrollmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Course Enrollment", variant: "h2" }] }, { type: "progress-dots", count: 2, currentIndex: 1 }, { type: "wizard-progress", steps: ["Student Info", "Course Selection"], currentStep: 1 }, { type: "divider" }, { type: "typography", content: "Course Selection", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["courseId"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      COMPLETE -> complete
        (persist create Enrollment @payload.data { emit: { success: "EnrollmentSaved", failure: "EnrollmentSaveFailed" } })
        (notify success "Enrollment created successfully")
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Enrolled!", variant: "h2" }, { type: "typography", content: "You have been successfully enrolled in the course.", variant: "body" }, { type: "button", label: "Start New", action: "RESTART", variant: "primary", icon: "refresh-cw" }] }] })
    }
    state complete {
      RESTART -> step1
        (fetch Enrollment { emit: { success: "EnrollmentLoaded", failure: "EnrollmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Course Enrollment", variant: "h2" }] }, { type: "progress-dots", count: 2, currentIndex: 0 }, { type: "wizard-progress", steps: ["Student Info", "Course Selection"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Student Info", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["studentName", "email"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      INIT -> step1
        (fetch Enrollment { emit: { success: "EnrollmentLoaded", failure: "EnrollmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "LMS", navItems: [{ label: "Courses", href: "/courses", icon: "book-open" }, { label: "Enroll", href: "/enroll", icon: "layout-list" }, { label: "Progress", href: "/progress", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Course Enrollment", variant: "h2" }] }, { type: "progress-dots", count: 2, currentIndex: 0 }, { type: "wizard-progress", steps: ["Student Info", "Course Selection"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Student Info", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["studentName", "email"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
    emits {
COMPLETE_LESSON -> external { id: string }
EnrollmentLoadFailed
      EnrollmentLoaded
EnrollmentSaveFailed
      EnrollmentSaved
    }
    listens {
      CourseOrbital.CourseBrowse.ENROLL -> INIT
          EnrollmentLoadFailed { error : string, code : string }
          COMPLETE { data : string }
    }
  }
  page "/enroll" -> EnrollmentWizard
}
orbital ProgressOrbital {
  entity Progress [runtime] {
    id : string!
    courseName : string
    lessonsCompleted : number
    totalLessons : number
    percentComplete : number
    lastActivity : datetime
  }

  type ProgressLoaded     = Event { data : [Progress] }                  "Fired when Progress finishes loading"
  type ProgressLoadFailed = Event { error : string, code : string } "Fired when Progress fails to load"
  trait ProgressDisplay -> Progress [interaction, collection] {
    initial: loading
    state loading {
      INIT -> displaying
        (set @entity.courseName "")
        (set @entity.lastActivity "")
