app std-cms "2.0.0"
"CMS: articles, media assets, categories. Pick for editorial/publishing platforms."

orbital ArticleOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Modal from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Search from "std/behaviors/std-search"
  uses Filter from "std/behaviors/std-filter"
  uses Stats from "std/behaviors/std-stats"
  uses Graphs from "std/behaviors/std-graphs"
  uses Browse from "std/behaviors/std-browse"
  uses Storage from "std/behaviors/std-service-storage"
  uses Audit from "std/behaviors/std-audit-capture"
  uses Lifecycle from "std/behaviors/std-lifecycle"
  uses Erasure from "std/behaviors/std-data-erasure"

  entity Article [persistent: articles] {
    id : string!
    title : string!
    slug : string!
    content : string
    author : string
    category : string
    status : "draft" | "review" | "published" | "archived" = "draft"
    publishedAt : datetime
    heroImage : string = ""
    pendingId : string = ""
  }

  trait ArticleAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.ArticleCatalog",
      appName: "CmsApp",
      navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }],
      searchEvent: "ARTICLE_SEARCH",
      notifications: [],
      notificationClickEvent: "ARTICLE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: ARTICLE_SEARCH
      NOTIFY_CLICK: ARTICLE_NOTIFICATIONS_OPEN
    }
  }

  trait ArticleCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "file-text" },
              { type: "typography", content: "Articles", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Create Article", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", children: ["@trait.ArticleSearch", "@trait.ArticleFilter"] },
          "@trait.ArticleStats",
          "@trait.ArticleGraphs",
          "@trait.ArticleBrowseList"
        ]})
      ARTICLE_SEARCH -> composing
      ARTICLE_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to articles", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      ArticleAppLayout.ARTICLE_SEARCH -> ARTICLE_SEARCH
      ArticleAppLayout.ARTICLE_NOTIFICATIONS_OPEN -> ARTICLE_NOTIFICATIONS_OPEN
      ARTICLE_SEARCH { value : string }
      ARTICLE_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait ArticleBrowseList = Browse.traits.BrowseItemBrowse -> Article {
    config: {
      fields: [
        { name: "title", variant: "h3", icon: "file-text" },
        { name: "status", variant: "badge" },
        { name: "author", variant: "caption" },
        { name: "category", variant: "badge" },
        { name: "publishedAt", variant: "caption" }
      ],
      imageField: "heroImage",
      itemActions: [
        { label: "View", event: "VIEW", variant: "ghost" },
        { label: "Edit", event: "EDIT", variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm",
      variant: "card"
    }
    listens {
      ArticlePersistor.ARTICLE_CREATED -> INIT
      ArticlePersistor.ARTICLE_UPDATED -> INIT
      ArticlePersistor.ARTICLE_DELETED -> INIT
    }
  }

  trait ArticleSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search articles...",
      searchEvent: "ARTICLE_SEARCH"
    }
  }

  trait ArticleFilter = Filter.traits.FilterTargetFilter {
    config: {
      facets: [
        { field: "status", label: "Status", values: ["draft", "published", "archived"] },
        { field: "category", label: "Category", values: [] }
      ]
    }
  }

  trait ArticleStats = Stats.traits.StatsItemStats {
    config: {
      metrics: [
        { label: "Total", aggregation: "count" },
        { label: "Published", aggregation: "count", filter: { status: "published" } },
        { label: "Drafts", aggregation: "count", filter: { status: "draft" } }
      ]
    }
    listens {
      ArticleBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait ArticleGraphs = Graphs.traits.GraphItemGraph {
    config: {
      chartType: "pie",
      categoryField: "status",
      title: "Articles by Status"
    }
    listens {
      ArticleBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait ArticleCreate = Modal.traits.ModalRecordModal -> Article {
    config: {
      mode: "create",
      icon: "plus-circle",
      title: "Create Article",
      fields: ["title", "slug", "content", "author", "category", "status", "publishedAt", "heroImage"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      ArticleCatalog.CREATE -> CREATE
      CREATE { id : string, row : Article }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ArticleEdit = Modal.traits.ModalRecordModal -> Article {
    config: {
      mode: "edit",
      icon: "edit",
      title: "Edit Article",
      fields: ["title", "slug", "content", "author", "category", "status", "publishedAt", "heroImage"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      ArticleBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Article }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ArticleView = Modal.traits.ModalRecordModal -> Article {
    config: {
      mode: "view",
      icon: "eye",
      title: "View Article",
      fields: ["title", "slug", "content", "author", "category", "status", "publishedAt", "heroImage"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      ArticleBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Article }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ArticleDelete = Confirmation.traits.ConfirmActionConfirmation -> Article {
    config: {
      icon: "alert-triangle",
      title: "Delete Article",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      ArticleBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Article }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait ArticleHeroImageUpload [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "sm", children: [
          { type: "input", inputType: "text", placeholder: "Paste hero image URL..." },
          { type: "button", label: "Upload Hero", action: "UPLOAD", variant: "secondary", icon: "upload" }
        ]})
      UPLOAD -> idle
        (call-service storage "upload" { bucket: "articles", acl: "public", file: "@payload.file" } { emit: { success: "ArticleHeroUploaded", failure: "ArticleHeroUploadFailed" } })
    }
    emits {
      ArticleHeroUploaded -> external { url : string }
      ArticleHeroUploadFailed { error : string, code : string }
      UPLOAD { source : string, file : string }
    }
    listens {
      UPLOAD { source : string, file : string }
      ArticleHeroUploadFailed { error : string, code : string }
    }
  }

  trait ArticlePersistor -> Article [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Article @payload.data { emit: { success: "ARTICLE_CREATED" } })
      DO_UPDATE -> idle
        (persist update Article @payload.data { emit: { success: "ARTICLE_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Article @payload.id { emit: { success: "ARTICLE_DELETED" } })
    }
    emits {
      ARTICLE_CREATED -> external { id : string }
      ARTICLE_UPDATED -> external { id : string }
      ARTICLE_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      ArticleCreate.SAVE -> DO_CREATE
      ArticleEdit.SAVE -> DO_UPDATE
      ArticleDelete.CONFIRM_DELETE -> DO_DELETE
      ArticleHeroImageUpload.ArticleHeroUploaded -> INIT
      ArticleHeroImageUpload.ArticleHeroUploadFailed -> INIT
    }
  }

  type ArticleLoaded = Event { data : [Article], totalCount : number } "Fired when Article finishes loading"
  type ArticleLoadFailed = Event { error : string, code : string } "Fired when Article fails to load"

  trait ArticleAuditCapture = Audit.traits.AuditCaptureListener {
    config: {
      captureEntity: "Article",
      captureEventTypes: [],
      excludeFields: [],
      captureBeforeAfter: true,
      retentionDays: 2555
    }
    events {
      EntityMutated: ARTICLE_UPDATED
    }
  }

  trait ArticleLifecycleScan = Lifecycle.traits.LifecycleScheduler {
    config: {
      targetEntity: "Article",
      rules: [
        { fromStatus: "draft",     toStatus: "review",    condition: { kind: "ageDays", value: 14, dateField: "publishedAt" } },
        { fromStatus: "published", toStatus: "archived",  condition: { kind: "ageDays", value: 365, dateField: "publishedAt" } }
      ],
      dryRun: false
    }
  }

  trait ArticleErasure = Erasure.traits.ErasureWorkflow {
    config: {
      targetEntity: "Article",
      gracePeriodDays: 30,
      anonymizeVsDelete: "anonymize",
      piiFields: ["author"]
    }
  }

  page "/articles" as ArticlesPage -> ArticleAppLayout, ArticleCatalog, ArticleBrowseList, ArticleSearch, ArticleFilter, ArticleStats, ArticleGraphs, ArticleHeroImageUpload, ArticleCreate, ArticleEdit, ArticleView, ArticleDelete, ArticlePersistor, ArticleAuditCapture, ArticleLifecycleScan, ArticleErasure
}

orbital MediaAssetOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Modal from "std/behaviors/std-modal"
  uses Gallery from "std/behaviors/std-gallery"
  uses Storage from "std/behaviors/std-service-storage"

  entity MediaAsset [persistent: mediaassets] {
    id : string!
    name : string!
    altText : string
    type : string
    url : string = ""
    pendingId : string = ""
  }

  trait MediaAssetAppLayout = AppShell.traits.AppLayout -> MediaAsset {
    config: {
      contentTrait: "@trait.MediaCatalog",
      appName: "CmsApp",
      navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }],
      searchEvent: "MEDIA_SEARCH",
      notifications: [],
      notificationClickEvent: "MEDIA_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: MEDIA_SEARCH
      NOTIFY_CLICK: MEDIA_NOTIFICATIONS_OPEN
    }
  }

  trait MediaCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "CmsApp", navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }], children: [
          { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
              { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
                { type: "icon", name: "image" },
                { type: "typography", content: "Media Library", variant: "h2" }
              ]},
              { type: "stack", direction: "horizontal", gap: "sm", children: [
                { type: "button", label: "Create MediaAsset", action: "CREATE", variant: "secondary", icon: "plus" }
              ]}
            ]},
            { type: "divider" },
            "@trait.MediaUpload",
            "@trait.MediaAssetGallery"
          ]}
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
  }

  trait MediaAssetGallery = Gallery.traits.GalleryItemGallery -> MediaAsset {
    config: {
      imageField: "url",
      titleField: "name",
      cols: 4,
      gap: "md"
    }
    listens {
      MediaUpload.MEDIA_UPLOADED -> INIT
      MediaPersistor.MEDIA_CREATED -> INIT
    }
  }

  trait MediaUpload [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "sm", align: "center", children: [
          { type: "input", inputType: "text", placeholder: "Paste file URL..." },
          { type: "button", label: "Upload File", action: "UPLOAD", variant: "primary", icon: "upload" }
        ]})
      UPLOAD -> uploading
        (call-service storage "upload" { bucket: "media", acl: "public", file: "@payload.file" } { emit: { success: "StorageUploaded", failure: "MediaUploadFailed" } })
        (render-ui main { type: "loading-state", title: "Uploading...", message: "Uploading file to storage." })
    }
    state uploading {
      StorageUploaded -> idle
        (persist create MediaAsset { name: "@payload.id", url: "@payload.url", type: "image" } { emit: { success: "MediaSaved", failure: "MediaUploadFailed" } })
        (emit MEDIA_UPLOADED { id: "@payload.id", url: "@payload.url" })
        (render-ui main { type: "stack", direction: "vertical", gap: "sm", align: "center", children: [
          { type: "icon", name: "check-circle" },
          { type: "alert", variant: "success", message: "Upload complete." },
          { type: "button", label: "Upload Another", action: "INIT", variant: "ghost" }
        ]})
      MediaUploadFailed -> idle
        (render-ui main { type: "error-state", title: "Upload Failed", message: "@payload.error", onRetry: "INIT" })
    }
    emits {
      MEDIA_UPLOADED -> external { id : string, url : string }
      StorageUploaded { id : string, url : string }
      MediaSaved { id : string }
      MediaUploadFailed { error : string, code : string }
      UPLOAD { source : string, file : string }
    }
    listens {
      UPLOAD { source : string, file : string }
      StorageUploaded { id : string, url : string }
      MediaUploadFailed { error : string, code : string }
    }
  }

  trait MediaAssetCreate = Modal.traits.ModalRecordModal -> MediaAsset {
    config: {
      mode: "create",
      icon: "plus-circle",
      title: "Add Media Asset",
      fields: ["name", "altText", "type", "url"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      MediaCatalog.CREATE -> CREATE
      CREATE { id : string, row : MediaAsset }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait MediaAssetView = Modal.traits.ModalRecordModal -> MediaAsset {
    config: {
      mode: "view",
      icon: "eye",
      title: "View Media Asset",
      fields: ["name", "altText", "type", "url"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      VIEW { id : string, row : MediaAsset }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait MediaPersistor -> MediaAsset [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create MediaAsset @payload.data { emit: { success: "MEDIA_CREATED" } })
      MediaSaved -> idle
    }
    emits {
      MEDIA_CREATED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      MediaSaved { id : string }
      MediaAssetCreate.SAVE -> DO_CREATE
      MediaUpload.MediaSaved -> MediaSaved
    }
  }

  type MediaAssetLoaded = Event { data : [MediaAsset], totalCount : number } "Fired when MediaAsset finishes loading"
  type MediaAssetLoadFailed = Event { error : string, code : string } "Fired when MediaAsset fails to load"

  page "/media" as MediaPage -> MediaAssetAppLayout, MediaCatalog, MediaAssetGallery, MediaUpload, MediaAssetCreate, MediaAssetView, MediaPersistor
}

orbital CategoryOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Modal from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Browse from "std/behaviors/std-browse"

  entity Category [persistent: categorys] {
    id : string!
    name : string!
    slug : string!
    description : string
    parentCategory : string
    articleCount : number
    pendingId : string = ""
  }

  trait CategoryAppLayout = AppShell.traits.AppLayout -> Category {
    config: {
      contentTrait: "@trait.CategoryCatalog",
      appName: "CmsApp",
      navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }],
      searchEvent: "CATEGORY_SEARCH",
      notifications: [],
      notificationClickEvent: "CATEGORY_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: CATEGORY_SEARCH
      NOTIFY_CLICK: CATEGORY_NOTIFICATIONS_OPEN
    }
  }

  trait CategoryCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "CmsApp", navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }], children: [
          { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
              { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
                { type: "icon", name: "folder" },
                { type: "typography", content: "Categories", variant: "h2" }
              ]},
              { type: "stack", direction: "horizontal", gap: "sm", children: [
                { type: "button", label: "Create Category", action: "CREATE", variant: "primary", icon: "plus" }
              ]}
            ]},
            { type: "divider" },
            "@trait.CategoryBrowseList"
          ]}
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
  }

  trait CategoryBrowseList = Browse.traits.BrowseItemBrowse -> Category {
    config: {
      fields: [
        { name: "name", variant: "h3", icon: "folder" },
        { name: "articleCount", label: "Articles", variant: "badge", format: "number" },
        { name: "description", variant: "body" },
        { name: "slug", variant: "caption" }
      ],
      itemActions: [
        { label: "View", event: "VIEW", variant: "ghost" },
        { label: "Edit", event: "EDIT", variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm",
      variant: "card"
    }
    listens {
      CategoryPersistor.CATEGORY_CREATED -> INIT
      CategoryPersistor.CATEGORY_UPDATED -> INIT
      CategoryPersistor.CATEGORY_DELETED -> INIT
    }
  }

  trait CategoryCreate = Modal.traits.ModalRecordModal -> Category {
    config: {
      mode: "create",
      icon: "plus-circle",
      title: "Create Category",
      fields: ["name", "slug", "description", "parentCategory", "articleCount"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      CategoryCatalog.CREATE -> CREATE
      CREATE { id : string, row : Category }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CategoryEdit = Modal.traits.ModalRecordModal -> Category {
    config: {
      mode: "edit",
      icon: "edit",
      title: "Edit Category",
      fields: ["name", "slug", "description", "parentCategory", "articleCount"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      CategoryBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Category }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CategoryView = Modal.traits.ModalRecordModal -> Category {
    config: {
      mode: "view",
      icon: "eye",
      title: "View Category",
      fields: ["name", "slug", "description", "parentCategory", "articleCount"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      CategoryBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Category }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CategoryDelete = Confirmation.traits.ConfirmActionConfirmation -> Category {
    config: {
      icon: "alert-triangle",
      title: "Delete Category",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      CategoryBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Category }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait CategoryPersistor -> Category [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Category @payload.data { emit: { success: "CATEGORY_CREATED" } })
      DO_UPDATE -> idle
        (persist update Category @payload.data { emit: { success: "CATEGORY_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Category @payload.id { emit: { success: "CATEGORY_DELETED" } })
    }
    emits {
      CATEGORY_CREATED -> external { id : string }
      CATEGORY_UPDATED -> external { id : string }
      CATEGORY_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      CategoryCreate.SAVE -> DO_CREATE
      CategoryEdit.SAVE -> DO_UPDATE
      CategoryDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  type CategoryLoaded = Event { data : [Category], totalCount : number } "Fired when Category finishes loading"
  type CategoryLoadFailed = Event { error : string, code : string } "Fired when Category fails to load"

  page "/categories" as CategoriesPage -> CategoryAppLayout, CategoryCatalog, CategoryBrowseList, CategoryCreate, CategoryEdit, CategoryView, CategoryDelete, CategoryPersistor
}

orbital CmsHubOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Browse from "std/behaviors/std-browse"

  entity CmsHub [runtime] {
    id : string!
  }

  entity HubArticle [persistent: articles] {
    id : string!
    title : string!
    slug : string!
    status : "draft" | "review" | "published" | "archived" = "draft"
    author : string
    category : string
    publishedAt : datetime
    heroImage : string = ""
  }

  trait CmsHubAppLayout = AppShell.traits.AppLayout -> HubArticle {
    config: {
      contentTrait: "@trait.CmsHubDisplay",
      appName: "CmsApp",
      navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }],
      searchEvent: "CMS_HUB_SEARCH",
      notifications: [],
      notificationClickEvent: "CMS_HUB_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: CMS_HUB_SEARCH
      NOTIFY_CLICK: CMS_HUB_NOTIFICATIONS_OPEN
    }
  }

  trait CmsHubDisplay [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "CmsApp", navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }], children: [
          { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "layout-grid" },
              { type: "typography", variant: "h2", content: "CMS Hub" }
            ]},
            { type: "divider" },
            { type: "typography", variant: "caption", color: "muted", content: "Recent articles across the platform" },
            "@trait.HubBrowseList"
          ]}
        ]})
    }
  }

  trait HubBrowseList = Browse.traits.BrowseItemBrowse -> HubArticle {
    config: {
      fields: [
        { name: "title", variant: "h3", icon: "file-text" },
        { name: "status", variant: "badge" },
        { name: "author", variant: "caption" },
        { name: "category", variant: "badge" }
      ],
      imageField: "heroImage",
      itemActions: [],
      cols: 1,
      gap: "sm",
      variant: "card"
    }
  }

  page "/cms-hub" as CmsHubPage -> CmsHubAppLayout, CmsHubDisplay, HubBrowseList
}
