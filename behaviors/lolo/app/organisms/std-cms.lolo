app std-cms "1.0.0"
"CMS: articles, media assets, categories. Pick for editorial/publishing platforms."

orbital ArticleOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  entity Article [persistent: articles] {
    id : string!
    title : string!
    slug : string!
    content : string
    author : string
    status : "draft" | "review" | "published" | "archived" = "draft"
    publishedAt : datetime
    pendingId : string = ""
  }

  trait CmsArticleAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.ArticleBrowse",
      appName: "CmsApp",
      navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }],
      searchEvent: "ARTICLE_SEARCH",
      notifications: [],
      notificationClickEvent: "NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: ARTICLE_SEARCH
      NOTIFY_CLICK: NOTIFICATIONS_OPEN
    }
  }

  type ArticleLoaded     = Event { data : [Article] }                  "Fired when Article finishes loading"
  type ArticleLoadFailed = Event { error : string, code : string } "Fired when Article fails to load"
  type ArticleSaved = Event { id : string }
  type ArticleSaveFailed = Event { error : string, code : string }
  type ArticleUpdated = Event { id : string }
  type ArticleUpdateFailed = Event { error : string, code : string }
  type ArticleDeleted = Event { id : string }
  type ArticleDeleteFailed = Event { error : string, code : string }
  type MediaAssetSaved = Event { id : string }
  type MediaAssetSaveFailed = Event { error : string, code : string }
  type CategorySaved = Event { id : string }
  type CategorySaveFailed = Event { error : string, code : string }
  type CategoryUpdated = Event { id : string }
  type CategoryUpdateFailed = Event { error : string, code : string }
  type CategoryDeleted = Event { id : string }
  type CategoryDeleteFailed = Event { error : string, code : string }
  trait ArticleBrowse -> Article [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      ARTICLE_SEARCH -> browsing
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Searching…" }] })
      NOTIFICATIONS_OPEN -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [{ type: "icon", name: "bell" }, { type: "typography", variant: "h3", content: "No notifications" }, { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." }, { type: "button", label: "Back to articles", action: "INIT", variant: "ghost" }] })
      ArticleLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "Articles", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Article", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "title", variant: "h3", icon: "file-text" }, { name: "status", variant: "badge" }, { name: "author", variant: "body" }, { name: "slug", variant: "caption" }, { name: "publishedAt", label: "Published", variant: "caption", format: "date" }], variant: "card", gap: "sm" }] })
      ArticleLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load article" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
PUBLISH -> external { id: string }
CATEGORIZE -> external { id: string }
CREATE
      VIEW { id : string!, row : Article }
EDIT { id : string!, row : Article }
DELETE { id : string!, row : Article }
ArticleLoaded
      ArticleLoadFailed
ArticleSaved
      ArticleSaveFailed
ArticleUpdated
      ArticleUpdateFailed
ArticleDeleted
      ArticleDeleteFailed
MediaAssetSaved
      MediaAssetSaveFailed
CategorySaved
      CategorySaveFailed
CategoryUpdated
      CategoryUpdateFailed
CategoryDeleted
      CategoryDeleteFailed
    }
    listens {
      ArticleCreate.ARTICLE_CREATED -> INIT
      ArticleEdit.ARTICLE_UPDATED -> INIT
      ArticleDelete.ARTICLE_DELETED -> INIT
      CmsArticleAppLayout.ARTICLE_SEARCH -> ARTICLE_SEARCH
      CmsArticleAppLayout.NOTIFICATIONS_OPEN -> NOTIFICATIONS_OPEN
      VIEW { id : string!, row : Article }
      EDIT { id : string!, row : Article }
      DELETE { id : string!, row : Article }
      ARTICLE_SEARCH { value : string }
      NOTIFICATIONS_OPEN { id : string }
          ArticleLoadFailed { error : string, code : string }

      ArticleSaveFailed { error : string, code : string }
      ArticleUpdateFailed { error : string, code : string }
      ArticleDeleteFailed { error : string, code : string }
      MediaAssetSaveFailed { error : string, code : string }
      CategorySaveFailed { error : string, code : string }
      CategoryUpdateFailed { error : string, code : string }
      CategoryDeleteFailed { error : string, code : string }
    }
  }
  trait ArticleCreate -> Article [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
      CREATE -> open
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Article", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "slug", "content", "author", "status", "publishedAt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Article @payload.data { emit: { success: "ArticleSaved", failure: "ArticleSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ARTICLE_CREATED)
    }
    emits {
ARTICLE_CREATED -> external { id: string }
ArticleLoadFailed
      ArticleLoaded
ArticleSaveFailed
      ArticleSaved
    }
    listens {
      SAVE { data : object! }
          ArticleLoadFailed { error : string, code : string }
      ArticleBrowse.CREATE -> CREATE
    }
  }
  trait ArticleEdit -> Article [interaction, collection] {
    listens {
      ArticleView.EDIT -> EDIT
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
      EDIT -> open
        (fetch Article {id: "@payload.id" , emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" }, emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Article", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "slug", "content", "author", "status", "publishedAt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Article @payload.data { emit: { success: "ArticleUpdated", failure: "ArticleUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit ARTICLE_UPDATED)
    }
    emits {
ARTICLE_UPDATED -> external { id: string }
ArticleLoadFailed
      ArticleLoaded
ArticleUpdateFailed
      ArticleUpdated
    }
    listens {
      EDIT { id : string!, row : Article }
      SAVE { data : object! }
          ArticleLoadFailed { error : string, code : string }
      ArticleBrowse.EDIT -> EDIT
    }
  }
  trait ArticleView -> Article [interaction, collection] {
    emits {
EDIT { id : string }
ArticleLoaded
      ArticleLoadFailed
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
      VIEW -> open
        (set @entity.title @payload.row.title)
        (set @entity.slug @payload.row.slug)
        (set @entity.content @payload.row.content)
        (set @entity.author @payload.row.author)
        (set @entity.status @payload.row.status)
        (set @entity.publishedAt @payload.row.publishedAt)
        (fetch Article {id: "@payload.id" , emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" }, emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.title" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Title" }, { type: "typography", variant: "body", content: "@entity.title" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Slug" }, { type: "typography", variant: "body", content: "@entity.slug" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Content" }, { type: "typography", variant: "body", content: "@entity.content" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Author" }, { type: "typography", variant: "body", content: "@entity.author" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Published At" }, { type: "typography", variant: "body", content: "@entity.publishedAt" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string!, row : Article }
      SAVE { data : object! }
          ArticleLoadFailed { error : string, code : string }
      ArticleBrowse.VIEW -> VIEW
    }
  }
  trait ArticleDelete -> Article [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Article {id: "@payload.id" , emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" }, emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Article", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Article @entity.pendingId { emit: { success: "ArticleDeleted", failure: "ArticleDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
        (emit ARTICLE_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Article { emit: { success: "ArticleLoaded", failure: "ArticleLoadFailed" } })
    }
    emits {
ARTICLE_DELETED -> external { id: string }
ArticleDeleteFailed
      ArticleDeleted
ArticleLoadFailed
      ArticleLoaded
    }
    listens {
      DELETE { id : string! }
          ArticleLoadFailed { error : string, code : string }
      ArticleBrowse.DELETE -> DELETE
    }
  }
  page "/articles" as ArticlesPage -> CmsArticleAppLayout, ArticleBrowse, ArticleCreate, ArticleEdit, ArticleView, ArticleDelete
}
orbital MediaAssetOrbital {
  entity MediaAsset [persistent: mediaassets] {
    id : string!
    fileName : string!
    fileType : string!
    fileSize : number
    url : string
    altText : string
    uploadedAt : datetime
  }

  type MediaAssetLoaded     = Event { data : [MediaAsset] }                  "Fired when MediaAsset finishes loading"
  type MediaAssetLoadFailed = Event { error : string, code : string } "Fired when MediaAsset fails to load"
  type MediaAssetSaveFailed = Event { error : string, code : string }
  type MediaAssetSaved = Event { id : string }
  trait MediaAssetBrowse -> MediaAsset [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch MediaAsset { emit: { success: "MediaAssetLoaded", failure: "MediaAssetLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      MediaAssetLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "CmsApp", navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "image" }, { type: "typography", content: "Media Library", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create MediaAsset", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }], fields: [{ name: "fileName", label: "File", variant: "h3", icon: "image" }, { name: "fileType", label: "Type", variant: "badge" }, { name: "fileSize", label: "Size", variant: "body", format: "number" }, { name: "altText", label: "Alt Text", variant: "caption" }], cols: 3, gap: "md" }] }] })
      MediaAssetLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load mediaasset" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
CREATE
      VIEW { id : string!, row : MediaAsset }
MediaAssetLoaded
      MediaAssetLoadFailed
    }
    listens {
      ArticleOrbital.ArticleBrowse.PUBLISH -> INIT
          MediaAssetLoadFailed { error : string, code : string }
    }
  }
  trait MediaAssetCreate -> MediaAsset [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch MediaAsset { emit: { success: "MediaAssetLoaded", failure: "MediaAssetLoadFailed" } })
      CREATE -> open
        (fetch MediaAsset { emit: { success: "MediaAssetLoaded", failure: "MediaAssetLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "New MediaAsset", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["fileName", "fileType", "fileSize", "url", "altText", "uploadedAt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create MediaAsset @payload.data { emit: { success: "MediaAssetSaved", failure: "MediaAssetSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
emits {
MediaAssetLoadFailed
      MediaAssetLoaded
MediaAssetSaveFailed
      MediaAssetSaved
    }

        listens {
      MediaAssetLoadFailed { error : string, code : string }
      SAVE { data : string }
      MediaAssetBrowse.CREATE -> CREATE
    }
  }
  trait MediaAssetView -> MediaAsset [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch MediaAsset { emit: { success: "MediaAssetLoaded", failure: "MediaAssetLoadFailed" } })
      VIEW -> open
        (set @entity.fileName @payload.row.fileName)
        (set @entity.fileType @payload.row.fileType)
        (set @entity.fileSize @payload.row.fileSize)
        (set @entity.url @payload.row.url)
        (set @entity.altText @payload.row.altText)
        (set @entity.uploadedAt @payload.row.uploadedAt)
        (fetch MediaAsset {id: "@payload.id" , emit: { success: "MediaAssetLoaded", failure: "MediaAssetLoadFailed" }, emit: { success: "MediaAssetLoaded", failure: "MediaAssetLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.fileName" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "File Name" }, { type: "typography", variant: "body", content: "@entity.fileName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "File Type" }, { type: "typography", variant: "body", content: "@entity.fileType" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "File Size" }, { type: "typography", variant: "body", content: "@entity.fileSize" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Url" }, { type: "typography", variant: "body", content: "@entity.url" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Alt Text" }, { type: "typography", variant: "body", content: "@entity.altText" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Uploaded At" }, { type: "typography", variant: "body", content: "@entity.uploadedAt" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
emits {
MediaAssetLoaded
      MediaAssetLoadFailed
    }

        listens {
      MediaAssetLoadFailed { error : string, code : string }
      VIEW { id : string!, row : MediaAsset }
      MediaAssetBrowse.VIEW -> VIEW
    }
  }
  page "/media" -> MediaAssetBrowse, MediaAssetCreate, MediaAssetView
}
orbital CategoryOrbital {
  entity Category [persistent: categorys] {
    id : string!
    name : string!
    slug : string!
    description : string
    parentCategory : string
    articleCount : number
    pendingId : string = ""
  }

  type CategoryLoaded     = Event { data : [Category] }                  "Fired when Category finishes loading"
  type CategoryLoadFailed = Event { error : string, code : string } "Fired when Category fails to load"
  type CategoryDeleteFailed = Event { error : string, code : string }
  type CategoryDeleted = Event { id : string }
  type CategorySaveFailed = Event { error : string, code : string }
  type CategorySaved = Event { id : string }
  type CategoryUpdateFailed = Event { error : string, code : string }
  type CategoryUpdated = Event { id : string }
  trait CategoryBrowse -> Category [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      CategoryLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "CmsApp", navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "folder" }, { type: "typography", content: "Categories", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Category", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "name", variant: "h3", icon: "folder" }, { name: "articleCount", label: "Articles", variant: "badge", format: "number" }, { name: "description", variant: "body" }, { name: "slug", variant: "caption" }], variant: "card", gap: "sm" }] }] })
      CategoryLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load category" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
CREATE
      VIEW { id : string!, row : Category }
EDIT { id : string!, row : Category }
DELETE { id : string!, row : Category }
CategoryLoaded
      CategoryLoadFailed
    }
    listens {
      CategoryCreate.CATEGORY_CREATED -> INIT
      CategoryEdit.CATEGORY_UPDATED -> INIT
      CategoryDelete.CATEGORY_DELETED -> INIT
      ArticleOrbital.ArticleBrowse.CATEGORIZE -> INIT
          CategoryLoadFailed { error : string, code : string }
    }
  }
  trait CategoryCreate -> Category [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
      CREATE -> open
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Category", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "slug", "description", "parentCategory", "articleCount"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Category @payload.data { emit: { success: "CategorySaved", failure: "CategorySaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit CATEGORY_CREATED)
    }
    emits {
CATEGORY_CREATED
      CategoryLoadFailed
CategoryLoaded
      CategorySaveFailed
CategorySaved
    
    }
    listens {
      CategoryLoadFailed { error : string, code : string }
      SAVE { data : string }
      CategoryBrowse.CREATE -> CREATE
    }
  }
  trait CategoryEdit -> Category [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
      EDIT -> open
        (fetch Category {id: "@payload.id" , emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" }, emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Category", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "slug", "description", "parentCategory", "articleCount"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Category @payload.data { emit: { success: "CategoryUpdated", failure: "CategoryUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit CATEGORY_UPDATED)
    }
    emits {
CATEGORY_UPDATED
      CategoryLoadFailed
CategoryLoaded
      CategoryUpdateFailed
CategoryUpdated
    
    }
    listens {
      CategoryView.EDIT -> EDIT
      CategoryLoadFailed { error : string, code : string }
      EDIT { id : string, row : Category }
      SAVE { data : string }
      CategoryBrowse.EDIT -> EDIT
    }
  }
  trait CategoryView -> Category [interaction, collection] {
    emits {
EDIT { id : string }
CategoryLoaded
      CategoryLoadFailed
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
      VIEW -> open
        (set @entity.name @payload.row.name)
        (set @entity.slug @payload.row.slug)
        (set @entity.description @payload.row.description)
        (set @entity.parentCategory @payload.row.parentCategory)
        (set @entity.articleCount @payload.row.articleCount)
        (fetch Category {id: "@payload.id" , emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" }, emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Slug" }, { type: "typography", variant: "body", content: "@entity.slug" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Parent Category" }, { type: "typography", variant: "body", content: "@entity.parentCategory" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Article Count" }, { type: "typography", variant: "body", content: "@entity.articleCount" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      CategoryLoadFailed { error : string, code : string }
      VIEW { id : string!, row : Category }
      CategoryBrowse.VIEW -> VIEW
    }
  }
  trait CategoryDelete -> Category [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Category {id: "@payload.id" , emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" }, emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Category", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Category @entity.pendingId { emit: { success: "CategoryDeleted", failure: "CategoryDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
        (emit CATEGORY_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Category { emit: { success: "CategoryLoaded", failure: "CategoryLoadFailed" } })
    }
    emits {
CATEGORY_DELETED
      CategoryDeleteFailed
CategoryDeleted
      CategoryLoadFailed
CategoryLoaded
    
    }
    listens {
      CategoryLoadFailed { error : string, code : string }
      DELETE { id : string }
      CategoryBrowse.DELETE -> DELETE
    }
  }
  page "/categories" -> CategoryBrowse, CategoryCreate, CategoryEdit, CategoryView, CategoryDelete
}

orbital CmsHubOrbital {
  uses Tabs from "std/behaviors/std-tabs"

  entity CmsHub [runtime] {
    id      : string!
    section : string = "articles"
  }

  trait CmsHubTabs = Tabs.traits.TabsItemTabs {
    config: {
      defaultTab: "articles",
      variant: "underline",
      tabs: [
        { id: "articles",   label: "Articles",   icon: "file-text" },
        { id: "media",      label: "Media",      icon: "image" },
        { id: "categories", label: "Categories", icon: "folder" }
      ]
    }
  }

  trait CmsHubLayout -> CmsHub [interaction, collection] {
    initial: viewing
    state viewing {
      INIT -> viewing
        (set @entity.section "articles")
        (render-ui main { type: "dashboard-layout", appName: "CmsApp", navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "layout-grid" }, { type: "typography", variant: "h2", content: "CMS Hub" }] }, { type: "divider" }, "@trait.CmsHubTabs", { type: "stack", direction: "vertical", gap: "sm", className: "p-4 border rounded-md", children: [{ type: "typography", variant: "overline", color: "secondary", content: "Active section" }, { type: "typography", variant: "h3", content: "@entity.section" }] }] }] })
      SECTION_CHANGED -> viewing
        (set @entity.section @payload.tabId)
        (render-ui main { type: "dashboard-layout", appName: "CmsApp", navItems: [{ label: "CMS Hub", href: "/cms-hub", icon: "layout-grid" }, { label: "Articles", href: "/articles", icon: "file-text" }, { label: "Media", href: "/media", icon: "image" }, { label: "Categories", href: "/categories", icon: "folder" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "layout-grid" }, { type: "typography", variant: "h2", content: "CMS Hub" }] }, { type: "divider" }, "@trait.CmsHubTabs", { type: "stack", direction: "vertical", gap: "sm", className: "p-4 border rounded-md", children: [{ type: "typography", variant: "overline", color: "secondary", content: "Active section" }, { type: "typography", variant: "h3", content: "@entity.section" }] }] }] })
    }
    listens {
      CmsHubTabs.TAB_CHANGED -> SECTION_CHANGED
      SECTION_CHANGED { tabId : string! }
    }
  }

  page "/cms-hub" as CmsHubPage -> CmsHubLayout, CmsHubTabs
}

