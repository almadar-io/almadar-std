app std-devops-dashboard "2.0.0"
"DevOps dashboard: services, alerts, logs, system metrics. Pick for SRE/observability."

orbital ServiceNodeOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Search       from "std/behaviors/std-search"
  uses Filter       from "std/behaviors/std-filter"
  uses Stats        from "std/behaviors/std-stats"
  uses Graphs       from "std/behaviors/std-graphs"
  uses Browse       from "std/behaviors/std-browse"

  entity ServiceNode [persistent: servicenodes] {
    id : string!
    name : string!
    status : "healthy" | "degraded" | "down" = "healthy"
    region : string = ""
    url : string = ""
    lastChecked : datetime
    failureCount : number = 0
    successCount : number = 0
    threshold : number = 5
    pendingId : string = ""
  }

  type ServiceNodeLoaded     = Event { data : [ServiceNode] }              "Fired when ServiceNode finishes loading"
  type ServiceNodeLoadFailed = Event { error : string, code : string }     "Fired when ServiceNode fails to load"

  trait ServiceNodeAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.ServiceNodeCatalog",
      appName: "DevOps Dashboard",
      navItems: [{ label: "Services", href: "/services", icon: "server" }, { label: "Alerts", href: "/alerts", icon: "bell" }, { label: "Logs", href: "/logs", icon: "terminal" }, { label: "Metrics", href: "/metrics", icon: "layout-list" }],
      searchEvent: "SERVICE_SEARCH",
      notifications: [],
      notificationClickEvent: "SERVICE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: SERVICE_SEARCH
      NOTIFY_CLICK: SERVICE_NOTIFICATIONS_OPEN
    }
  }

  trait ServiceNodeCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "server" },
              { type: "typography", content: "Services", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Register Service", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.ServiceNodeSearch",
            "@trait.ServiceNodeFilter"
          ]},
          "@trait.ServiceNodeStats",
          "@trait.ServiceNodeGraphs",
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
            { type: "status-dot", status: "online", pulse: false, label: "Healthy" },
            { type: "status-dot", status: "warning", pulse: false, label: "Degraded" },
            { type: "status-dot", status: "critical", pulse: true, label: "Down" }
          ]},
          "@trait.ServiceNodeBrowseList",
          { type: "divider" },
          "@trait.ServiceNodeCircuitBreaker"
        ]})
      SERVICE_SEARCH -> composing
      SERVICE_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to services", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      ServiceNodeAppLayout.SERVICE_SEARCH -> SERVICE_SEARCH
      ServiceNodeAppLayout.SERVICE_NOTIFICATIONS_OPEN -> SERVICE_NOTIFICATIONS_OPEN
      SERVICE_SEARCH { value : string }
      SERVICE_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait ServiceNodeSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search services…",
      event: "SERVICE_SEARCH"
    }
  }

  trait ServiceNodeFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "status", label: "Status", filterType: "select", options: ["healthy", "degraded", "down"] },
        { field: "region", label: "Region", filterType: "select", options: ["us-east", "us-west", "eu-central", "ap-south"] }
      ],
      event: "SERVICE_FILTER"
    }
  }

  trait ServiceNodeStats = Stats.traits.StatsItemStats {
    config: {
      title: "Services",
      metrics: [
        { aggregation: "count", label: "Total",    icon: "server",       variant: "primary", format: "number" },
        { aggregation: "count", label: "Healthy",  icon: "check-circle", variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "healthy"]] },
        { aggregation: "count", label: "Degraded", icon: "alert-circle", variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "degraded"]] },
        { aggregation: "count", label: "Down",     icon: "alert-triangle", variant: "error",  format: "number", filter: ["fn", "row", ["=", "@row.status", "down"]] }
      ]
    }
    listens {
      ServiceNodeBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait ServiceNodeGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Services by Status",
      subtitle: "Health distribution across the fleet",
      chartType: "pie",
      categoryField: "status",
      aggregation: "count",
      height: 240,
      showLegend: true
    }
    listens {
      ServiceNodeBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait ServiceNodeBrowseList = Browse.traits.BrowseItemBrowse -> ServiceNode {
    config: {
      fields: [
        { name: "name",        variant: "h4",      icon: "server" },
        { name: "status",      variant: "badge" },
        { name: "region",      variant: "body" },
        { name: "lastChecked", variant: "caption", format: "date" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      ServiceNodeSearch.SEARCH                 -> REFETCH_QUERY
      ServiceNodeFilter.FILTER                 -> REFETCH_FILTER
      ServiceNodePersistor.SERVICE_CREATED     -> INIT
      ServiceNodePersistor.SERVICE_UPDATED     -> INIT
      ServiceNodePersistor.SERVICE_DELETED     -> INIT
    }
  }

  trait ServiceNodeCreate = Modal.traits.ModalRecordModal -> ServiceNode {
    config: {
      icon: "plus-circle",
      title: "Register Service",
      mode: "create",
      fields: ["name", "status", "region", "url", "threshold"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      ServiceNodeCatalog.CREATE -> CREATE
      CREATE { id : string, row : ServiceNode }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ServiceNodeEdit = Modal.traits.ModalRecordModal -> ServiceNode {
    config: {
      icon: "edit",
      title: "Edit Service",
      mode: "edit",
      fields: ["name", "status", "region", "url", "threshold"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      ServiceNodeBrowseList.EDIT -> EDIT
      EDIT { id : string, row : ServiceNode }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ServiceNodeView = Modal.traits.ModalRecordModal -> ServiceNode {
    config: {
      icon: "eye",
      title: "View Service",
      mode: "edit",
      fields: ["name", "status", "region", "url", "lastChecked", "failureCount", "successCount", "threshold"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      ServiceNodeBrowseList.VIEW -> VIEW
      VIEW { id : string, row : ServiceNode }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ServiceNodeDelete = Confirmation.traits.ConfirmActionConfirmation -> ServiceNode {
    config: {
      icon: "alert-triangle",
      title: "Delete Service",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      ServiceNodeBrowseList.DELETE -> DELETE
      DELETE { id : string, row : ServiceNode }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait ServiceNodePersistor -> ServiceNode [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create ServiceNode @payload.data { emit: { success: "SERVICE_CREATED" } })
      DO_UPDATE -> idle
        (persist update ServiceNode @payload.data { emit: { success: "SERVICE_UPDATED" } })
      DO_DELETE -> idle
        (persist delete ServiceNode @payload.id { emit: { success: "SERVICE_DELETED" } })
    }
    emits {
      SERVICE_CREATED -> external { id : string }
      SERVICE_UPDATED -> external { id : string }
      SERVICE_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      ServiceNodeCreate.SAVE          -> DO_CREATE
      ServiceNodeEdit.SAVE            -> DO_UPDATE
      ServiceNodeDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  ;; Circuit-breaker state machine — kept inline because the topology
  ;; (closed -> open -> halfOpen) is the whole point of the trait.
  trait ServiceNodeCircuitBreaker -> ServiceNode [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.failureCount 0)
        (set @entity.successCount 0)
        (set @entity.threshold 5)
        (fetch ServiceNode { emit: { success: "ServiceNodeLoaded", failure: "ServiceNodeLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "shield-check" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "online", pulse: false, label: "Circuit Closed" }] }, { type: "alert", variant: "success", message: "All requests are being processed." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }, { type: "meter", value: "@entity.failureCount", min: 0, max: "@entity.threshold" }] })
      FAILURE -> open
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "critical", pulse: true, label: "Circuit Open" }] }, { type: "alert", variant: "error", message: "Circuit is open. Requests are being rejected to prevent cascading failures." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }, { type: "meter", value: "@entity.failureCount", min: 0, max: "@entity.threshold" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      SUCCESS -> closed
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "shield-check" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "online", pulse: false, label: "Circuit Closed" }] }, { type: "alert", variant: "success", message: "All requests are being processed." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }, { type: "meter", value: "@entity.failureCount", min: 0, max: "@entity.threshold" }] })
    }
    state open {
      TIMEOUT -> halfOpen
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "activity" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "warning", pulse: true, label: "Half-Open" }] }, { type: "alert", variant: "warning", message: "Testing recovery. Limited requests are being allowed through." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }] })
      RESET -> closed
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "shield-check" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "online", pulse: false, label: "Circuit Closed" }] }, { type: "alert", variant: "success", message: "All requests are being processed." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }, { type: "meter", value: "@entity.failureCount", min: 0, max: "@entity.threshold" }] })
    }
    state halfOpen {
      SUCCESS -> closed
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "shield-check" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "online", pulse: false, label: "Circuit Closed" }] }, { type: "alert", variant: "success", message: "All requests are being processed." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }, { type: "meter", value: "@entity.failureCount", min: 0, max: "@entity.threshold" }] })
      FAILURE -> open
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "critical", pulse: true, label: "Circuit Open" }] }, { type: "alert", variant: "error", message: "Circuit is open. Requests are being rejected to prevent cascading failures." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }, { type: "meter", value: "@entity.failureCount", min: 0, max: "@entity.threshold" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      RESET -> closed
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "shield-check" }, { type: "typography", content: "Circuit Breaker", variant: "h3" }] }, { type: "status-dot", status: "online", pulse: false, label: "Circuit Closed" }] }, { type: "alert", variant: "success", message: "All requests are being processed." }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Failures", value: "@entity.failureCount" }, { type: "stat-display", label: "Successes", value: "@entity.successCount" }] }, { type: "meter", value: "@entity.failureCount", min: 0, max: "@entity.threshold" }] })
    }
    emits {
      ServiceNodeLoaded
      ServiceNodeLoadFailed
    }
    listens {
      ServiceNodeLoadFailed { error : string, code : string }
    }
  }

  page "/services" as ServicesPage -> ServiceNodeAppLayout, ServiceNodeCatalog, ServiceNodeSearch, ServiceNodeFilter, ServiceNodeStats, ServiceNodeGraphs, ServiceNodeBrowseList, ServiceNodeCreate, ServiceNodeEdit, ServiceNodeView, ServiceNodeDelete, ServiceNodePersistor, ServiceNodeCircuitBreaker
}

orbital AlertMetricOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Browse       from "std/behaviors/std-browse"
  uses Email        from "std/behaviors/std-service-email"

  entity AlertMetric [persistent: alertmetrics] {
    id : string!
    severity : "info" | "warning" | "critical" = "info"
    message : string!
    timestamp : datetime
    source : string = ""
    pendingId : string = ""
  }

  trait AlertMetricAppLayout = AppShell.traits.AppLayout -> AlertMetric {
    config: {
      contentTrait: "@trait.AlertCatalog",
      appName: "DevOps Dashboard",
      navItems: [{ label: "Services", href: "/services", icon: "server" }, { label: "Alerts", href: "/alerts", icon: "bell" }, { label: "Logs", href: "/logs", icon: "terminal" }, { label: "Metrics", href: "/metrics", icon: "layout-list" }],
      searchEvent: "ALERT_SEARCH",
      notifications: [],
      notificationClickEvent: "ALERT_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: ALERT_SEARCH
      NOTIFY_CLICK: ALERT_NOTIFICATIONS_OPEN
    }
  }

  trait AlertCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "bell" },
              { type: "typography", content: "Alerts", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Alert", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.AlertBrowseList"
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
  }

  trait AlertBrowseList = Browse.traits.BrowseItemBrowse -> AlertMetric {
    config: {
      fields: [
        { name: "severity",  variant: "badge" },
        { name: "message",   variant: "h4",      icon: "alert-triangle" },
        { name: "source",    variant: "body" },
        { name: "timestamp", variant: "caption", format: "date" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      AlertPersistor.ALERT_CREATED     -> INIT
      AlertPersistor.ALERT_UPDATED     -> INIT
      AlertPersistor.ALERT_DELETED     -> INIT
    }
  }

  trait AlertCreate = Modal.traits.ModalRecordModal -> AlertMetric {
    config: {
      icon: "plus-circle",
      title: "New Alert",
      mode: "create",
      fields: ["severity", "message", "source", "timestamp"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      AlertCatalog.CREATE -> CREATE
      CREATE { id : string, row : AlertMetric }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait AlertEdit = Modal.traits.ModalRecordModal -> AlertMetric {
    config: {
      icon: "edit",
      title: "Edit Alert",
      mode: "edit",
      fields: ["severity", "message", "source", "timestamp"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      AlertBrowseList.EDIT -> EDIT
      EDIT { id : string, row : AlertMetric }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait AlertView = Modal.traits.ModalRecordModal -> AlertMetric {
    config: {
      icon: "eye",
      title: "View Alert",
      mode: "edit",
      fields: ["severity", "message", "source", "timestamp"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      AlertBrowseList.VIEW -> VIEW
      VIEW { id : string, row : AlertMetric }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait AlertDelete = Confirmation.traits.ConfirmActionConfirmation -> AlertMetric {
    config: {
      icon: "alert-triangle",
      title: "Delete Alert",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      AlertBrowseList.DELETE -> DELETE
      DELETE { id : string, row : AlertMetric }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait AlertPersistor -> AlertMetric [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create AlertMetric @payload.data { emit: { success: "ALERT_CREATED" } })
      DO_UPDATE -> idle
        (persist update AlertMetric @payload.data { emit: { success: "ALERT_UPDATED" } })
      DO_DELETE -> idle
        (persist delete AlertMetric @payload.id { emit: { success: "ALERT_DELETED" } })
    }
    emits {
      ALERT_CREATED -> external { id : string }
      ALERT_UPDATED -> external { id : string }
      ALERT_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      AlertCreate.SAVE          -> DO_CREATE
      AlertEdit.SAVE            -> DO_UPDATE
      AlertDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  ;; Email-out for critical alerts. Listens for AlertPersistor.ALERT_CREATED
  ;; and dispatches via the std-service-email service when severity is critical.
  trait AlertEmail -> AlertMetric [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      ALERT_TRIGGERED -> idle when (= "@payload.severity" "critical")
        (call-service email "send" {
          recipient: "@payload.recipient",
          subject: "@payload.subject",
          body: "@payload.body",
          sender: "alerts@example.com"
        })
    }
    listens {
      ALERT_TRIGGERED { id : string, severity : string, recipient : string, subject : string, body : string }
      AlertPersistor.ALERT_CREATED -> ALERT_TRIGGERED
    }
  }

  page "/alerts" as AlertsPage -> AlertMetricAppLayout, AlertCatalog, AlertBrowseList, AlertCreate, AlertEdit, AlertView, AlertDelete, AlertPersistor, AlertEmail
}

orbital LogEntryOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Browse   from "std/behaviors/std-browse"

  entity LogEntry [persistent: logentries] {
    id : string!
    level : "debug" | "info" | "warn" | "error" = "info"
    message : string!
    timestamp : datetime
    service : string = ""
  }

  trait LogEntryAppLayout = AppShell.traits.AppLayout -> LogEntry {
    config: {
      contentTrait: "@trait.LogCatalog",
      appName: "DevOps Dashboard",
      navItems: [{ label: "Services", href: "/services", icon: "server" }, { label: "Alerts", href: "/alerts", icon: "bell" }, { label: "Logs", href: "/logs", icon: "terminal" }, { label: "Metrics", href: "/metrics", icon: "layout-list" }],
      searchEvent: "LOG_SEARCH",
      notifications: [],
      notificationClickEvent: "LOG_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: LOG_SEARCH
      NOTIFY_CLICK: LOG_NOTIFICATIONS_OPEN
    }
  }

  trait LogCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "terminal" },
              { type: "typography", content: "Logs", variant: "h2" }
            ]}
          ]},
          { type: "divider" },
          "@trait.LogBrowseList"
        ]})
    }
  }

  trait LogBrowseList = Browse.traits.BrowseItemBrowse -> LogEntry {
    config: {
      variant: "dense",
      fields: [
        { name: "level",     variant: "badge" },
        { name: "message",   variant: "body",    icon: "file-text" },
        { name: "service",   variant: "caption" },
        { name: "timestamp", variant: "caption", format: "date" }
      ],
      cols: 1,
      gap: "sm"
    }
  }

  page "/logs" as LogsPage -> LogEntryAppLayout, LogCatalog, LogBrowseList
}

orbital SystemMetricOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Browse   from "std/behaviors/std-browse"

  entity SystemMetric [persistent: systemmetrics] {
    id : string!
    name : string!
    value : number!
    unit : string = ""
    trend : "up" | "down" | "flat" = "flat"
  }

  trait SystemMetricAppLayout = AppShell.traits.AppLayout -> SystemMetric {
    config: {
      contentTrait: "@trait.SystemMetricDisplay",
      appName: "DevOps Dashboard",
      navItems: [{ label: "Services", href: "/services", icon: "server" }, { label: "Alerts", href: "/alerts", icon: "bell" }, { label: "Logs", href: "/logs", icon: "terminal" }, { label: "Metrics", href: "/metrics", icon: "layout-list" }],
      searchEvent: "SYSTEM_METRIC_SEARCH",
      notifications: [],
      notificationClickEvent: "SYSTEM_METRIC_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: SYSTEM_METRIC_SEARCH
      NOTIFY_CLICK: SYSTEM_METRIC_NOTIFICATIONS_OPEN
    }
  }

  trait SystemMetricsBrowse = Browse.traits.BrowseItemBrowse -> SystemMetric {
    config: {
      pageSize: 100,
      displayPageSize: 10,
      fields: [
        { name: "name",  label: "Metric", variant: "h4" },
        { name: "value", label: "Value",  variant: "h3", format: "number" },
        { name: "unit",  label: "Unit",   variant: "caption" },
        { name: "trend", label: "Trend",  variant: "badge" }
      ]
    }
  }

  trait SystemMetricDisplay [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-6xl mx-auto w-full p-4", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
            { type: "icon", name: "activity" },
            { type: "typography", variant: "h2", content: "System Metrics" }
          ]},
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Recent" },
          "@trait.SystemMetricsBrowse"
        ]})
    }
  }

  page "/metrics" -> SystemMetricAppLayout, SystemMetricDisplay, SystemMetricsBrowse
}
