app std-subscription-billing "1.1.0"
"Subscription billing: plans browser with stats + graphs, embedded recurring-charge + trial managers, modal/confirm CRUD over plans, invoices browser, dunning queue. Composes std-lifecycle (auto-overdue scan), std-notify-on-event (customer-facing notifications), and std-audit-capture (compliance audit trail) for the invoice domain."

orbital SubscriptionOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Recurring    from "std/behaviors/std-recurring-charge"
  uses Trial        from "std/behaviors/std-trial"
  uses Search       from "std/behaviors/std-search"
  uses Filter       from "std/behaviors/std-filter"
  uses Browse       from "std/behaviors/std-browse"
  uses Stats        from "std/behaviors/std-stats"
  uses Graphs       from "std/behaviors/std-graphs"

  entity Plan [persistent: plans] {
    id : string!
    name : string!
    description : string = ""
    interval : "monthly" | "yearly" = "monthly"
    amount : number = 0
    currency : string = "USD"
    trialDays : number = 0
    status : "active" | "archived" = "active"
    pendingId : string = ""
  }

  trait PlanAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.PlanCatalog",
      appName: "Subscription Billing",
      navItems: [{ label: "Plans", href: "/plans", icon: "credit-card" }, { label: "Invoices", href: "/invoices", icon: "receipt" }, { label: "Dunning", href: "/dunning", icon: "alert-triangle" }],
      searchEvent: "PLAN_SEARCH",
      notifications: [],
      notificationClickEvent: "PLAN_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: PLAN_SEARCH
      NOTIFY_CLICK: PLAN_NOTIFICATIONS_OPEN
    }
  }

  trait PlanCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "credit-card" },
              { type: "typography", content: "Plans", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Plan", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.PlanSearch",
            "@trait.PlanFilter"
          ]},
          "@trait.PlanStats",
          "@trait.PlanGraphs",
          { type: "divider" },
          "@trait.PlanBrowseList",
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Active Subscriptions" },
          "@trait.PlanSubscriptionManage",
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Trials" },
          "@trait.PlanTrialManage"
        ]})
      PLAN_SEARCH -> composing
      PLAN_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to plans", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      PlanAppLayout.PLAN_SEARCH -> PLAN_SEARCH
      PlanAppLayout.PLAN_NOTIFICATIONS_OPEN -> PLAN_NOTIFICATIONS_OPEN
      PLAN_SEARCH { value : string }
      PLAN_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait PlanSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search plans…",
      event: "PLAN_SEARCH"
    }
  }

  trait PlanFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "interval", label: "Interval", filterType: "select", options: ["monthly", "yearly"] },
        { field: "status",   label: "Status",   filterType: "select", options: ["active", "archived"] }
      ],
      event: "PLAN_FILTER"
    }
  }

  trait PlanStats = Stats.traits.StatsItemStats {
    config: {
      title: "Plans",
      metrics: [
        { aggregation: "count", label: "Total",    icon: "credit-card", variant: "primary", format: "number" },
        { aggregation: "count", label: "Active",   icon: "check-circle", variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "active"]] },
        { aggregation: "count", label: "Archived", icon: "archive",      variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "archived"]] }
      ]
    }
    listens {
      PlanBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait PlanGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Plans by Interval",
      subtitle: "Monthly vs yearly distribution",
      chartType: "bar",
      categoryField: "interval",
      aggregation: "count",
      height: 240,
      showLegend: false
    }
    listens {
      PlanBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait PlanBrowseList = Browse.traits.BrowseItemBrowse -> Plan {
    config: {
      fields: [
        { name: "name",        variant: "h3",      icon: "credit-card" },
        { name: "description", variant: "caption" },
        { name: "interval",    variant: "badge" },
        { name: "amount",      variant: "body" },
        { name: "currency",    variant: "badge" },
        { name: "status",      variant: "badge" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      PlanSearch.SEARCH            -> REFETCH_QUERY
      PlanFilter.FILTER            -> REFETCH_FILTER
      PlanPersistor.PLAN_CREATED   -> INIT
      PlanPersistor.PLAN_UPDATED   -> INIT
      PlanPersistor.PLAN_DELETED   -> INIT
    }
  }

  trait PlanCreate = Modal.traits.ModalRecordModal -> Plan {
    config: {
      icon: "plus-circle",
      title: "New Plan",
      mode: "create",
      fields: ["name", "description", "interval", "amount", "currency", "trialDays", "status"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      PlanCatalog.CREATE -> CREATE
      CREATE { id : string, row : Plan }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait PlanEdit = Modal.traits.ModalRecordModal -> Plan {
    config: {
      icon: "edit",
      title: "Edit Plan",
      mode: "edit",
      fields: ["name", "description", "interval", "amount", "currency", "trialDays", "status"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      PlanBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Plan }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait PlanView = Modal.traits.ModalRecordModal -> Plan {
    config: {
      icon: "eye",
      title: "View Plan",
      mode: "edit",
      fields: ["name", "description", "interval", "amount", "currency", "trialDays", "status"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      PlanBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Plan }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait PlanDelete = Confirmation.traits.ConfirmActionConfirmation -> Plan {
    config: {
      icon: "alert-triangle",
      title: "Delete Plan",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      PlanBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Plan }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait PlanSubscriptionManage = Recurring.traits.SubscriptionManage {
    config: {
      title: "Active Subscriptions",
      maxRetries: 4
    }
  }

  trait PlanTrialManage = Trial.traits.TrialManage {
    config: {
      title: "Trials"
    }
  }

  trait PlanPersistor -> Plan [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Plan @payload.data { emit: { success: "PLAN_CREATED" } })
      DO_UPDATE -> idle
        (persist update Plan @payload.data { emit: { success: "PLAN_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Plan @payload.id { emit: { success: "PLAN_DELETED" } })
    }
    emits {
      PLAN_CREATED -> external { id : string }
      PLAN_UPDATED -> external { id : string }
      PLAN_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      PlanCreate.SAVE          -> DO_CREATE
      PlanEdit.SAVE            -> DO_UPDATE
      PlanDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/plans" as PlansPage -> PlanAppLayout, PlanCatalog, PlanSearch, PlanFilter, PlanStats, PlanGraphs, PlanBrowseList, PlanCreate, PlanEdit, PlanView, PlanDelete, PlanSubscriptionManage, PlanTrialManage, PlanPersistor
}

orbital InvoiceOrbital {
  uses AppShell  from "std/behaviors/std-app-layout"
  uses Modal     from "std/behaviors/std-modal"
  uses Inv       from "std/behaviors/std-invoice"
  uses Browse    from "std/behaviors/std-browse"
  uses Lifecycle from "std/behaviors/std-lifecycle"
  uses Notify    from "std/behaviors/std-notify-on-event"
  uses Audit     from "std/behaviors/std-audit-capture"

  entity InvoiceNote [persistent: invoicenotes] {
    id : string!
    invoiceId : string!
    body : string = ""
    author : string = ""
    createdAt : string = ""
    pendingId : string = ""
  }

  trait InvoiceAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.InvoiceCatalog",
      appName: "Subscription Billing",
      navItems: [{ label: "Plans", href: "/plans", icon: "credit-card" }, { label: "Invoices", href: "/invoices", icon: "receipt" }, { label: "Dunning", href: "/dunning", icon: "alert-triangle" }],
      searchEvent: "INVOICE_SEARCH",
      notifications: [],
      notificationClickEvent: "INVOICE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: INVOICE_SEARCH
      NOTIFY_CLICK: INVOICE_NOTIFICATIONS_OPEN
    }
  }

  trait InvoiceCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "receipt" },
              { type: "typography", content: "Invoices", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Add Note", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.InvoiceManageBlock",
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Recent Notes" },
          "@trait.InvoiceNoteBrowseList"
        ]})
      INVOICE_SEARCH -> composing
      INVOICE_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to invoices", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      InvoiceAppLayout.INVOICE_SEARCH -> INVOICE_SEARCH
      InvoiceAppLayout.INVOICE_NOTIFICATIONS_OPEN -> INVOICE_NOTIFICATIONS_OPEN
      INVOICE_SEARCH { value : string }
      INVOICE_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait InvoiceManageBlock = Inv.traits.InvoiceManage {
    config: {
      title: "Invoices",
      refundTiersJson: "[]",
      currency: "USD",
      taxStrategy: "exclusive",
      gracePeriodDays: 30,
      lateFeePolicy: "none",
      lateFeeAmount: 0,
      complianceJurisdiction: "US",
      retentionYears: 7
    }
  }

  trait InvoiceLifecycleScan = Lifecycle.traits.LifecycleScheduler {
    config: {
      targetEntity: "InvoiceRecord",
      rules: [
        { fromStatus: "sent",    toStatus: "overdue", condition: { kind: "ageDays", value: 30, dateField: "dueAt" } },
        { fromStatus: "overdue", toStatus: "void",    condition: { kind: "ageDays", value: 90, dateField: "dueAt" } }
      ],
      dryRun: false
    }
  }

  trait InvoiceNotifier = Notify.traits.NotifyOnEventListener {
    config: {
      listensFor: ["InvoiceUpdated"],
      notifyChannel: "in-app",
      template: "Invoice updated",
      severity: "info",
      recipients: [],
      suppressionList: []
    }
    events {
      EventOccurred: InvoiceUpdated
    }
  }

  trait InvoiceAuditCapture = Audit.traits.AuditCaptureListener {
    config: {
      captureEntity: "InvoiceRecord",
      captureEventTypes: [],
      excludeFields: [],
      captureBeforeAfter: false,
      retentionDays: 2555
    }
    events {
      EntityMutated: InvoiceUpdated
    }
  }

  trait InvoiceNoteBrowseList = Browse.traits.BrowseItemBrowse -> InvoiceNote {
    config: {
      fields: [
        { name: "invoiceId", variant: "h4",      icon: "receipt" },
        { name: "body",      variant: "body" },
        { name: "author",    variant: "caption" },
        { name: "createdAt", variant: "caption" }
      ],
      itemActions: [
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      InvoiceNotePersistor.NOTE_CREATED -> INIT
      InvoiceNotePersistor.NOTE_DELETED -> INIT
    }
  }

  trait InvoiceNoteCreate = Modal.traits.ModalRecordModal -> InvoiceNote {
    config: {
      icon: "plus-circle",
      title: "New Note",
      mode: "create",
      fields: ["invoiceId", "body", "author"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      InvoiceCatalog.CREATE -> CREATE
      CREATE { id : string, row : InvoiceNote }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait InvoiceNotePersistor -> InvoiceNote [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create InvoiceNote @payload.data { emit: { success: "NOTE_CREATED" } })
      DO_DELETE -> idle
        (persist delete InvoiceNote @payload.id { emit: { success: "NOTE_DELETED" } })
    }
    emits {
      NOTE_CREATED -> external { id : string }
      NOTE_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_DELETE { id : string }
      InvoiceNoteCreate.SAVE        -> DO_CREATE
      InvoiceNoteBrowseList.DELETE  -> DO_DELETE
    }
  }

  page "/invoices" as InvoicesPage -> InvoiceAppLayout, InvoiceCatalog, InvoiceManageBlock, InvoiceLifecycleScan, InvoiceNotifier, InvoiceAuditCapture, InvoiceNoteBrowseList, InvoiceNoteCreate, InvoiceNotePersistor
}

orbital DunningOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Modal    from "std/behaviors/std-modal"
  uses Dunning  from "std/behaviors/std-dunning"
  uses Browse   from "std/behaviors/std-browse"

  entity DunningNote [persistent: dunningnotes] {
    id : string!
    caseId : string!
    body : string = ""
    author : string = ""
    createdAt : string = ""
    pendingId : string = ""
  }

  trait DunningAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.DunningCatalog",
      appName: "Subscription Billing",
      navItems: [{ label: "Plans", href: "/plans", icon: "credit-card" }, { label: "Invoices", href: "/invoices", icon: "receipt" }, { label: "Dunning", href: "/dunning", icon: "alert-triangle" }],
      searchEvent: "DUNNING_SEARCH",
      notifications: [],
      notificationClickEvent: "DUNNING_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: DUNNING_SEARCH
      NOTIFY_CLICK: DUNNING_NOTIFICATIONS_OPEN
    }
  }

  trait DunningCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "alert-triangle" },
              { type: "typography", content: "Dunning", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Log Note", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.DunningEscalateBlock",
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Case Notes" },
          "@trait.DunningNoteBrowseList"
        ]})
      DUNNING_SEARCH -> composing
      DUNNING_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to dunning", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      DunningAppLayout.DUNNING_SEARCH -> DUNNING_SEARCH
      DunningAppLayout.DUNNING_NOTIFICATIONS_OPEN -> DUNNING_NOTIFICATIONS_OPEN
      DUNNING_SEARCH { value : string }
      DUNNING_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait DunningEscalateBlock = Dunning.traits.DunningEscalate {
    config: {
      title: "Open Cases"
    }
  }

  trait DunningNoteBrowseList = Browse.traits.BrowseItemBrowse -> DunningNote {
    config: {
      fields: [
        { name: "caseId",    variant: "h4",      icon: "alert-triangle" },
        { name: "body",      variant: "body" },
        { name: "author",    variant: "caption" },
        { name: "createdAt", variant: "caption" }
      ],
      itemActions: [
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      DunningNotePersistor.NOTE_CREATED -> INIT
      DunningNotePersistor.NOTE_DELETED -> INIT
    }
  }

  trait DunningNoteCreate = Modal.traits.ModalRecordModal -> DunningNote {
    config: {
      icon: "plus-circle",
      title: "New Note",
      mode: "create",
      fields: ["caseId", "body", "author"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      DunningCatalog.CREATE -> CREATE
      CREATE { id : string, row : DunningNote }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait DunningNotePersistor -> DunningNote [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create DunningNote @payload.data { emit: { success: "NOTE_CREATED" } })
      DO_DELETE -> idle
        (persist delete DunningNote @payload.id { emit: { success: "NOTE_DELETED" } })
    }
    emits {
      NOTE_CREATED -> external { id : string }
      NOTE_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_DELETE { id : string }
      DunningNoteCreate.SAVE        -> DO_CREATE
      DunningNoteBrowseList.DELETE  -> DO_DELETE
    }
  }

  page "/dunning" as DunningPage -> DunningAppLayout, DunningCatalog, DunningEscalateBlock, DunningNoteBrowseList, DunningNoteCreate, DunningNotePersistor
}
