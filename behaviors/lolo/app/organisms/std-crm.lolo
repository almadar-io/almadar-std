app std-crm "1.0.0"
"std-crm as a Function"

orbital ContactOrbital {
  entity Contact [runtime] {
    id : string!
    name : string = ""
    company : string = ""
    email : string = ""
    phone : string = ""
    status : "lead" | "prospect" | "customer" | "inactive" = "lead"
    pendingId : string = ""
  }

  type ContactLoaded     = Event { data : [Contact] }                  "Fired when Contact finishes loading"
  type ContactLoadFailed = Event { error : string, code : string } "Fired when Contact fails to load"
  type ContactSaved = Event { id : string }
  type ContactSaveFailed = Event { error : string, code : string }
  type ContactUpdated = Event { id : string }
  type ContactUpdateFailed = Event { error : string, code : string }
  type ContactDeleted = Event { id : string }
  type ContactDeleteFailed = Event { error : string, code : string }
  type DealSaved = Event { id : string }
  type DealSaveFailed = Event { error : string, code : string }
  type DealUpdated = Event { id : string }
  type DealUpdateFailed = Event { error : string, code : string }
  type DealDeleted = Event { id : string }
  type DealDeleteFailed = Event { error : string, code : string }
  type NoteSaved = Event { id : string }
  type NoteSaveFailed = Event { error : string, code : string }
  trait ContactBrowse -> Contact [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      ContactLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "CRM", navItems: [{ label: "Contacts", href: "/contacts", icon: "users" }, { label: "Deals", href: "/deals", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "bar-chart-2" }, { label: "Notes", href: "/notes", icon: "file-text" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "Contacts", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Add Contact", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 1, children: [{ type: "stat-display", label: "Total Contacts", value: "@entity", icon: "users" }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, fields: [], itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], columns: [{ name: "name", variant: "h3", icon: "user" }, { name: "status", variant: "badge" }, { name: "company", variant: "body" }, { name: "email", variant: "caption" }, { name: "phone", variant: "caption" }], variant: "card", gap: "sm" }] }] })
      ContactLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load contact" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      CONVERT_LEAD external { id: string }
    }
    listens {
      ContactCreate CONTACT_CREATED -> INIT
      ContactEdit CONTACT_UPDATED -> INIT
      ContactDelete CONTACT_DELETED -> INIT
      VIEW { id : string!, row : Contact }
      EDIT { id : string!, row : Contact }
      DELETE { id : string!, row : Contact }
          ContactLoadFailed { error : string, code : string }
    
      ContactSaveFailed { error : string, code : string }
      ContactUpdateFailed { error : string, code : string }
      ContactDeleteFailed { error : string, code : string }
      DealSaveFailed { error : string, code : string }
      DealUpdateFailed { error : string, code : string }
      DealDeleteFailed { error : string, code : string }
      NoteSaveFailed { error : string, code : string }
    }
    emits: [ContactLoaded, ContactLoadFailed, ContactSaved, ContactSaveFailed, ContactUpdated, ContactUpdateFailed, ContactDeleted, ContactDeleteFailed, DealSaved, DealSaveFailed, DealUpdated, DealUpdateFailed, DealDeleted, DealDeleteFailed, NoteSaved, NoteSaveFailed]
  }
  trait ContactCreate -> Contact [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
      CREATE -> open
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "New Contact", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "company", "email", "phone", "status"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Contact @payload.data { emit: { success: "ContactSaved", failure: "ContactSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit CONTACT_CREATED)
    }
    emits {
      CONTACT_CREATED external { id: string }
    }
    listens {
      SAVE { data : object! }
          ContactLoadFailed { error : string, code : string }
    }
    emits: [ContactLoadFailed, ContactLoaded, ContactSaveFailed, ContactSaved]
  }
  trait ContactEdit -> Contact [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
      EDIT -> open
        (fetch Contact {id: "@payload.id" , emit: { success: "ContactLoaded", failure: "ContactLoadFailed" }, emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Contact", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "company", "email", "phone", "status"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Contact @payload.data { emit: { success: "ContactUpdated", failure: "ContactUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit CONTACT_UPDATED)
    }
    emits {
      CONTACT_UPDATED external { id: string }
    }
    listens {
      EDIT { id : string!, row : Contact }
      SAVE { data : object! }
          ContactLoadFailed { error : string, code : string }
    }
    emits: [ContactLoadFailed, ContactLoaded, ContactUpdateFailed, ContactUpdated]
  }
  trait ContactView -> Contact [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
      VIEW -> open
        (fetch Contact {id: "@payload.id" , emit: { success: "ContactLoaded", failure: "ContactLoadFailed" }, emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Company" }, { type: "typography", variant: "body", content: "@entity.company" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          ContactLoadFailed { error : string, code : string }
    }
    emits: [ContactLoaded, ContactLoadFailed]
  }
  trait ContactDelete -> Contact [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Contact {id: "@payload.id" , emit: { success: "ContactLoaded", failure: "ContactLoadFailed" }, emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Contact", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Contact @entity.pendingId { emit: { success: "ContactDeleted", failure: "ContactDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
        (emit CONTACT_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Contact { emit: { success: "ContactLoaded", failure: "ContactLoadFailed" } })
    }
    emits {
      CONTACT_DELETED external { id: string }
    }
    listens {
      DELETE { id : string! }
          ContactLoadFailed { error : string, code : string }
    }
    emits: [ContactDeleteFailed, ContactDeleted, ContactLoadFailed, ContactLoaded]
  }
  page "/contacts" as ContactsPage -> ContactBrowse, ContactCreate, ContactEdit, ContactView, ContactDelete
}
orbital DealOrbital {
  entity Deal [runtime] {
    id : string!
    title : string
    contactId : string
    value : number
    stage : string
    closedAt : datetime
    pendingId : string = ""
  }

  type DealLoaded     = Event { data : [Deal] }                  "Fired when Deal finishes loading"
  type DealLoadFailed = Event { error : string, code : string } "Fired when Deal fails to load"
  type DealDeleteFailed = Event { error : string, code : string }
  type DealDeleted = Event { id : string }
  type DealSaveFailed = Event { error : string, code : string }
  type DealSaved = Event { id : string }
  type DealUpdateFailed = Event { error : string, code : string }
  type DealUpdated = Event { id : string }
  trait DealBrowse -> Deal [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      DealLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "CRM", navItems: [{ label: "Contacts", href: "/contacts", icon: "users" }, { label: "Deals", href: "/deals", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "bar-chart-2" }, { label: "Notes", href: "/notes", icon: "file-text" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "briefcase" }, { type: "typography", content: "Deals", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "New Deal", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, fields: [], itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], columns: [{ name: "title", variant: "h3", icon: "briefcase" }, { name: "stage", variant: "badge" }, { name: "value", variant: "h4", format: "currency" }, { name: "contactId", label: "Contact", variant: "caption" }], cols: 2, gap: "md" }] }] })
      DealLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load deal" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      CLOSE_DEAL external { id: string }
    }
    listens {
      DealCreate DEAL_CREATED -> INIT
      DealEdit DEAL_UPDATED -> INIT
      DealDelete DEAL_DELETED -> INIT
      * CONVERT_LEAD -> INIT
          DealLoadFailed { error : string, code : string }
    }
    emits: [DealLoaded, DealLoadFailed]
  }
  trait DealCreate -> Deal [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
      CREATE -> open
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Deal", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "contactId", "value", "stage", "closedAt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Deal @payload.data { emit: { success: "DealSaved", failure: "DealSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit DEAL_CREATED)
    }
    emits {
      DEAL_CREATED
    }
    emits: [DealLoadFailed, DealLoaded, DealSaveFailed, DealSaved]
    listens {
      DealLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait DealEdit -> Deal [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
      EDIT -> open
        (fetch Deal {id: "@payload.id" , emit: { success: "DealLoaded", failure: "DealLoadFailed" }, emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Deal", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "contactId", "value", "stage", "closedAt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Deal @payload.data { emit: { success: "DealUpdated", failure: "DealUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit DEAL_UPDATED)
    }
    emits {
      DEAL_UPDATED
    }
    emits: [DealLoadFailed, DealLoaded, DealUpdateFailed, DealUpdated]
    listens {
      DealLoadFailed { error : string, code : string }
      EDIT { id : string, row : Deal }
      SAVE { data : string }
    }
  }
  trait DealView -> Deal [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
      VIEW -> open
        (fetch Deal {id: "@payload.id" , emit: { success: "DealLoaded", failure: "DealLoadFailed" }, emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.title" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Title" }, { type: "typography", variant: "body", content: "@entity.title" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Contact ID" }, { type: "typography", variant: "body", content: "@entity.contactId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Value" }, { type: "typography", variant: "body", content: "@entity.value" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Stage" }, { type: "typography", variant: "body", content: "@entity.stage" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Closed At" }, { type: "typography", variant: "body", content: "@entity.closedAt" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    emits: [DealLoaded, DealLoadFailed]
    listens {
      DealLoadFailed { error : string, code : string }
      VIEW { id : string }
    }
  }
  trait DealDelete -> Deal [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Deal {id: "@payload.id" , emit: { success: "DealLoaded", failure: "DealLoadFailed" }, emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Deal", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Deal @entity.pendingId { emit: { success: "DealDeleted", failure: "DealDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
        (emit DEAL_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Deal { emit: { success: "DealLoaded", failure: "DealLoadFailed" } })
    }
    emits {
      DEAL_DELETED
    }
    emits: [DealDeleteFailed, DealDeleted, DealLoadFailed, DealLoaded]
    listens {
      DealLoadFailed { error : string, code : string }
      DELETE { id : string }
    }
  }
  page "/deals" -> DealBrowse, DealCreate, DealEdit, DealView, DealDelete
}
orbital PipelineOrbital {
  entity Pipeline [runtime] {
    id : string!
    totalDeals : number
    totalValue : number
    wonDeals : number
    lostDeals : number
    conversionRate : number
  }

  type PipelineLoaded     = Event { data : [Pipeline] }                  "Fired when Pipeline finishes loading"
  type PipelineLoadFailed = Event { error : string, code : string } "Fired when Pipeline fails to load"
  trait PipelineDisplay -> Pipeline [interaction, collection] {
    initial: loading
    state loading {
      INIT -> displaying
        (fetch Pipeline { emit: { success: "PipelineLoaded", failure: "PipelineLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "CRM", navItems: [{ label: "Contacts", href: "/contacts", icon: "users" }, { label: "Deals", href: "/deals", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "bar-chart-2" }, { label: "Notes", href: "/notes", icon: "file-text" }], children: [{ type: "scaled-diagram", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "breadcrumb", items: [{ label: "Home", href: "/" }, { label: "Pipeline" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "bar-chart-2" }, { type: "typography", content: "Pipeline", variant: "h2" }] }, { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }] }, { type: "divider" }, { type: "box", padding: "md", children: [{ type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "TotalDeals", value: "@entity.totalDeals" }, { type: "stat-display", label: "TotalValue", value: "@entity.totalValue" }, { type: "stat-display", label: "WonDeals", value: "@entity.wonDeals" }, { type: "stat-display", label: "LostDeals", value: "@entity.lostDeals" }, { type: "stat-display", label: "ConversionRate", value: "@entity.conversionRate" }] }] }, { type: "divider" }, { type: "grid", cols: 2, gap: "md", children: [{ type: "card", children: [{ type: "typography", variant: "caption", content: "Chart View" }] }, { type: "card", children: [{ type: "typography", variant: "caption", content: "Graph View" }] }] }, { type: "line-chart", data: [{ date: "Jan", value: 12 }, { date: "Feb", value: 19 }, { date: "Mar", value: 15 }, { date: "Apr", value: 25 }, { date: "May", value: 22 }, { date: "Jun", value: 30 }] }, { type: "chart-legend", items: [{ label: "Current", color: "primary" }, { label: "Previous", color: "muted" }] }, { type: "graph-view", nodes: [{ id: "a", label: "Start" }, { id: "b", label: "Process" }, { id: "c", label: "End" }], edges: [{ source: "a", target: "b" }, { source: "b", target: "c" }], width: 400, height: 200 }] }] }] })
