app std-wiki "1.0.0"
"Wiki: rich-block authoring, page tree, version history with diff/rollback, full-text search, tags, and backlinks. Pick for internal knowledge bases."

orbital DocumentOrbital {
  uses AppShell    from "std/behaviors/std-app-layout"
  uses Modal       from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Editor      from "std/behaviors/std-rich-editor"
  uses Versions    from "std/behaviors/std-version-history"
  uses PageTree    from "std/behaviors/std-page-tree"
  uses Search      from "std/behaviors/std-search"
  uses Filter      from "std/behaviors/std-filter"
  uses Browse      from "std/behaviors/std-browse"
  uses Related     from "std/behaviors/std-related"
  uses Tags        from "std/behaviors/std-tag-taxonomy"

  entity WikiPage [persistent: wikipages] {
    id         : string!
    title      : string!
    slug       : string!
    blocksJson : [object]
    authorId   : string = ""
    parentId   : string = ""
    kind       : "page" | "doc" | "post" = "page"
    status     : "draft" | "published" | "archived" = "draft"
    version    : number = 1
    tagIds     : [string]
    createdAt  : string = ""
    updatedAt  : string = ""
    pendingId  : string = ""
  }

  trait WikiAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.WikiWorkspace",
      appName: "Wiki",
      navItems: [
        { label: "Pages",    href: "/wiki",      icon: "book-open" },
        { label: "History",  href: "/revisions", icon: "history" },
        { label: "Tags",     href: "/wiki/tags", icon: "tag" }
      ],
      searchEvent: "WIKI_SEARCH",
      notifications: [],
      notificationClickEvent: "WIKI_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: WIKI_SEARCH
      NOTIFY_CLICK: WIKI_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome: two-pane layout with page tree on the left and the
  ;; selected page's editor / browse list on the right. Drives the
  ;; CREATE button at the top and surfaces the search / filter row.
  trait WikiWorkspace [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "book-open" },
              { type: "typography", content: "Wiki", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Page", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.WikiSearch",
            "@trait.WikiFilter"
          ]},
          { type: "stack", direction: "horizontal", gap: "lg", children: [
            { type: "stack", direction: "vertical", gap: "md", className: "w-72 shrink-0", children: [
              "@trait.WikiPageTree"
            ]},
            { type: "stack", direction: "vertical", gap: "md", className: "flex-1", children: [
              "@trait.WikiBrowseList",
              { type: "divider" },
              "@trait.WikiBacklinks"
            ]}
          ]}
        ]})
      WIKI_SEARCH -> composing
      WIKI_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to wiki", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      WikiAppLayout.WIKI_SEARCH -> WIKI_SEARCH
      WikiAppLayout.WIKI_NOTIFICATIONS_OPEN -> WIKI_NOTIFICATIONS_OPEN
      WIKI_SEARCH { value : string }
      WIKI_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait WikiSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search wiki…",
      event: "WIKI_FULLTEXT_SEARCH"
    }
  }

  trait WikiFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "kind",   label: "Kind",   filterType: "select", options: ["page", "doc", "post"] },
        { field: "status", label: "Status", filterType: "select", options: ["draft", "published", "archived"] }
      ],
      event: "WIKI_FILTER"
    }
  }

  ;; Hierarchical sidebar nav. SELECT_PAGE drives the editor's OPEN.
  trait WikiPageTree = PageTree.traits.PageNodeBrowse {
    config: {
      title: "Pages"
    }
  }

  ;; Data-grid list of pages, refetches on persist + on search/filter input.
  trait WikiBrowseList = Browse.traits.BrowseItemBrowse -> WikiPage {
    config: {
      fields: [
        { name: "title",     variant: "h3",      icon: "file-text" },
        { name: "kind",      variant: "badge" },
        { name: "status",    variant: "badge" },
        { name: "version",   variant: "caption", label: "v" },
        { name: "updatedAt", variant: "caption", label: "Updated" }
      ],
      itemActions: [
        { label: "Open",    event: "VIEW",   variant: "ghost",  icon: "eye" },
        { label: "Edit",    event: "EDIT",   variant: "ghost",  icon: "edit" },
        { label: "History", event: "VIEW_HISTORY", variant: "ghost", icon: "history" },
        { label: "Delete",  event: "DELETE", variant: "danger", icon: "trash" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      WikiSearch.SEARCH               -> REFETCH_QUERY
      WikiFilter.FILTER               -> REFETCH_FILTER
      WikiPersistor.WIKI_CREATED      -> INIT
      WikiPersistor.WIKI_UPDATED      -> INIT
      WikiPersistor.WIKI_DELETED      -> INIT
    }
  }

  ;; Backlinks panel — listens for VIEW from the browse list to load
  ;; pages that link to the selected page. Bound from std-related.
  trait WikiBacklinks = Related.traits.RelatedItemList -> WikiPage {
    listens {
      WikiBrowseList.VIEW -> INIT
    }
  }

  trait WikiCreate = Modal.traits.ModalRecordModal -> WikiPage {
    config: {
      icon: "plus-circle",
      title: "New Page",
      mode: "create",
      fields: ["title", "slug", "kind", "status", "parentId", "authorId"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      WikiWorkspace.CREATE -> CREATE
      CREATE { id : string, row : WikiPage }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  ;; Edit binding opens the rich-block editor (std-rich-editor) inside
  ;; the modal. mode=edit so the modal opens only when @payload.row is
  ;; supplied by the BrowseList row.
  trait WikiEdit = Modal.traits.ModalRecordModal -> WikiPage {
    config: {
      icon: "edit",
      title: "Edit Page",
      mode: "edit",
      fields: ["title", "slug", "kind", "status", "parentId", "authorId", "blocksJson"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      WikiBrowseList.EDIT -> EDIT
      EDIT { id : string, row : WikiPage }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait WikiView = Modal.traits.ModalRecordModal -> WikiPage {
    config: {
      icon: "eye",
      title: "View Page",
      mode: "edit",
      fields: ["title", "slug", "kind", "status", "version", "updatedAt", "blocksJson"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      WikiBrowseList.VIEW -> VIEW
      VIEW { id : string, row : WikiPage }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait WikiDelete = Confirmation.traits.ConfirmActionConfirmation -> WikiPage {
    config: {
      icon: "alert-triangle",
      title: "Delete Page",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      WikiBrowseList.DELETE -> DELETE
      DELETE { id : string, row : WikiPage }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  ;; Version-history sidecar. Listens for VIEW_HISTORY from the browse
  ;; list and renders the revision data-grid at the configured route.
  trait WikiVersionHistory = Versions.traits.RevisionManage {
    config: {
      title: "Version History"
    }
  }

  ;; Tag taxonomy — categories sidebar surfaced on /wiki/tags.
  trait WikiTagBrowse = Tags.traits.TagBrowse {
    config: {
      title: "Tags",
      allowEdit: true
    }
  }

  ;; Coordinator: persists Create / Edit / Delete fan-outs.
  trait WikiPersistor -> WikiPage [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create WikiPage @payload.data { emit: { success: "WIKI_CREATED" } })
      DO_UPDATE -> idle
        (persist update WikiPage @payload.data { emit: { success: "WIKI_UPDATED" } })
      DO_DELETE -> idle
        (persist delete WikiPage @payload.id { emit: { success: "WIKI_DELETED" } })
    }
    emits {
      WIKI_CREATED -> external { id : string }
      WIKI_UPDATED -> external { id : string }
      WIKI_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      WikiCreate.SAVE          -> DO_CREATE
      WikiEdit.SAVE            -> DO_UPDATE
      WikiDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/wiki" as WikiPagesPage -> WikiAppLayout, WikiWorkspace, WikiSearch, WikiFilter, WikiPageTree, WikiBrowseList, WikiBacklinks, WikiCreate, WikiEdit, WikiView, WikiDelete, WikiPersistor
  page "/wiki/history" as WikiHistoryPage -> WikiAppLayout, WikiWorkspace, WikiVersionHistory
  page "/wiki/tags" as WikiTagsPage -> WikiAppLayout, WikiWorkspace, WikiTagBrowse
}

orbital RevisionOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Modal    from "std/behaviors/std-modal"
  uses Browse   from "std/behaviors/std-browse"

  entity WikiRevision [persistent: wikirevisions] {
    id            : string!
    documentId    : string!
    documentType  : string = "page"
    versionNumber : number = 1
    authorId      : string = ""
    authorName    : string = ""
    content       : string = ""
    summary       : string = ""
    createdAt     : string = ""
    pendingId     : string = ""
  }

  trait RevisionAppLayout = AppShell.traits.AppLayout -> WikiRevision {
    config: {
      contentTrait: "@trait.RevisionWorkspace",
      appName: "Wiki",
      navItems: [
        { label: "Pages",    href: "/wiki",      icon: "book-open" },
        { label: "History",  href: "/revisions", icon: "history" },
        { label: "Tags",     href: "/wiki/tags", icon: "tag" }
      ],
      searchEvent: "REVISION_SEARCH",
      notifications: [],
      notificationClickEvent: "REVISION_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: REVISION_SEARCH
      NOTIFY_CLICK: REVISION_NOTIFICATIONS_OPEN
    }
  }

  ;; Revision page chrome: header + new-revision button + browse list.
  trait RevisionWorkspace [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "history" },
              { type: "typography", content: "Version History", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Revision", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Recent" },
          "@trait.RevisionBrowseList"
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
  }

  ;; Flat browse list of revisions for a recent-activity feed.
  trait RevisionBrowseList = Browse.traits.BrowseItemBrowse -> WikiRevision {
    config: {
      fields: [
        { name: "summary",       variant: "h4",      icon: "history" },
        { name: "documentType",  variant: "badge" },
        { name: "versionNumber", variant: "badge",   label: "v" },
        { name: "authorName",    variant: "caption" },
        { name: "createdAt",     variant: "caption", label: "Saved" }
      ],
      itemActions: [
        { label: "Inspect", event: "VIEW", variant: "ghost", icon: "eye" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      RevisionPersistor.REVISION_CREATED -> INIT
    }
  }

  trait RevisionCreate = Modal.traits.ModalRecordModal -> WikiRevision {
    config: {
      icon: "plus-circle",
      title: "New Revision",
      mode: "create",
      fields: ["documentId", "documentType", "versionNumber", "authorId", "authorName", "summary", "content"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      RevisionWorkspace.CREATE -> CREATE
      CREATE { id : string, row : WikiRevision }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait RevisionPersistor -> WikiRevision [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create WikiRevision @payload.data { emit: { success: "REVISION_CREATED" } })
    }
    emits {
      REVISION_CREATED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      RevisionCreate.SAVE -> DO_CREATE
    }
  }

  page "/revisions" as RevisionsPage -> RevisionAppLayout, RevisionWorkspace, RevisionBrowseList, RevisionCreate, RevisionPersistor
}
