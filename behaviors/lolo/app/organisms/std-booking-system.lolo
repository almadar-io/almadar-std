app std-booking-system "1.0.0"
"std-booking-system as a Function"

orbital ProviderOrbital {
  entity Provider [persistent: providers] {
    id : string!
    name : string!
    specialty : string!
    location : string
    phone : string
    rating : number = 0
    available : boolean = true
    pendingId : string = ""
  }

  type ProviderLoaded     = Event { data : [Provider] }                  "Fired when Provider finishes loading"
  type ProviderLoadFailed = Event { error : string, code : string } "Fired when Provider fails to load"
  type ProviderSaved = Event { id : string }
  type ProviderSaveFailed = Event { error : string, code : string }
  type ProviderUpdated = Event { id : string }
  type ProviderUpdateFailed = Event { error : string, code : string }
  type ProviderDeleted = Event { id : string }
  type ProviderDeleteFailed = Event { error : string, code : string }
  type BookingSaved = Event { id : string }
  type BookingSaveFailed = Event { error : string, code : string }
  type AppointmentSaved = Event { id : string }
  type AppointmentSaveFailed = Event { error : string, code : string }
  type AppointmentUpdated = Event { id : string }
  type AppointmentUpdateFailed = Event { error : string, code : string }
  type AppointmentDeleted = Event { id : string }
  type AppointmentDeleteFailed = Event { error : string, code : string }
  trait ProviderBrowse -> Provider [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      ProviderLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "BookingSystemApp", navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "briefcase" }, { type: "typography", content: "Providers", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Provider", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "name", variant: "h3", icon: "briefcase" }, { name: "specialty", variant: "badge" }, { name: "rating", variant: "body", format: "number" }, { name: "location", variant: "body" }, { name: "phone", variant: "caption" }], cols: 2, gap: "md" }] }] })
      ProviderLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load provider" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      BOOK external { id: string }
      CREATE
      VIEW { id : string!, row : Provider }
      EDIT { id : string!, row : Provider }
      DELETE { id : string!, row : Provider }
    }
    listens {
      ProviderCreate PROVIDER_CREATED -> INIT
      ProviderEdit PROVIDER_UPDATED -> INIT
      ProviderDelete PROVIDER_DELETED -> INIT
      VIEW { id : string!, row : Provider }
      EDIT { id : string!, row : Provider }
      DELETE { id : string!, row : Provider }
          ProviderLoadFailed { error : string, code : string }
    
      ProviderSaveFailed { error : string, code : string }
      ProviderUpdateFailed { error : string, code : string }
      ProviderDeleteFailed { error : string, code : string }
      BookingSaveFailed { error : string, code : string }
      AppointmentSaveFailed { error : string, code : string }
      AppointmentUpdateFailed { error : string, code : string }
      AppointmentDeleteFailed { error : string, code : string }
    }
    emits: [ProviderLoaded, ProviderLoadFailed, ProviderSaved, ProviderSaveFailed, ProviderUpdated, ProviderUpdateFailed, ProviderDeleted, ProviderDeleteFailed, BookingSaved, BookingSaveFailed, AppointmentSaved, AppointmentSaveFailed, AppointmentUpdated, AppointmentUpdateFailed, AppointmentDeleted, AppointmentDeleteFailed]
  }
  trait ProviderCreate -> Provider [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      CREATE -> open
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Provider", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "specialty", "location", "phone", "rating", "available"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Provider @payload.data { emit: { success: "ProviderSaved", failure: "ProviderSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit PROVIDER_CREATED)
    }
    emits {
      PROVIDER_CREATED external { id: string }
    }
    listens {
      SAVE { data : object! }
          ProviderLoadFailed { error : string, code : string }
      ProviderBrowse CREATE -> CREATE
    }
    emits: [ProviderLoadFailed, ProviderLoaded, ProviderSaveFailed, ProviderSaved]
  }
  trait ProviderEdit -> Provider [interaction, collection] {
    listens {
      ProviderView EDIT -> EDIT
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      EDIT -> open
        (fetch Provider {id: "@payload.id" , emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" }, emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Provider", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "specialty", "location", "phone", "rating", "available"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Provider @payload.data { emit: { success: "ProviderUpdated", failure: "ProviderUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit PROVIDER_UPDATED)
    }
    emits {
      PROVIDER_UPDATED external { id: string }
    }
    listens {
      EDIT { id : string!, row : Provider }
      SAVE { data : object! }
          ProviderLoadFailed { error : string, code : string }
      ProviderBrowse EDIT -> EDIT
    }
    emits: [ProviderLoadFailed, ProviderLoaded, ProviderUpdateFailed, ProviderUpdated]
  }
  trait ProviderView -> Provider [interaction, collection] {
    emits {
      EDIT { id : string }
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      VIEW -> open
        (fetch Provider {id: "@payload.id" , emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" }, emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Specialty" }, { type: "typography", variant: "body", content: "@entity.specialty" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Location" }, { type: "typography", variant: "body", content: "@entity.location" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Rating" }, { type: "typography", variant: "body", content: "@entity.rating" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Available" }, { type: "typography", variant: "body", content: "@entity.available" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          ProviderLoadFailed { error : string, code : string }
      ProviderBrowse VIEW -> VIEW
    }
    emits: [ProviderLoaded, ProviderLoadFailed]
  }
  trait ProviderDelete -> Provider [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Provider {id: "@payload.id" , emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" }, emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Provider", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Provider @entity.pendingId { emit: { success: "ProviderDeleted", failure: "ProviderDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (emit PROVIDER_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
    }
    emits {
      PROVIDER_DELETED external { id: string }
    }
    listens {
      DELETE { id : string! }
          ProviderLoadFailed { error : string, code : string }
      ProviderBrowse DELETE -> DELETE
    }
    emits: [ProviderDeleteFailed, ProviderDeleted, ProviderLoadFailed, ProviderLoaded]
  }
  page "/providers" as ProvidersPage -> ProviderBrowse, ProviderCreate, ProviderEdit, ProviderView, ProviderDelete
}
orbital BookingOrbital {
  entity Booking [runtime] {
    id : string!
    providerName : string!
    customerName : string!
    customerEmail : string!
    date : string!
    time : string!
    notes : string
  }

  type BookingLoaded     = Event { data : [Booking] }                  "Fired when Booking finishes loading"
  type BookingLoadFailed = Event { error : string, code : string } "Fired when Booking fails to load"
  type BookingSaveFailed = Event { error : string, code : string }
  type BookingSaved = Event { id : string }
  trait BookingWizard -> Booking [interaction, collection] {
    initial: step1
    state step1 {
      INIT -> step1
        (fetch Booking { emit: { success: "BookingLoaded", failure: "BookingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "BookingSystemApp", navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "Book Appointment", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 0 }, { type: "wizard-progress", steps: ["Provider Selection", "Your Details", "Date and Time"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Provider Selection", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["providerName"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      NEXT -> step2
        (fetch Booking { emit: { success: "BookingLoaded", failure: "BookingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "BookingSystemApp", navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "Book Appointment", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 1 }, { type: "wizard-progress", steps: ["Provider Selection", "Your Details", "Date and Time"], currentStep: 1 }, { type: "divider" }, { type: "typography", content: "Your Details", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["customerName", "customerEmail"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
    state step2 {
      NEXT -> step3
        (fetch Booking { emit: { success: "BookingLoaded", failure: "BookingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "BookingSystemApp", navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "Book Appointment", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 2 }, { type: "wizard-progress", steps: ["Provider Selection", "Your Details", "Date and Time"], currentStep: 2 }, { type: "divider" }, { type: "typography", content: "Date and Time", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["date", "time", "notes"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      PREV -> step1
        (fetch Booking { emit: { success: "BookingLoaded", failure: "BookingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "BookingSystemApp", navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "Book Appointment", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 0 }, { type: "wizard-progress", steps: ["Provider Selection", "Your Details", "Date and Time"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Provider Selection", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["providerName"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
