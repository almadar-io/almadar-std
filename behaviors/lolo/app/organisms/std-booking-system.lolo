app std-booking-system "2.0.0"
"std-booking-system as a Function — providers, schedule, appointment slots, and bookings (clinic/salon/consult). Stripe-backed deposit payment, email + SMS confirmations."

orbital ProviderOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Browse from "std/behaviors/std-browse"
  uses Search from "std/behaviors/std-search"
  uses Filter from "std/behaviors/std-filter"
  uses Stats from "std/behaviors/std-stats"
  uses Graphs from "std/behaviors/std-graphs"

  entity Provider [persistent: providers] {
    id : string!
    name : string!
    specialty : string!
    location : string
    phone : string
    rating : number = 0
    hourlyRate : number = 0
    available : boolean = true
    pendingId : string = ""
  }

  trait BookingProviderAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.ProviderCatalog",
      appName: "BookingSystemApp",
      navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }],
      searchEvent: "BOOKING_SEARCH",
      notifications: [],
      notificationClickEvent: "BOOKING_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: BOOKING_SEARCH
      NOTIFY_CLICK: BOOKING_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait. Owns the header (icon + Providers + Add Provider button)
  ;; and embeds the toolbar (search/filter), stats, graphs, and the std-browse list.
  trait ProviderCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "user" },
              { type: "typography", content: "Providers", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Add Provider", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.ProviderSearch",
            "@trait.ProviderFilter"
          ]},
          { type: "divider" },
          "@trait.ProviderStats",
          "@trait.ProviderGraphs",
          { type: "divider" },
          "@trait.ProviderBrowseList"
        ]})
      BOOKING_SEARCH -> composing
      BOOKING_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to providers", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      BookingProviderAppLayout.BOOKING_SEARCH -> BOOKING_SEARCH
      BookingProviderAppLayout.BOOKING_NOTIFICATIONS_OPEN -> BOOKING_NOTIFICATIONS_OPEN
      BOOKING_SEARCH { value : string }
      BOOKING_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait ProviderSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search providers…",
      event: "SEARCH"
    }
  }

  trait ProviderFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "specialty", label: "Specialty", filterType: "select", options: ["general", "dental", "dermatology", "cardiology", "psychiatry"] },
        { field: "rating", label: "Rating", filterType: "select", options: ["1", "2", "3", "4", "5"] }
      ],
      event: "FILTER"
    }
  }

  trait ProviderStats = Stats.traits.StatsItemStats {
    config: {
      title: "Provider Overview",
      metrics: [
        { label: "Total Providers", aggregation: "count", icon: "users",       variant: "primary", format: "number" },
        { label: "Active",          aggregation: "count", icon: "check-circle", variant: "success", format: "number", filter: { available: true } },
        { label: "Avg Rating",      aggregation: "avg",   icon: "star",        variant: "info",    format: "number", field: "rating" },
        { label: "Avg Hourly Rate", aggregation: "avg",   icon: "dollar-sign", variant: "info",    format: "currency", field: "hourlyRate" }
      ]
    }
    listens {
      ProviderBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait ProviderGraphs = Graphs.traits.GraphItemGraph {
    config: {
      chartType: "pie",
      categoryField: "specialty",
      aggregation: "count",
      title: "Providers by Specialty",
      subtitle: "Distribution across specialties"
    }
    listens {
      ProviderBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  ;; The data-grid list, bound from std-browse via the `@trait.X` embedding pattern.
  trait ProviderBrowseList = Browse.traits.BrowseItemBrowse -> Provider {
    config: {
      fields: [
        { name: "name", variant: "h3", icon: "user" },
        { name: "specialty", variant: "badge" },
        { name: "rating", variant: "body", format: "number" },
        { name: "hourlyRate", label: "Hourly Rate", variant: "h4", format: "currency" },
        { name: "available", label: "Availability", variant: "body", format: "boolean" }
      ],
      itemActions: [
        { label: "View", event: "VIEW", variant: "ghost" },
        { label: "Edit", event: "EDIT", variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 2,
      gap: "md"
    }
    listens {
      ProviderCreate.PROVIDER_CREATED -> INIT
      ProviderEdit.PROVIDER_UPDATED -> INIT
      ProviderDelete.PROVIDER_DELETED -> INIT
      ProviderSearch.SEARCH -> REFETCH_QUERY
      ProviderFilter.FILTER -> REFETCH_FILTER
    }
  }

  type ProviderLoaded     = Event { data : [Provider] }                  "Fired when Provider finishes loading"
  type ProviderLoadFailed = Event { error : string, code : string } "Fired when Provider fails to load"
  type ProviderSaved = Event { id : string }
  type ProviderSaveFailed = Event { error : string, code : string }
  type ProviderUpdated = Event { id : string }
  type ProviderUpdateFailed = Event { error : string, code : string }
  type ProviderDeleted = Event { id : string }
  type ProviderDeleteFailed = Event { error : string, code : string }
  trait ProviderCreate -> Provider [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      CREATE -> open
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Add Provider", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "specialty", "location", "phone", "rating", "hourlyRate", "available"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Provider @payload.data { emit: { success: "ProviderSaved", failure: "ProviderSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit PROVIDER_CREATED)
    }
    emits {
      PROVIDER_CREATED -> external { id: string }
      ProviderLoadFailed
      ProviderLoaded
      ProviderSaveFailed
      ProviderSaved
    }
    listens {
      SAVE { data : object! }
      ProviderLoadFailed { error : string, code : string }
      ProviderCatalog.CREATE -> CREATE
    }
  }
  trait ProviderEdit -> Provider [interaction, collection] {
    listens {
      ProviderView.EDIT -> EDIT
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      EDIT -> open
        (fetch Provider {id: "@payload.id" , emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" }, emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Provider", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "specialty", "location", "phone", "rating", "hourlyRate", "available"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Provider @payload.data { emit: { success: "ProviderUpdated", failure: "ProviderUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit PROVIDER_UPDATED)
    }
    emits {
      PROVIDER_UPDATED -> external { id: string }
      ProviderLoadFailed
      ProviderLoaded
      ProviderUpdateFailed
      ProviderUpdated
    }
    listens {
      EDIT { id : string!, row : Provider }
      SAVE { data : object! }
      ProviderLoadFailed { error : string, code : string }
      ProviderBrowseList.EDIT -> EDIT
    }
  }
  trait ProviderView -> Provider [interaction, collection] {
    emits {
      EDIT { id : string }
      ProviderLoaded
      ProviderLoadFailed
    }
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.available true)
        (set @entity.hourlyRate 0)
        (set @entity.location "")
        (set @entity.name "")
        (set @entity.phone "")
        (set @entity.rating 0)
        (set @entity.specialty "")
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      VIEW -> open
        (fetch Provider {id: "@payload.id" , emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" }, emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Specialty" }, { type: "typography", variant: "body", content: "@entity.specialty" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Location" }, { type: "typography", variant: "body", content: "@entity.location" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Rating" }, { type: "typography", variant: "body", content: "@entity.rating" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Hourly Rate" }, { type: "typography", variant: "body", content: "@entity.hourlyRate" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Available" }, { type: "typography", variant: "body", content: "@entity.available" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
      ProviderLoadFailed { error : string, code : string }
      ProviderBrowseList.VIEW -> VIEW
    }
  }
  trait ProviderDelete -> Provider [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Provider {id: "@payload.id" , emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" }, emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Provider", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Provider @entity.pendingId { emit: { success: "ProviderDeleted", failure: "ProviderDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
        (emit PROVIDER_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Provider { emit: { success: "ProviderLoaded", failure: "ProviderLoadFailed" } })
    }
    emits {
      PROVIDER_DELETED -> external { id: string }
      ProviderDeleteFailed
      ProviderDeleted
      ProviderLoadFailed
      ProviderLoaded
    }
    listens {
      DELETE { id : string! }
      ProviderLoadFailed { error : string, code : string }
      ProviderBrowseList.DELETE -> DELETE
    }
  }
  page "/providers" as ProvidersPage -> BookingProviderAppLayout, ProviderCatalog, ProviderSearch, ProviderFilter, ProviderStats, ProviderGraphs, ProviderBrowseList, ProviderCreate, ProviderEdit, ProviderView, ProviderDelete
}
orbital BookingOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Stripe from "std/behaviors/std-service-stripe"

  entity Booking [runtime] {
    id : string!
    providerName : string!
    customerName : string!
    email : string!
    phone : string!
    scheduledAt : string!
    notes : string
    depositAmount : number = 0
    status : string = "draft"
  }

  trait BookingAppLayout = AppShell.traits.AppLayout -> Booking {
    config: {
      contentTrait: "@trait.BookingWizard",
      appName: "BookingSystemApp",
      navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }],
      searchEvent: "BOOKING_SEARCH",
      topBarActions: [],
      notifications: [],
      notificationClickEvent: "BOOKING_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: BOOKING_SEARCH
      NOTIFY_CLICK: BOOKING_NOTIFICATIONS_OPEN
    }
  }

  ;; Stripe service binding — Pattern B (uiTrait override). Pulls amount from
  ;; the wizard's @entity.depositAmount, points UI slot at the consumer's
  ;; BookingPaymentForm. The wizard's `listens` block at the bottom
  ;; references ServiceStripeStripeCompleted directly to advance to confirmation.
  trait BookingPayment = Stripe.traits.ServiceStripeStripe {
    config: {
      amount: 0,
      currency: "usd",
      metadata: {},
      uiTrait: "@trait.BookingPaymentForm"
    }
    listens {
      BookingPaymentForm.CREATE_PAYMENT -> CREATE_PAYMENT
      PAYMENT_CREATED { id : string!, clientSecret : string! }
      FAILED { error : string! }
      ServiceStripeLoadFailed { message : string }
      ServiceStripeStripeFailed { error : string, code : string }
    }
  }

  ;; Consumer's payment form — fills the uiTrait slot on BookingPayment. Emits
  ;; CREATE_PAYMENT when user clicks Pay; the Stripe trait above listens.
  trait BookingPaymentForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [
          { type: "alert", variant: "info", message: "Enter card details to pay your booking deposit." },
          { type: "input", inputType: "text", placeholder: "Card number" },
          { type: "stack", direction: "horizontal", gap: "sm", children: [
            { type: "input", inputType: "text", placeholder: "MM/YY" },
            { type: "input", inputType: "text", placeholder: "CVC" }
          ]},
          { type: "button", label: "Pay deposit", action: "CREATE_PAYMENT", variant: "primary", icon: "credit-card" }
        ]})
    }
    emits {
      CREATE_PAYMENT -> external { source : string }
    }
  }

  type BookingLoaded     = Event { data : [Booking] }                  "Fired when Booking finishes loading"
  type BookingLoadFailed = Event { error : string, code : string } "Fired when Booking fails to load"
  type BookingSaveFailed = Event { error : string, code : string }
  type BookingSaved = Event { id : string }
  type BookingEmailSent = Event { messageId : string }
  type BookingEmailFailed = Event { error : string, code : string }
  type BookingSmsSent = Event { messageSid : string }
  type BookingSmsFailed = Event { error : string, code : string }

  trait BookingWizard -> Booking [interaction, instance] {
    initial: step1
    state step1 {
      INIT -> step1
        (set @entity.providerName "")
        (set @entity.customerName "")
        (set @entity.email "")
        (set @entity.phone "")
        (set @entity.scheduledAt "")
        (set @entity.notes "")
        (set @entity.depositAmount 50)
        (set @entity.status "draft")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Select Provider" },
          { type: "form-section", mode: "create", submitEvent: "NEXT", submitLabel: "Continue", showCancel: false, fields: [{ name: "providerName", required: true, min: 2 }] }
        ]})
      ;; Guard: step1 -> step2 only fires when providerName is populated.
      NEXT -> step2 when @payload.data.providerName
        (set @entity.providerName @payload.data.providerName)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Select Time" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: [{ name: "scheduledAt", required: true }] }
        ]})
    }
    state step2 {
      ;; Guard: step2 -> step3 requires step1 to have committed providerName
      ;; AND the current submission to carry scheduledAt.
      NEXT -> step3 when (and @entity.providerName @payload.data.scheduledAt)
        (set @entity.scheduledAt @payload.data.scheduledAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 2 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Your Details" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: [{ name: "customerName", required: true, min: 2 }, { name: "email", type: "email", required: true }, { name: "phone", required: true }, { name: "notes" }] }
        ]})
      PREV -> step1
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Select Provider" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", submitLabel: "Continue", showCancel: false, fields: [{ name: "providerName", required: true, min: 2 }] }
        ]})
    }
    state step3 {
      ;; Guard: step3 -> step4 (payment) requires customerName + email + phone.
      NEXT -> step4 when (and @payload.data.customerName @payload.data.email @payload.data.phone)
        (set @entity.customerName @payload.data.customerName)
        (set @entity.email @payload.data.email)
        (set @entity.phone @payload.data.phone)
        (set @entity.notes @payload.data.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 3 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Pay Deposit" },
          "@trait.BookingPayment",
          { type: "stack", direction: "horizontal", gap: "sm", justify: "start", children: [
            { type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }
          ]}
        ]})
      PREV -> step2
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Select Time" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: [{ name: "scheduledAt", required: true }] }
        ]})
    }
    state step4 {
      ;; Guard: PAYMENT_DONE -> review requires the full booking entity to
      ;; be populated by previous steps. Stripe fires PAYMENT_DONE.
      PAYMENT_DONE -> review when (and @entity.providerName @entity.scheduledAt @entity.customerName @entity.email @entity.phone)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Review your booking" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 4 },
          { type: "divider" },
          { type: "stack", direction: "vertical", gap: "sm", children: [
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Provider" }, { type: "typography", variant: "body", content: "@entity.providerName" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "When" }, { type: "typography", variant: "body", content: "@entity.scheduledAt" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Customer" }, { type: "typography", variant: "body", content: "@entity.customerName" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Deposit Paid" }, { type: "typography", variant: "body", content: "@entity.depositAmount" }] }
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", justify: "between", children: [
            { type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" },
            { type: "button", label: "Confirm booking", action: "COMPLETE", variant: "primary", icon: "check" }
          ]}
        ]})
      PREV -> step3
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 2 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Your Details" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: [{ name: "customerName", required: true, min: 2 }, { name: "email", type: "email", required: true }, { name: "phone", required: true }, { name: "notes" }] }
        ]})
    }
    state review {
      ;; Guard: COMPLETE only fires from review when the whole entity is set.
      COMPLETE -> complete when (and @entity.providerName @entity.scheduledAt @entity.customerName @entity.email @entity.phone)
        (set @entity.status "confirmed")
        (persist create Booking @entity { emit: { success: "BookingSaved", failure: "BookingSaveFailed" } })
        (call-service email "send" { recipient: "@entity.email", subject: "Booking Confirmed", body: "Your booking is confirmed.", sender: "noreply@bookings.example" } { emit: { success: "BookingEmailSent", failure: "BookingEmailFailed" } })
        (call-service twilio "sendSMS" { recipient: "@entity.phone", body: "Booking confirmed for @entity.scheduledAt", sender: "+15551234567" } { emit: { success: "BookingSmsSent", failure: "BookingSmsFailed" } })
        (emit BOOKING_CONFIRMED { id: "@entity.id" })
        (notify success "Booking confirmed")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "icon", name: "check-circle" },
          { type: "typography", variant: "h2", content: "Booking confirmed" },
          { type: "typography", variant: "body", color: "muted", content: "We have emailed and SMS-confirmed your appointment." },
          { type: "button", label: "Book another", action: "RESTART", variant: "ghost", icon: "rotate-ccw" }
        ]})
      PREV -> step4
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 3 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Pay Deposit" },
          "@trait.BookingPayment",
          { type: "stack", direction: "horizontal", gap: "sm", justify: "start", children: [
            { type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }
          ]}
        ]})
    }
    state complete {
      RESTART -> step1
        (set @entity.providerName "")
        (set @entity.customerName "")
        (set @entity.email "")
        (set @entity.phone "")
        (set @entity.scheduledAt "")
        (set @entity.notes "")
        (set @entity.depositAmount 50)
        (set @entity.status "draft")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Book Appointment" },
          { type: "wizard-progress", steps: ["Select Provider", "Select Time", "Your Details", "Payment", "Confirmation"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Select Provider" },
          { type: "form-section", mode: "create", submitEvent: "NEXT", submitLabel: "Continue", showCancel: false, fields: [{ name: "providerName", required: true, min: 2 }] }
        ]})
    }
    emits {
      BOOKING_CONFIRMED -> external { id : string }
      BookingSaved
      BookingSaveFailed
      BookingEmailSent
      BookingEmailFailed
      BookingSmsSent
      BookingSmsFailed
    }
    listens {
      ProviderOrbital.ProviderBrowseList.VIEW -> INIT
      BookingPayment.ServiceStripeStripeCompleted -> PAYMENT_DONE
      BookingPayment.ServiceStripeStripeFailed -> PAYMENT_FAILED
      BookingPayment.ServiceStripeLoaded -> NOOP
      BookingPayment.ServiceStripeLoadFailed -> NOOP
      NEXT { data : object! }
      PREV { }
      PAYMENT_DONE { result : object }
      PAYMENT_FAILED { error : string, code : string }
      NOOP { id : string, message : string }
      COMPLETE { }
      BookingSaveFailed { error : string, code : string }
      BookingEmailFailed { error : string, code : string }
      BookingSmsFailed { error : string, code : string }
    }
  }
  page "/book" -> BookingAppLayout, BookingWizard, BookingPayment, BookingPaymentForm
}
orbital AppointmentOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Calendar from "std/behaviors/std-calendar"
  uses Browse from "std/behaviors/std-browse"
  uses Reminder from "std/behaviors/std-reminder-scheduler"
  uses Notify   from "std/behaviors/std-notify-on-event"
  uses Approval from "std/behaviors/std-approval-gate"

  entity Appointment [persistent: appointments] {
    id : string!
    providerName : string!
    customerName : string!
    summary : string!
    scheduledAt : datetime!
    time : string!
    status : string = "scheduled"
    notes : string
    pendingId : string = ""
  }

  type AppointmentLoaded     = Event { data : [Appointment] }                  "Fired when Appointment finishes loading"
  type AppointmentLoadFailed = Event { error : string, code : string } "Fired when Appointment fails to load"
  type AppointmentDeleteFailed = Event { error : string, code : string }
  type AppointmentDeleted = Event { id : string }
  type AppointmentSaveFailed = Event { error : string, code : string }
  type AppointmentSaved = Event { id : string }
  type AppointmentUpdateFailed = Event { error : string, code : string }
  type AppointmentUpdated = Event { id : string }

  trait AppointmentAppLayout = AppShell.traits.AppLayout -> Appointment {
    config: {
      contentTrait: "@trait.AppointmentDashboard",
      appName: "BookingSystemApp",
      navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }],
      searchEvent: "APPOINTMENT_SEARCH",
      topBarActions: [],
      notifications: [],
      notificationClickEvent: "APPOINTMENT_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: APPOINTMENT_SEARCH
      NOTIFY_CLICK: APPOINTMENT_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait that owns the header (icon + title + Create button)
  ;; and embeds the Calendar primary view + BrowseList fallback.
  trait AppointmentDashboard [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "calendar" },
              { type: "typography", content: "Appointments", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Create Appointment", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.AppointmentCalendar",
          { type: "divider" },
          "@trait.AppointmentBrowseList"
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
  }

  ;; Calendar view as the primary surface — domain-fit for appointments.
  trait AppointmentCalendar = Calendar.traits.CalendarEventCalendar -> Appointment {
    config: {
      dateField: "scheduledAt",
      titleField: "summary",
      colorField: "status"
    }
    listens {
      AppointmentCreate.APPOINTMENT_CREATED -> INIT
      AppointmentEdit.APPOINTMENT_UPDATED -> INIT
      AppointmentDelete.APPOINTMENT_DELETED -> INIT
      BookingOrbital.BookingWizard.BOOKING_CONFIRMED -> INIT
    }
  }

  ;; Fallback list for table/grid rendering of the same appointments.
  trait AppointmentBrowseList = Browse.traits.BrowseItemBrowse -> Appointment {
    config: {
      fields: [
        { name: "summary", label: "Summary", variant: "h3", icon: "calendar" },
        { name: "providerName", label: "Provider", variant: "body" },
        { name: "customerName", label: "Customer", variant: "body" },
        { name: "scheduledAt", label: "When", variant: "body", format: "date" },
        { name: "time", variant: "caption" },
        { name: "status", variant: "badge" }
      ],
      itemActions: [
        { label: "View", event: "VIEW", variant: "ghost" },
        { label: "Edit", event: "EDIT", variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      AppointmentCreate.APPOINTMENT_CREATED -> INIT
      AppointmentEdit.APPOINTMENT_UPDATED -> INIT
      AppointmentDelete.APPOINTMENT_DELETED -> INIT
      BookingOrbital.BookingWizard.BOOKING_CONFIRMED -> INIT
    }
  }

  trait AppointmentCreate -> Appointment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
      CREATE -> open
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Appointment", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["providerName", "customerName", "summary", "scheduledAt", "time", "status", "notes"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Appointment @payload.data { emit: { success: "AppointmentSaved", failure: "AppointmentSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit APPOINTMENT_CREATED)
    }
    emits {
      APPOINTMENT_CREATED
      AppointmentLoadFailed
      AppointmentLoaded
      AppointmentSaveFailed
      AppointmentSaved
    }
    listens {
      AppointmentLoadFailed { error : string, code : string }
      SAVE { data : string }
      AppointmentDashboard.CREATE -> CREATE
    }
  }
  trait AppointmentEdit -> Appointment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
      EDIT -> open
        (fetch Appointment {id: "@payload.id" , emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" }, emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Appointment", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["providerName", "customerName", "summary", "scheduledAt", "time", "status", "notes"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Appointment @payload.data { emit: { success: "AppointmentUpdated", failure: "AppointmentUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit APPOINTMENT_UPDATED)
    }
    emits {
      APPOINTMENT_UPDATED
      AppointmentLoadFailed
      AppointmentLoaded
      AppointmentUpdateFailed
      AppointmentUpdated
    }
    listens {
      AppointmentView.EDIT -> EDIT
      AppointmentLoadFailed { error : string, code : string }
      EDIT { id : string, row : Appointment }
      SAVE { data : string }
      AppointmentBrowseList.EDIT -> EDIT
    }
  }
  trait AppointmentView -> Appointment [interaction, collection] {
    emits {
      EDIT { id : string }
      AppointmentLoaded
      AppointmentLoadFailed
    }
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.customerName "")
        (set @entity.summary "")
        (set @entity.notes "")
        (set @entity.providerName "")
        (set @entity.scheduledAt "")
        (set @entity.status "")
        (set @entity.time "")
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
      VIEW -> open
        (fetch Appointment {id: "@payload.id" , emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" }, emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.summary" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Provider" }, { type: "typography", variant: "body", content: "@entity.providerName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Customer" }, { type: "typography", variant: "body", content: "@entity.customerName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "When" }, { type: "typography", variant: "body", content: "@entity.scheduledAt" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Time" }, { type: "typography", variant: "body", content: "@entity.time" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      AppointmentLoadFailed { error : string, code : string }
      VIEW { id : string }
      AppointmentBrowseList.VIEW -> VIEW
    }
  }
  trait AppointmentDelete -> Appointment [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Appointment {id: "@payload.id" , emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" }, emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Appointment", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Appointment @entity.pendingId { emit: { success: "AppointmentDeleted", failure: "AppointmentDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
        (emit APPOINTMENT_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Appointment { emit: { success: "AppointmentLoaded", failure: "AppointmentLoadFailed" } })
    }
    emits {
      APPOINTMENT_DELETED
      AppointmentDeleteFailed
      AppointmentDeleted
      AppointmentLoadFailed
      AppointmentLoaded
    }
    listens {
      AppointmentLoadFailed { error : string, code : string }
      DELETE { id : string }
      AppointmentBrowseList.DELETE -> DELETE
    }
  }
  trait AppointmentReminder = Reminder.traits.ReminderScheduler {
    config: {
      targetEntity: "Appointment",
      dateField: "scheduledAt",
      offsetsHours: [24, 1],
      severity: "info",
      template: "Reminder: your appointment is approaching",
      windowToleranceMinutes: 60
    }
  }

  trait AppointmentNotifier = Notify.traits.NotifyOnEventListener {
    config: {
      listensFor: ["BookingConfirmed", "BookingCancelled"],
      notifyChannel: "in-app",
      template: "Your booking has been updated",
      severity: "info",
      recipients: [],
      suppressionList: []
    }
    events {
      EventOccurred: BookingConfirmed
    }
  }

  trait AppointmentOverbookApproval = Approval.traits.ApprovalGateReview {
    config: {
      approverRoles: ["manager"],
      threshold: 0,
      autoApproveBelowThreshold: true,
      valueField: "overbookCount",
      escalationHours: 4,
      escalationRoles: ["director"]
    }
  }

  page "/appointments" -> AppointmentAppLayout, AppointmentDashboard, AppointmentCalendar, AppointmentBrowseList, AppointmentCreate, AppointmentEdit, AppointmentView, AppointmentDelete, AppointmentReminder, AppointmentNotifier, AppointmentOverbookApproval
}
orbital ScheduleOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  entity Schedule [singleton] {
    id : string!
    totalBookings : number = 0
    confirmedToday : number = 0
    pendingBookings : number = 0
    availableSlots : number = 0
  }

  trait ScheduleAppLayout = AppShell.traits.AppLayout -> Schedule {
    config: {
      contentTrait: "@trait.ScheduleDisplay",
      appName: "BookingSystemApp",
      navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }],
      searchEvent: "SCHEDULE_SEARCH",
      topBarActions: [],
      notifications: [],
      notificationClickEvent: "SCHEDULE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: SCHEDULE_SEARCH
      NOTIFY_CLICK: SCHEDULE_NOTIFICATIONS_OPEN
    }
  }

  type ScheduleLoaded     = Event { data : [Schedule] }                  "Fired when Schedule finishes loading"
  type ScheduleLoadFailed = Event { error : string, code : string } "Fired when Schedule fails to load"

  ;; Custom render-ui retained — schedule grids (day x time-slot with availability
  ;; indicators) are domain-specific layouts that don't generalize into a std atom.
  trait ScheduleDisplay -> Schedule [interaction, collection] {
    initial: loading
    state loading {
      INIT -> displaying
        (set @entity.availableSlots 0)
        (set @entity.confirmedToday 0)
        (set @entity.pendingBookings 0)
        (set @entity.totalBookings 0)
        (fetch Schedule { emit: { success: "ScheduleLoaded", failure: "ScheduleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "clock" },
              { type: "typography", content: "Schedule Overview", variant: "h2" }
            ]},
            { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }
          ]},
          { type: "divider" },
          { type: "simple-grid", cols: 4, children: [
            { type: "stat-display", label: "Total Bookings", value: "@entity.totalBookings", icon: "calendar" },
            { type: "stat-display", label: "Confirmed Today", value: "@entity.confirmedToday", icon: "check-circle" },
            { type: "stat-display", label: "Pending", value: "@entity.pendingBookings", icon: "clock" },
            { type: "stat-display", label: "Available Slots", value: "@entity.availableSlots", icon: "calendar-plus" }
          ]},
          { type: "divider" },
          ;; Domain-specific grid: rows=days, cols=time-slots, cells indicate
          ;; availability. Inlined because no std atom captures schedule grids.
          { type: "calendar-grid" }
        ]})
    }
    state displaying {
      REFRESH -> refreshing
        (fetch Schedule { emit: { success: "ScheduleLoaded", failure: "ScheduleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Refreshing…" }] })
      ScheduleLoaded -> displaying
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "clock" },
              { type: "typography", content: "Schedule Overview", variant: "h2" }
            ]},
            { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }
          ]},
          { type: "divider" },
          { type: "simple-grid", cols: 4, children: [
            { type: "stat-display", label: "Total Bookings", value: "@entity.totalBookings", icon: "calendar" },
            { type: "stat-display", label: "Confirmed Today", value: "@entity.confirmedToday", icon: "check-circle" },
            { type: "stat-display", label: "Pending", value: "@entity.pendingBookings", icon: "clock" },
            { type: "stat-display", label: "Available Slots", value: "@entity.availableSlots", icon: "calendar-plus" }
          ]},
          { type: "divider" },
          { type: "calendar-grid" }
        ]})
    }
    state refreshing {
      ScheduleLoaded -> displaying
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "clock" },
              { type: "typography", content: "Schedule Overview", variant: "h2" }
            ]},
            { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }
          ]},
          { type: "divider" },
          { type: "simple-grid", cols: 4, children: [
            { type: "stat-display", label: "Total Bookings", value: "@entity.totalBookings", icon: "calendar" },
            { type: "stat-display", label: "Confirmed Today", value: "@entity.confirmedToday", icon: "check-circle" },
            { type: "stat-display", label: "Pending", value: "@entity.pendingBookings", icon: "clock" },
            { type: "stat-display", label: "Available Slots", value: "@entity.availableSlots", icon: "calendar-plus" }
          ]},
          { type: "divider" },
          { type: "calendar-grid" }
        ]})
      ScheduleLoadFailed -> displaying
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to refresh schedule" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "REFRESH", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      ScheduleLoaded
      ScheduleLoadFailed
    }
    listens {
      ScheduleLoadFailed { error : string, code : string }
      BookingOrbital.BookingWizard.BOOKING_CONFIRMED -> INIT
    }
  }
  page "/schedule" -> ScheduleAppLayout, ScheduleDisplay
}

orbital AppointmentPolicyFromStdOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Policies from "std/behaviors/std-appointment-policy"

  entity AppointmentPolicy [persistent: appointment_policies] {
    id                         : string!
    name                       : string!
    description                : string = ""
    rescheduleWindowHours      : number = 24
    maxReschedules             : number = 2
    cancellationPolicy         : "free" | "partial-refund" | "no-refund" = "free"
    noShowGracePeriodMinutes   : number = 15
    noShowFeeAmount            : number = 0
    lateArrivalGraceMinutes    : number = 10
    status                     : "active" | "archived" = "active"
    createdAt                  : string
  }

  trait AppointmentPolicyFromStdAppLayout = AppShell.traits.AppLayout -> AppointmentPolicy {
    config: {
      contentTrait: "@trait.AppointmentPolicyFromStdManageBlock",
      appName: "BookingSystemApp",
      navItems: [{ label: "Providers", href: "/providers", icon: "user-check" }, { label: "Book", href: "/book", icon: "calendar-plus" }, { label: "Appointments", href: "/appointments", icon: "calendar" }, { label: "Schedule", href: "/schedule", icon: "clock" }, { label: "Appointment Policies", href: "/appointment-policies-from-std", icon: "calendar-check" }],
      searchEvent: "APPOINTMENT_POLICY_SEARCH",
      notifications: [],
      notificationClickEvent: "APPOINTMENT_POLICY_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: APPOINTMENT_POLICY_SEARCH
      NOTIFY_CLICK: APPOINTMENT_POLICY_NOTIFICATIONS_OPEN
    }
  }

  trait AppointmentPolicyFromStdManageBlock = Policies.traits.AppointmentPolicyManage -> AppointmentPolicy {
    config: {
      title: "Appointment Policies"
    }
  }

  page "/appointment-policies-from-std" as AppointmentPolicyFromStdPage -> AppointmentPolicyFromStdAppLayout, AppointmentPolicyFromStdManageBlock
}
