app std-api-gateway "2.0.0"
"API gateway admin: routes, backends, analytics. Pick for API management dashboards."

orbital RouteOrbital {
  uses AppShell      from "std/behaviors/std-app-layout"
  uses Modal         from "std/behaviors/std-modal"
  uses Confirmation  from "std/behaviors/std-confirmation"
  uses Search        from "std/behaviors/std-search"
  uses Filter        from "std/behaviors/std-filter"
  uses Stats         from "std/behaviors/std-stats"
  uses Graphs        from "std/behaviors/std-graphs"
  uses Browse        from "std/behaviors/std-browse"
  uses Audit         from "std/behaviors/std-audit-capture"
  uses Notify        from "std/behaviors/std-notify-on-event"

  entity Route [persistent: routes] {
    id : string!
    path : string!
    method : "GET" | "POST" | "PUT" | "DELETE" = "GET"
    status : "active" | "disabled" = "active"
    target : string!
    hits : number = 0
    rateLimit : number = 0
    pendingId : string = ""
  }

  trait RouteAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.RouteCatalog",
      appName: "API Gateway",
      navItems: [{ label: "Routes", href: "/routes", icon: "git-branch" }, { label: "Backends", href: "/backends", icon: "server" }, { label: "Analytics", href: "/analytics", icon: "bar-chart-2" }],
      searchEvent: "ROUTE_SEARCH",
      notifications: [],
      notificationClickEvent: "ROUTE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: ROUTE_SEARCH
      NOTIFY_CLICK: ROUTE_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait. Owns the header (icon + Routes + Create button)
  ;; + toolbar (search/filter) + stat row + graphs + embedded list. The
  ;; AppLayout's `contentTrait` points here.
  trait RouteCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "git-branch" },
              { type: "typography", content: "Routes", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Create Route", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.RouteSearch",
            "@trait.RouteFilter"
          ]},
          "@trait.RouteStats",
          "@trait.RouteGraphs",
          { type: "divider" },
          "@trait.RouteBrowseList"
        ]})
      ROUTE_SEARCH -> composing
      ROUTE_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to routes", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      RouteAppLayout.ROUTE_SEARCH -> ROUTE_SEARCH
      RouteAppLayout.ROUTE_NOTIFICATIONS_OPEN -> ROUTE_NOTIFICATIONS_OPEN
      ROUTE_SEARCH { value : string }
      ROUTE_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait RouteSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search routes…",
      event: "ROUTE_SEARCH"
    }
  }

  trait RouteFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "method", label: "Method", filterType: "select", options: ["GET", "POST", "PUT", "DELETE"] },
        { field: "status", label: "Status", filterType: "select", options: ["active", "disabled"] }
      ],
      event: "ROUTE_FILTER"
    }
  }

  trait RouteStats = Stats.traits.StatsItemStats {
    config: {
      title: "Routes",
      metrics: [
        { aggregation: "count", label: "Total",    icon: "git-branch",   variant: "primary", format: "number" },
        { aggregation: "count", label: "Active",   icon: "check-circle", variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "active"]] },
        { aggregation: "count", label: "Disabled", icon: "x-circle",     variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "disabled"]] }
      ]
    }
    listens {
      RouteBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait RouteGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Routes by Method",
      subtitle: "Distribution across HTTP methods",
      chartType: "pie",
      categoryField: "method",
      aggregation: "count",
      height: 240,
      showLegend: true
    }
    listens {
      RouteBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait RouteBrowseList = Browse.traits.BrowseItemBrowse -> Route {
    config: {
      fields: [
        { name: "path",      variant: "h3",      icon: "git-branch" },
        { name: "method",    variant: "badge" },
        { name: "status",    variant: "badge" },
        { name: "target",    variant: "body" },
        { name: "hits",      label: "Hits",      variant: "caption", format: "number" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      RouteSearch.SEARCH               -> REFETCH_QUERY
      RouteFilter.FILTER               -> REFETCH_FILTER
      RoutePersistor.ROUTE_CREATED     -> INIT
      RoutePersistor.ROUTE_UPDATED     -> INIT
      RoutePersistor.ROUTE_DELETED     -> INIT
    }
  }

  trait RouteCreate = Modal.traits.ModalRecordModal -> Route {
    config: {
      icon: "plus-circle",
      title: "New Route",
      mode: "create",
      fields: ["path", "method", "status", "target", "rateLimit"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      RouteCatalog.CREATE -> CREATE
      CREATE { id : string, row : Route }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait RouteEdit = Modal.traits.ModalRecordModal -> Route {
    config: {
      icon: "edit",
      title: "Edit Route",
      mode: "edit",
      fields: ["path", "method", "status", "target", "rateLimit"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      RouteBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Route }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait RouteView = Modal.traits.ModalRecordModal -> Route {
    config: {
      icon: "eye",
      title: "View Route",
      mode: "edit",
      fields: ["path", "method", "status", "target", "rateLimit"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      RouteBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Route }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait RouteDelete = Confirmation.traits.ConfirmActionConfirmation -> Route {
    config: {
      icon: "alert-triangle",
      title: "Delete Route",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      RouteBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Route }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  ;; Coordinator — owns persist side-effects fired by Modal/Confirm trait emits.
  trait RoutePersistor -> Route [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Route @payload.data { emit: { success: "ROUTE_CREATED" } })
      DO_UPDATE -> idle
        (persist update Route @payload.data { emit: { success: "ROUTE_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Route @payload.id { emit: { success: "ROUTE_DELETED" } })
    }
    emits {
      ROUTE_CREATED -> external { id : string }
      ROUTE_UPDATED -> external { id : string }
      ROUTE_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      RouteCreate.SAVE          -> DO_CREATE
      RouteEdit.SAVE            -> DO_UPDATE
      RouteDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  trait RouteAuditCapture = Audit.traits.AuditCaptureListener {
    config: {
      captureEntity: "Route",
      captureEventTypes: [],
      excludeFields: [],
      captureBeforeAfter: true,
      retentionDays: 2555
    }
    events {
      EntityMutated: ROUTE_UPDATED
    }
  }

  trait RouteUptimeNotifier = Notify.traits.NotifyOnEventListener {
    config: {
      listensFor: ["ROUTE_UPDATED"],
      notifyChannel: "email",
      template: "Route uptime alert",
      severity: "warning",
      recipients: [],
      suppressionList: []
    }
    events {
      EventOccurred: ROUTE_UPDATED
    }
  }

  page "/routes" as RoutesPage -> RouteAppLayout, RouteCatalog, RouteSearch, RouteFilter, RouteStats, RouteGraphs, RouteBrowseList, RouteCreate, RouteEdit, RouteView, RouteDelete, RoutePersistor, RouteAuditCapture, RouteUptimeNotifier
}

orbital BackendOrbital {
  uses AppShell       from "std/behaviors/std-app-layout"
  uses Modal          from "std/behaviors/std-modal"
  uses Confirmation   from "std/behaviors/std-confirmation"
  uses Browse         from "std/behaviors/std-browse"
  uses CircuitBreaker from "std/behaviors/std-circuit-breaker"
  uses RateLimiter    from "std/behaviors/std-rate-limiter"
  uses CacheAside     from "std/behaviors/std-cache-aside"

  entity Backend [persistent: backends] {
    id : string!
    name : string!
    url : string!
    status : "active" | "disabled" = "active"
    latency : number = 0
    pendingId : string = ""
  }

  trait BackendAppLayout = AppShell.traits.AppLayout -> Backend {
    config: {
      contentTrait: "@trait.BackendCatalog",
      appName: "API Gateway",
      navItems: [{ label: "Routes", href: "/routes", icon: "git-branch" }, { label: "Backends", href: "/backends", icon: "server" }, { label: "Analytics", href: "/analytics", icon: "bar-chart-2" }],
      searchEvent: "BACKEND_SEARCH",
      notifications: [],
      notificationClickEvent: "BACKEND_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: BACKEND_SEARCH
      NOTIFY_CLICK: BACKEND_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait — header + browse list + circuit breaker visualization
  ;; from the std-circuit-breaker atom (which renders its own UI).
  trait BackendCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "server" },
              { type: "typography", content: "Backends", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Create Backend", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.BackendBrowseList",
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Service Health" },
          "@trait.BackendCircuitBreaker",
          "@trait.BackendRateLimiter",
          "@trait.BackendCache"
        ]})
      BACKEND_SEARCH -> composing
      BACKEND_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to backends", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      BackendAppLayout.BACKEND_SEARCH -> BACKEND_SEARCH
      BackendAppLayout.BACKEND_NOTIFICATIONS_OPEN -> BACKEND_NOTIFICATIONS_OPEN
      BACKEND_SEARCH { value : string }
      BACKEND_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait BackendBrowseList = Browse.traits.BrowseItemBrowse -> Backend {
    config: {
      fields: [
        { name: "name",    variant: "h3",      icon: "server" },
        { name: "url",     variant: "body" },
        { name: "status",  variant: "badge" },
        { name: "latency", label: "Latency",   variant: "caption", format: "number" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      BackendPersistor.BACKEND_CREATED -> INIT
      BackendPersistor.BACKEND_UPDATED -> INIT
      BackendPersistor.BACKEND_DELETED -> INIT
    }
  }

  ;; Resilience visualizations: circuit breaker, rate limiter, cache.
  ;; Atoms render their own UI; we just bind them.
  trait BackendCircuitBreaker = CircuitBreaker.traits.ServiceNodeCircuitBreaker { }

  trait BackendRateLimiter = RateLimiter.traits.RateBucketRateLimiter { }

  trait BackendCache = CacheAside.traits.CacheEntryCacheManager { }

  trait BackendCreate = Modal.traits.ModalRecordModal -> Backend {
    config: {
      icon: "plus-circle",
      title: "New Backend",
      mode: "create",
      fields: ["name", "url", "status", "latency"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      BackendCatalog.CREATE -> CREATE
      CREATE { id : string, row : Backend }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait BackendEdit = Modal.traits.ModalRecordModal -> Backend {
    config: {
      icon: "edit",
      title: "Edit Backend",
      mode: "edit",
      fields: ["name", "url", "status", "latency"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      BackendBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Backend }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait BackendView = Modal.traits.ModalRecordModal -> Backend {
    config: {
      icon: "eye",
      title: "View Backend",
      mode: "edit",
      fields: ["name", "url", "status", "latency"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      BackendBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Backend }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait BackendDelete = Confirmation.traits.ConfirmActionConfirmation -> Backend {
    config: {
      icon: "alert-triangle",
      title: "Delete Backend",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      BackendBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Backend }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait BackendPersistor -> Backend [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Backend @payload.data { emit: { success: "BACKEND_CREATED" } })
      DO_UPDATE -> idle
        (persist update Backend @payload.data { emit: { success: "BACKEND_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Backend @payload.id { emit: { success: "BACKEND_DELETED" } })
    }
    emits {
      BACKEND_CREATED -> external { id : string }
      BACKEND_UPDATED -> external { id : string }
      BACKEND_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      BackendCreate.SAVE          -> DO_CREATE
      BackendEdit.SAVE            -> DO_UPDATE
      BackendDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/backends" as BackendsPage -> BackendAppLayout, BackendCatalog, BackendBrowseList, BackendCircuitBreaker, BackendRateLimiter, BackendCache, BackendCreate, BackendEdit, BackendView, BackendDelete, BackendPersistor
}

orbital AnalyticsOrbital {
  uses AppShell from "std/behaviors/std-app-layout"
  uses Browse   from "std/behaviors/std-browse"

  entity AnalyticsRecord [persistent: analyticsrecords] {
    id : string!
    routePath : string!
    method : string
    statusCode : number = 200
    latencyMs : number = 0
    timestamp : string = ""
  }

  trait AnalyticsAppLayout = AppShell.traits.AppLayout -> AnalyticsRecord {
    config: {
      contentTrait: "@trait.AnalyticsDisplay",
      appName: "API Gateway",
      navItems: [{ label: "Routes", href: "/routes", icon: "git-branch" }, { label: "Backends", href: "/backends", icon: "server" }, { label: "Analytics", href: "/analytics", icon: "bar-chart-2" }],
      searchEvent: "ANALYTICS_SEARCH",
      notifications: [],
      notificationClickEvent: "ANALYTICS_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: ANALYTICS_SEARCH
      NOTIFY_CLICK: ANALYTICS_NOTIFICATIONS_OPEN
    }
  }

  trait AnalyticsBrowseList = Browse.traits.BrowseItemBrowse -> AnalyticsRecord {
    config: {
      pageSize: 100,
      displayPageSize: 10,
      fields: [
        { name: "routePath",  label: "Route",   variant: "h4", icon: "bar-chart-2" },
        { name: "method",     label: "Method",  variant: "badge" },
        { name: "statusCode", label: "Status",  variant: "badge" },
        { name: "latencyMs",  label: "Latency", variant: "caption", format: "number" },
        { name: "timestamp",  label: "Time",    variant: "caption", format: "date" }
      ],
      cols: 1,
      gap: "sm"
    }
  }

  ;; Page-chrome trait: pure layout, embeds the analytics browse list.
  ;; Aggregations (Stats/Graphs) live on the /routes page in RouteOrbital —
  ;; binding them again here would clash on the atom-owned StatsItem /
  ;; GraphItem entities (atoms can be bound only once per file).
  trait AnalyticsDisplay [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-6xl mx-auto w-full p-4", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
            { type: "icon", name: "bar-chart-2" },
            { type: "typography", variant: "h2", content: "Analytics" }
          ]},
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Recent requests" },
          "@trait.AnalyticsBrowseList"
        ]})
      ANALYTICS_SEARCH -> composing
      ANALYTICS_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to analytics", action: "INIT", variant: "ghost" }
        ]})
    }
    listens {
      AnalyticsAppLayout.ANALYTICS_SEARCH -> ANALYTICS_SEARCH
      AnalyticsAppLayout.ANALYTICS_NOTIFICATIONS_OPEN -> ANALYTICS_NOTIFICATIONS_OPEN
      ANALYTICS_SEARCH { value : string }
      ANALYTICS_NOTIFICATIONS_OPEN { id : string }
    }
  }

  page "/analytics" -> AnalyticsAppLayout, AnalyticsDisplay, AnalyticsBrowseList
}
