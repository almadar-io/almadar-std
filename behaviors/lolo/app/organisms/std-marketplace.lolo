app std-marketplace "1.0.0"
"Marketplace: vendors list products, buyers leave star ratings, admin reviews flagged listings."

;; Each shared atom (Search, Filter, Stats, ModQueue, Flag, RatingReview)
;; lives in exactly ONE orbital so its `[runtime]` entity isn't inlined twice.
;; AppShell + Modal + Confirmation + Browse are imported across orbitals but
;; are always rebound via `-> Entity` so their inlined entities collapse onto
;; the local entity instead of duplicating.
orbital VendorOrbital {
  uses AppShell      from "std/behaviors/std-app-layout"
  uses Modal         from "std/behaviors/std-modal"
  uses Confirmation  from "std/behaviors/std-confirmation"
  uses Browse        from "std/behaviors/std-browse"
  uses Payout        from "std/behaviors/std-payout-ledger"

  entity Vendor [persistent: vendors] {
    id           : string!
    name         : string!
    businessName : string = ""
    status       : "active" | "pending" | "suspended" | "closed" = "pending"
    totalSales   : number = 0
    rating       : number = 0
    createdAt    : string = ""
    pendingId    : string = ""
  }

  trait VendorAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.VendorCatalog",
      appName: "Marketplace",
      navItems: [{ label: "Vendors", href: "/vendors", icon: "store" }, { label: "Listings", href: "/listings", icon: "package" }, { label: "Orders", href: "/orders", icon: "shopping-cart" }],
      searchEvent: "VENDOR_SEARCH",
      notifications: [],
      notificationClickEvent: "VENDOR_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: VENDOR_SEARCH
      NOTIFY_CLICK: VENDOR_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait. Owns the header (icon + Vendors + New Vendor button)
  ;; + toolbar (search/filter) + stat row + embedded list + payout ledger
  ;; + moderation queue. AppLayout's contentTrait points here.
  trait VendorCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "store" },
              { type: "typography", content: "Vendors", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Vendor", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.VendorBrowseList",
          { type: "divider" },
          "@trait.VendorPayoutLedger"
        ]})
      VENDOR_SEARCH -> composing
      VENDOR_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to vendors", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      VendorAppLayout.VENDOR_SEARCH -> VENDOR_SEARCH
      VendorAppLayout.VENDOR_NOTIFICATIONS_OPEN -> VENDOR_NOTIFICATIONS_OPEN
      VENDOR_SEARCH { value : string }
      VENDOR_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait VendorBrowseList = Browse.traits.BrowseItemBrowse -> Vendor {
    config: {
      fields: [
        { name: "name",         variant: "h3",      icon: "store" },
        { name: "businessName", variant: "body" },
        { name: "status",       variant: "badge" },
        { name: "totalSales",   variant: "caption", format: "currency" },
        { name: "rating",       variant: "caption" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      VendorPersistor.VENDOR_CREATED    -> INIT
      VendorPersistor.VENDOR_UPDATED    -> INIT
      VendorPersistor.VENDOR_DELETED    -> INIT
    }
  }

  trait VendorPayoutLedger = Payout.traits.PayoutLedger {
    config: {
      title: "Vendor Payouts",
      minimumWithdrawal: 50
    }
  }

  trait VendorCreate = Modal.traits.ModalRecordModal -> Vendor {
    config: {
      icon: "plus-circle",
      title: "New Vendor",
      mode: "create",
      fields: ["name", "businessName", "status", "totalSales", "rating"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      VendorCatalog.CREATE -> CREATE
      CREATE { id : string, row : Vendor }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait VendorEdit = Modal.traits.ModalRecordModal -> Vendor {
    config: {
      icon: "edit",
      title: "Edit Vendor",
      mode: "edit",
      fields: ["name", "businessName", "status", "totalSales", "rating"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      VendorBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Vendor }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait VendorView = Modal.traits.ModalRecordModal -> Vendor {
    config: {
      icon: "eye",
      title: "View Vendor",
      mode: "edit",
      fields: ["name", "businessName", "status", "totalSales", "rating"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      VendorBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Vendor }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait VendorDelete = Confirmation.traits.ConfirmActionConfirmation -> Vendor {
    config: {
      icon: "alert-triangle",
      title: "Delete Vendor",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      VendorBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Vendor }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait VendorPersistor -> Vendor [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Vendor @payload.data { emit: { success: "VENDOR_CREATED" } })
      DO_UPDATE -> idle
        (persist update Vendor @payload.data { emit: { success: "VENDOR_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Vendor @payload.id { emit: { success: "VENDOR_DELETED" } })
    }
    emits {
      VENDOR_CREATED -> external { id : string }
      VENDOR_UPDATED -> external { id : string }
      VENDOR_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      VendorCreate.SAVE          -> DO_CREATE
      VendorEdit.SAVE            -> DO_UPDATE
      VendorDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/vendors" as VendorsPage -> VendorAppLayout, VendorCatalog, VendorBrowseList, VendorPayoutLedger, VendorCreate, VendorEdit, VendorView, VendorDelete, VendorPersistor
}

orbital ListingOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Search       from "std/behaviors/std-search"
  uses Filter       from "std/behaviors/std-filter"
  uses Stats        from "std/behaviors/std-stats"
  uses ImageUpload  from "std/behaviors/std-image-upload-multi"
  uses RatingReview from "std/behaviors/std-rating-review"
  uses ModQueue     from "std/behaviors/std-mod-queue"
  uses Flag         from "std/behaviors/std-flag"
  uses TagTaxonomy  from "std/behaviors/std-tag-taxonomy"
  uses Browse       from "std/behaviors/std-browse"

  entity Listing [persistent: listings] {
    id            : string!
    vendorId      : string!
    title         : string!
    description   : string = ""
    price         : number!
    currency      : string = "USD"
    images        : [string] = []
    status        : "draft" | "active" | "sold" | "removed" = "draft"
    tags          : [string] = []
    ratingAverage : number = 0
    reviewCount   : number = 0
    createdAt     : string = ""
    pendingId     : string = ""
  }

  trait ListingAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.ListingCatalog",
      appName: "Marketplace",
      navItems: [{ label: "Vendors", href: "/vendors", icon: "store" }, { label: "Listings", href: "/listings", icon: "package" }, { label: "Orders", href: "/orders", icon: "shopping-cart" }],
      searchEvent: "LISTING_SEARCH",
      notifications: [],
      notificationClickEvent: "LISTING_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: LISTING_SEARCH
      NOTIFY_CLICK: LISTING_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait. Header + toolbar + tag taxonomy filter + browse list
  ;; + image uploader + rating + flag + mod queue. Composes the full
  ;; listing-management surface for both vendors and admins.
  trait ListingCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "package" },
              { type: "typography", content: "Listings", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Listing", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.ListingSearch",
            "@trait.ListingFilter"
          ]},
          "@trait.ListingStats",
          "@trait.ListingTags",
          { type: "divider" },
          "@trait.ListingBrowseList",
          { type: "divider" },
          "@trait.ListingImages",
          { type: "divider" },
          "@trait.ListingRating",
          { type: "divider" },
          "@trait.ListingFlag",
          { type: "divider" },
          "@trait.ListingModQueue"
        ]})
      LISTING_SEARCH -> composing
      LISTING_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to listings", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      ListingAppLayout.LISTING_SEARCH -> LISTING_SEARCH
      ListingAppLayout.LISTING_NOTIFICATIONS_OPEN -> LISTING_NOTIFICATIONS_OPEN
      LISTING_SEARCH { value : string }
      LISTING_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait ListingSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search listings…",
      event: "LISTING_SEARCH"
    }
  }

  trait ListingFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "status",   label: "Status",   filterType: "select", options: ["draft", "active", "sold", "removed"] },
        { field: "currency", label: "Currency", filterType: "select", options: ["USD", "EUR", "GBP"] }
      ],
      event: "LISTING_FILTER"
    }
  }

  trait ListingStats = Stats.traits.StatsItemStats {
    config: {
      title: "Listings",
      metrics: [
        { aggregation: "count", label: "Total",   icon: "package",      variant: "primary", format: "number" },
        { aggregation: "count", label: "Active",  icon: "check-circle", variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "active"]] },
        { aggregation: "count", label: "Draft",   icon: "edit",         variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "draft"]] }
      ]
    }
    listens {
      ListingBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait ListingTags = TagTaxonomy.traits.TagBrowse {
    config: {
      title: "Categories",
      allowEdit: false
    }
  }

  trait ListingBrowseList = Browse.traits.BrowseItemBrowse -> Listing {
    config: {
      fields: [
        { name: "title",         variant: "h3",      icon: "package" },
        { name: "price",         variant: "h4",      format: "currency" },
        { name: "currency",      variant: "badge" },
        { name: "status",        variant: "badge" },
        { name: "ratingAverage", variant: "caption" },
        { name: "reviewCount",   variant: "caption" },
        { name: "description",   variant: "caption" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      ListingSearch.SEARCH               -> REFETCH_QUERY
      ListingFilter.FILTER               -> REFETCH_FILTER
      ListingPersistor.LISTING_CREATED   -> INIT
      ListingPersistor.LISTING_UPDATED   -> INIT
      ListingPersistor.LISTING_DELETED   -> INIT
    }
  }

  trait ListingImages = ImageUpload.traits.UploadedImageUpload {
    config: {
      title: "Listing Images",
      maxImages: 10,
      maxBytesPerImage: 10485760,
      accept: "image/*"
    }
  }

  trait ListingRating = RatingReview.traits.RatingReviewSubmit {
    config: {
      maxStars: 5,
      allowComment: true,
      allowPhotos: false,
      title: "Rate this listing",
      submitEvent: "SUBMIT_REVIEW"
    }
  }

  trait ListingFlag = Flag.traits.FlagReport {
    config: {
      title: "Report listing",
      reasons: ["spam", "abuse", "off-topic", "misinformation", "nsfw", "other"]
    }
  }

  trait ListingModQueue = ModQueue.traits.ModQueueItemReview {
    config: {
      title: "Listing Moderation Queue",
      autoEscalateThreshold: 5
    }
  }

  trait ListingCreate = Modal.traits.ModalRecordModal -> Listing {
    config: {
      icon: "plus-circle",
      title: "New Listing",
      mode: "create",
      fields: ["vendorId", "title", "description", "price", "currency", "status"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      ListingCatalog.CREATE -> CREATE
      CREATE { id : string, row : Listing }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ListingEdit = Modal.traits.ModalRecordModal -> Listing {
    config: {
      icon: "edit",
      title: "Edit Listing",
      mode: "edit",
      fields: ["vendorId", "title", "description", "price", "currency", "status"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      ListingBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Listing }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ListingView = Modal.traits.ModalRecordModal -> Listing {
    config: {
      icon: "eye",
      title: "View Listing",
      mode: "edit",
      fields: ["vendorId", "title", "description", "price", "currency", "status"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      ListingBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Listing }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ListingDelete = Confirmation.traits.ConfirmActionConfirmation -> Listing {
    config: {
      icon: "alert-triangle",
      title: "Delete Listing",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      ListingBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Listing }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait ListingPersistor -> Listing [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Listing @payload.data { emit: { success: "LISTING_CREATED" } })
      DO_UPDATE -> idle
        (persist update Listing @payload.data { emit: { success: "LISTING_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Listing @payload.id { emit: { success: "LISTING_DELETED" } })
    }
    emits {
      LISTING_CREATED -> external { id : string }
      LISTING_UPDATED -> external { id : string }
      LISTING_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      ListingCreate.SAVE          -> DO_CREATE
      ListingEdit.SAVE            -> DO_UPDATE
      ListingDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/listings" as ListingsPage -> ListingAppLayout, ListingCatalog, ListingSearch, ListingFilter, ListingStats, ListingTags, ListingBrowseList, ListingImages, ListingRating, ListingFlag, ListingModQueue, ListingCreate, ListingEdit, ListingView, ListingDelete, ListingPersistor
}

orbital OrderOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Browse       from "std/behaviors/std-browse"
  uses Cart         from "std/behaviors/std-cart"
  uses Approval     from "std/behaviors/std-approval-gate"
  uses Erasure      from "std/behaviors/std-data-erasure"
  uses Audit        from "std/behaviors/std-audit-capture"

  entity Order [persistent: orders] {
    id          : string!
    buyerId     : string!
    listingId   : string!
    quantity    : number = 1
    totalAmount : number!
    status      : "pending" | "paid" | "shipped" | "delivered" | "refunded" = "pending"
    createdAt   : string = ""
    pendingId   : string = ""
  }

  trait OrderAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.OrderCatalog",
      appName: "Marketplace",
      navItems: [{ label: "Vendors", href: "/vendors", icon: "store" }, { label: "Listings", href: "/listings", icon: "package" }, { label: "Orders", href: "/orders", icon: "shopping-cart" }],
      searchEvent: "ORDER_SEARCH",
      notifications: [],
      notificationClickEvent: "ORDER_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: ORDER_SEARCH
      NOTIFY_CLICK: ORDER_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait. Owns the header and embeds the order browse list +
  ;; the std-cart molecule's CartBrowse trait so buyers can review their
  ;; pending cart alongside their order history on a single screen.
  trait OrderCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "shopping-cart" },
              { type: "typography", content: "Orders", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Order", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.OrderBrowseList",
          { type: "divider" },
          "@trait.OrderCart"
        ]})
      ORDER_SEARCH -> composing
      ORDER_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to orders", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      OrderAppLayout.ORDER_SEARCH -> ORDER_SEARCH
      OrderAppLayout.ORDER_NOTIFICATIONS_OPEN -> ORDER_NOTIFICATIONS_OPEN
      ORDER_SEARCH { value : string }
      ORDER_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait OrderBrowseList = Browse.traits.BrowseItemBrowse -> Order {
    config: {
      fields: [
        { name: "buyerId",     variant: "caption" },
        { name: "listingId",   variant: "caption" },
        { name: "quantity",    variant: "caption" },
        { name: "totalAmount", variant: "h4",     format: "currency" },
        { name: "status",      variant: "badge" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      OrderPersistor.ORDER_CREATED -> INIT
      OrderPersistor.ORDER_UPDATED -> INIT
      OrderPersistor.ORDER_DELETED -> INIT
    }
  }

  ;; Bind the full std-cart molecule traits — CartItemCartBrowse alone leaves
  ;; ADD_ITEM and REQUEST_REMOVE unlistened (they're consumed by AddItem and
  ;; RemoveConfirm sibling traits inside the molecule). Pulling all four keeps
  ;; the contract closed.
  trait OrderCart = Cart.traits.CartItemCartBrowse {
  }

  trait OrderCartAdd = Cart.traits.CartItemAddItem {
  }

  trait OrderCartRemove = Cart.traits.CartItemRemoveConfirm {
  }

  trait OrderCartPersistor = Cart.traits.CartItemPersistor {
  }

  trait OrderCreate = Modal.traits.ModalRecordModal -> Order {
    config: {
      icon: "plus-circle",
      title: "New Order",
      mode: "create",
      fields: ["buyerId", "listingId", "quantity", "totalAmount", "status"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      OrderCatalog.CREATE -> CREATE
      CREATE { id : string, row : Order }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait OrderEdit = Modal.traits.ModalRecordModal -> Order {
    config: {
      icon: "edit",
      title: "Edit Order",
      mode: "edit",
      fields: ["buyerId", "listingId", "quantity", "totalAmount", "status"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      OrderBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Order }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait OrderView = Modal.traits.ModalRecordModal -> Order {
    config: {
      icon: "eye",
      title: "View Order",
      mode: "edit",
      fields: ["buyerId", "listingId", "quantity", "totalAmount", "status"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      OrderBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Order }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait OrderDelete = Confirmation.traits.ConfirmActionConfirmation -> Order {
    config: {
      icon: "alert-triangle",
      title: "Delete Order",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      OrderBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Order }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait OrderPersistor -> Order [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Order @payload.data { emit: { success: "ORDER_CREATED" } })
      DO_UPDATE -> idle
        (persist update Order @payload.data { emit: { success: "ORDER_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Order @payload.id { emit: { success: "ORDER_DELETED" } })
    }
    emits {
      ORDER_CREATED -> external { id : string }
      ORDER_UPDATED -> external { id : string }
      ORDER_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      OrderCreate.SAVE          -> DO_CREATE
      OrderEdit.SAVE            -> DO_UPDATE
      OrderDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  trait OrderRefundApproval = Approval.traits.ApprovalGateReview {
    config: {
      approverRoles: ["marketplace-ops"],
      threshold: 200,
      autoApproveBelowThreshold: true,
      valueField: "totalAmount",
      escalationHours: 24,
      escalationRoles: ["trust-and-safety"]
    }
  }

  trait OrderErasure = Erasure.traits.ErasureWorkflow {
    config: {
      targetEntity: "Order",
      gracePeriodDays: 30,
      anonymizeVsDelete: "anonymize",
      piiFields: ["buyerId"]
    }
  }

  trait OrderAudit = Audit.traits.AuditCaptureListener {
    config: {
      captureEntity: "Order",
      captureEventTypes: [],
      excludeFields: [],
      captureBeforeAfter: false,
      retentionDays: 2555
    }
    events {
      EntityMutated: ORDER_UPDATED
    }
  }

  page "/orders" as OrdersPage -> OrderAppLayout, OrderCatalog, OrderBrowseList, OrderCart, OrderCartAdd, OrderCartRemove, OrderCartPersistor, OrderCreate, OrderEdit, OrderView, OrderDelete, OrderPersistor, OrderRefundApproval, OrderErasure, OrderAudit
}
