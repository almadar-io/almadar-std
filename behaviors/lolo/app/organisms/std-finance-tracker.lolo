app std-finance-tracker "1.0.0"
"std-finance-tracker as a Function"

orbital TransactionOrbital {
  entity Transaction [persistent: transactions] {
    id : string!
    description : string!
    amount : number!
    category : string
    date : datetime
    pendingId : string = ""
  }

  type TransactionLoaded     = Event { data : [Transaction] }                  "Fired when Transaction finishes loading"
  type TransactionLoadFailed = Event { error : string, code : string } "Fired when Transaction fails to load"
  type TransactionSaved = Event { id : string }
  type TransactionSaveFailed = Event { error : string, code : string }
  type TransactionUpdated = Event { id : string }
  type TransactionUpdateFailed = Event { error : string, code : string }
  type TransactionDeleted = Event { id : string }
  type TransactionDeleteFailed = Event { error : string, code : string }
  type FinanceReportSaved = Event { id : string }
  type FinanceReportSaveFailed = Event { error : string, code : string }
  trait TransactionBrowse -> Transaction [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      TransactionLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Finance Tracker", navItems: [{ label: "Transactions", href: "/transactions", icon: "dollar-sign" }, { label: "Summary", href: "/summary", icon: "layout-list" }, { label: "Reports", href: "/reports", icon: "bar-chart" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Transactions", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create Transaction", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "description", variant: "h3", icon: "credit-card" }, { name: "category", variant: "badge" }, { name: "amount", variant: "h4", format: "currency" }, { name: "date", variant: "caption", format: "date" }], variant: "card", gap: "sm" }] }] })
      TransactionLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load transaction" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    listens {
      TransactionCreate TRANSACTION_CREATED -> INIT
      TransactionEdit TRANSACTION_UPDATED -> INIT
      TransactionDelete TRANSACTION_DELETED -> INIT
      VIEW { id : string!, row : Transaction }
      EDIT { id : string!, row : Transaction }
      DELETE { id : string!, row : Transaction }
          TransactionLoadFailed { error : string, code : string }
    
      TransactionSaveFailed { error : string, code : string }
      TransactionUpdateFailed { error : string, code : string }
      TransactionDeleteFailed { error : string, code : string }
      FinanceReportSaveFailed { error : string, code : string }
    }
    emits: [TransactionLoaded, TransactionLoadFailed, TransactionSaved, TransactionSaveFailed, TransactionUpdated, TransactionUpdateFailed, TransactionDeleted, TransactionDeleteFailed, FinanceReportSaved, FinanceReportSaveFailed]
  }
  trait TransactionCreate -> Transaction [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
      CREATE -> open
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Transaction", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["description", "amount", "category", "date"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Transaction @payload.data { emit: { success: "TransactionSaved", failure: "TransactionSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit TRANSACTION_CREATED)
    }
    emits {
      TRANSACTION_CREATED external { id: string }
    }
    listens {
      SAVE { data : object! }
          TransactionLoadFailed { error : string, code : string }
    }
    emits: [TransactionLoadFailed, TransactionLoaded, TransactionSaveFailed, TransactionSaved]
  }
  trait TransactionEdit -> Transaction [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
      EDIT -> open
        (fetch Transaction {id: "@payload.id" , emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" }, emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Transaction", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["description", "amount", "category", "date"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Transaction @payload.data { emit: { success: "TransactionUpdated", failure: "TransactionUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit TRANSACTION_UPDATED)
    }
    emits {
      TRANSACTION_UPDATED external { id: string }
    }
    listens {
      EDIT { id : string!, row : Transaction }
      SAVE { data : object! }
          TransactionLoadFailed { error : string, code : string }
    }
    emits: [TransactionLoadFailed, TransactionLoaded, TransactionUpdateFailed, TransactionUpdated]
  }
  trait TransactionView -> Transaction [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
      VIEW -> open
        (fetch Transaction {id: "@payload.id" , emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" }, emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.description" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Amount" }, { type: "typography", variant: "body", content: "@entity.amount" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Category" }, { type: "typography", variant: "body", content: "@entity.category" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Date" }, { type: "typography", variant: "body", content: "@entity.date" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }

    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          TransactionLoadFailed { error : string, code : string }
    }
    emits: [TransactionLoaded, TransactionLoadFailed]
  }
  trait TransactionDelete -> Transaction [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Transaction {id: "@payload.id" , emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" }, emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Transaction", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Transaction @entity.pendingId { emit: { success: "TransactionDeleted", failure: "TransactionDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
        (emit TRANSACTION_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Transaction { emit: { success: "TransactionLoaded", failure: "TransactionLoadFailed" } })
    }
    emits {
      TRANSACTION_DELETED external { id: string }
    }
    listens {
      DELETE { id : string! }
          TransactionLoadFailed { error : string, code : string }
    }
    emits: [TransactionDeleteFailed, TransactionDeleted, TransactionLoadFailed, TransactionLoaded]
  }
  page "/transactions" as TransactionsPage -> TransactionBrowse, TransactionCreate, TransactionEdit, TransactionView, TransactionDelete
}
orbital FinanceSummaryOrbital {
  entity FinanceSummary [runtime] {
    id : string!
    totalIncome : number
    totalExpenses : number
    balance : number
    savingsRate : number
  }

  type FinanceSummaryLoaded     = Event { data : [FinanceSummary] }                  "Fired when FinanceSummary finishes loading"
  type FinanceSummaryLoadFailed = Event { error : string, code : string } "Fired when FinanceSummary fails to load"
  trait FinanceSummaryDisplay -> FinanceSummary [interaction, collection] {
    initial: loading
    state loading {
      INIT -> displaying
        (fetch FinanceSummary { emit: { success: "FinanceSummaryLoaded", failure: "FinanceSummaryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Finance Tracker", navItems: [{ label: "Transactions", href: "/transactions", icon: "dollar-sign" }, { label: "Summary", href: "/summary", icon: "layout-list" }, { label: "Reports", href: "/reports", icon: "bar-chart" }], children: [{ type: "scaled-diagram", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "breadcrumb", items: [{ label: "Home", href: "/" }, { label: "Financial Summary" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "pie-chart" }, { type: "typography", content: "Financial Summary", variant: "h2" }] }, { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }] }, { type: "divider" }, { type: "box", padding: "md", children: [{ type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "TotalIncome", value: "@entity.totalIncome" }, { type: "stat-display", label: "TotalExpenses", value: "@entity.totalExpenses" }, { type: "stat-display", label: "Balance", value: "@entity.balance" }, { type: "stat-display", label: "SavingsRate", value: "@entity.savingsRate" }] }] }, { type: "divider" }, { type: "grid", cols: 2, gap: "md", children: [{ type: "card", children: [{ type: "typography", variant: "caption", content: "Chart View" }] }, { type: "card", children: [{ type: "typography", variant: "caption", content: "Graph View" }] }] }, { type: "line-chart", data: [{ date: "Jan", value: 12 }, { date: "Feb", value: 19 }, { date: "Mar", value: 15 }, { date: "Apr", value: 25 }, { date: "May", value: 22 }, { date: "Jun", value: 30 }] }, { type: "chart-legend", items: [{ label: "Current", color: "primary" }, { label: "Previous", color: "muted" }] }, { type: "graph-view", nodes: [{ id: "a", label: "Start" }, { id: "b", label: "Process" }, { id: "c", label: "End" }], edges: [{ source: "a", target: "b" }, { source: "b", target: "c" }], width: 400, height: 200 }] }] }] })
      LOADED -> displaying
        (fetch FinanceSummary { emit: { success: "FinanceSummaryLoaded", failure: "FinanceSummaryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Finance Tracker", navItems: [{ label: "Transactions", href: "/transactions", icon: "dollar-sign" }, { label: "Summary", href: "/summary", icon: "layout-list" }, { label: "Reports", href: "/reports", icon: "bar-chart" }], children: [{ type: "scaled-diagram", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "breadcrumb", items: [{ label: "Home", href: "/" }, { label: "Financial Summary" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "pie-chart" }, { type: "typography", content: "Financial Summary", variant: "h2" }] }, { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }] }, { type: "divider" }, { type: "box", padding: "md", children: [{ type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "TotalIncome", value: "@entity.totalIncome" }, { type: "stat-display", label: "TotalExpenses", value: "@entity.totalExpenses" }, { type: "stat-display", label: "Balance", value: "@entity.balance" }, { type: "stat-display", label: "SavingsRate", value: "@entity.savingsRate" }] }] }, { type: "divider" }, { type: "grid", cols: 2, gap: "md", children: [{ type: "card", children: [{ type: "typography", variant: "caption", content: "Chart View" }] }, { type: "card", children: [{ type: "typography", variant: "caption", content: "Graph View" }] }] }, { type: "line-chart", data: [{ date: "Jan", value: 12 }, { date: "Feb", value: 19 }, { date: "Mar", value: 15 }, { date: "Apr", value: 25 }, { date: "May", value: 22 }, { date: "Jun", value: 30 }] }, { type: "chart-legend", items: [{ label: "Current", color: "primary" }, { label: "Previous", color: "muted" }] }, { type: "graph-view", nodes: [{ id: "a", label: "Start" }, { id: "b", label: "Process" }, { id: "c", label: "End" }], edges: [{ source: "a", target: "b" }, { source: "b", target: "c" }], width: 400, height: 200 }] }] }] })
    }
    state displaying {
      INIT -> displaying
        (fetch FinanceSummary { emit: { success: "FinanceSummaryLoaded", failure: "FinanceSummaryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Finance Tracker", navItems: [{ label: "Transactions", href: "/transactions", icon: "dollar-sign" }, { label: "Summary", href: "/summary", icon: "layout-list" }, { label: "Reports", href: "/reports", icon: "bar-chart" }], children: [{ type: "scaled-diagram", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "breadcrumb", items: [{ label: "Home", href: "/" }, { label: "Financial Summary" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "pie-chart" }, { type: "typography", content: "Financial Summary", variant: "h2" }] }, { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }] }, { type: "divider" }, { type: "box", padding: "md", children: [{ type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "TotalIncome", value: "@entity.totalIncome" }, { type: "stat-display", label: "TotalExpenses", value: "@entity.totalExpenses" }, { type: "stat-display", label: "Balance", value: "@entity.balance" }, { type: "stat-display", label: "SavingsRate", value: "@entity.savingsRate" }] }] }, { type: "divider" }, { type: "grid", cols: 2, gap: "md", children: [{ type: "card", children: [{ type: "typography", variant: "caption", content: "Chart View" }] }, { type: "card", children: [{ type: "typography", variant: "caption", content: "Graph View" }] }] }, { type: "line-chart", data: [{ date: "Jan", value: 12 }, { date: "Feb", value: 19 }, { date: "Mar", value: 15 }, { date: "Apr", value: 25 }, { date: "May", value: 22 }, { date: "Jun", value: 30 }] }, { type: "chart-legend", items: [{ label: "Current", color: "primary" }, { label: "Previous", color: "muted" }] }, { type: "graph-view", nodes: [{ id: "a", label: "Start" }, { id: "b", label: "Process" }, { id: "c", label: "End" }], edges: [{ source: "a", target: "b" }, { source: "b", target: "c" }], width: 400, height: 200 }] }] }] })
      REFRESH -> refreshing
        (fetch FinanceSummary { emit: { success: "FinanceSummaryLoaded", failure: "FinanceSummaryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Finance Tracker", navItems: [{ label: "Transactions", href: "/transactions", icon: "dollar-sign" }, { label: "Summary", href: "/summary", icon: "layout-list" }, { label: "Reports", href: "/reports", icon: "bar-chart" }], children: [{ type: "scaled-diagram", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "breadcrumb", items: [{ label: "Home", href: "/" }, { label: "Financial Summary" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "pie-chart" }, { type: "typography", content: "Financial Summary", variant: "h2" }] }, { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }] }, { type: "divider" }, { type: "box", padding: "md", children: [{ type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "TotalIncome", value: "@entity.totalIncome" }, { type: "stat-display", label: "TotalExpenses", value: "@entity.totalExpenses" }, { type: "stat-display", label: "Balance", value: "@entity.balance" }, { type: "stat-display", label: "SavingsRate", value: "@entity.savingsRate" }] }] }, { type: "divider" }, { type: "grid", cols: 2, gap: "md", children: [{ type: "card", children: [{ type: "typography", variant: "caption", content: "Chart View" }] }, { type: "card", children: [{ type: "typography", variant: "caption", content: "Graph View" }] }] }, { type: "line-chart", data: [{ date: "Jan", value: 12 }, { date: "Feb", value: 19 }, { date: "Mar", value: 15 }, { date: "Apr", value: 25 }, { date: "May", value: 22 }, { date: "Jun", value: 30 }] }, { type: "chart-legend", items: [{ label: "Current", color: "primary" }, { label: "Previous", color: "muted" }] }, { type: "graph-view", nodes: [{ id: "a", label: "Start" }, { id: "b", label: "Process" }, { id: "c", label: "End" }], edges: [{ source: "a", target: "b" }, { source: "b", target: "c" }], width: 400, height: 200 }] }] }] })
    }
    state refreshing {
      REFRESHED -> displaying
        (fetch FinanceSummary { emit: { success: "FinanceSummaryLoaded", failure: "FinanceSummaryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Finance Tracker", navItems: [{ label: "Transactions", href: "/transactions", icon: "dollar-sign" }, { label: "Summary", href: "/summary", icon: "layout-list" }, { label: "Reports", href: "/reports", icon: "bar-chart" }], children: [{ type: "scaled-diagram", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "breadcrumb", items: [{ label: "Home", href: "/" }, { label: "Financial Summary" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "pie-chart" }, { type: "typography", content: "Financial Summary", variant: "h2" }] }, { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }] }, { type: "divider" }, { type: "box", padding: "md", children: [{ type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "TotalIncome", value: "@entity.totalIncome" }, { type: "stat-display", label: "TotalExpenses", value: "@entity.totalExpenses" }, { type: "stat-display", label: "Balance", value: "@entity.balance" }, { type: "stat-display", label: "SavingsRate", value: "@entity.savingsRate" }] }] }, { type: "divider" }, { type: "grid", cols: 2, gap: "md", children: [{ type: "card", children: [{ type: "typography", variant: "caption", content: "Chart View" }] }, { type: "card", children: [{ type: "typography", variant: "caption", content: "Graph View" }] }] }, { type: "line-chart", data: [{ date: "Jan", value: 12 }, { date: "Feb", value: 19 }, { date: "Mar", value: 15 }, { date: "Apr", value: 25 }, { date: "May", value: 22 }, { date: "Jun", value: 30 }] }, { type: "chart-legend", items: [{ label: "Current", color: "primary" }, { label: "Previous", color: "muted" }] }, { type: "graph-view", nodes: [{ id: "a", label: "Start" }, { id: "b", label: "Process" }, { id: "c", label: "End" }], edges: [{ source: "a", target: "b" }, { source: "b", target: "c" }], width: 400, height: 200 }] }] }] })
    }
    emits: [FinanceSummaryLoaded, FinanceSummaryLoadFailed]
    listens {
      FinanceSummaryLoadFailed { error : string, code : string }
    }
  }
  page "/summary" -> FinanceSummaryDisplay
}
orbital FinanceReportOrbital {
  entity FinanceReport [persistent: financereports] {
    id : string!
    title : string!
    period : string!
    total : number
    generatedAt : datetime
  }

  type FinanceReportLoaded     = Event { data : [FinanceReport] }                  "Fired when FinanceReport finishes loading"
  type FinanceReportLoadFailed = Event { error : string, code : string } "Fired when FinanceReport fails to load"
  type FinanceReportSaveFailed = Event { error : string, code : string }
  type FinanceReportSaved = Event { id : string }
  trait FinanceReportBrowse -> FinanceReport [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch FinanceReport { emit: { success: "FinanceReportLoaded", failure: "FinanceReportLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      FinanceReportLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Finance Tracker", navItems: [{ label: "Transactions", href: "/transactions", icon: "dollar-sign" }, { label: "Summary", href: "/summary", icon: "layout-list" }, { label: "Reports", href: "/reports", icon: "bar-chart" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "Reports", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Create FinanceReport", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }], fields: [{ name: "title", variant: "h3", icon: "file-text" }, { name: "period", variant: "badge" }, { name: "total", variant: "h4", format: "currency" }, { name: "generatedAt", label: "Generated", variant: "caption", format: "date" }], variant: "card", gap: "sm" }] }] })
      FinanceReportLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load financereport" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    listens {
          FinanceReportLoadFailed { error : string, code : string }
    }
    emits: [FinanceReportLoaded, FinanceReportLoadFailed]
  }
  trait FinanceReportCreate -> FinanceReport [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch FinanceReport { emit: { success: "FinanceReportLoaded", failure: "FinanceReportLoadFailed" } })
      CREATE -> open
        (fetch FinanceReport { emit: { success: "FinanceReportLoaded", failure: "FinanceReportLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "New FinanceReport", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "period", "total", "generatedAt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create FinanceReport @payload.data { emit: { success: "FinanceReportSaved", failure: "FinanceReportSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
    }

    emits: [FinanceReportLoadFailed, FinanceReportLoaded, FinanceReportSaveFailed, FinanceReportSaved]
    listens {
      FinanceReportLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait FinanceReportView -> FinanceReport [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch FinanceReport { emit: { success: "FinanceReportLoaded", failure: "FinanceReportLoadFailed" } })
      VIEW -> open
        (fetch FinanceReport {id: "@payload.id" , emit: { success: "FinanceReportLoaded", failure: "FinanceReportLoadFailed" }, emit: { success: "FinanceReportLoaded", failure: "FinanceReportLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.title" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Title" }, { type: "typography", variant: "body", content: "@entity.title" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Period" }, { type: "typography", variant: "body", content: "@entity.period" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Total" }, { type: "typography", variant: "body", content: "@entity.total" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Generated At" }, { type: "typography", variant: "body", content: "@entity.generatedAt" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }

    emits: [FinanceReportLoaded, FinanceReportLoadFailed]
    listens {
      FinanceReportLoadFailed { error : string, code : string }
      VIEW { id : string }
    }
  }
  page "/reports" -> FinanceReportBrowse, FinanceReportCreate, FinanceReportView
}
