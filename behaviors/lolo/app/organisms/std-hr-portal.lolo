app std-hr-portal "2.0.0"
"HR portal: employees, onboarding wizard, time-off calendar, org chart. Composed from std atoms (Browse/Modal/Confirmation/Search/Filter/Stats/Graphs/Calendar) with email + storage."

orbital EmployeeOrbital {
  uses AppShell      from "std/behaviors/std-app-layout"
  uses Browse        from "std/behaviors/std-browse"
  uses Modal         from "std/behaviors/std-modal"
  uses Confirmation  from "std/behaviors/std-confirmation"
  uses Search        from "std/behaviors/std-search"
  uses Filter        from "std/behaviors/std-filter"
  uses Stats         from "std/behaviors/std-stats"
  uses Graphs        from "std/behaviors/std-graphs"
  uses Storage       from "std/behaviors/std-service-storage"
  uses Email         from "std/behaviors/std-service-email"

  entity Employee [persistent: employees] {
    id : string!
    name : string!
    email : string!
    department : string!
    role : string!
    hireDate : datetime!
    avatar : string = ""
    status : "active" | "leave" | "terminated" = "active"
    pendingId : string = ""
  }

  trait EmployeeAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.EmployeeCatalog",
      appName: "HRPortal",
      navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "clipboard-check" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "git-branch" }],
      searchEvent: "EMPLOYEE_SEARCH",
      notifications: [],
      notificationClickEvent: "EMPLOYEE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: EMPLOYEE_SEARCH
      NOTIFY_CLICK: EMPLOYEE_NOTIFICATIONS_OPEN
    }
  }

  trait EmployeeCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "users" },
              { type: "typography", content: "Employees", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Add Employee", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", children: ["@trait.EmployeeSearch", "@trait.EmployeeFilter"] },
          "@trait.EmployeeStats",
          "@trait.EmployeeGraphs",
          { type: "divider" },
          "@trait.EmployeeBrowseList"
        ]})
      EMPLOYEE_SEARCH -> composing
      EMPLOYEE_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to employees", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      EmployeeAppLayout.EMPLOYEE_SEARCH -> EMPLOYEE_SEARCH
      EmployeeAppLayout.EMPLOYEE_NOTIFICATIONS_OPEN -> EMPLOYEE_NOTIFICATIONS_OPEN
      EMPLOYEE_SEARCH { value : string }
      EMPLOYEE_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait EmployeeSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search employees by name…",
      event: "SEARCH"
    }
  }

  trait EmployeeFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "department", label: "Department", options: ["engineering", "design", "marketing", "sales", "hr", "finance"], filterType: "select" },
        { field: "role", label: "Role", options: ["manager", "lead", "ic", "intern"], filterType: "select" },
        { field: "status", label: "Status", options: ["active", "leave", "terminated"], filterType: "select" }
      ],
      event: "FILTER"
    }
  }

  trait EmployeeStats = Stats.traits.StatsItemStats {
    config: {
      title: "Workforce Overview",
      metrics: [
        { aggregation: "count", label: "Total Employees", icon: "users", variant: "primary", format: "number" },
        { aggregation: "count", label: "By Department", icon: "layers", variant: "default", format: "number" },
        { aggregation: "count", label: "New This Month", icon: "user-plus", variant: "info", format: "number" },
        { aggregation: "count", label: "On Leave", icon: "calendar-off", variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "leave"]] }
      ]
    }
    listens {
      EmployeeBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait EmployeeGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Employees by Department",
      subtitle: "Headcount distribution",
      chartType: "pie",
      categoryField: "department",
      aggregation: "count",
      height: 280,
      showLegend: true
    }
    listens {
      EmployeeBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait EmployeeBrowseList = Browse.traits.BrowseItemBrowse -> Employee {
    config: {
      fields: [
        { name: "name", variant: "h3", icon: "user" },
        { name: "role", variant: "body" },
        { name: "department", variant: "badge" },
        { name: "email", variant: "caption" },
        { name: "hireDate", label: "Joined", variant: "caption", format: "date" }
      ],
      imageField: "avatar",
      itemActions: [
        { label: "View", event: "VIEW", variant: "ghost" },
        { label: "Edit", event: "EDIT", variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      gap: "sm"
    }
    listens {
      EmployeeCreate.EMPLOYEE_CREATED -> INIT
      EmployeeEdit.EMPLOYEE_UPDATED -> INIT
      EmployeeDelete.EMPLOYEE_DELETED -> INIT
      OnboardingOrbital.OnboardingWizard.ONBOARDED -> INIT
      EmployeeSearch.SEARCH -> REFETCH_QUERY
      EmployeeFilter.FILTER -> REFETCH_FILTER
    }
  }

  trait EmployeeCreate = Modal.traits.ModalRecordModal -> Employee {
    config: {
      icon: "plus-circle",
      title: "Add Employee",
      fields: ["name", "email", "department", "role", "hireDate", "status"],
      mode: "create"
    }
    events {
      OPEN: CREATE
      SAVE: EMPLOYEE_CREATED
    }
    listens {
      EmployeeCatalog.CREATE -> CREATE
      CREATE { id : string, row : Employee }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait EmployeeEdit = Modal.traits.ModalRecordModal -> Employee {
    config: {
      icon: "edit",
      title: "Edit Employee",
      fields: ["name", "email", "department", "role", "hireDate", "status"],
      mode: "edit"
    }
    events {
      OPEN: EDIT
      SAVE: EMPLOYEE_UPDATED
    }
    listens {
      EmployeeBrowseList.EDIT -> EDIT
      EDIT { id : string, row : Employee }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait EmployeeView = Modal.traits.ModalRecordModal -> Employee {
    config: {
      icon: "eye",
      title: "Employee Details",
      fields: ["name", "email", "department", "role", "hireDate", "status"],
      mode: "edit"
    }
    events {
      OPEN: VIEW
    }
    listens {
      EmployeeBrowseList.VIEW -> VIEW
      VIEW { id : string, row : Employee }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait EmployeeDelete = Confirmation.traits.ConfirmActionConfirmation -> Employee {
    config: {
      icon: "alert-triangle",
      title: "Delete Employee",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: EMPLOYEE_DELETED
    }
    listens {
      EmployeeBrowseList.DELETE -> DELETE
      DELETE { id : string, row : Employee }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait EmployeePersistor -> Employee [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Employee @payload.data { emit: { success: "EMPLOYEE_CREATED" } })
      DO_UPDATE -> idle
        (persist update Employee @payload.data { emit: { success: "EMPLOYEE_UPDATED" } })
      DO_DELETE -> idle
        (persist delete Employee @payload.id { emit: { success: "EMPLOYEE_DELETED" } })
    }
    emits {
      EMPLOYEE_CREATED -> external { id : string! }
      EMPLOYEE_UPDATED -> external { id : string! }
      EMPLOYEE_DELETED -> external { id : string! }
    }
    listens {
      DO_CREATE { data : Employee! }
      DO_UPDATE { data : Employee! }
      DO_DELETE { id : string! }
      EmployeeCreate.EMPLOYEE_CREATED -> DO_CREATE
      EmployeeEdit.EMPLOYEE_UPDATED -> DO_UPDATE
      EmployeeDelete.EMPLOYEE_DELETED -> DO_DELETE
    }
  }

  ;; Avatar upload — Pattern A binding to Storage atom (uiTrait = the picker
  ;; below). Allowed mime types and size cap are configured here.
  trait EmployeeAvatarUpload = Storage.traits.ServiceStorageStorage {
    config: {
      bucket: "employee-avatars",
      acl: "public-read",
      maxSize: 5242880,
      allowedMimeTypes: ["image/jpeg", "image/png", "image/webp"],
      uiTrait: "@trait.EmployeeAvatarUploadForm"
    }
  }

  ;; Custom file picker UI — fills Storage's uiTrait slot.
  trait EmployeeAvatarUploadForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
            { type: "icon", name: "image" },
            { type: "typography", variant: "h3", content: "Upload Avatar" }
          ]},
          { type: "input", inputType: "text", placeholder: "Choose file path…" },
          { type: "button", label: "Upload", action: "UPLOAD", variant: "primary", icon: "upload" }
        ]})
    }
    emits {
      UPLOAD -> external { source : string }
    }
  }

  page "/employees" as EmployeesPage -> EmployeeAppLayout, EmployeeCatalog, EmployeeSearch, EmployeeFilter, EmployeeStats, EmployeeGraphs, EmployeeBrowseList, EmployeeCreate, EmployeeEdit, EmployeeView, EmployeeDelete, EmployeePersistor
  page "/employees/upload" as EmployeeAvatarPage -> EmployeeAppLayout, EmployeeAvatarUpload, EmployeeAvatarUploadForm
}

orbital OnboardingOrbital {
  uses Email from "std/behaviors/std-service-email"

  entity Onboarding [persistent: onboardings] {
    id : string!
    employeeName : string!
    email : string!
    department : string!
    manager : string!
    equipmentReady : boolean = false
    accessGranted : boolean = false
  }

  type OnboardingLoaded     = Event { data : [Onboarding] }
  type OnboardingLoadFailed = Event { error : string, code : string }
  type OnboardingSaved      = Event { id : string }
  type OnboardingSaveFailed = Event { error : string, code : string }

  ;; Custom wizard pattern — mirrors std-ecommerce CheckoutWizard. State per
  ;; step, (set @entity.X) on advance, (and @entity.X @entity.Y) guards
  ;; protect against programmatic skips. Persist + emit ONBOARDED + welcome
  ;; email on COMPLETE; EmployeeBrowseList listens and refetches.
  trait OnboardingWizard -> Onboarding [interaction, instance] {
    initial: step1
    state step1 {
      INIT -> step1
        (set @entity.employeeName "")
        (set @entity.email "")
        (set @entity.department "")
        (set @entity.manager "")
        (set @entity.equipmentReady false)
        (set @entity.accessGranted false)
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
            { type: "icon", name: "clipboard-check" },
            { type: "typography", content: "Employee Onboarding", variant: "h2" }
          ]},
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Employee Details" },
          { type: "form-section", mode: "create", submitEvent: "NEXT", submitLabel: "Continue", showCancel: false, fields: [{ name: "employeeName", required: true, min: 2 }, { name: "email", type: "email", required: true }, { name: "department", required: true }] }
        ]})
      NEXT -> step2 when (and @payload.data.employeeName @payload.data.email @payload.data.department)
        (set @entity.employeeName @payload.data.employeeName)
        (set @entity.email @payload.data.email)
        (set @entity.department @payload.data.department)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Employee Onboarding" },
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Manager Assignment" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: [{ name: "manager", required: true }] }
        ]})
    }
    state step2 {
      NEXT -> step3 when (and @entity.employeeName @entity.email @entity.department @payload.data.manager)
        (set @entity.manager @payload.data.manager)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Employee Onboarding" },
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 2 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Setup Checklist" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: ["equipmentReady", "accessGranted"] }
        ]})
      PREV -> step1
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Employee Onboarding" },
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Employee Details" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", submitLabel: "Continue", showCancel: false, fields: [{ name: "employeeName", required: true, min: 2 }, { name: "email", type: "email", required: true }, { name: "department", required: true }] }
        ]})
    }
    state step3 {
      NEXT -> review when (and @entity.employeeName @entity.email @entity.department @entity.manager)
        (set @entity.equipmentReady @payload.data.equipmentReady)
        (set @entity.accessGranted @payload.data.accessGranted)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Review Onboarding" },
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 3 },
          { type: "divider" },
          { type: "stack", direction: "vertical", gap: "sm", children: [
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Employee" }, { type: "typography", variant: "body", content: "@entity.employeeName" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Department" }, { type: "typography", variant: "body", content: "@entity.department" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Manager" }, { type: "typography", variant: "body", content: "@entity.manager" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Equipment Ready" }, { type: "typography", variant: "body", content: "@entity.equipmentReady" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Access Granted" }, { type: "typography", variant: "body", content: "@entity.accessGranted" }] }
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "sm", justify: "between", children: [
            { type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" },
            { type: "button", label: "Complete Onboarding", action: "COMPLETE", variant: "primary", icon: "check" }
          ]}
        ]})
      PREV -> step2
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Employee Onboarding" },
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Manager Assignment" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: [{ name: "manager", required: true }] }
        ]})
    }
    state review {
      COMPLETE -> complete when (and @entity.employeeName @entity.email @entity.department @entity.manager)
        (persist create Onboarding @entity { emit: { success: "OnboardingSaved", failure: "OnboardingSaveFailed" } })
        (call-service email "send" { recipient: "@entity.email", subject: "Welcome to the team", body: "Welcome aboard! Your manager and equipment have been set up.", sender: "hr@example.com" } { emit: { success: "OnboardingEmailSent", failure: "OnboardingEmailFailed" } })
        (emit ONBOARDED { id: "@entity.id" })
        (notify success "Onboarding complete")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "icon", name: "check-circle" },
          { type: "typography", variant: "h2", content: "Onboarding Complete!" },
          { type: "typography", variant: "body", color: "muted", content: "The new employee has been fully onboarded." },
          { type: "button", label: "Start new onboarding", action: "RESTART", variant: "ghost", icon: "rotate-ccw" }
        ]})
      PREV -> step3
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Employee Onboarding" },
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 2 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Setup Checklist" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", submitLabel: "Continue", cancelLabel: "Back", fields: ["equipmentReady", "accessGranted"] }
        ]})
    }
    state complete {
      OnboardingEmailSent -> complete
        (notify success "Welcome email sent")
      OnboardingEmailFailed -> complete
        (notify error "Welcome email failed")
      RESTART -> step1
        (set @entity.employeeName "")
        (set @entity.email "")
        (set @entity.department "")
        (set @entity.manager "")
        (set @entity.equipmentReady false)
        (set @entity.accessGranted false)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "typography", variant: "h2", content: "Employee Onboarding" },
          { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h3", content: "Employee Details" },
          { type: "form-section", mode: "create", submitEvent: "NEXT", submitLabel: "Continue", showCancel: false, fields: [{ name: "employeeName", required: true, min: 2 }, { name: "email", type: "email", required: true }, { name: "department", required: true }] }
        ]})
    }
    emits {
      ONBOARDED -> external { id : string }
      OnboardingLoaded
      OnboardingLoadFailed
      OnboardingSaved
      OnboardingSaveFailed
      OnboardingEmailSent { id : string }
      OnboardingEmailFailed { error : string, code : string }
    }
    listens {
      NEXT { data : object! }
      PREV { }
      COMPLETE { }
      OnboardingLoadFailed { error : string, code : string }
      OnboardingSaveFailed { error : string, code : string }
      OnboardingEmailSent { id : string }
      OnboardingEmailFailed { error : string, code : string }
    }
  }

  page "/onboarding" as OnboardingPage -> OnboardingWizard
}

orbital TimeOffOrbital {
  uses Browse        from "std/behaviors/std-browse"
  uses Modal         from "std/behaviors/std-modal"
  uses Confirmation  from "std/behaviors/std-confirmation"
  uses Calendar      from "std/behaviors/std-calendar"
  uses Email         from "std/behaviors/std-service-email"

  entity TimeOff [persistent: timeoffs] {
    id : string!
    employeeName : string!
    employeeEmail : string!
    leaveType : "vacation" | "sick" | "personal" | "bereavement" = "vacation"
    startDate : datetime!
    endDate : datetime!
    reason : string = ""
    status : "pending" | "approved" | "denied" = "pending"
    pendingId : string = ""
  }

  trait TimeOffCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "calendar" },
              { type: "typography", content: "Time Off Requests", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "Request Time Off", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          "@trait.TimeOffCalendar",
          { type: "divider" },
          "@trait.TimeOffBrowseList"
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
  }

  trait TimeOffCalendar = Calendar.traits.CalendarEventCalendar -> TimeOff {
    config: {
      dateField: "startDate",
      titleField: "reason",
      colorField: "status"
    }
    listens {
      TimeOffCreate.TIME_OFF_CREATED -> INIT
      TimeOffEdit.TIME_OFF_UPDATED -> INIT
      TimeOffDelete.TIME_OFF_DELETED -> INIT
    }
  }

  trait TimeOffBrowseList = Browse.traits.BrowseItemBrowse -> TimeOff {
    config: {
      fields: [
        { name: "employeeName", label: "Employee", variant: "h4", icon: "user" },
        { name: "leaveType", label: "Type", variant: "badge" },
        { name: "status", variant: "badge" },
        { name: "startDate", label: "From", variant: "caption", format: "date" },
        { name: "endDate", label: "To", variant: "caption", format: "date" },
        { name: "reason", variant: "caption" }
      ],
      itemActions: [
        { label: "View", event: "VIEW", variant: "ghost" },
        { label: "Edit", event: "EDIT", variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      gap: "sm"
    }
    listens {
      TimeOffCreate.TIME_OFF_CREATED -> INIT
      TimeOffEdit.TIME_OFF_UPDATED -> INIT
      TimeOffDelete.TIME_OFF_DELETED -> INIT
    }
  }

  trait TimeOffCreate = Modal.traits.ModalRecordModal -> TimeOff {
    config: {
      icon: "plus-circle",
      title: "Request Time Off",
      fields: ["employeeName", "employeeEmail", "leaveType", "startDate", "endDate", "reason", "status"],
      mode: "create"
    }
    events {
      OPEN: CREATE
      SAVE: TIME_OFF_CREATED
    }
    listens {
      TimeOffCatalog.CREATE -> CREATE
      CREATE { id : string, row : TimeOff }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TimeOffEdit = Modal.traits.ModalRecordModal -> TimeOff {
    config: {
      icon: "edit",
      title: "Edit Time Off",
      fields: ["employeeName", "employeeEmail", "leaveType", "startDate", "endDate", "reason", "status"],
      mode: "edit"
    }
    events {
      OPEN: EDIT
      SAVE: TIME_OFF_UPDATED
    }
    listens {
      TimeOffBrowseList.EDIT -> EDIT
      EDIT { id : string, row : TimeOff }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TimeOffView = Modal.traits.ModalRecordModal -> TimeOff {
    config: {
      icon: "eye",
      title: "Time Off Details",
      fields: ["employeeName", "employeeEmail", "leaveType", "startDate", "endDate", "reason", "status"],
      mode: "edit"
    }
    events {
      OPEN: VIEW
    }
    listens {
      TimeOffBrowseList.VIEW -> VIEW
      VIEW { id : string, row : TimeOff }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait TimeOffDelete = Confirmation.traits.ConfirmActionConfirmation -> TimeOff {
    config: {
      icon: "alert-triangle",
      title: "Delete Time Off Request",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: TIME_OFF_DELETED
    }
    listens {
      TimeOffBrowseList.DELETE -> DELETE
      DELETE { id : string, row : TimeOff }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  ;; Coordinator: persist + email notification on approval/denial. Email
  ;; outcome fires as TimeOffEmailSent / TimeOffEmailFailed and is consumed
  ;; by an in-trait notification transition.
  trait TimeOffPersistor -> TimeOff [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create TimeOff @payload.data { emit: { success: "TIME_OFF_CREATED" } })
      DO_UPDATE -> idle
        (persist update TimeOff @payload.data { emit: { success: "TIME_OFF_UPDATED" } })
        (call-service email "send" { recipient: "@payload.data.employeeEmail", subject: "Time-off @payload.data.status", body: "Your time-off request has been updated. Status: @payload.data.status.", sender: "hr@example.com" } { emit: { success: "TimeOffEmailSent", failure: "TimeOffEmailFailed" } })
      DO_DELETE -> idle
        (persist delete TimeOff @payload.id { emit: { success: "TIME_OFF_DELETED" } })
      TimeOffEmailSent -> idle
        (notify success "Notification email sent")
      TimeOffEmailFailed -> idle
        (notify error "Email notification failed")
    }
    emits {
      TIME_OFF_CREATED -> external { id : string! }
      TIME_OFF_UPDATED -> external { id : string! }
      TIME_OFF_DELETED -> external { id : string! }
      TimeOffEmailSent { id : string }
      TimeOffEmailFailed { error : string, code : string }
    }
    listens {
      DO_CREATE { data : TimeOff! }
      DO_UPDATE { data : TimeOff! }
      DO_DELETE { id : string! }
      TimeOffEmailSent { id : string }
      TimeOffEmailFailed { error : string, code : string }
      TimeOffCreate.TIME_OFF_CREATED -> DO_CREATE
      TimeOffEdit.TIME_OFF_UPDATED -> DO_UPDATE
      TimeOffDelete.TIME_OFF_DELETED -> DO_DELETE
    }
  }

  page "/timeoff" as TimeOffPage -> TimeOffCatalog, TimeOffCalendar, TimeOffBrowseList, TimeOffCreate, TimeOffEdit, TimeOffView, TimeOffDelete, TimeOffPersistor
}

orbital OrgChartOrbital {
  uses Related from "std/behaviors/std-related"

  entity OrgNode [runtime] {
    id : string!
    name : string = ""
    role : string = ""
    department : string = ""
    managerId : string = ""
  }

  type OrgChartLoaded     = Event { data : [OrgNode] }
  type OrgChartLoadFailed = Event { error : string, code : string }

  ;; Fetches direct reports for the focused node — Related atom keys off the
  ;; managerId field. Drives the "expand node" interaction in the tree view.
  trait EmployeeRelated = Related.traits.RelatedItemList -> OrgNode {
    config: {
      relationField: "managerId"
    }
  }

  ;; Custom domain-specific tree/hierarchy visualization. Std atoms don't
  ;; cover org-chart layouts so we render the graph inline.
  trait OrgChartDisplay -> OrgNode [interaction, instance] {
    initial: loading
    state loading {
      INIT -> displaying
        (set @entity.name "")
        (set @entity.role "")
        (set @entity.department "")
        (set @entity.managerId "")
        (fetch OrgNode { emit: { success: "OrgChartLoaded", failure: "OrgChartLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-6xl mx-auto w-full p-4", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "git-branch" },
              { type: "typography", variant: "h2", content: "Org Chart" }
            ]},
            { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }
          ]},
          { type: "divider" },
          { type: "graph-view", nodes: [{ id: "ceo", label: "CEO" }, { id: "vp-eng", label: "VP Engineering" }, { id: "vp-sales", label: "VP Sales" }, { id: "lead-fe", label: "Frontend Lead" }, { id: "lead-be", label: "Backend Lead" }], edges: [{ source: "ceo", target: "vp-eng" }, { source: "ceo", target: "vp-sales" }, { source: "vp-eng", target: "lead-fe" }, { source: "vp-eng", target: "lead-be" }], width: 800, height: 400 }
        ]})
      OrgChartLoaded -> displaying
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-6xl mx-auto w-full p-4", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "git-branch" },
              { type: "typography", variant: "h2", content: "Org Chart" }
            ]},
            { type: "button", label: "Refresh", action: "REFRESH", variant: "secondary", icon: "refresh-cw" }
          ]},
          { type: "divider" },
          { type: "graph-view", nodes: [{ id: "ceo", label: "CEO" }, { id: "vp-eng", label: "VP Engineering" }, { id: "vp-sales", label: "VP Sales" }, { id: "lead-fe", label: "Frontend Lead" }, { id: "lead-be", label: "Backend Lead" }], edges: [{ source: "ceo", target: "vp-eng" }, { source: "ceo", target: "vp-sales" }, { source: "vp-eng", target: "lead-fe" }, { source: "vp-eng", target: "lead-be" }], width: 800, height: 400 }
        ]})
    }
    state displaying {
      REFRESH -> loading
        (fetch OrgNode { emit: { success: "OrgChartLoaded", failure: "OrgChartLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Refreshing…" }] })
    }
    emits {
      OrgChartLoaded
      OrgChartLoadFailed
    }
    listens {
      REFRESH { }
      OrgChartLoadFailed { error : string, code : string }
    }
  }

  page "/org-chart" as OrgChartPage -> OrgChartDisplay, EmployeeRelated
}
