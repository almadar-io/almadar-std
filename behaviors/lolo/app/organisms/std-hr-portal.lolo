app std-hr-portal "1.0.0"
"HR portal: employees, onboarding flows, time-off requests, and org chart."

orbital EmployeeOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  entity Employee [runtime] {
    id : string!
    name : string = ""
    email : string = ""
    department : string = ""
    role : string = ""
    startDate : datetime = ""
    pendingId : string = ""
  }

  trait EmployeeAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.EmployeeBrowse",
      appName: "HRPortal",
      navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }],
      searchEvent: "EMPLOYEE_SEARCH",
      notifications: [],
      notificationClickEvent: "EMPLOYEE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: EMPLOYEE_SEARCH
      NOTIFY_CLICK: EMPLOYEE_NOTIFICATIONS_OPEN
    }
  }

  type EmployeeLoaded     = Event { data : [Employee] }                  "Fired when Employee finishes loading"
  type EmployeeLoadFailed = Event { error : string, code : string } "Fired when Employee fails to load"
  type EmployeeSaved = Event { id : string }
  type EmployeeSaveFailed = Event { error : string, code : string }
  type EmployeeUpdated = Event { id : string }
  type EmployeeUpdateFailed = Event { error : string, code : string }
  type EmployeeDeleted = Event { id : string }
  type EmployeeDeleteFailed = Event { error : string, code : string }
  type OnboardingSaved = Event { id : string }
  type OnboardingSaveFailed = Event { error : string, code : string }
  type TimeOffSaved = Event { id : string }
  type TimeOffSaveFailed = Event { error : string, code : string }
  type TimeOffUpdated = Event { id : string }
  type TimeOffUpdateFailed = Event { error : string, code : string }
  type TimeOffDeleted = Event { id : string }
  type TimeOffDeleteFailed = Event { error : string, code : string }
  trait EmployeeBrowse -> Employee [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      EMPLOYEE_SEARCH -> browsing
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Searching…" }] })
      EMPLOYEE_NOTIFICATIONS_OPEN -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [{ type: "icon", name: "bell" }, { type: "typography", variant: "h3", content: "No notifications" }, { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." }, { type: "button", label: "Back to employees", action: "INIT", variant: "ghost" }] })
      EmployeeLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "Employees", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Add Employee", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "name", variant: "h3", icon: "user" }, { name: "department", variant: "badge" }, { name: "role", variant: "body" }, { name: "email", variant: "caption" }, { name: "startDate", label: "Joined", variant: "caption", format: "date" }], variant: "card", gap: "sm" }] })
      EmployeeLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load employee" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
ONBOARD -> external { id: string }
CREATE
      VIEW { id : string!, row : Employee }
EDIT { id : string!, row : Employee }
DELETE { id : string!, row : Employee }
EmployeeLoaded
      EmployeeLoadFailed
EmployeeSaved
      EmployeeSaveFailed
EmployeeUpdated
      EmployeeUpdateFailed
EmployeeDeleted
      EmployeeDeleteFailed
OnboardingSaved
      OnboardingSaveFailed
TimeOffSaved
      TimeOffSaveFailed
TimeOffUpdated
      TimeOffUpdateFailed
TimeOffDeleted
      TimeOffDeleteFailed
    }
    listens {
      EmployeeCreate.EMPLOYEE_CREATED -> INIT
      EmployeeEdit.EMPLOYEE_UPDATED -> INIT
      EmployeeDelete.EMPLOYEE_DELETED -> INIT
      EmployeeAppLayout.EMPLOYEE_SEARCH -> EMPLOYEE_SEARCH
      EmployeeAppLayout.EMPLOYEE_NOTIFICATIONS_OPEN -> EMPLOYEE_NOTIFICATIONS_OPEN
      VIEW { id : string!, row : Employee }
      EDIT { id : string!, row : Employee }
      DELETE { id : string!, row : Employee }
      EMPLOYEE_SEARCH { value : string }
      EMPLOYEE_NOTIFICATIONS_OPEN { id : string }
          EmployeeLoadFailed { error : string, code : string }

      EmployeeSaveFailed { error : string, code : string }
      EmployeeUpdateFailed { error : string, code : string }
      EmployeeDeleteFailed { error : string, code : string }
      OnboardingSaveFailed { error : string, code : string }
      TimeOffSaveFailed { error : string, code : string }
      TimeOffUpdateFailed { error : string, code : string }
      TimeOffDeleteFailed { error : string, code : string }
    }
  }
  trait EmployeeCreate -> Employee [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
      CREATE -> open
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "New Employee", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "email", "department", "role", "startDate"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Employee @payload.data { emit: { success: "EmployeeSaved", failure: "EmployeeSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit EMPLOYEE_CREATED)
    }
    emits {
EMPLOYEE_CREATED -> external { id: string }
EmployeeLoadFailed
      EmployeeLoaded
EmployeeSaveFailed
      EmployeeSaved
    }
    listens {
      SAVE { data : object! }
          EmployeeLoadFailed { error : string, code : string }
      EmployeeBrowse.CREATE -> CREATE
    }
  }
  trait EmployeeEdit -> Employee [interaction, collection] {
    listens {
      EmployeeView.EDIT -> EDIT
    }
    initial: closed
    state closed {
      INIT -> closed
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
      EDIT -> open
        (fetch Employee {id: "@payload.id" , emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" }, emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit Employee", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["name", "email", "department", "role", "startDate"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update Employee @payload.data { emit: { success: "EmployeeUpdated", failure: "EmployeeUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit EMPLOYEE_UPDATED)
    }
    emits {
EMPLOYEE_UPDATED -> external { id: string }
EmployeeLoadFailed
      EmployeeLoaded
EmployeeUpdateFailed
      EmployeeUpdated
    }
    listens {
      EDIT { id : string!, row : Employee }
      SAVE { data : object! }
          EmployeeLoadFailed { error : string, code : string }
      EmployeeBrowse.EDIT -> EDIT
    }
  }
  trait EmployeeView -> Employee [interaction, collection] {
    emits {
EDIT { id : string }
EmployeeLoaded
      EmployeeLoadFailed
    }
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.department "")
        (set @entity.email "")
        (set @entity.name "")
        (set @entity.role "")
        (set @entity.startDate "")
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
      VIEW -> open
        (fetch Employee {id: "@payload.id" , emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" }, emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.name" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Department" }, { type: "typography", variant: "body", content: "@entity.department" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Role" }, { type: "typography", variant: "body", content: "@entity.role" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Start Date" }, { type: "typography", variant: "body", content: "@entity.startDate" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          EmployeeLoadFailed { error : string, code : string }
      EmployeeBrowse.VIEW -> VIEW
    }
  }
  trait EmployeeDelete -> Employee [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch Employee {id: "@payload.id" , emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" }, emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete Employee", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete Employee @entity.pendingId { emit: { success: "EmployeeDeleted", failure: "EmployeeDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
        (emit EMPLOYEE_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch Employee { emit: { success: "EmployeeLoaded", failure: "EmployeeLoadFailed" } })
    }
    emits {
EMPLOYEE_DELETED -> external { id: string }
EmployeeDeleteFailed
      EmployeeDeleted
EmployeeLoadFailed
      EmployeeLoaded
    }
    listens {
      DELETE { id : string! }
          EmployeeLoadFailed { error : string, code : string }
      EmployeeBrowse.DELETE -> DELETE
    }
  }
  page "/employees" as EmployeesPage -> EmployeeAppLayout, EmployeeBrowse, EmployeeCreate, EmployeeEdit, EmployeeView, EmployeeDelete
}
orbital OnboardingOrbital {
  entity Onboarding [runtime] {
    id : string!
    employeeName : string
    department : string = ""
    manager : string
    equipmentReady : boolean
    accessGranted : boolean
  }

  type OnboardingLoaded     = Event { data : [Onboarding] }                  "Fired when Onboarding finishes loading"
  type OnboardingLoadFailed = Event { error : string, code : string } "Fired when Onboarding fails to load"
  type OnboardingSaveFailed = Event { error : string, code : string }
  type OnboardingSaved = Event { id : string }
  trait OnboardingWizard -> Onboarding [interaction, collection] {
    initial: step1
    state step1 {
      INIT -> step1
        (set @entity.accessGranted false)
        (set @entity.department "")
        (set @entity.employeeName "")
        (set @entity.equipmentReady false)
        (set @entity.manager "")
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 0 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Employee Details", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["employeeName", "department"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      NEXT -> step2
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 1 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 1 }, { type: "divider" }, { type: "typography", content: "Manager Assignment", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["manager"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
    state step2 {
      NEXT -> step3
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 2 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 2 }, { type: "divider" }, { type: "typography", content: "Setup Checklist", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["equipmentReady", "accessGranted"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      PREV -> step1
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 0 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Employee Details", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["employeeName", "department"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
    state step3 {
      NEXT -> review
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "badge", label: "Review" }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 3 }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Employee Name" }, { type: "typography", variant: "body", content: "@entity.employeeName" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Department" }, { type: "typography", variant: "body", content: "@entity.department" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Manager" }, { type: "typography", variant: "body", content: "@entity.manager" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Equipment Ready" }, { type: "typography", variant: "body", content: "@entity.equipmentReady" }] }, { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", content: "Access Granted" }, { type: "typography", variant: "body", content: "@entity.accessGranted" }] }] }, { type: "wizard-navigation", currentStep: 3, totalSteps: 4, showBack: true, showComplete: true, showNext: false }] }] })
      PREV -> step2
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 1 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 1 }, { type: "divider" }, { type: "typography", content: "Manager Assignment", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["manager"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
    state review {
      PREV -> step3
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 2 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 2 }, { type: "divider" }, { type: "typography", content: "Setup Checklist", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["equipmentReady", "accessGranted"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Back", action: "PREV", variant: "ghost", icon: "arrow-left" }, { type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      COMPLETE -> complete
        (persist create Onboarding @payload.data { emit: { success: "OnboardingSaved", failure: "OnboardingSaveFailed" } })
        (notify success "Onboarding created successfully")
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Onboarding Complete!", variant: "h2" }, { type: "typography", content: "The new employee has been fully onboarded.", variant: "body" }, { type: "button", label: "Start New", action: "RESTART", variant: "primary", icon: "refresh-cw" }] }] })
    }
    state complete {
      RESTART -> step1
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 0 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Employee Details", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["employeeName", "department"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
      INIT -> step1
        (fetch Onboarding { emit: { success: "OnboardingLoaded", failure: "OnboardingLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "container", maxWidth: "lg", padding: "lg", children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-check" }, { type: "typography", content: "Employee Onboarding", variant: "h2" }] }, { type: "progress-dots", count: 3, currentIndex: 0 }, { type: "wizard-progress", steps: ["Employee Details", "Manager Assignment", "Setup Checklist"], currentStep: 0 }, { type: "divider" }, { type: "typography", content: "Employee Details", variant: "h3" }, { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["employeeName", "department"] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Next", action: "NEXT", variant: "primary", icon: "arrow-right" }] }] }] }] })
    }
emits {
OnboardingLoadFailed
      OnboardingLoaded
OnboardingSaveFailed
      OnboardingSaved
    }

        listens {
      EmployeeOrbital.EmployeeBrowse.ONBOARD -> INIT
          OnboardingLoadFailed { error : string, code : string }
          COMPLETE { data : string }
    }
  }
  page "/onboarding" -> OnboardingWizard
}
orbital TimeOffOrbital {
  entity TimeOff [runtime] {
    id : string!
    employeeName : string
    leaveType : string
    startDate : datetime = ""
    endDate : datetime
    status : string
    pendingId : string = ""
  }

  type TimeOffLoaded     = Event { data : [TimeOff] }                  "Fired when TimeOff finishes loading"
  type TimeOffLoadFailed = Event { error : string, code : string } "Fired when TimeOff fails to load"
  type TimeOffDeleteFailed = Event { error : string, code : string }
  type TimeOffDeleted = Event { id : string }
  type TimeOffSaveFailed = Event { error : string, code : string }
  type TimeOffSaved = Event { id : string }
  type TimeOffUpdateFailed = Event { error : string, code : string }
  type TimeOffUpdated = Event { id : string }
  trait TimeOffBrowse -> TimeOff [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      TimeOffLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "HRPortal", navItems: [{ label: "Employees", href: "/employees", icon: "users" }, { label: "Onboarding", href: "/onboarding", icon: "layout-list" }, { label: "Time Off", href: "/timeoff", icon: "calendar" }, { label: "Org Chart", href: "/org-chart", icon: "layout-list" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "Time Off Requests", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Request Time Off", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }, { label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "employeeName", label: "Employee", variant: "h3", icon: "calendar" }, { name: "leaveType", label: "Type", variant: "badge" }, { name: "status", variant: "badge" }, { name: "startDate", label: "From", variant: "body", format: "date" }, { name: "endDate", label: "To", variant: "body", format: "date" }], variant: "card", gap: "sm" }] }] })
      TimeOffLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load timeoff" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
APPROVE_LEAVE -> external { id: string }
CREATE
      VIEW { id : string!, row : TimeOff }
EDIT { id : string!, row : TimeOff }
DELETE { id : string!, row : TimeOff }
TimeOffLoaded
      TimeOffLoadFailed
    }
    listens {
      TimeOffCreate.TIME_OFF_CREATED -> INIT
      TimeOffEdit.TIME_OFF_UPDATED -> INIT
      TimeOffDelete.TIME_OFF_DELETED -> INIT
          TimeOffLoadFailed { error : string, code : string }
    }
  }
  trait TimeOffCreate -> TimeOff [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
      CREATE -> open
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "New Time Off Request", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["employeeName", "leaveType", "startDate", "endDate", "status"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create TimeOff @payload.data { emit: { success: "TimeOffSaved", failure: "TimeOffSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit TIME_OFF_CREATED)
    }
    emits {
TIME_OFF_CREATED
      TimeOffLoadFailed
TimeOffLoaded
      TimeOffSaveFailed
TimeOffSaved
    
    }
    listens {
      TimeOffLoadFailed { error : string, code : string }
      SAVE { data : string }
      TimeOffBrowse.CREATE -> CREATE
    }
  }
  trait TimeOffEdit -> TimeOff [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
      EDIT -> open
        (fetch TimeOff {id: "@payload.id" , emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" }, emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "Edit TimeOff", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["employeeName", "leaveType", "startDate", "endDate", "status"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update TimeOff @payload.data { emit: { success: "TimeOffUpdated", failure: "TimeOffUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit TIME_OFF_UPDATED)
    }
    emits {
TIME_OFF_UPDATED
      TimeOffLoadFailed
TimeOffLoaded
      TimeOffUpdateFailed
TimeOffUpdated
    
    }
    listens {
      TimeOffView.EDIT -> EDIT
      TimeOffLoadFailed { error : string, code : string }
      EDIT { id : string, row : TimeOff }
      SAVE { data : string }
      TimeOffBrowse.EDIT -> EDIT
    }
  }
  trait TimeOffView -> TimeOff [interaction, collection] {
    emits {
EDIT { id : string }
TimeOffLoaded
      TimeOffLoadFailed
    }
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.employeeName "")
        (set @entity.endDate "")
        (set @entity.leaveType "")
        (set @entity.startDate "")
        (set @entity.status "")
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
      VIEW -> open
        (fetch TimeOff {id: "@payload.id" , emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" }, emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.employeeName" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Employee Name" }, { type: "typography", variant: "body", content: "@entity.employeeName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Leave Type" }, { type: "typography", variant: "body", content: "@entity.leaveType" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Start Date" }, { type: "typography", variant: "body", content: "@entity.startDate" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "End Date" }, { type: "typography", variant: "body", content: "@entity.endDate" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Edit", action: "EDIT", variant: "primary", icon: "edit" }, { type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      TimeOffLoadFailed { error : string, code : string }
      VIEW { id : string }
      TimeOffBrowse.VIEW -> VIEW
    }
  }
  trait TimeOffDelete -> TimeOff [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
      DELETE -> confirming
        (set @entity.pendingId @payload.id)
        (fetch TimeOff {id: "@payload.id" , emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" }, emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Delete TimeOff", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "This action cannot be undone." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "Delete", action: "CONFIRM_DELETE", variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM_DELETE -> idle
        (persist delete TimeOff @entity.pendingId { emit: { success: "TimeOffDeleted", failure: "TimeOffDeleteFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
        (emit TIME_OFF_DELETED)
      CANCEL -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
      CLOSE -> idle
        (render-ui modal null)
        (render-ui main { type: "box" })
        (fetch TimeOff { emit: { success: "TimeOffLoaded", failure: "TimeOffLoadFailed" } })
    }
    emits {
TIME_OFF_DELETED
      TimeOffDeleteFailed
TimeOffDeleted
      TimeOffLoadFailed
TimeOffLoaded
    
    }
    listens {
      TimeOffLoadFailed { error : string, code : string }
      DELETE { id : string }
      TimeOffBrowse.DELETE -> DELETE
    }
  }
  page "/timeoff" -> TimeOffBrowse, TimeOffCreate, TimeOffEdit, TimeOffView, TimeOffDelete
}
orbital OrgChartOrbital {
