app std-nonprofit-donations "1.0.0"
"Nonprofit donations: fundraising campaigns, donors, campaign goals, and tax-deductible receipts. Pick for charity/nonprofit fundraising apps."

orbital CampaignOrbital {
  uses AppShell        from "std/behaviors/std-app-layout"
  uses Modal           from "std/behaviors/std-modal"
  uses Confirmation    from "std/behaviors/std-confirmation"
  uses Search          from "std/behaviors/std-search"
  uses Filter          from "std/behaviors/std-filter"
  uses Stats           from "std/behaviors/std-stats"
  uses Graphs          from "std/behaviors/std-graphs"
  uses Browse          from "std/behaviors/std-browse"
  uses Donor           from "std/behaviors/std-donor"
  uses CampaignGoal    from "std/behaviors/std-campaign-goal"
  uses DonationReceipt from "std/behaviors/std-donation-receipt"

  entity FundraisingCampaign [persistent: fundraisingcampaigns] {
    id           : string!
    name         : string!
    goalAmount   : number = 0
    raisedAmount : number = 0
    status       : "active" | "completed" | "paused" | "draft" = "draft"
    startDate    : string = ""
    endDate      : string = ""
    pendingId    : string = ""
  }

  trait CampaignAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.CampaignCatalog",
      appName: "Donations",
      navItems: [{ label: "Campaigns", href: "/campaigns", icon: "target" }, { label: "Donors", href: "/donors", icon: "heart-handshake" }, { label: "Goals", href: "/goals", icon: "flag" }, { label: "Receipts", href: "/receipts", icon: "receipt" }],
      searchEvent: "CAMPAIGN_SEARCH",
      notifications: [],
      notificationClickEvent: "CAMPAIGN_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: CAMPAIGN_SEARCH
      NOTIFY_CLICK: CAMPAIGN_NOTIFICATIONS_OPEN
    }
  }

  trait CampaignCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "target" },
              { type: "typography", content: "Fundraising Campaigns", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Campaign", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.CampaignSearch",
            "@trait.CampaignFilter"
          ]},
          "@trait.CampaignStats",
          "@trait.CampaignGraphs",
          { type: "divider" },
          "@trait.CampaignBrowseList"
        ]})
      CAMPAIGN_SEARCH -> composing
      CAMPAIGN_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to campaigns", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      CampaignAppLayout.CAMPAIGN_SEARCH             -> CAMPAIGN_SEARCH
      CampaignAppLayout.CAMPAIGN_NOTIFICATIONS_OPEN -> CAMPAIGN_NOTIFICATIONS_OPEN
      CAMPAIGN_SEARCH             { value : string }
      CAMPAIGN_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait CampaignSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search campaigns…",
      event: "CAMPAIGN_SEARCH"
    }
  }

  trait CampaignFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "status", label: "Status", filterType: "select", options: ["active", "completed", "paused", "draft"] }
      ],
      event: "CAMPAIGN_FILTER"
    }
  }

  trait CampaignStats = Stats.traits.StatsItemStats {
    config: {
      title: "Campaigns",
      metrics: [
        { aggregation: "count", label: "Total",     icon: "target",      variant: "primary", format: "number" },
        { aggregation: "count", label: "Active",    icon: "zap",         variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "active"]] },
        { aggregation: "sum",   label: "Goal",      icon: "flag",        variant: "info",    format: "number", field: "goalAmount" },
        { aggregation: "sum",   label: "Raised",    icon: "trending-up", variant: "success", format: "number", field: "raisedAmount" }
      ]
    }
    listens {
      CampaignBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait CampaignGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Campaigns by Status",
      subtitle: "Volume across campaign lifecycle",
      chartType: "bar",
      categoryField: "status",
      aggregation: "count",
      height: 240,
      showLegend: false
    }
    listens {
      CampaignBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait CampaignBrowseList = Browse.traits.BrowseItemBrowse -> FundraisingCampaign {
    config: {
      fields: [
        { name: "name",         variant: "h3",      icon: "target" },
        { name: "status",       variant: "badge" },
        { name: "goalAmount",   variant: "body",    format: "number" },
        { name: "raisedAmount", variant: "body",    format: "number" },
        { name: "startDate",    variant: "caption", format: "date" },
        { name: "endDate",      variant: "caption", format: "date" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      CampaignSearch.SEARCH                  -> REFETCH_QUERY
      CampaignFilter.FILTER                  -> REFETCH_FILTER
      CampaignPersistor.CAMPAIGN_CREATED     -> INIT
      CampaignPersistor.CAMPAIGN_UPDATED     -> INIT
      CampaignPersistor.CAMPAIGN_DELETED     -> INIT
    }
  }

  trait CampaignCreate = Modal.traits.ModalRecordModal -> FundraisingCampaign {
    config: {
      icon: "plus-circle",
      title: "New Campaign",
      mode: "create",
      fields: ["name", "goalAmount", "raisedAmount", "status", "startDate", "endDate"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      CampaignCatalog.CREATE -> CREATE
      CREATE { id : string, row : FundraisingCampaign }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CampaignEdit = Modal.traits.ModalRecordModal -> FundraisingCampaign {
    config: {
      icon: "edit",
      title: "Edit Campaign",
      mode: "edit",
      fields: ["name", "goalAmount", "raisedAmount", "status", "startDate", "endDate"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      CampaignBrowseList.EDIT -> EDIT
      EDIT { id : string, row : FundraisingCampaign }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CampaignView = Modal.traits.ModalRecordModal -> FundraisingCampaign {
    config: {
      icon: "eye",
      title: "View Campaign",
      mode: "edit",
      fields: ["name", "goalAmount", "raisedAmount", "status", "startDate", "endDate"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      CampaignBrowseList.VIEW -> VIEW
      VIEW { id : string, row : FundraisingCampaign }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CampaignDelete = Confirmation.traits.ConfirmActionConfirmation -> FundraisingCampaign {
    config: {
      icon: "alert-triangle",
      title: "Delete Campaign",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      CampaignBrowseList.DELETE -> DELETE
      DELETE { id : string, row : FundraisingCampaign }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait CampaignPersistor -> FundraisingCampaign [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create FundraisingCampaign @payload.data { emit: { success: "CAMPAIGN_CREATED" } })
      DO_UPDATE -> idle
        (persist update FundraisingCampaign @payload.data { emit: { success: "CAMPAIGN_UPDATED" } })
      DO_DELETE -> idle
        (persist delete FundraisingCampaign @payload.id { emit: { success: "CAMPAIGN_DELETED" } })
    }
    emits {
      CAMPAIGN_CREATED -> external { id : string }
      CAMPAIGN_UPDATED -> external { id : string }
      CAMPAIGN_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      CampaignCreate.SAVE           -> DO_CREATE
      CampaignEdit.SAVE             -> DO_UPDATE
      CampaignDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  trait CampaignDonorsPanel = Donor.traits.DonorRoster {
    config: {
      title: "Donors"
    }
  }

  trait CampaignGoalsPanel = CampaignGoal.traits.CampaignGoalTracker {
    config: {
      title: "Campaign Goals"
    }
  }

  trait CampaignReceiptsPanel = DonationReceipt.traits.DonationReceiptIssuer {
    config: {
      title: "Donation Receipts"
    }
  }

  page "/campaigns" as CampaignsPage -> CampaignAppLayout, CampaignCatalog, CampaignSearch, CampaignFilter, CampaignStats, CampaignGraphs, CampaignBrowseList, CampaignCreate, CampaignEdit, CampaignView, CampaignDelete, CampaignPersistor
  page "/donors"    as DonorsPage    -> CampaignAppLayout, CampaignDonorsPanel
  page "/goals"     as GoalsPage     -> CampaignAppLayout, CampaignGoalsPanel
  page "/receipts"  as ReceiptsPage  -> CampaignAppLayout, CampaignReceiptsPanel
}
