app std-social-feed "1.0.0"
"std-social-feed as a Function"

orbital PostOrbital {
  entity Post [runtime] {
    id : string!
    title : string = ""
    content : string = ""
    author : string = ""
    createdAt : datetime = ""
    likes : number = 0
  }

  type PostLoaded     = Event { data : [Post] }                  "Fired when Post finishes loading"
  type PostLoadFailed = Event { error : string, code : string } "Fired when Post fails to load"
  type PostSaved = Event { id : string }
  type PostSaveFailed = Event { error : string, code : string }
  type CommentSaved = Event { id : string }
  type CommentSaveFailed = Event { error : string, code : string }
  trait PostBrowse -> Post [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Post { emit: { success: "PostLoaded", failure: "PostLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      PostLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "SocialFeed", navItems: [{ label: "Feed", href: "/feed", icon: "layout-list" }, { label: "Messages", href: "/messages", icon: "message-circle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "rss" }, { type: "typography", content: "Feed", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "New Post", action: "CREATE", variant: "primary", icon: "plus" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }], fields: [{ name: "title", variant: "h3", icon: "rss" }, { name: "likes", variant: "badge", format: "number" }, { name: "author", variant: "body" }, { name: "content", variant: "body" }, { name: "createdAt", label: "Posted", variant: "caption", format: "date" }], variant: "card", gap: "sm" }] }] })
      PostLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load post" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      COMMENT external { id: string }
      CREATE
      VIEW { id : string!, row : Post }
    }
    listens {
      VIEW { id : string!, row : Post }
          PostLoadFailed { error : string, code : string }
    
      PostSaveFailed { error : string, code : string }
      CommentSaveFailed { error : string, code : string }
    }
    emits: [PostLoaded, PostLoadFailed, PostSaved, PostSaveFailed, CommentSaved, CommentSaveFailed]
  }
  trait PostCreate -> Post [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Post { emit: { success: "PostLoaded", failure: "PostLoadFailed" } })
      CREATE -> open
        (fetch Post { emit: { success: "PostLoaded", failure: "PostLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Create Post", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["title", "content", "author", "likes"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Post @payload.data { emit: { success: "PostSaved", failure: "PostSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      SAVE { data : object! }
          PostLoadFailed { error : string, code : string }
      PostBrowse CREATE -> CREATE
    }
    emits: [PostLoadFailed, PostLoaded, PostSaveFailed, PostSaved]
  }
  trait PostView -> Post [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Post { emit: { success: "PostLoaded", failure: "PostLoadFailed" } })
      VIEW -> open
        (fetch Post {id: "@payload.id" , emit: { success: "PostLoaded", failure: "PostLoadFailed" }, emit: { success: "PostLoaded", failure: "PostLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.title" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Title" }, { type: "typography", variant: "body", content: "@entity.title" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Content" }, { type: "typography", variant: "body", content: "@entity.content" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Author" }, { type: "typography", variant: "body", content: "@entity.author" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Created At" }, { type: "typography", variant: "body", content: "@entity.createdAt" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Likes" }, { type: "typography", variant: "body", content: "@entity.likes" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    listens {
      VIEW { id : string! }
      SAVE { data : object! }
          PostLoadFailed { error : string, code : string }
      PostBrowse VIEW -> VIEW
    }
    emits: [PostLoaded, PostLoadFailed]
  }
  page "/feed" as FeedPage -> PostBrowse, PostCreate, PostView
}
orbital CommentOrbital {
  entity Comment [runtime] {
    id : string!
    body : string
    author : string = ""
    postId : string
    createdAt : datetime = ""
  }

  type CommentLoaded     = Event { data : [Comment] }                  "Fired when Comment finishes loading"
  type CommentLoadFailed = Event { error : string, code : string } "Fired when Comment fails to load"
  type CommentSaveFailed = Event { error : string, code : string }
  type CommentSaved = Event { id : string }
  trait CommentBrowse -> Comment [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Comment { emit: { success: "CommentLoaded", failure: "CommentLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      CommentLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "SocialFeed", navItems: [{ label: "Feed", href: "/feed", icon: "layout-list" }, { label: "Messages", href: "/messages", icon: "message-circle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "Messages", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compose", action: "COMPOSE", variant: "primary", icon: "edit" }] }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost" }], fields: [{ name: "author", variant: "h4", icon: "message-circle" }, { name: "body", variant: "body" }, { name: "createdAt", variant: "caption", format: "date" }], variant: "card", gap: "sm" }] }] })
      CommentLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load comment" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      COMPOSE
      VIEW { id : string!, row : Comment }
    }
    listens {
      CommentCompose SEND -> INIT
      * COMMENT -> INIT
          CommentLoadFailed { error : string, code : string }
    }
    emits: [CommentLoaded, CommentLoadFailed]
  }
  trait CommentCompose -> Comment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Comment { emit: { success: "CommentLoaded", failure: "CommentLoadFailed" } })
      COMPOSE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "edit" }, { type: "typography", content: "New Comment", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SEND", cancelEvent: "CLOSE", fields: ["body", "author", "postId"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SEND -> closed
        (persist create Comment @payload.data { emit: { success: "CommentSaved", failure: "CommentSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    emits {
      SEND
    }
    emits: [CommentLoadFailed, CommentLoaded, CommentSaveFailed, CommentSaved]
    listens {
      CommentLoadFailed { error : string, code : string }
      SEND { data : string }
      CommentBrowse COMPOSE -> COMPOSE
    }
  }
  trait CommentView -> Comment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Comment { emit: { success: "CommentLoaded", failure: "CommentLoadFailed" } })
      VIEW -> open
        (fetch Comment {id: "@payload.id" , emit: { success: "CommentLoaded", failure: "CommentLoadFailed" }, emit: { success: "CommentLoaded", failure: "CommentLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "eye" }, { type: "typography", variant: "h3", content: "@entity.body" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Body" }, { type: "typography", variant: "body", content: "@entity.body" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Author" }, { type: "typography", variant: "body", content: "@entity.author" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Post ID" }, { type: "typography", variant: "body", content: "@entity.postId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Created At" }, { type: "typography", variant: "body", content: "@entity.createdAt" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Close", action: "CLOSE", variant: "ghost" }] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    emits: [CommentLoaded, CommentLoadFailed]
    listens {
      CommentLoadFailed { error : string, code : string }
      VIEW { id : string }
      CommentBrowse VIEW -> VIEW
    }
  }
  page "/messages" -> CommentBrowse, CommentCompose, CommentView
}
