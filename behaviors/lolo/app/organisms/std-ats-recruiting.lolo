app std-ats-recruiting "1.0.0"
"ATS recruiting: job openings catalog, applicant intake pipeline, interview scheduling, and offer letters. Pick for hiring/talent apps."

orbital JobOpeningOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Search       from "std/behaviors/std-search"
  uses Filter       from "std/behaviors/std-filter"
  uses Stats        from "std/behaviors/std-stats"
  uses Graphs       from "std/behaviors/std-graphs"
  uses Browse       from "std/behaviors/std-browse"

  entity JobOpening [persistent: jobopenings] {
    id : string!
    title : string!
    department : string = ""
    status : "open" | "closed" | "draft" = "open"
    location : string = ""
    hiringManager : string = ""
    headcount : number = 1
    pendingId : string = ""
  }

  trait JobOpeningAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.JobOpeningCatalog",
      appName: "ATSRecruiting",
      navItems: [{ label: "Openings", href: "/openings", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "user-plus" }, { label: "Interviews", href: "/interviews", icon: "calendar" }, { label: "Offers", href: "/offers", icon: "file-text" }],
      searchEvent: "JOB_OPENING_SEARCH",
      notifications: [],
      notificationClickEvent: "JOB_OPENING_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: JOB_OPENING_SEARCH
      NOTIFY_CLICK: JOB_OPENING_NOTIFICATIONS_OPEN
    }
  }

  trait JobOpeningCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "briefcase" },
              { type: "typography", content: "Job Openings", variant: "h2" }
            ]},
            { type: "stack", direction: "horizontal", gap: "sm", children: [
              { type: "button", label: "New Opening", action: "CREATE", variant: "primary", icon: "plus" }
            ]}
          ]},
          { type: "divider" },
          { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [
            "@trait.JobOpeningSearch",
            "@trait.JobOpeningFilter"
          ]},
          "@trait.JobOpeningStats",
          "@trait.JobOpeningGraphs",
          { type: "divider" },
          "@trait.JobOpeningBrowseList"
        ]})
      JOB_OPENING_SEARCH -> composing
      JOB_OPENING_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to openings", action: "INIT", variant: "ghost" }
        ]})
    }
    emits {
      CREATE -> external { source : string }
    }
    listens {
      JobOpeningAppLayout.JOB_OPENING_SEARCH -> JOB_OPENING_SEARCH
      JobOpeningAppLayout.JOB_OPENING_NOTIFICATIONS_OPEN -> JOB_OPENING_NOTIFICATIONS_OPEN
      JOB_OPENING_SEARCH { value : string }
      JOB_OPENING_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait JobOpeningSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search openings…",
      event: "JOB_OPENING_SEARCH"
    }
  }

  trait JobOpeningFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [
        { field: "status",     label: "Status",     filterType: "select", options: ["open", "closed", "draft"] },
        { field: "department", label: "Department", filterType: "select", options: ["engineering", "design", "marketing", "sales", "hr", "finance", "operations"] }
      ],
      event: "JOB_OPENING_FILTER"
    }
  }

  trait JobOpeningStats = Stats.traits.StatsItemStats {
    config: {
      title: "Openings",
      metrics: [
        { aggregation: "count", label: "Total",   icon: "briefcase",    variant: "primary", format: "number" },
        { aggregation: "count", label: "Open",    icon: "circle",       variant: "success", format: "number", filter: ["fn", "row", ["=", "@row.status", "open"]] },
        { aggregation: "count", label: "Drafts",  icon: "edit",         variant: "warning", format: "number", filter: ["fn", "row", ["=", "@row.status", "draft"]] },
        { aggregation: "sum",   label: "Seats",   icon: "users",        variant: "primary", format: "number", field: "headcount" }
      ]
    }
    listens {
      JobOpeningBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait JobOpeningGraphs = Graphs.traits.GraphItemGraph {
    config: {
      title: "Openings by Department",
      subtitle: "Headcount distribution across teams",
      chartType: "bar",
      categoryField: "department",
      aggregation: "count",
      height: 240,
      showLegend: false
    }
    listens {
      JobOpeningBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait JobOpeningBrowseList = Browse.traits.BrowseItemBrowse -> JobOpening {
    config: {
      fields: [
        { name: "title",         variant: "h3",      icon: "briefcase" },
        { name: "department",    variant: "badge" },
        { name: "status",        variant: "badge" },
        { name: "location",      variant: "body" },
        { name: "hiringManager", variant: "caption" },
        { name: "headcount",     variant: "caption" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      JobOpeningSearch.SEARCH                   -> REFETCH_QUERY
      JobOpeningFilter.FILTER                   -> REFETCH_FILTER
      JobOpeningPersistor.JOB_OPENING_CREATED   -> INIT
      JobOpeningPersistor.JOB_OPENING_UPDATED   -> INIT
      JobOpeningPersistor.JOB_OPENING_DELETED   -> INIT
    }
  }

  trait JobOpeningCreate = Modal.traits.ModalRecordModal -> JobOpening {
    config: {
      icon: "plus-circle",
      title: "New Opening",
      mode: "create",
      fields: ["title", "department", "status", "location", "hiringManager", "headcount"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      JobOpeningCatalog.CREATE -> CREATE
      CREATE { id : string, row : JobOpening }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait JobOpeningEdit = Modal.traits.ModalRecordModal -> JobOpening {
    config: {
      icon: "edit",
      title: "Edit Opening",
      mode: "edit",
      fields: ["title", "department", "status", "location", "hiringManager", "headcount"]
    }
    events {
      OPEN: EDIT
    }
    listens {
      JobOpeningBrowseList.EDIT -> EDIT
      EDIT { id : string, row : JobOpening }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait JobOpeningView = Modal.traits.ModalRecordModal -> JobOpening {
    config: {
      icon: "eye",
      title: "View Opening",
      mode: "edit",
      fields: ["title", "department", "status", "location", "hiringManager", "headcount"]
    }
    events {
      OPEN: VIEW
    }
    listens {
      JobOpeningBrowseList.VIEW -> VIEW
      VIEW { id : string, row : JobOpening }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait JobOpeningDelete = Confirmation.traits.ConfirmActionConfirmation -> JobOpening {
    config: {
      icon: "alert-triangle",
      title: "Delete Opening",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      JobOpeningBrowseList.DELETE -> DELETE
      DELETE { id : string, row : JobOpening }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait JobOpeningPersistor -> JobOpening [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create JobOpening @payload.data { emit: { success: "JOB_OPENING_CREATED" } })
      DO_UPDATE -> idle
        (persist update JobOpening @payload.data { emit: { success: "JOB_OPENING_UPDATED" } })
      DO_DELETE -> idle
        (persist delete JobOpening @payload.id { emit: { success: "JOB_OPENING_DELETED" } })
    }
    emits {
      JOB_OPENING_CREATED -> external { id : string }
      JOB_OPENING_UPDATED -> external { id : string }
      JOB_OPENING_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      JobOpeningCreate.SAVE          -> DO_CREATE
      JobOpeningEdit.SAVE            -> DO_UPDATE
      JobOpeningDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/openings" as OpeningsPage -> JobOpeningAppLayout, JobOpeningCatalog, JobOpeningSearch, JobOpeningFilter, JobOpeningStats, JobOpeningGraphs, JobOpeningBrowseList, JobOpeningCreate, JobOpeningEdit, JobOpeningView, JobOpeningDelete, JobOpeningPersistor
}

orbital ApplicantPipelineOrbital {
  uses AppShell      from "std/behaviors/std-app-layout"
  uses ApplicantForm from "std/behaviors/std-applicant-form"

  entity ApplicationIntake [persistent: applicationintakes] {
    id                : string!
    applicantName     : string!
    applicantEmail    : string = ""
    applicantPhone    : string = ""
    jobId             : string = ""
    resumeUrl         : string = ""
    firstInterviewAt  : string = ""
    interviewerName   : string = ""
    interviewFormat   : "phone" | "video" | "onsite" = "video"
    status            : "draft" | "submitted" | "interviewing" | "completed" = "draft"
    notes             : string = ""
    pendingId         : string = ""
  }

  trait ApplicantPipelineAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.PipelineIntakeBrowse",
      appName: "ATSRecruiting",
      navItems: [{ label: "Openings", href: "/openings", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "user-plus" }, { label: "Interviews", href: "/interviews", icon: "calendar" }, { label: "Offers", href: "/offers", icon: "file-text" }],
      searchEvent: "PIPELINE_SEARCH",
      notifications: [],
      notificationClickEvent: "PIPELINE_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: PIPELINE_SEARCH
      NOTIFY_CLICK: PIPELINE_NOTIFICATIONS_OPEN
    }
  }

  trait PipelineIntakeBrowse = ApplicantForm.traits.ApplicationIntakeBrowse -> ApplicationIntake {
    listens {
      PipelineIntakePersistor.INTAKE_CREATED -> INIT
      PipelineIntakePersistor.INTAKE_UPDATED -> INIT
      PipelineIntakePersistor.INTAKE_DELETED -> INIT
    }
  }
  trait PipelineIntakeCreate = ApplicantForm.traits.ApplicationIntakeCreate -> ApplicationIntake {
    listens {
      PipelineIntakeBrowse.CREATE -> CREATE
      CREATE { id : string, row : ApplicationIntake }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }
  trait PipelineIntakeEdit = ApplicantForm.traits.ApplicationIntakeEdit -> ApplicationIntake {
    listens {
      PipelineIntakeBrowse.REQUEST_EDIT -> EDIT
      EDIT { id : string, row : ApplicationIntake }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }
  trait PipelineIntakeDelete = ApplicantForm.traits.ApplicationIntakeDelete -> ApplicationIntake {
    listens {
      PipelineIntakeBrowse.REQUEST_DELETE -> DELETE
      DELETE { id : string, row : ApplicationIntake }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }
  trait PipelineIntakePersistor = ApplicantForm.traits.ApplicationIntakePersistor -> ApplicationIntake {
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      PipelineIntakeCreate.SAVE          -> DO_CREATE
      PipelineIntakeEdit.SAVE            -> DO_UPDATE
      PipelineIntakeDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/pipeline" as PipelinePage -> ApplicantPipelineAppLayout, PipelineIntakeBrowse, PipelineIntakeCreate, PipelineIntakeEdit, PipelineIntakeDelete, PipelineIntakePersistor
}

orbital ApplicantOrbital {
  uses AppShell  from "std/behaviors/std-app-layout"
  uses Applicant from "std/behaviors/std-applicant"

  entity Applicant [persistent: applicants] {
    id         : string!
    name       : string!
    email      : string = ""
    phone      : string = ""
    jobId      : string = ""
    resumeUrl  : string = ""
    stage      : "applied" | "screening" | "interview" | "offer" | "hired" | "rejected" = "applied"
    notes      : string = ""
    appliedAt  : string = ""
  }

  trait ApplicantAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.ApplicantList",
      appName: "ATSRecruiting",
      navItems: [{ label: "Openings", href: "/openings", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "user-plus" }, { label: "Interviews", href: "/interviews", icon: "calendar" }, { label: "Offers", href: "/offers", icon: "file-text" }],
      searchEvent: "APPLICANT_SEARCH",
      notifications: [],
      notificationClickEvent: "APPLICANT_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: APPLICANT_SEARCH
      NOTIFY_CLICK: APPLICANT_NOTIFICATIONS_OPEN
    }
  }

  trait ApplicantList = Applicant.traits.ApplicantPipeline {
    config: {
      title: "Applicants"
    }
  }

  page "/applicants" as ApplicantsPage -> ApplicantAppLayout, ApplicantList
}

orbital InterviewScheduleOrbital {
  uses AppShell      from "std/behaviors/std-app-layout"
  uses InterviewSlot from "std/behaviors/std-interview-slot"

  entity InterviewSlot [persistent: interviewslots] {
    id              : string!
    applicantId     : string!
    applicantName   : string = ""
    interviewerName : string = ""
    scheduledAt     : string!
    durationMinutes : number = 60
    format          : "phone" | "video" | "onsite" = "video"
    status          : "scheduled" | "completed" | "cancelled" | "no_show" = "scheduled"
    notes           : string = ""
  }

  trait InterviewScheduleAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.InterviewScheduleList",
      appName: "ATSRecruiting",
      navItems: [{ label: "Openings", href: "/openings", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "user-plus" }, { label: "Interviews", href: "/interviews", icon: "calendar" }, { label: "Offers", href: "/offers", icon: "file-text" }],
      searchEvent: "INTERVIEW_SEARCH",
      notifications: [],
      notificationClickEvent: "INTERVIEW_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: INTERVIEW_SEARCH
      NOTIFY_CLICK: INTERVIEW_NOTIFICATIONS_OPEN
    }
  }

  trait InterviewScheduleList = InterviewSlot.traits.InterviewSlotSchedule {
    config: {
      title: "Interview Schedule"
    }
  }

  page "/interviews" as InterviewSchedulePage -> InterviewScheduleAppLayout, InterviewScheduleList
}

orbital OfferLetterFlowOrbital {
  uses AppShell    from "std/behaviors/std-app-layout"
  uses OfferLetter from "std/behaviors/std-offer-letter"

  entity OfferLetter [persistent: offerletters] {
    id             : string!
    applicantId    : string!
    applicantName  : string = ""
    position       : string = ""
    salary         : number = 0
    startDate      : string = ""
    status         : "draft" | "sent" | "accepted" | "rejected" | "expired" = "draft"
    expiresAt      : string = ""
    notes          : string = ""
  }

  trait OfferLetterAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.OfferLetterList",
      appName: "ATSRecruiting",
      navItems: [{ label: "Openings", href: "/openings", icon: "briefcase" }, { label: "Pipeline", href: "/pipeline", icon: "user-plus" }, { label: "Interviews", href: "/interviews", icon: "calendar" }, { label: "Offers", href: "/offers", icon: "file-text" }],
      searchEvent: "OFFER_SEARCH",
      notifications: [],
      notificationClickEvent: "OFFER_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: OFFER_SEARCH
      NOTIFY_CLICK: OFFER_NOTIFICATIONS_OPEN
    }
  }

  trait OfferLetterList = OfferLetter.traits.OfferLetterFlow {
    config: {
      title: "Offer Letters"
    }
  }

  page "/offers" as OfferLetterPage -> OfferLetterAppLayout, OfferLetterList
}
