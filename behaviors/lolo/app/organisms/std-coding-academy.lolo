app std-coding-academy "2.0.0"
"Coding academy: sequence/build/event programming challenges (game-shell) plus a student progress dashboard."

orbital SeqChallengeOrbital {
  uses YouTube from "std/behaviors/std-service-youtube"
  uses Storage from "std/behaviors/std-service-storage"

  entity SeqChallenge [runtime] {
    id : string!
    title : string!
    difficulty : string = "easy"
    score : number = 0
    completed : boolean = false
    level : number = 1
    videoId : string = ""
  }

  type SeqChallengeLoaded     = Event SeqChallenge                  "Fired when SeqChallenge finishes loading"
  type SeqChallengeLoadFailed = Event { message : string }          "Fired when SeqChallenge fails to load"

  ;; Game keeps game-shell chrome (game-hud, game-menu, sequencer-board,
  ;; game-over-screen). The deviation from AppShell is intentional: these
  ;; UI components are domain-specific to programming-puzzle gameplay.
  trait SeqChallengeSequencerGame -> SeqChallenge [interaction, collection] {
    initial: menu
    state menu {
      INIT -> menu
        (set @entity.level 1)
        (set @entity.score 0)
        (fetch SeqChallenge { emit: { success: "SeqChallengeLoaded", failure: "SeqChallengeLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Sequencer Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
      START -> playing
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, "@trait.SeqLessonVideo", { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "typography", variant: "h3", content: "Sequencer Challenge" }, { type: "typography", variant: "body", color: "muted", content: "Arrange the action blocks in the correct order." }, { type: "button", label: "Complete", action: "COMPLETE", variant: "primary", icon: "check" }] }] }] }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Sequencer Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
    }
    emits {
      SeqChallengeLoaded
      SeqChallengeLoadFailed
    }
    listens {
      SeqChallengeLoadFailed { message : string }
    }
  }

  ;; Inline lesson video — bound from std-service-youtube. The atom's render
  ;; is a card placeholder until a real youtube-embed pattern lands; the
  ;; uiTrait slot points at SeqLessonPlayer for domain framing.
  trait SeqLessonVideo = YouTube.traits.ServiceYoutubeYoutube {
    config: {
      videoId: "@entity.videoId",
      autoplay: false,
      controls: true,
      uiTrait: "@trait.SeqLessonPlayer"
    }
    listens {
      ServiceYoutubeYoutubeReady { videoId : string }
      ServiceYoutubeYoutubeFailed { error : string, code : string }
    }
  }

  trait SeqLessonPlayer [interaction, instance] {
    config {
      videoId : string = ""
    }
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", align: "center", children: [{ type: "icon", name: "video" }, { type: "typography", variant: "caption", color: "muted", content: "Lesson video" }, { type: "typography", variant: "body", content: "@config.videoId" }] }] })
    }
  }

  ;; Inline storage call for game-state save/load.
  trait SeqProgressStorage = Storage.traits.ServiceStorageStorage {
    config: {
      uiTrait: "@trait.SeqProgressForm",
      bucket: "coding-academy-progress",
      acl: "private",
      maxSize: 102400,
      allowedMimeTypes: ["application/json"]
    }
    listens {
      SeqProgressForm.UPLOAD -> UPLOAD
    }
  }

  trait SeqProgressForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "save" }, { type: "button", label: "Save Progress", action: "UPLOAD", variant: "ghost", icon: "save" }] })
    }
    emits {
      UPLOAD -> external { source : string, file : string }
    }
  }

  page "/sequencer" as SequencerPage -> SeqChallengeSequencerGame, SeqLessonVideo, SeqLessonPlayer, SeqProgressStorage, SeqProgressForm
}

orbital BuildChallengeOrbital {
  entity BuildChallenge [runtime] {
    id : string!
    title : string!
    difficulty : string = "easy"
    score : number = 0
    completed : boolean = false
    level : number = 1
  }

  type BuildChallengeLoaded     = Event BuildChallenge                  "Fired when BuildChallenge finishes loading"
  type BuildChallengeLoadFailed = Event { message : string }            "Fired when BuildChallenge fails to load"

  ;; Game keeps game-shell chrome (game-hud, game-menu, builder-board,
  ;; game-over-screen). Deviation from AppShell is intentional.
  trait BuildChallengeBuilderGame -> BuildChallenge [interaction, collection] {
    initial: menu
    state menu {
      INIT -> menu
        (set @entity.level 1)
        (set @entity.score 0)
        (fetch BuildChallenge { emit: { success: "BuildChallengeLoaded", failure: "BuildChallengeLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Builder Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
      START -> playing
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "typography", variant: "h3", content: "Builder Challenge" }, { type: "typography", variant: "body", color: "muted", content: "Drag components into the slots to build the solution." }, { type: "button", label: "Complete", action: "COMPLETE", variant: "primary", icon: "check" }] }] }] }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Builder Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
    }
    emits {
      BuildChallengeLoaded
      BuildChallengeLoadFailed
    }
    listens {
      BuildChallengeLoadFailed { message : string }
    }
  }

  page "/builder" -> BuildChallengeBuilderGame
}

orbital EventChallengeOrbital {
  entity EventChallenge [runtime] {
    id : string!
    title : string!
    difficulty : string = "easy"
    score : number = 0
    completed : boolean = false
    level : number = 1
  }

  type EventChallengeLoaded     = Event EventChallenge                  "Fired when EventChallenge finishes loading"
  type EventChallengeLoadFailed = Event { message : string }            "Fired when EventChallenge fails to load"

  ;; Game keeps game-shell chrome (game-hud, game-menu, event-handler-board,
  ;; game-over-screen). Deviation from AppShell is intentional.
  trait EventChallengeEventHandlerGame -> EventChallenge [interaction, collection] {
    initial: menu
    state menu {
      INIT -> menu
        (set @entity.level 1)
        (set @entity.score 0)
        (fetch EventChallenge { emit: { success: "EventChallengeLoaded", failure: "EventChallengeLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Event Handler Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
      START -> playing
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", align: "center", children: [{ type: "typography", variant: "h3", content: "Event Handler Challenge" }, { type: "typography", variant: "body", color: "muted", content: "Wire the event handlers to fire on the right triggers." }, { type: "button", label: "Complete", action: "COMPLETE", variant: "primary", icon: "check" }] }] }] }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Event Handler Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
    }
    emits {
      EventChallengeLoaded
      EventChallengeLoadFailed
    }
    listens {
      EventChallengeLoadFailed { message : string }
    }
  }

  page "/events" -> EventChallengeEventHandlerGame
}

orbital StudentProgressOrbital {
  uses AppShell     from "std/behaviors/std-app-layout"
  uses Modal        from "std/behaviors/std-modal"
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Browse       from "std/behaviors/std-browse"
  uses Stats        from "std/behaviors/std-stats"
  uses Graphs       from "std/behaviors/std-graphs"

  entity StudentProgress [persistent: studentprogresses] {
    id : string!
    student : string = ""
    lessonsCompleted : number = 0
    avgScore : number = 0
    streak : number = 0
    totalTimeMinutes : number = 0
    progressPct : number = 0
    day : string = ""
    lastActiveAt : string = ""
  }

  trait StudentProgressAppLayout = AppShell.traits.AppLayout {
    config: {
      contentTrait: "@trait.StudentProgressCatalog",
      appName: "Coding Academy",
      navItems: [{ label: "Sequencer", href: "/sequencer", icon: "list-ordered" }, { label: "Builder", href: "/builder", icon: "wrench" }, { label: "Events", href: "/events", icon: "zap" }, { label: "Progress", href: "/progress", icon: "trending-up" }],
      searchEvent: "STUDENT_PROGRESS_SEARCH",
      notifications: [],
      notificationClickEvent: "STUDENT_PROGRESS_NOTIFICATIONS_OPEN"
    }
    events {
      SEARCH: STUDENT_PROGRESS_SEARCH
      NOTIFY_CLICK: STUDENT_PROGRESS_NOTIFICATIONS_OPEN
    }
  }

  ;; Page-chrome trait: header + stats + graphs + browse list.
  trait StudentProgressCatalog [interaction, instance] {
    initial: composing
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [
          { type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [
            { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
              { type: "icon", name: "trending-up" },
              { type: "typography", content: "Progress", variant: "h2" }
            ]}
          ]},
          { type: "divider" },
          "@trait.StudentProgressStats",
          "@trait.StudentProgressGraphs",
          { type: "divider" },
          "@trait.StudentProgressBrowseList"
        ]})
      STUDENT_PROGRESS_SEARCH -> composing
      STUDENT_PROGRESS_NOTIFICATIONS_OPEN -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [
          { type: "icon", name: "bell" },
          { type: "typography", variant: "h3", content: "No notifications" },
          { type: "typography", variant: "caption", color: "muted", content: "You're all caught up." },
          { type: "button", label: "Back to progress", action: "INIT", variant: "ghost" }
        ]})
    }
    listens {
      StudentProgressAppLayout.STUDENT_PROGRESS_SEARCH -> STUDENT_PROGRESS_SEARCH
      StudentProgressAppLayout.STUDENT_PROGRESS_NOTIFICATIONS_OPEN -> STUDENT_PROGRESS_NOTIFICATIONS_OPEN
      STUDENT_PROGRESS_SEARCH { value : string }
      STUDENT_PROGRESS_NOTIFICATIONS_OPEN { id : string }
    }
  }

  trait StudentProgressStats = Stats.traits.StatsItemStats {
    config: {
      title: "Student Progress",
      metrics: [
        { label: "Lessons Completed", aggregation: "sum", field: "lessonsCompleted", icon: "check-circle", variant: "success", format: "number" },
        { label: "Average Score",     aggregation: "avg", field: "avgScore",         icon: "star",         variant: "primary", format: "number" },
        { label: "Streak",            aggregation: "max", field: "streak",           icon: "flame",        variant: "warning", format: "number", suffix: "d" },
        { label: "Total Time",        aggregation: "sum", field: "totalTimeMinutes", icon: "clock",        variant: "info",    format: "number", suffix: "m" }
      ]
    }
    listens {
      StudentProgressBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait StudentProgressGraphs = Graphs.traits.GraphItemGraph {
    config: {
      chartType: "line",
      dateField: "day",
      valueField: "progressPct",
      title: "Progress over time",
      subtitle: "Daily progress %",
      height: 280,
      showLegend: true
    }
    listens {
      StudentProgressBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait StudentProgressBrowseList = Browse.traits.BrowseItemBrowse -> StudentProgress {
    config: {
      fields: [
        { name: "student",          label: "Student",            variant: "h4", icon: "user" },
        { name: "lessonsCompleted", label: "Lessons Completed",  variant: "body" },
        { name: "avgScore",         label: "Avg Score",          variant: "badge" },
        { name: "streak",           label: "Streak",             variant: "body" },
        { name: "lastActiveAt",     label: "Last Active",        variant: "caption", format: "date" }
      ],
      itemActions: [
        { label: "View",   event: "VIEW",   variant: "ghost" },
        { label: "Edit",   event: "EDIT",   variant: "ghost" },
        { label: "Delete", event: "DELETE", variant: "danger" }
      ],
      cols: 1,
      gap: "sm"
    }
    listens {
      StudentProgressPersistor.PROGRESS_UPDATED -> INIT
      StudentProgressPersistor.PROGRESS_DELETED -> INIT
    }
  }

  trait StudentProgressView = Modal.traits.ModalRecordModal -> StudentProgress {
    config: { icon: "eye", title: "View Progress", mode: "edit", fields: ["student", "lessonsCompleted", "avgScore", "streak", "totalTimeMinutes", "progressPct", "lastActiveAt"] }
    events { OPEN: VIEW }
    listens {
      StudentProgressBrowseList.VIEW -> VIEW
      VIEW { id : string, row : StudentProgress }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait StudentProgressEdit = Modal.traits.ModalRecordModal -> StudentProgress {
    config: { icon: "edit", title: "Edit Progress", mode: "edit", fields: ["student", "lessonsCompleted", "avgScore", "streak", "totalTimeMinutes", "progressPct", "lastActiveAt"] }
    events { OPEN: EDIT }
    listens {
      StudentProgressBrowseList.EDIT -> EDIT
      EDIT { id : string, row : StudentProgress }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait StudentProgressDelete = Confirmation.traits.ConfirmActionConfirmation -> StudentProgress {
    config: { icon: "alert-triangle", title: "Delete Progress", alertMessage: "This action cannot be undone.", confirmLabel: "Delete" }
    events { REQUEST: DELETE, CONFIRM: CONFIRM_DELETE }
    listens {
      StudentProgressBrowseList.DELETE -> DELETE
      DELETE { id : string, row : StudentProgress }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait StudentProgressPersistor -> StudentProgress [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_UPDATE -> idle
        (persist update StudentProgress @payload.data { emit: { success: "PROGRESS_UPDATED" } })
      DO_DELETE -> idle
        (persist delete StudentProgress @payload.id { emit: { success: "PROGRESS_DELETED" } })
    }
    emits {
      PROGRESS_UPDATED -> external { id : string }
      PROGRESS_DELETED -> external { id : string }
    }
    listens {
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      StudentProgressEdit.SAVE             -> DO_UPDATE
      StudentProgressDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/progress" -> StudentProgressAppLayout, StudentProgressCatalog, StudentProgressStats, StudentProgressGraphs, StudentProgressBrowseList, StudentProgressView, StudentProgressEdit, StudentProgressDelete, StudentProgressPersistor
}
