app std-coding-academy "1.0.0"
"Coding academy: sequence/build/event programming challenges with student progress."

orbital SeqChallengeOrbital {
  entity SeqChallenge [runtime] {
    id : string!
    title : string!
    difficulty : string = "easy"
    score : number = 0
    completed : boolean = false
    level : number = 1
  }

  type SeqChallengeLoaded     = Event SeqChallenge                  "Fired when SeqChallenge finishes loading"
  type SeqChallengeLoadFailed = Event { message : string } "Fired when SeqChallenge fails to load"
  trait SeqChallengeSequencerGame -> SeqChallenge [interaction, collection] {
    initial: menu
    state menu {
      INIT -> menu
        (set @entity.level 1)
        (set @entity.score 0)
        (fetch SeqChallenge { emit: { success: "SeqChallengeLoaded", failure: "SeqChallengeLoadFailed" } })
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Sequencer Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
      START -> playing
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "game-hud", stats: [{ label: "Score", value: "@entity.score" }, { label: "Level", value: "@entity.level" }] }, { type: "sequencer-board", entity: "SeqChallenge", completeEvent: "COMPLETE" }] }] })
      NAVIGATE -> menu
    }
    state playing {
      COMPLETE -> complete
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-over-screen", title: "Well Done!", menuItems: [{ label: "Play Again", event: "RESTART", variant: "primary" }] }] })
    }
    state complete {
      RESTART -> menu
        (render-ui main { type: "game-shell", appName: "Coding Academy", showTopBar: true, children: [{ type: "game-menu", title: "Sequencer Challenge", menuItems: [{ label: "Start", event: "START", variant: "primary" }] }] })
    }
emits {
SeqChallengeLoaded
      SeqChallengeLoadFailed
    }

        listens {
      SeqChallengeLoadFailed { message : string }
    }
  }
  page "/sequencer" as SequencerPage -> SeqChallengeSequencerGame
}
orbital BuildChallengeOrbital {
  entity BuildChallenge [runtime] {
    id : string!
    title : string!
    difficulty : string = "easy"
    score : number = 0
    completed : boolean = false
    level : number = 1
  }

  type BuildChallengeLoaded     = Event BuildChallenge                  "Fired when BuildChallenge finishes loading"
  type BuildChallengeLoadFailed = Event { message : string } "Fired when BuildChallenge fails to load"
  trait BuildChallengeBuilderGame -> BuildChallenge [interaction, collection] {
    initial: menu
