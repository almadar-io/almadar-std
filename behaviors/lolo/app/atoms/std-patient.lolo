app std-patient "1.0.0"
"std-patient — patient record management with PHI handling, consent gating, and status lifecycle. Listens for SET_STATUS so std-lifecycle can drive transitions."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital PatientOrbital {
  entity Patient [persistent: patients] {
    id              : string!
    firstName       : string!
    lastName        : string!
    dateOfBirth     : string = ""
    consentType     : "standard" | "research" | "parental" | "minor" = "standard"
    mrn             : string = ""
    primaryProvider : string = ""
    status          : "active" | "inactive" | "deceased" = "active"
    createdAt       : string = ""
    updatedAt       : string = ""
  }

  type PatientLoaded        = Event { data : [Patient] }                "Fired when the patient collection finishes loading"
  type PatientLoadFailed    = Event { error : string, code : string }   "Fired when the patient collection fails to load"
  type PatientUpdated       = Event { row : Patient }                   "Fired after a patient row's status persists"
  type PatientUpdateFailed  = Event { error : string, code : string }   "Fired when a patient row's status update fails to persist"

  trait PatientManage -> Patient [interaction, collection] {
    config {
      title : string = "Patients"
        @label "Section title"
        @description "Heading shown above the patient list"
        @tier "presentation"
      fields : [FieldSpec] = [
        { name: "firstName",       label: "First name",  variant: "caption" },
        { name: "lastName",        label: "Last name",   variant: "caption" },
        { name: "mrn",             label: "MRN",         variant: "caption" },
        { name: "primaryProvider", label: "Provider",    variant: "caption" },
        { name: "consentType",     label: "Consent",     variant: "badge"   },
        { name: "status",          label: "Status",      variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Patient entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",       event: "OPEN_PATIENT",    variant: "primary", icon: "arrow-right" },
        { label: "Deactivate", event: "DEACTIVATE",      variant: "danger",  icon: "x" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each patient row"
        @tier "presentation"
      consentTypesRequired : [string] = ["hipaa", "treatment"]
        @label "Consent types required"
        @description "Required consent forms before patient enters active status. Compose std-audit-capture for logging."
        @tier "domain"
        @synonyms "consent forms, authorization, signed agreements"
      parentalConsentMinorThresholdYears : number = 18
        @label "Parental consent age (years)"
        @description "Below this age, parental consent is required in addition to the patient's own."
        @tier "domain"
        @synonyms "minor age, adult of majority"
      phiDisclosureLogRequired : boolean = true
        @label "Log PHI disclosures"
        @description "Record every disclosure of protected health information for HIPAA audit."
        @tier "domain"
        @synonyms "audit log, HIPAA log"
      breakGlassRolesAllowed : [string] = ["emergency-physician", "oncall-attending"]
        @label "Break-glass roles"
        @description "Roles permitted to override consent in emergencies; always audited."
        @tier "domain"
        @synonyms "emergency override, BTG access"
      defaultRecordRetentionYears : number = 7
        @label "Record retention (years)"
        @description "Years to retain a closed patient record before deletion (compose std-lifecycle + std-data-erasure)."
        @tier "domain"
      pseudonymizeOnExport : boolean = true
        @label "Pseudonymize on export"
        @description "Replace identifiers with stable hashes when exporting for research or analytics."
        @tier "domain"
      mrnFormat : string = "MRN-####-####"
        @label "MRN format pattern"
        @description "Display format for the medical record number; # = digit."
        @tier "domain"
      dependentLinkagePolicy : "none" | "household" | "guardian" = "household"
        @label "Dependent linkage"
        @description "How dependent patients (children, wards) link to a primary contact."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Patient { emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading patients…" }] })
      PatientLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total patients", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "Active", value: "0", icon: "check-circle" }, { type: "stat-display", label: "New this month", value: "0", icon: "user-plus" }, { type: "stat-display", label: "Pending consent", value: "0", icon: "alert-triangle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      PatientLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_PATIENT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.firstName @payload.row.firstName)
        (set @entity.lastName @payload.row.lastName)
        (set @entity.dateOfBirth @payload.row.dateOfBirth)
        (set @entity.consentType @payload.row.consentType)
        (set @entity.mrn @payload.row.mrn)
        (set @entity.primaryProvider @payload.row.primaryProvider)
        (set @entity.status @payload.row.status)
        (set @entity.createdAt @payload.row.createdAt)
        (set @entity.updatedAt @payload.row.updatedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "user" }, { type: "typography", content: "@entity.firstName", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "MRN" }, { type: "typography", variant: "body", content: "@entity.mrn" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Date of birth" }, { type: "typography", variant: "body", content: "@entity.dateOfBirth" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Provider" }, { type: "typography", variant: "body", content: "@entity.primaryProvider" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Consent" }, { type: "typography", variant: "body", content: "@entity.consentType" }] }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Deactivate", variant: "danger", action: "DEACTIVATE", actionPayload: { id: "@entity.id" } }] }] })
      DEACTIVATE -> loading
        (set @entity.id @payload.id)
        (set @entity.status "inactive")
        (persist update Patient @entity { emit: { success: "PatientUpdated", failure: "PatientUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deactivating patient…" }] })
      PatientUpdated -> loading
        (fetch Patient { emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
      PatientUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update Patient @entity { emit: { success: "PatientUpdated", failure: "PatientUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating patient status…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Patient { emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading patients…" }] })
      DEACTIVATE -> loading
        (set @entity.id @payload.id)
        (set @entity.status "inactive")
        (persist update Patient @entity { emit: { success: "PatientUpdated", failure: "PatientUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deactivating patient…" }] })
    }
    state error {
      INIT -> loading
        (fetch Patient { emit: { success: "PatientLoaded", failure: "PatientLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_PATIENT { id : string!, row : Patient }
      CLOSE_VIEW   { }
      DEACTIVATE   { id : string! }
      PatientLoaded       { data : [Patient] }
      PatientLoadFailed   { error : string, code : string }
      PatientUpdated      { row : Patient }
      PatientUpdateFailed { error : string, code : string }
    }
    listens {
      OPEN_PATIENT { id : string!, row : Patient }
      CLOSE_VIEW   { }
      DEACTIVATE   { id : string! }
      SET_STATUS   { entityId : string!, newStatus : string! }
      PatientLoaded       { data : [Patient] }
      PatientLoadFailed   { error : string, code : string }
      PatientUpdated      { row : Patient }
      PatientUpdateFailed { error : string, code : string }
    }
  }
  page "/patients" as PatientManagePage -> PatientManage
}
