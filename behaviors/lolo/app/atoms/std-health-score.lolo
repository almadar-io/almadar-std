app std-health-score "1.1.0"
"std-health-score — customer success health score primitive surfacing churn risk via composite usage/support/engagement signals. Lists health scores in `browsing`; opens detail in `viewing_single` with Recalculate / Assign CSM actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

orbital HealthScoreOrbital {
  entity HealthScore [persistent: healthscores] {
    id                : string!
    customerId        : string!
    customerName      : string = ""
    score             : number = 50
    tier              : "green" | "yellow" | "red" = "green"
    usageScore        : number = 0
    supportScore      : number = 0
    engagementScore   : number = 0
    trend             : "improving" | "stable" | "declining" = "stable"
    lastCalculatedAt  : string = ""
    assignedCsm       : string = ""
    pendingId         : string = ""
  }

  type HealthScoreLoaded     = Event { data : [HealthScore], totalCount : number } "Fired when the health score collection finishes loading"
  type HealthScoreLoadFailed = Event { message : string }                          "Fired when the health score collection fails to load"

  trait HealthScoreDashboard -> HealthScore [interaction, collection] {
    config {
      title       : string   = "Customer Health Scores"
      fields      : [object] = [
        { name: "customerName", label: "Customer", variant: "caption" },
        { name: "score",        label: "Score",    variant: "badge"   },
        { name: "tier",         label: "Tier",     variant: "badge"   },
        { name: "usageScore",   label: "Usage",    variant: "caption" },
        { name: "supportScore", label: "Support",  variant: "caption" },
        { name: "trend",        label: "Trend",    variant: "badge"   },
        { name: "assignedCsm",  label: "CSM",      variant: "caption" }
      ]
      itemActions : [object] = [
        { label: "Open",        event: "OPEN_SCORE",   variant: "primary",   icon: "arrow-right" },
        { label: "Recalculate", event: "RECALCULATE",  variant: "secondary" }
      ]
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading health scores…" }] })
      HealthScoreLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "activity" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total customers", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "Green tier", value: "62%", icon: "smile" }, { type: "stat-display", label: "At risk (red)", value: "8", icon: "alert-triangle" }, { type: "stat-display", label: "30d trend", value: "+4.2%", icon: "trending-up" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      HealthScoreLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.message" })
    }
    state browsing {
      OPEN_SCORE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.customerId @payload.row.customerId)
        (set @entity.customerName @payload.row.customerName)
        (set @entity.score @payload.row.score)
        (set @entity.tier @payload.row.tier)
        (set @entity.usageScore @payload.row.usageScore)
        (set @entity.supportScore @payload.row.supportScore)
        (set @entity.engagementScore @payload.row.engagementScore)
        (set @entity.trend @payload.row.trend)
        (set @entity.lastCalculatedAt @payload.row.lastCalculatedAt)
        (set @entity.assignedCsm @payload.row.assignedCsm)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "activity" }, { type: "typography", content: "@entity.customerName", variant: "h3" }, { type: "badge", label: "@entity.tier", variant: "primary" }, { type: "badge", label: "@entity.trend", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Customer ID" }, { type: "typography", variant: "body", content: "@entity.customerId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Assigned CSM" }, { type: "typography", variant: "body", content: "@entity.assignedCsm" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Composite", value: "@entity.score", icon: "activity" }, { type: "stat-display", label: "Usage", value: "@entity.usageScore", icon: "bar-chart" }, { type: "stat-display", label: "Support", value: "@entity.supportScore", icon: "life-buoy" }, { type: "stat-display", label: "Engagement", value: "@entity.engagementScore", icon: "users" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Recalculate", variant: "primary", action: "RECALCULATE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Assign CSM", variant: "secondary", action: "ASSIGN_CSM", actionPayload: { id: "@entity.id" } }] }] })
      RECALCULATE -> loading
        (set @entity.id @payload.id)
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Recalculating health score…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading health scores…" }] })
      RECALCULATE -> loading
        (set @entity.id @payload.id)
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Recalculating health score…" }] })
      ASSIGN_CSM -> loading
        (set @entity.id @payload.id)
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Assigning CSM…" }] })
    }
    state error {
      INIT -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_SCORE            { id : string!, row : HealthScore }
      CLOSE_VIEW            { }
      RECALCULATE           { id : string! }
      ASSIGN_CSM            { id : string! }
      HealthScoreLoaded     { data : [HealthScore], totalCount : number }
      HealthScoreLoadFailed { message : string }
    }
    listens {
      OPEN_SCORE            { id : string!, row : HealthScore }
      CLOSE_VIEW            { }
      RECALCULATE           { id : string! }
      ASSIGN_CSM            { id : string! }
      HealthScoreLoaded     { data : [HealthScore], totalCount : number }
      HealthScoreLoadFailed { message : string }
    }
  }
  page "/health-scores" as HealthScorePage -> HealthScoreDashboard
}
