app std-health-score "1.0.0"
"std-health-score — Customer success health score primitive surfacing churn risk via composite usage/support/engagement signals."

orbital HealthScoreOrbital {
  entity HealthScore [persistent: healthscores] {
    id                : string!
    customerId        : string!
    customerName      : string = ""
    score             : number = 50
    tier              : "green" | "yellow" | "red" = "green"
    usageScore        : number = 0
    supportScore      : number = 0
    engagementScore   : number = 0
    trend             : "improving" | "stable" | "declining" = "stable"
    lastCalculatedAt  : string = ""
    assignedCsm       : string = ""
    pendingId         : string = ""
  }

  type HealthScoreLoaded     = Event { data : [HealthScore], totalCount : number } "Fired when the health score collection finishes loading"
  type HealthScoreLoadFailed = Event { message : string }                          "Fired when the health score collection fails to load"

  trait HealthScoreDashboard -> HealthScore [interaction, collection] {
    config {
      title : string = "Customer Health Scores"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading health scores…" }] })
      HealthScoreLoaded -> viewing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "activity" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "customerName", label: "Customer", variant: "caption" }, { name: "score", label: "Score", variant: "badge" }, { name: "tier", label: "Tier", variant: "badge" }, { name: "usageScore", label: "Usage", variant: "caption" }, { name: "supportScore", label: "Support", variant: "caption" }, { name: "trend", label: "Trend", variant: "badge" }, { name: "assignedCsm", label: "CSM", variant: "caption" }, { name: "lastCalculatedAt", label: "Updated", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "View", event: "VIEW", variant: "secondary" }, { label: "Edit", event: "EDIT", variant: "secondary" }, { label: "Recalculate", event: "RECALCULATE", variant: "primary" }, { label: "Assign CSM", event: "ASSIGN_CSM", variant: "ghost" }] }] })
      HealthScoreLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.message" })
    }
    state viewing {
      REFRESH -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Refreshing health scores…" }] })
      SEARCH -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Searching health scores…" }] })
      FILTER_TIER -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Filtering by tier…" }] })
      FILTER_TREND -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Filtering by trend…" }] })
      VIEW -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Viewing health score" })
      EDIT -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Editing health score" })
      RECALCULATE -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Recalculation triggered" })
      ASSIGN_CSM -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Assigning CSM" })
    }
    state error {
      INIT -> loading
        (fetch HealthScore { emit: { success: "HealthScoreLoaded", failure: "HealthScoreLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      VIEW                  { id : string!, source : string }
      EDIT                  { id : string!, source : string }
      RECALCULATE           { id : string!, source : string }
      ASSIGN_CSM            { id : string!, source : string }
      HealthScoreLoaded     { data : [HealthScore], totalCount : number }
      HealthScoreLoadFailed { message : string }
    }
    listens {
      VIEW                  { id : string! }
      EDIT                  { id : string! }
      RECALCULATE           { id : string! }
      ASSIGN_CSM            { id : string! }
      REFRESH               { source : string }
      SEARCH                { query : string }
      FILTER_TIER           { tier : string }
      FILTER_TREND          { trend : string }
      HealthScoreLoaded     { data : [HealthScore], totalCount : number }
      HealthScoreLoadFailed { message : string }
    }
  }
  page "/health-scores" as HealthScorePage -> HealthScoreDashboard
}
