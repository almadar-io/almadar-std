app std-response-collector "1.0.0"
"std-response-collector — survey per-respondent answer accumulator. ResponseCollect fetches Response rows on INIT, lists them, and on SUBMIT persists a new answer row tagged with surveyId, respondentId, questionId, and serialized answerJson, emitting ResponseSubmitted for cross-trait listeners."

orbital ResponseCollectorOrbital {
  entity Response [persistent: responses] {
    id           : string!
    surveyId     : string!
    respondentId : string!
    questionId   : string!
    answerJson   : string
    submittedAt  : string
  }

  type ResponseLoaded        = Event { data : [Response] }                "Fired when the response collection finishes loading"
  type ResponseLoadFailed    = Event { error : string, code : string }    "Fired when the response collection fails to load"
  type ResponseSubmitted     = Event { row : Response }                   "Fired after a response persists successfully"
  type ResponseSubmitFailed  = Event { error : string, code : string }    "Fired when persisting a response fails"

  trait ResponseCollect -> Response [interaction, collection] {
    config {
      title : string = "Responses"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading responses…" }] })
      ResponseLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@config.title", variant: "h3" }, { type: "data-grid", entity: @payload.data, fields: [{ name: "questionId", label: "Question" }, { name: "respondentId", label: "Respondent" }, { name: "answerJson", label: "Answer" }, { name: "submittedAt", label: "Submitted" }], itemActions: [{ label: "View", event: "SUBMIT", icon: "eye" }] }] })
      ResponseLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      SUBMIT -> submitting
        (set @entity.surveyId @payload.surveyId)
        (set @entity.respondentId @payload.respondentId)
        (set @entity.questionId @payload.questionId)
        (set @entity.answerJson @payload.answerJson)
        (persist create Response @payload.data { emit: { success: "ResponseSubmitted", failure: "ResponseSubmitFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Submitting response…" }] })
    }
    state submitting {
      ResponseSubmitted -> loading
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Refreshing responses…" }] })
      ResponseSubmitFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state error {
      INIT -> loading
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading responses…" }] })
    }
    emits {
      SUBMIT { surveyId : string!, respondentId : string!, questionId : string!, answerJson : string, data : object! }
      ResponseLoaded { data : [Response] }
      ResponseLoadFailed { error : string, code : string }
      ResponseSubmitted { row : Response }
      ResponseSubmitFailed { error : string, code : string }
    }
    listens {
      SUBMIT { surveyId : string!, respondentId : string!, questionId : string!, answerJson : string, data : object! }
      ResponseLoaded { data : [Response] }
      ResponseLoadFailed { error : string, code : string }
      ResponseSubmitted { row : Response }
      ResponseSubmitFailed { error : string, code : string }
    }
  }
  page "/responses/collect" as ResponseCollectPage -> ResponseCollect
}
