app std-response-collector "1.2.0"
"std-response-collector — survey per-respondent answer accumulator. Lists responses; detail offers Resubmit / Delete. Exposes Communication knobs (suppressionListEnabled, gdprConsentRequired, …) for the questionnaire."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital ResponseCollectorOrbital {
  entity Response [persistent: responses] {
    id           : string!
    surveyId     : string!
    respondentId : string!
    questionId   : string!
    answerJson   : string
    submittedAt  : string
  }

  type ResponseLoaded     = Event { data : [Response] }              "Fired when the response collection finishes loading"
  type ResponseLoadFailed = Event { error : string, code : string }  "Fired when the response collection fails to load"

  trait ResponseCollect -> Response [interaction, collection] {
    config {
      title       : string   = "Responses"
        @label "Section title"
        @description "Heading shown above the survey response list"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "questionId",   label: "Question",   variant: "caption" },
        { name: "respondentId", label: "Respondent", variant: "caption" },
        { name: "surveyId",     label: "Survey",     variant: "caption" },
        { name: "answerJson",   label: "Answer",     variant: "caption" },
        { name: "submittedAt",  label: "Submitted",  variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Response entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",   event: "OPEN_RESPONSE",   variant: "primary", icon: "arrow-right" },
        { label: "Delete", event: "DELETE_RESPONSE", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each response row"
        @tier "presentation"
      sendsPerHour              : number  = 500
        @label "Sends per hour"
        @description "Cap on follow-up dispatch volume per hour. v1.2 declarative."
        @tier "domain"
      respectQuietHours         : boolean = true
        @label "Respect quiet hours"
        @description "Suppress follow-up sends during recipient-local quiet hours."
        @tier "domain"
      suppressionListEnabled    : boolean = true
        @label "Honor suppression list"
        @description "Skip respondents on the global suppression / bounce list when dispatching follow-ups."
        @tier "domain"
      frequencyCapPerWeek       : number  = 2
        @label "Frequency cap (per week)"
        @description "Max survey-related touches per respondent per 7-day window."
        @tier "domain"
      gdprConsentRequired       : boolean = true
        @label "GDPR consent required"
        @description "Require survey consent before recording or following up with EU/UK respondents."
        @tier "domain"
      trackOpens                : boolean = false
        @label "Track opens"
        @description "Embed a tracking pixel on outbound survey reminders."
        @tier "domain"
      trackClicks               : boolean = false
        @label "Track clicks"
        @description "Wrap survey links for click attribution on reminder mailings."
        @tier "domain"
      includeUnsubscribeLink    : boolean = true
        @label "Include unsubscribe link"
        @description "Append a CAN-SPAM/GDPR-compliant unsubscribe link to every follow-up."
        @tier "domain"
      physicalAddressFooter     : string  = ""
        @label "Physical address footer"
        @description "CAN-SPAM-required postal address appended to every follow-up."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading responses…" }] })
      ResponseLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-list" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total responses", value: "@payload.data.length", icon: "clipboard-list" }, { type: "stat-display", label: "Completion", value: "84%", icon: "check-circle" }, { type: "stat-display", label: "Respondents", value: "312", icon: "users" }, { type: "stat-display", label: "Surveys", value: "6", icon: "file-text" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      ResponseLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_RESPONSE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.surveyId @payload.row.surveyId)
        (set @entity.respondentId @payload.row.respondentId)
        (set @entity.questionId @payload.row.questionId)
        (set @entity.answerJson @payload.row.answerJson)
        (set @entity.submittedAt @payload.row.submittedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "clipboard-list" }, { type: "typography", content: "@entity.respondentId", variant: "h3" }, { type: "badge", label: "Submitted", variant: "success" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Survey" }, { type: "typography", variant: "body", content: "@entity.surveyId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Question" }, { type: "typography", variant: "body", content: "@entity.questionId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Answer" }, { type: "typography", variant: "body", content: "@entity.answerJson" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Respondent", value: "@entity.respondentId", icon: "user" }, { type: "stat-display", label: "Submitted", value: "@entity.submittedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Resubmit", variant: "primary", action: "RESUBMIT", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Delete", variant: "danger", action: "DELETE_RESPONSE", actionPayload: { id: "@entity.id" } }] }] })
      RESUBMIT -> loading
        (set @entity.id @payload.id)
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Resubmitting response…" }] })
      DELETE_RESPONSE -> loading
        (set @entity.id @payload.id)
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting response…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading responses…" }] })
      RESUBMIT -> loading
        (set @entity.id @payload.id)
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Resubmitting response…" }] })
      DELETE_RESPONSE -> loading
        (set @entity.id @payload.id)
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting response…" }] })
    }
    state error {
      INIT -> loading
        (fetch Response { emit: { success: "ResponseLoaded", failure: "ResponseLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_RESPONSE      { id : string!, row : Response }
      CLOSE_VIEW         { }
      RESUBMIT           { id : string! }
      DELETE_RESPONSE    { id : string! }
      ResponseLoaded     { data : [Response] }
      ResponseLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_RESPONSE      { id : string!, row : Response }
      CLOSE_VIEW         { }
      RESUBMIT           { id : string! }
      DELETE_RESPONSE    { id : string! }
      ResponseLoaded     { data : [Response] }
      ResponseLoadFailed { error : string, code : string }
    }
  }
  page "/responses/collect" as ResponseCollectPage -> ResponseCollect
}
