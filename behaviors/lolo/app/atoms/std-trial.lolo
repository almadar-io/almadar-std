app std-trial "1.2.0"
"std-trial — subscription trial countdown with Convert / Expire / Cancel actions. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes CRM-pattern knobs."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital TrialOrbital {
  entity Trial [persistent: trials] {
    id             : string!
    subscriptionId : string!
    customerId     : string!
    planId         : string!
    startedAt      : string
    expiresAt      : string!
    status         : "active" | "converted" | "expired" | "cancelled" = "active"
    convertedAt    : string
    notifiedAt     : string
  }

  type TrialLoaded       = Event { data : [Trial] }                  "Fired when the trial collection finishes loading"
  type TrialLoadFailed   = Event { error : string, code : string }   "Fired when the trial collection fails to load"
  type TrialUpdated      = Event { row : Trial }                     "Fired after a trial's status persists"
  type TrialUpdateFailed = Event { error : string, code : string }   "Fired when a trial's status update fails to persist"

  trait TrialManage -> Trial [interaction, collection] {
    config {
      title : string = "Trials"
        @label "Section title"
        @description "Heading shown above the trial subscriptions list"
        @tier "presentation"
      fields      : [FieldSpec] = [{ name: "customerId", label: "Customer", variant: "caption" }, { name: "planId", label: "Plan", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "startedAt", label: "Started", variant: "caption" }, { name: "expiresAt", label: "Expires", variant: "caption" }, { name: "convertedAt", label: "Converted", variant: "caption" }, { name: "notifiedAt", label: "Notified", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Trial entity"
        @tier "presentation"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_TRIAL", variant: "primary", icon: "arrow-right" }, { label: "Cancel", event: "CANCEL", variant: "danger", icon: "x" }]
        @label "Row actions"
        @description "Buttons users can click on each trial row"
        @tier "presentation"
      healthScoreThresholdAlert : number = 30
        @label "Health score threshold"
        @description "Trial users below this engagement score get flagged for CSM outreach. Declarative; wire via sibling std-notify."
        @tier "domain"
      renewalReminderDaysBefore : [number] = [7, 3, 1]
        @label "Trial reminder days-before"
        @description "Days before expiresAt to send conversion reminders. Declarative; wire via sibling std-reminder-scheduler."
        @tier "domain"
      archiveInactiveAfterDays : number = 90
        @label "Archive inactive after (days)"
        @description "Days post-expiration before trial record is archived. Declarative; wire via sibling std-lifecycle."
        @tier "domain"
      consentTrackingEnabled : boolean = true
        @label "Track consent"
        @description "Whether to record marketing consent during trial signup. Declarative."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading trials…" }] })
      TrialLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clock" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Active trials", value: "@payload.data.length", icon: "clock" }, { type: "stat-display", label: "Conversion rate", value: "42%", icon: "trending-up" }, { type: "stat-display", label: "Expiring 7d", value: "18", icon: "alert-triangle" }, { type: "stat-display", label: "Converted this mo", value: "31", icon: "check-circle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      TrialLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_TRIAL -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.subscriptionId @payload.row.subscriptionId)
        (set @entity.customerId @payload.row.customerId)
        (set @entity.planId @payload.row.planId)
        (set @entity.startedAt @payload.row.startedAt)
        (set @entity.expiresAt @payload.row.expiresAt)
        (set @entity.status @payload.row.status)
        (set @entity.convertedAt @payload.row.convertedAt)
        (set @entity.notifiedAt @payload.row.notifiedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "clock" }, { type: "typography", content: "@entity.customerId", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Plan" }, { type: "typography", variant: "body", content: "@entity.planId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Subscription" }, { type: "typography", variant: "body", content: "@entity.subscriptionId" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Started", value: "@entity.startedAt", icon: "calendar" }, { type: "stat-display", label: "Expires", value: "@entity.expiresAt", icon: "calendar-clock" }, { type: "stat-display", label: "Converted", value: "@entity.convertedAt", icon: "check-circle" }, { type: "stat-display", label: "Notified", value: "@entity.notifiedAt", icon: "bell" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Convert", variant: "primary", action: "CONVERT", actionPayload: { trialId: "@entity.id", convertedAt: "@entity.expiresAt", row: "@entity" } }, { type: "button", label: "Expire", variant: "secondary", action: "EXPIRE", actionPayload: { trialId: "@entity.id", row: "@entity" } }, { type: "button", label: "Cancel", variant: "danger", action: "CANCEL", actionPayload: { trialId: "@entity.id", row: "@entity" } }] }] })
      CANCEL -> loading
        (set @entity.id @payload.trialId)
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling trial…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update Trial @entity { emit: { success: "TrialUpdated", failure: "TrialUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating trial status…" }] })
      TrialUpdated -> loading
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
      TrialUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading trials…" }] })
      CONVERT -> loading
        (set @entity.id @payload.trialId)
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Converting trial…" }] })
      EXPIRE -> loading
        (set @entity.id @payload.trialId)
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Expiring trial…" }] })
      CANCEL -> loading
        (set @entity.id @payload.trialId)
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling trial…" }] })
    }
    state error {
      INIT -> loading
        (fetch Trial { emit: { success: "TrialLoaded", failure: "TrialLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_TRIAL { id : string!, row : Trial }
      CLOSE_VIEW { }
      CONVERT    { trialId : string!, convertedAt : string!, row : Trial }
      EXPIRE     { trialId : string!, row : Trial }
      CANCEL     { trialId : string!, row : Trial }
      TrialLoaded       { data : [Trial] }
      TrialLoadFailed   { error : string, code : string }
      TrialUpdated      { row : Trial }
      TrialUpdateFailed { error : string, code : string }
    }
    listens {
      OPEN_TRIAL { id : string!, row : Trial }
      CLOSE_VIEW { }
      CONVERT    { trialId : string!, convertedAt : string!, row : Trial }
      EXPIRE     { trialId : string!, row : Trial }
      CANCEL     { trialId : string!, row : Trial }
      SET_STATUS { entityId : string!, newStatus : string! }
      TrialLoaded       { data : [Trial] }
      TrialLoadFailed   { error : string, code : string }
      TrialUpdated      { row : Trial }
      TrialUpdateFailed { error : string, code : string }
    }
  }
  page "/trials/manage" as TrialManagePage -> TrialManage
}
