app std-moderation-rule "1.0.0"
"std-moderation-rule — content moderation policy layer over std-mod-queue with thresholds, auto-actions, appeal + escalation."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital ModerationRuleOrbital {
  entity ModerationRule [persistent: moderation_rules] {
    id          : string!
    name        : string!
    description : string = ""
    appliesTo   : string = ""
    priority    : number = 0
    status      : "active" | "testing" | "archived" = "active"
    createdAt   : string = ""
  }

  type ModerationRuleLoaded     = Event { data : [ModerationRule] }              "Fired when the moderation rule collection finishes loading"
  type ModerationRuleLoadFailed = Event { error : string, code : string }        "Fired when the moderation rule collection fails to load"

  trait ModerationRuleManage -> ModerationRule [interaction, collection] {
    config {
      title       : string   = "Moderation Rules"
        @label "Section title"
        @description "Heading shown above the moderation rules list"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "name",      label: "Rule",      variant: "caption" },
        { name: "appliesTo", label: "Applies to", variant: "caption" },
        { name: "priority",  label: "Priority",  variant: "caption" },
        { name: "status",    label: "Status",    variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Moderation Rule entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_RULE",    variant: "primary", icon: "arrow-right" },
        { label: "Archive", event: "ARCHIVE_RULE", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each rule row"
        @tier "presentation"
      toxicityThreshold : number = 0.85
        @label "Toxicity threshold (0-1)"
        @description "Confidence score above which content is flagged. Lower = more aggressive moderation."
        @tier "domain"
        @synonyms "abuse threshold, content sensitivity"
      autoAction : "flag" | "hide" | "shadow-ban" | "delete" | "ban-user" = "flag"
        @label "Auto action"
        @description "What to do when the rule fires."
        @tier "domain"
        @synonyms "moderation action, enforcement"
      appealWindowHours : number = 48
        @label "Appeal window (hours)"
        @description "Hours a user has to appeal an enforcement action before it becomes permanent."
        @tier "domain"
      repeatOffenderEscalation : "warn" | "tempban" | "ban" = "tempban"
        @label "Repeat-offender escalation"
        @description "Action for users who triggered this rule N times in a rolling window."
        @tier "domain"
        @synonyms "recidivism policy"
      humanReviewThreshold : number = 0.6
        @label "Human review threshold"
        @description "Toxicity score above which content goes to human review queue instead of auto-action. 0 = always human review; 1 = never."
        @tier "domain"
        @synonyms "review queue threshold"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch ModerationRule { emit: { success: "ModerationRuleLoaded", failure: "ModerationRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading moderation rules…" }] })
      ModerationRuleLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "shield" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total rules", value: "@payload.data.length", icon: "shield" }, { type: "stat-display", label: "Active", value: "23", icon: "check-circle" }, { type: "stat-display", label: "Actions today", value: "112", icon: "alert-octagon" }, { type: "stat-display", label: "Appeals open", value: "7", icon: "message-circle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      ModerationRuleLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_RULE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.description @payload.row.description)
        (set @entity.appliesTo @payload.row.appliesTo)
        (set @entity.priority @payload.row.priority)
        (set @entity.status @payload.row.status)
        (set @entity.createdAt @payload.row.createdAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "shield" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Applies to" }, { type: "typography", variant: "body", content: "@entity.appliesTo" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Priority" }, { type: "typography", variant: "body", content: "@entity.priority" }] }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Test", variant: "secondary", action: "TEST_RULE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Archive", variant: "danger", action: "ARCHIVE_RULE", actionPayload: { id: "@entity.id" } }] }] })
      ARCHIVE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch ModerationRule { emit: { success: "ModerationRuleLoaded", failure: "ModerationRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving rule…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch ModerationRule { emit: { success: "ModerationRuleLoaded", failure: "ModerationRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading moderation rules…" }] })
      TEST_RULE -> loading
        (set @entity.id @payload.id)
        (fetch ModerationRule { emit: { success: "ModerationRuleLoaded", failure: "ModerationRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Testing rule…" }] })
      ARCHIVE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch ModerationRule { emit: { success: "ModerationRuleLoaded", failure: "ModerationRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving rule…" }] })
    }
    state error {
      INIT -> loading
        (fetch ModerationRule { emit: { success: "ModerationRuleLoaded", failure: "ModerationRuleLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_RULE                  { id : string!, row : ModerationRule }
      CLOSE_VIEW                 { }
      TEST_RULE                  { id : string!, row : ModerationRule }
      ARCHIVE_RULE               { id : string!, row : ModerationRule }
      ModerationRuleLoaded       { data : [ModerationRule] }
      ModerationRuleLoadFailed   { error : string, code : string }
    }
    listens {
      OPEN_RULE                  { id : string!, row : ModerationRule }
      CLOSE_VIEW                 { }
      TEST_RULE                  { id : string! }
      ARCHIVE_RULE               { id : string! }
      ModerationRuleLoaded       { data : [ModerationRule] }
      ModerationRuleLoadFailed   { error : string, code : string }
    }
  }
  page "/moderation-rules" as ModerationRulePage -> ModerationRuleManage
}
