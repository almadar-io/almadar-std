app std-time-entry "1.0.0"
"std-time-entry — Time tracking line within a timesheet: project/task, hours, date, billable flag, and rate."

orbital TimeEntryOrbital {
  entity TimeEntry [persistent: timeentries] {
    id              : string!
    timesheetId     : string!
    projectId       : string = ""
    projectName     : string = ""
    taskDescription : string!
    workDate        : string!
    hours           : number = 0
    billable        : boolean = false
    hourlyRate      : number = 0
    status          : "draft" | "submitted" | "approved" | "rejected" = "draft"
    notes           : string = ""
    pendingId       : string = ""
  }

  type TimeEntryLoaded     = Event { data : [TimeEntry], totalCount : number } "Fired when the time entry collection finishes loading"
  type TimeEntryLoadFailed = Event { error : string, code : string }           "Fired when the time entry collection fails to load"

  trait TimeEntryLog -> TimeEntry [interaction, collection] {
    config {
      title : string = "Time Entries"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading time entries…" }] })
      TimeEntryLoaded -> viewing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clock" }, { type: "typography", content: "@config.title", variant: "h3" }, { type: "button", label: "Log Time", variant: "primary", action: "CREATE" }] }, { type: "tabs", tabs: [{ id: "active", label: "Active" }, { id: "logged", label: "Logged" }, { id: "approved", label: "Approved" }], defaultActiveTab: "active", variant: "underline" }, { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "timer-display", seconds: 1845, running: true, format: "mm:ss", size: "lg" }, { type: "meter", value: 32, min: 0, max: 40, label: "Weekly Utilization", unit: "h", variant: "linear", thresholds: [{ value: 20, color: "warning" }, { value: 35, color: "success" }] }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "projectName", label: "Project", variant: "caption" }, { name: "taskDescription", label: "Task", variant: "caption" }, { name: "workDate", label: "Date", variant: "caption" }, { name: "hours", label: "Hours", variant: "caption" }, { name: "billable", label: "Billable", variant: "badge" }, { name: "hourlyRate", label: "Rate", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "View", event: "VIEW", variant: "secondary" }, { label: "Edit", event: "EDIT", variant: "secondary" }, { label: "Delete", event: "REQUEST_DELETE", variant: "danger" }] }] })
      TimeEntryLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing {
      REFRESH -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Refreshing time entries…" }] })
      SEARCH -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Searching time entries…" }] })
      FILTER_BILLABLE -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Filtering time entries…" }] })
      FILTER_STATUS -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Filtering time entries…" }] })
      CREATE -> viewing
        (render-ui main { type: "alert", variant: "info", message: "Logging new time entry" })
      VIEW -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Viewing time entry" })
      EDIT -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Editing time entry" })
      REQUEST_DELETE -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "warning", message: "Delete requested" })
    }
    state error {
      INIT -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      VIEW                 { id : string!, source : string }
      EDIT                 { id : string!, source : string }
      CREATE               { source : string }
      REQUEST_DELETE       { id : string!, source : string }
      TimeEntryLoaded      { data : [TimeEntry], totalCount : number }
      TimeEntryLoadFailed  { error : string, code : string }
    }
    listens {
      VIEW                 { id : string! }
      EDIT                 { id : string! }
      CREATE               { source : string }
      REQUEST_DELETE       { id : string! }
      REFRESH              { source : string }
      SEARCH               { query : string }
      FILTER_BILLABLE      { billable : boolean }
      FILTER_STATUS        { status : string }
      TimeEntryLoaded      { data : [TimeEntry], totalCount : number }
      TimeEntryLoadFailed  { error : string, code : string }
    }
  }
  page "/time-entries" as TimeEntryPage -> TimeEntryLog
}
