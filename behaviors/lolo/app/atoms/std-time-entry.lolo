app std-time-entry "1.1.0"
"std-time-entry — time tracking line within a timesheet: project/task, hours, date, billable flag, rate. Lists entries in `browsing`; opens entry detail in `viewing_single` with Delete action. Agents tune the list shape via `config.fields` + `config.itemActions`."

orbital TimeEntryOrbital {
  entity TimeEntry [persistent: timeentries] {
    id              : string!
    timesheetId     : string!
    projectId       : string = ""
    projectName     : string = ""
    taskDescription : string!
    workDate        : string!
    hours           : number = 0
    billable        : boolean = false
    hourlyRate      : number = 0
    status          : "draft" | "submitted" | "approved" | "rejected" = "draft"
    notes           : string = ""
    pendingId       : string = ""
  }

  type TimeEntryLoaded     = Event { data : [TimeEntry], totalCount : number } "Fired when the time entry collection finishes loading"
  type TimeEntryLoadFailed = Event { error : string, code : string }           "Fired when the time entry collection fails to load"

  trait TimeEntryLog -> TimeEntry [interaction, collection] {
    config {
      title : string = "Time Entries"
      fields      : [object] = [{ name: "projectName", label: "Project", variant: "caption" }, { name: "taskDescription", label: "Task", variant: "caption" }, { name: "workDate", label: "Date", variant: "caption" }, { name: "hours", label: "Hours", variant: "caption" }, { name: "billable", label: "Billable", variant: "badge" }, { name: "hourlyRate", label: "Rate", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }]
      itemActions : [object] = [{ label: "Open", event: "OPEN_ENTRY", variant: "primary", icon: "arrow-right" }, { label: "Delete", event: "REQUEST_DELETE", variant: "danger" }]
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading time entries…" }] })
      TimeEntryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clock" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total entries", value: "@payload.data.length", icon: "list" }, { type: "stat-display", label: "Hours this week", value: "32", icon: "clock" }, { type: "stat-display", label: "Billable %", value: "78%", icon: "dollar-sign" }, { type: "stat-display", label: "Avg per day", value: "6.4h", icon: "trending-up" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      TimeEntryLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_ENTRY -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.timesheetId @payload.row.timesheetId)
        (set @entity.projectId @payload.row.projectId)
        (set @entity.projectName @payload.row.projectName)
        (set @entity.taskDescription @payload.row.taskDescription)
        (set @entity.workDate @payload.row.workDate)
        (set @entity.hours @payload.row.hours)
        (set @entity.hourlyRate @payload.row.hourlyRate)
        (set @entity.status @payload.row.status)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "clock" }, { type: "typography", content: "@entity.projectName", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Task" }, { type: "typography", variant: "body", content: "@entity.taskDescription" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Timesheet" }, { type: "typography", variant: "body", content: "@entity.timesheetId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Hours", value: "@entity.hours", icon: "clock" }, { type: "stat-display", label: "Rate", value: "@entity.hourlyRate", icon: "dollar-sign" }, { type: "stat-display", label: "Date", value: "@entity.workDate", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Delete", variant: "danger", action: "REQUEST_DELETE", actionPayload: { id: "@entity.id" } }] }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting time entry…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading time entries…" }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting time entry…" }] })
    }
    state error {
      INIT -> loading
        (fetch TimeEntry { emit: { success: "TimeEntryLoaded", failure: "TimeEntryLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ENTRY           { id : string!, row : TimeEntry }
      CLOSE_VIEW           { }
      REQUEST_DELETE       { id : string! }
      TimeEntryLoaded      { data : [TimeEntry], totalCount : number }
      TimeEntryLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_ENTRY           { id : string!, row : TimeEntry }
      CLOSE_VIEW           { }
      REQUEST_DELETE       { id : string! }
      TimeEntryLoaded      { data : [TimeEntry], totalCount : number }
      TimeEntryLoadFailed  { error : string, code : string }
    }
  }
  page "/time-entries" as TimeEntryPage -> TimeEntryLog
}
