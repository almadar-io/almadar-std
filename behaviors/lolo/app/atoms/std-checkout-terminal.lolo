app std-checkout-terminal "1.0.0"
"std-checkout-terminal — retail POS checkout terminal. Owns a CheckoutSession entity (one row per active register session) and a single terminal trait that loads open sessions, renders cart + total + status in a data-grid, and supports tender / void session actions."

orbital CheckoutSessionOrbital {
  entity CheckoutSession [persistent: checkoutsessions] {
    id            : string!
    terminalId    : string!
    cashierId     : string = ""
    cashierName   : string = ""
    cartItemsJson : string = ""
    subtotal      : number = 0
    tax           : number = 0
    total         : number = 0
    paymentMethod : "cash" | "card" | "gift_card" | "split" = "card"
    status        : "open" | "paying" | "completed" | "voided" = "open"
    openedAt      : string = ""
    completedAt   : string = ""
  }

  type CheckoutSessionLoaded     = Event { data : [CheckoutSession] }        "Fired when the checkout session collection finishes loading"
  type CheckoutSessionLoadFailed = Event { error : string, code : string }   "Fired when the checkout session collection fails to load"

  trait CheckoutSessionTerminal -> CheckoutSession [interaction, collection] {
    config {
      title : string = "Terminals"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch CheckoutSession { emit: { success: "CheckoutSessionLoaded", failure: "CheckoutSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner", size: "md" }, { type: "typography", variant: "caption", color: "muted", content: "Loading terminals…" }] })
      CheckoutSessionLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "carousel", items: [{ src: "https://picsum.photos/seed/feat1/800/300", alt: "Featured promo", caption: "Buy 2 get 1 free" }, { src: "https://picsum.photos/seed/feat2/800/300", alt: "Seasonal sale", caption: "Holiday bundle 20% off" }, { src: "https://picsum.photos/seed/feat3/800/300", alt: "New arrival", caption: "Just landed in store" }], autoPlay: true, autoPlayInterval: 5000, showDots: true, showArrows: true, loop: true }, { type: "pricing-grid", plans: [{ name: "Single", price: "$4.99", description: "One item", features: ["Standard pricing"], action: { label: "Add", href: "#tender" } }, { name: "Bundle", price: "$12.99", description: "Three items", features: ["10% off", "Free wrap"], action: { label: "Add", href: "#tender" }, highlighted: true }, { name: "Family", price: "$24.99", description: "Six items", features: ["20% off", "Free wrap", "Priority pickup"], action: { label: "Add", href: "#tender" } }] }, { type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "typography", variant: "caption", color: "muted", content: "Qty" }, { type: "number-stepper", value: 1, min: 1, max: 99, step: 1, size: "md", action: "TENDER_PAYMENT" }, { type: "combo-counter", combo: 3, multiplier: 2, streak: 5, size: "md" }, { type: "resource-bar", resources: [{ id: "subtotal", label: "Subtotal", value: 42.50, icon: "wallet" }, { id: "tax", label: "Tax", value: 3.40, icon: "percent" }, { id: "total", label: "Total", value: 45.90, icon: "credit-card" }], size: "md" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "action-button", label: "Tender", icon: "credit-card", variant: "primary", size: "md", hotkey: "T" }, { type: "choice-button", text: "Cash", index: 1 }, { type: "choice-button", text: "Card", index: 2, selected: true }, { type: "choice-button", text: "Gift", index: 3 }, { type: "control-button", label: "Hold", icon: "pause", size: "md", shape: "round", variant: "secondary" }, { type: "d-pad", size: "md", includeDiagonals: false }] }, { type: "action-palette", actions: [{ id: "discount", label: "Discount", category: "promo" }, { id: "refund", label: "Refund", category: "ops" }, { id: "void", label: "Void", category: "ops" }, { id: "split", label: "Split", category: "tender" }], size: "md", label: "Cashier actions", allowDuplicates: true }, { type: "side-panel", title: "Cart", isOpen: true, onClose: "VOID_SESSION", closeEvent: "VOID_SESSION", position: "right", width: "w-96", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", variant: "h4", content: "Items in cart" }, { type: "typography", variant: "caption", color: "muted", content: "Cart side panel preview" }] }] }, { type: "toast-slot", variant: "success", title: "Payment ready", duration: 4000 }, { type: "floating-action-button", icon: "zap", action: "TENDER_PAYMENT", variant: "primary", label: "Quick sale", position: "bottom-right" }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "terminalId", label: "Terminal", variant: "caption" }, { name: "cashierName", label: "Cashier", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "total", label: "Total", variant: "caption" }, { name: "openedAt", label: "Opened", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Tender", event: "TENDER_PAYMENT", variant: "primary" }, { label: "Void", event: "VOID_SESSION", variant: "danger" }] }] })
      CheckoutSessionLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      TENDER_PAYMENT -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Payment tendered" })
      VOID_SESSION -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Session voided" })
    }
    state error {
      INIT -> loading
        (fetch CheckoutSession { emit: { success: "CheckoutSessionLoaded", failure: "CheckoutSessionLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      TENDER_PAYMENT { id : string! }
      VOID_SESSION   { id : string! }
      CheckoutSessionLoaded     { data : [CheckoutSession] }
      CheckoutSessionLoadFailed { error : string, code : string }
    }
    listens {
      TENDER_PAYMENT { id : string! }
      VOID_SESSION   { id : string! }
      CheckoutSessionLoaded     { data : [CheckoutSession] }
      CheckoutSessionLoadFailed { error : string, code : string }
    }
  }
  page "/terminals" as CheckoutSessionPage -> CheckoutSessionTerminal
}
