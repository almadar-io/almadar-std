app std-offer-letter "1.0.0"
"std-offer-letter — formal job offer primitive. Owns an OfferLetter entity (applicant, position, salary, start date, acceptance status). Browses offers in a data-grid with Send / Revoke actions."

orbital OfferLetterOrbital {
  entity OfferLetter [persistent: offerletters] {
    id             : string!
    applicantId    : string!
    applicantName  : string = ""
    position       : string = ""
    salary         : number = 0
    startDate      : string = ""
    status         : "draft" | "sent" | "accepted" | "rejected" | "expired" = "draft"
    expiresAt      : string = ""
    notes          : string = ""
  }

  type OfferLetterLoaded     = Event { data : [OfferLetter] }            "Fired when the offer letter collection finishes loading"
  type OfferLetterLoadFailed = Event { error : string, code : string }   "Fired when the offer letter collection fails to load"

  trait OfferLetterFlow -> OfferLetter [interaction, collection] {
    config {
      title : string = "Offer Letters"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch OfferLetter { emit: { success: "OfferLetterLoaded", failure: "OfferLetterLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading offer letters…" }] })
      OfferLetterLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "applicantName", label: "Applicant", variant: "caption" }, { name: "position", label: "Position", variant: "caption" }, { name: "salary", label: "Salary", variant: "caption" }, { name: "startDate", label: "Start Date", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Send", event: "SEND_OFFER", variant: "primary" }, { label: "Revoke", event: "REVOKE_OFFER", variant: "danger" }] }] })
      OfferLetterLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      SEND_OFFER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Offer sent" })
      REVOKE_OFFER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Offer revoked" })
    }
    state error {
      INIT -> loading
        (fetch OfferLetter { emit: { success: "OfferLetterLoaded", failure: "OfferLetterLoadFailed" } })
    }
    emits {
      SEND_OFFER             { id : string! }
      REVOKE_OFFER           { id : string! }
      OfferLetterLoaded      { data : [OfferLetter] }
      OfferLetterLoadFailed  { error : string, code : string }
    }
    listens {
      SEND_OFFER             { id : string! }
      REVOKE_OFFER           { id : string! }
      OfferLetterLoaded      { data : [OfferLetter] }
      OfferLetterLoadFailed  { error : string, code : string }
    }
  }
  page "/offers" as OfferLetterPage -> OfferLetterFlow
}
