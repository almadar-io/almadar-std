app std-portfolio "1.0.0"
"std-portfolio — portfolio rebalancing, tax-lot accounting, and drift policies for trading apps."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital PortfolioOrbital {
  entity Portfolio [persistent: portfolios] {
    id                    : string!
    name                  : string!
    ownerAccountId        : string!
    currentValueUSD       : number
    targetAllocationJson  : string = "{}"
    driftBps              : number = 0
    status                : "active" | "rebalancing" | "frozen" | "archived" = "active"
    lastRebalancedAt      : string
    createdAt             : string
  }

  type PortfolioLoaded        = Event { data : [Portfolio] }              "Fired when the portfolio collection finishes loading"
  type PortfolioLoadFailed    = Event { error : string, code : string }   "Fired when the portfolio collection fails to load"

  trait PortfolioManage -> Portfolio [interaction, collection] {
    config {
      title : string = "Portfolios"
        @label "Section title"
        @description "Heading shown above the portfolio list"
        @tier "presentation"
      fields      : [FieldSpec] = [{ name: "name", label: "Name", variant: "caption" }, { name: "ownerAccountId", label: "Owner", variant: "caption" }, { name: "currentValueUSD", label: "Value (USD)", variant: "caption" }, { name: "driftBps", label: "Drift (bps)", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "lastRebalancedAt", label: "Last Rebalanced", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Portfolio entity"
        @tier "presentation"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_PORTFOLIO", variant: "primary", icon: "arrow-right" }, { label: "Rebalance", event: "REBALANCE", variant: "primary", icon: "refresh-cw" }]
        @label "Row actions"
        @description "Buttons users can click on each portfolio row"
        @tier "presentation"
      rebalancingFrequencyDays : number = 90
        @label "Rebalance cadence (days)"
        @description "How often the portfolio gets auto-rebalanced toward target allocation."
        @tier "domain"
        @synonyms "rebalance interval"
      driftThresholdBps : number = 500
        @label "Drift threshold (bps)"
        @description "Maximum drift from target allocation before triggering rebalance."
        @tier "domain"
        @synonyms "drift band, rebalance trigger"
      taxLotMethod : "FIFO" | "LIFO" | "HIFO" | "specific-lot" = "FIFO"
        @label "Tax lot method"
        @description "Cost-basis accounting method when selling shares."
        @tier "domain"
        @synonyms "lot accounting, cost basis"
      dividendReinvestPolicy : "auto" | "cash" | "specified-fund" = "auto"
        @label "Dividend reinvestment"
        @description "What to do with dividends: reinvest into source security, take as cash, or sweep to a designated fund."
        @tier "domain"
        @synonyms "DRIP, dividend handling"
      cashBufferPct : number = 5
        @label "Cash buffer (%)"
        @description "Minimum percentage held in cash for liquidity needs and rebalancing."
        @tier "domain"
        @synonyms "cash reserve"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Portfolio { emit: { success: "PortfolioLoaded", failure: "PortfolioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading portfolios…" }] })
      PortfolioLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "pie-chart" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total portfolios", value: "@payload.data.length", icon: "pie-chart" }, { type: "stat-display", label: "AUM", value: "$8.4M", icon: "dollar-sign" }, { type: "stat-display", label: "Needs rebalance", value: "6", icon: "alert-triangle" }, { type: "stat-display", label: "Rebalanced today", value: "3", icon: "refresh-cw" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      PortfolioLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_PORTFOLIO -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.ownerAccountId @payload.row.ownerAccountId)
        (set @entity.currentValueUSD @payload.row.currentValueUSD)
        (set @entity.targetAllocationJson @payload.row.targetAllocationJson)
        (set @entity.driftBps @payload.row.driftBps)
        (set @entity.status @payload.row.status)
        (set @entity.lastRebalancedAt @payload.row.lastRebalancedAt)
        (set @entity.createdAt @payload.row.createdAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "pie-chart" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Owner" }, { type: "typography", variant: "body", content: "@entity.ownerAccountId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Target Allocation" }, { type: "typography", variant: "body", content: "@entity.targetAllocationJson" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Current Value", value: "@entity.currentValueUSD", icon: "dollar-sign" }, { type: "stat-display", label: "Drift (bps)", value: "@entity.driftBps", icon: "trending-up" }, { type: "stat-display", label: "Last Rebalanced", value: "@entity.lastRebalancedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Rebalance", variant: "primary", action: "REBALANCE", actionPayload: { id: "@entity.id", row: "@entity" } }, { type: "button", label: "Freeze", variant: "secondary", action: "FREEZE", actionPayload: { id: "@entity.id", row: "@entity" } }, { type: "button", label: "Archive", variant: "danger", action: "ARCHIVE", actionPayload: { id: "@entity.id", row: "@entity" } }] }] })
      REBALANCE -> loading
        (set @entity.id @payload.id)
        (fetch Portfolio { emit: { success: "PortfolioLoaded", failure: "PortfolioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Rebalancing portfolio…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Portfolio { emit: { success: "PortfolioLoaded", failure: "PortfolioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading portfolios…" }] })
      REBALANCE -> loading
        (set @entity.id @payload.id)
        (fetch Portfolio { emit: { success: "PortfolioLoaded", failure: "PortfolioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Rebalancing portfolio…" }] })
      FREEZE -> loading
        (set @entity.id @payload.id)
        (fetch Portfolio { emit: { success: "PortfolioLoaded", failure: "PortfolioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Freezing portfolio…" }] })
      ARCHIVE -> loading
        (set @entity.id @payload.id)
        (fetch Portfolio { emit: { success: "PortfolioLoaded", failure: "PortfolioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving portfolio…" }] })
    }
    state error {
      INIT -> loading
        (fetch Portfolio { emit: { success: "PortfolioLoaded", failure: "PortfolioLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_PORTFOLIO { id : string!, row : Portfolio }
      CLOSE_VIEW     { }
      REBALANCE      { id : string!, row : Portfolio }
      FREEZE         { id : string!, row : Portfolio }
      ARCHIVE        { id : string!, row : Portfolio }
      PortfolioLoaded       { data : [Portfolio] }
      PortfolioLoadFailed   { error : string, code : string }
    }
    listens {
      OPEN_PORTFOLIO { id : string!, row : Portfolio }
      CLOSE_VIEW     { }
      REBALANCE      { id : string!, row : Portfolio }
      FREEZE         { id : string!, row : Portfolio }
      ARCHIVE        { id : string!, row : Portfolio }
      PortfolioLoaded       { data : [Portfolio] }
      PortfolioLoadFailed   { error : string, code : string }
    }
  }
  page "/portfolios/manage" as PortfolioManagePage -> PortfolioManage
}
