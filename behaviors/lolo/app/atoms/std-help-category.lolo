app std-help-category "1.2.0"
"std-help-category — help center category directory grouping articles (Getting Started, Billing, API Reference…). Listens for SET_STATUS so std-lifecycle can drive transitions. Exposes Content/Knowledge knobs (visibilityScope, enabledLocales, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital HelpCategoryOrbital {
  entity HelpCategory [persistent: helpcategories] {
    id           : string!
    name         : string!
    slug         : string!
    description  : string = ""
    icon         : string = "folder"
    sortOrder    : number = 0
    articleCount : number = 0
    status       : "published" | "draft" | "archived" = "draft"
    updatedAt    : string = ""
    pendingId    : string = ""
  }

  type HelpCategoryLoaded       = Event { data : [HelpCategory], totalCount : number } "Fired when the help category collection finishes loading"
  type HelpCategoryLoadFailed   = Event { message : string }                            "Fired when the help category collection fails to load"
  type HelpCategoryUpdated      = Event { row : HelpCategory }                          "Fired after a help category's status persists (SET_STATUS / lifecycle)"
  type HelpCategoryUpdateFailed = Event { message : string }                            "Fired when a help category's status update fails to persist"

  trait HelpCategoryDirectory -> HelpCategory [interaction, collection] {
    config {
      title       : string   = "Help Categories"
        @label "Section title"
        @description "Heading shown above the help center categories"
        @tier "customization"
      fields      : [FieldSpec] = [
        { name: "name",         label: "Name",     variant: "caption" },
        { name: "slug",         label: "Slug",     variant: "caption" },
        { name: "articleCount", label: "Articles", variant: "caption" },
        { name: "sortOrder",    label: "Order",    variant: "caption" },
        { name: "status",       label: "Status",   variant: "badge"   },
        { name: "updatedAt",    label: "Updated",  variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Help Category entity"
        @tier "customization"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_CATEGORY", variant: "primary", icon: "arrow-right" },
        { label: "Archive", event: "ARCHIVE",       variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each category row"
        @tier "customization"
      visibilityScope          : "public" | "internal" | "customer" = "public"
        @label "Visibility scope"
        @description "Who can see published categories: public web, internal staff, signed-in customers."
        @tier "essential"
      scheduledPublishEnabled  : boolean = false
        @label "Scheduled publish"
        @description "Allow authors to schedule category publish. v1.2 declarative."
        @tier "customization"
      keepVersions             : number  = 5
        @label "Versions to retain"
        @description "Number of revisions to keep per category."
        @tier "customization"
      allowRollback            : boolean = true
        @label "Allow rollback"
        @description "Permit reverting a category to a prior version."
        @tier "customization"
      seoEnabled               : boolean = true
        @label "SEO meta enabled"
        @description "Emit canonical + meta description tags on the category index page."
        @tier "customization"
      enabledLocales           : [string] = ["en"]
        @label "Enabled locales"
        @description "Locales the category name/description can be translated into."
        @tier "customization"
      defaultLocale            : string  = "en"
        @label "Default locale"
        @description "Locale used when no translation matches the reader's language."
        @tier "customization"
      draftAutosaveSeconds     : number  = 30
        @label "Draft autosave interval (s)"
        @description "Seconds between draft autosaves in the editor."
        @tier "advanced"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch HelpCategory { emit: { success: "HelpCategoryLoaded", failure: "HelpCategoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading help categories…" }] })
      HelpCategoryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "folder" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total categories", value: "@payload.data.length", icon: "folder" }, { type: "stat-display", label: "Published", value: "18", icon: "check-circle" }, { type: "stat-display", label: "Articles", value: "246", icon: "book-open" }, { type: "stat-display", label: "Avg per category", value: "13", icon: "bar-chart" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      HelpCategoryLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.message" })
    }
    state browsing {
      OPEN_CATEGORY -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.slug @payload.row.slug)
        (set @entity.description @payload.row.description)
        (set @entity.icon @payload.row.icon)
        (set @entity.sortOrder @payload.row.sortOrder)
        (set @entity.articleCount @payload.row.articleCount)
        (set @entity.status @payload.row.status)
        (set @entity.updatedAt @payload.row.updatedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "folder" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Slug" }, { type: "typography", variant: "body", content: "@entity.slug" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Icon" }, { type: "typography", variant: "body", content: "@entity.icon" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Articles", value: "@entity.articleCount", icon: "book-open" }, { type: "stat-display", label: "Sort order", value: "@entity.sortOrder", icon: "list-ordered" }, { type: "stat-display", label: "Updated", value: "@entity.updatedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Publish", variant: "primary", action: "PUBLISH", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Archive", variant: "danger", action: "ARCHIVE", actionPayload: { id: "@entity.id" } }] }] })
      ARCHIVE -> loading
        (set @entity.id @payload.id)
        (fetch HelpCategory { emit: { success: "HelpCategoryLoaded", failure: "HelpCategoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving category…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update HelpCategory @entity { emit: { success: "HelpCategoryUpdated", failure: "HelpCategoryUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating category status…" }] })
      HelpCategoryUpdated -> loading
        (fetch HelpCategory { emit: { success: "HelpCategoryLoaded", failure: "HelpCategoryLoadFailed" } })
      HelpCategoryUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.message" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch HelpCategory { emit: { success: "HelpCategoryLoaded", failure: "HelpCategoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading help categories…" }] })
      PUBLISH -> loading
        (set @entity.id @payload.id)
        (fetch HelpCategory { emit: { success: "HelpCategoryLoaded", failure: "HelpCategoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Publishing category…" }] })
      ARCHIVE -> loading
        (set @entity.id @payload.id)
        (fetch HelpCategory { emit: { success: "HelpCategoryLoaded", failure: "HelpCategoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving category…" }] })
    }
    state error {
      INIT -> loading
        (fetch HelpCategory { emit: { success: "HelpCategoryLoaded", failure: "HelpCategoryLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_CATEGORY            { id : string!, row : HelpCategory }
      CLOSE_VIEW               { }
      PUBLISH                  { id : string! }
      ARCHIVE                  { id : string! }
      HelpCategoryLoaded       { data : [HelpCategory], totalCount : number }
      HelpCategoryLoadFailed   { message : string }
      HelpCategoryUpdated      { row : HelpCategory }
      HelpCategoryUpdateFailed { message : string }
    }
    listens {
      OPEN_CATEGORY            { id : string!, row : HelpCategory }
      CLOSE_VIEW               { }
      PUBLISH                  { id : string! }
      ARCHIVE                  { id : string! }
      SET_STATUS               { entityId : string!, newStatus : string! }
      HelpCategoryLoaded       { data : [HelpCategory], totalCount : number }
      HelpCategoryLoadFailed   { message : string }
      HelpCategoryUpdated      { row : HelpCategory }
      HelpCategoryUpdateFailed { message : string }
    }
  }
  page "/help-categories" as HelpCategoryPage -> HelpCategoryDirectory
}
