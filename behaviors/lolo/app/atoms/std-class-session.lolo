app std-class-session "1.1.0"
"std-class-session — scheduled fitness/yoga/dance class session. Lists sessions in `browsing`; opens session detail in `viewing_single` with Start / Cancel actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

orbital ClassSessionOrbital {
  entity ClassSession [persistent: classsessions] {
    id              : string!
    className       : string!
    instructorName  : string = ""
    startTime       : string!
    durationMinutes : number = 60
    capacity        : number = 0
    bookedCount     : number = 0
    location        : string = ""
    status          : "scheduled" | "in_progress" | "completed" | "cancelled" = "scheduled"
    notes           : string = ""
  }

  type ClassSessionLoaded     = Event { data : [ClassSession] }            "Fired when the class-session collection finishes loading"
  type ClassSessionLoadFailed = Event { error : string, code : string }    "Fired when the class-session collection fails to load"

  trait ClassSessionSchedule -> ClassSession [interaction, collection] {
    config {
      title       : string   = "Class Sessions"
        @label "Section title"
        @description "Heading shown above the class schedule"
      fields      : [object] = [
        { name: "className",      label: "Class",      variant: "caption" },
        { name: "instructorName", label: "Instructor", variant: "caption" },
        { name: "startTime",      label: "Start",      variant: "caption" },
        { name: "capacity",       label: "Capacity",   variant: "badge"   },
        { name: "bookedCount",    label: "Booked",     variant: "badge"   },
        { name: "status",         label: "Status",     variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Class Session entity"
      itemActions : [object] = [
        { label: "Open",   event: "OPEN_SESSION", variant: "primary", icon: "arrow-right" },
        { label: "Cancel", event: "CANCEL_CLASS", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each session row"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch ClassSession { emit: { success: "ClassSessionLoaded", failure: "ClassSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading class sessions…" }] })
      ClassSessionLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Sessions", value: "@payload.data.length", icon: "calendar" }, { type: "stat-display", label: "Today", value: "12", icon: "clock" }, { type: "stat-display", label: "Capacity used", value: "78%", icon: "users" }, { type: "stat-display", label: "Cancelled", value: "2", icon: "x-circle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      ClassSessionLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_SESSION -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.className @payload.row.className)
        (set @entity.instructorName @payload.row.instructorName)
        (set @entity.startTime @payload.row.startTime)
        (set @entity.durationMinutes @payload.row.durationMinutes)
        (set @entity.capacity @payload.row.capacity)
        (set @entity.bookedCount @payload.row.bookedCount)
        (set @entity.location @payload.row.location)
        (set @entity.status @payload.row.status)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "calendar" }, { type: "typography", content: "@entity.className", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Instructor" }, { type: "typography", variant: "body", content: "@entity.instructorName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Location" }, { type: "typography", variant: "body", content: "@entity.location" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Start", value: "@entity.startTime", icon: "clock" }, { type: "stat-display", label: "Duration", value: "@entity.durationMinutes", icon: "timer" }, { type: "stat-display", label: "Booked", value: "@entity.bookedCount", icon: "users" }, { type: "stat-display", label: "Capacity", value: "@entity.capacity", icon: "user-plus" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Start Class", variant: "primary", action: "START_CLASS", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Cancel", variant: "danger", action: "CANCEL_CLASS", actionPayload: { id: "@entity.id" } }] }] })
      CANCEL_CLASS -> loading
        (set @entity.id @payload.id)
        (fetch ClassSession { emit: { success: "ClassSessionLoaded", failure: "ClassSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling class…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch ClassSession { emit: { success: "ClassSessionLoaded", failure: "ClassSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading class sessions…" }] })
      START_CLASS -> loading
        (set @entity.id @payload.id)
        (fetch ClassSession { emit: { success: "ClassSessionLoaded", failure: "ClassSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Starting class…" }] })
      CANCEL_CLASS -> loading
        (set @entity.id @payload.id)
        (fetch ClassSession { emit: { success: "ClassSessionLoaded", failure: "ClassSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling class…" }] })
    }
    state error {
      INIT -> loading
        (fetch ClassSession { emit: { success: "ClassSessionLoaded", failure: "ClassSessionLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_SESSION            { id : string!, row : ClassSession }
      CLOSE_VIEW              { }
      START_CLASS             { id : string! }
      CANCEL_CLASS            { id : string! }
      ClassSessionLoaded      { data : [ClassSession] }
      ClassSessionLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_SESSION            { id : string!, row : ClassSession }
      CLOSE_VIEW              { }
      START_CLASS             { id : string! }
      CANCEL_CLASS            { id : string! }
      ClassSessionLoaded      { data : [ClassSession] }
      ClassSessionLoadFailed  { error : string, code : string }
    }
  }
  page "/class-sessions" as ClassSessionPage -> ClassSessionSchedule
}
