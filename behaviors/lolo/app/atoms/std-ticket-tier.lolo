app std-ticket-tier "1.1.0"
"std-ticket-tier — event ticket pricing tiers (VIP, general, early-bird) with quantity tracking. Lists tiers in `browsing`; opens detail in `viewing_single` with Update / Sell / Close actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital TicketTierOrbital {
  entity TicketTier [persistent: tickettiers] {
    id             : string!
    eventId        : string!
    name           : string!
    price          : number!
    currency       : string = "USD"
    quantityTotal  : number!
    quantitySold   : number! = 0
    availableFrom  : string
    availableUntil : string
    status         : "available" | "sold-out" | "closed" = "available"
  }

  type TicketTierLoaded      = Event { data : [TicketTier] }              "Fired when the ticket-tier collection finishes loading"
  type TicketTierLoadFailed  = Event { error : string, code : string }    "Fired when the ticket-tier collection fails to load"

  trait TicketTierManage -> TicketTier [interaction, collection] {
    config {
      title : string = "Ticket Tiers"
        @label "Section title"
        @description "Heading shown above the ticket pricing tiers"
        @tier "customization"
      fields      : [FieldSpec] = [{ name: "name", label: "Tier", variant: "badge" }, { name: "price", label: "Price", variant: "caption" }, { name: "currency", label: "Currency", variant: "badge" }, { name: "quantityTotal", label: "Total", variant: "caption" }, { name: "quantitySold", label: "Sold", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Ticket Tier entity"
        @tier "advanced"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_TIER", variant: "primary", icon: "arrow-right" }, { label: "Close", event: "CLOSE", variant: "danger", icon: "x" }]
        @label "Row actions"
        @description "Buttons users can click on each tier row"
        @tier "customization"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading ticket tiers…" }] })
      TicketTierLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "ticket" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total tiers", value: "@payload.data.length", icon: "ticket" }, { type: "stat-display", label: "Gross sales", value: "$184,200", icon: "dollar-sign" }, { type: "stat-display", label: "Sold seats", value: "2,840", icon: "users" }, { type: "stat-display", label: "Sell-through", value: "73%", icon: "trending-up" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      TicketTierLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_TIER -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.eventId @payload.row.eventId)
        (set @entity.name @payload.row.name)
        (set @entity.price @payload.row.price)
        (set @entity.currency @payload.row.currency)
        (set @entity.quantityTotal @payload.row.quantityTotal)
        (set @entity.quantitySold @payload.row.quantitySold)
        (set @entity.availableFrom @payload.row.availableFrom)
        (set @entity.availableUntil @payload.row.availableUntil)
        (set @entity.status @payload.row.status)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "ticket" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Event" }, { type: "typography", variant: "body", content: "@entity.eventId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Available from" }, { type: "typography", variant: "body", content: "@entity.availableFrom" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Available until" }, { type: "typography", variant: "body", content: "@entity.availableUntil" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Price", value: "@entity.price", icon: "dollar-sign" }, { type: "stat-display", label: "Currency", value: "@entity.currency", icon: "globe" }, { type: "stat-display", label: "Total seats", value: "@entity.quantityTotal", icon: "users" }, { type: "stat-display", label: "Sold", value: "@entity.quantitySold", icon: "check-circle" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Update", variant: "primary", action: "UPDATE", actionPayload: { tierId: "@entity.id", row: "@entity", data: {} } }, { type: "button", label: "Sell", variant: "secondary", action: "SELL", actionPayload: { tierId: "@entity.id", row: "@entity", qty: 1 } }, { type: "button", label: "Close", variant: "danger", action: "CLOSE", actionPayload: { tierId: "@entity.id", row: "@entity" } }] }] })
      UPDATE -> loading
        (set @entity.id @payload.tierId)
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating tier…" }] })
      SELL -> loading
        (set @entity.id @payload.tierId)
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Selling tickets…" }] })
      CLOSE -> loading
        (set @entity.id @payload.tierId)
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Closing tier…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading ticket tiers…" }] })
      UPDATE -> loading
        (set @entity.id @payload.tierId)
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating tier…" }] })
      SELL -> loading
        (set @entity.id @payload.tierId)
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Selling tickets…" }] })
      CLOSE -> loading
        (set @entity.id @payload.tierId)
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Closing tier…" }] })
    }
    state error {
      INIT -> loading
        (fetch TicketTier { emit: { success: "TicketTierLoaded", failure: "TicketTierLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_TIER  { id : string!, row : TicketTier }
      CLOSE_VIEW { }
      UPDATE     { tierId : string!, row : TicketTier, data : object! }
      SELL       { tierId : string!, row : TicketTier, qty : number! }
      CLOSE      { tierId : string!, row : TicketTier }
      TicketTierLoaded      { data : [TicketTier] }
      TicketTierLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_TIER  { id : string!, row : TicketTier }
      CLOSE_VIEW { }
      UPDATE     { tierId : string!, row : TicketTier, data : object! }
      SELL       { tierId : string!, row : TicketTier, qty : number! }
      CLOSE      { tierId : string!, row : TicketTier }
      TicketTierLoaded      { data : [TicketTier] }
      TicketTierLoadFailed  { error : string, code : string }
    }
  }
  page "/tickettiers/manage" as TicketTierManagePage -> TicketTierManage
}
