app std-driver "1.0.0"
"std-driver — fleet driver primitive tracking license info, hire date, status, and currently-assigned vehicle."

orbital DriverOrbital {
  entity Driver [persistent: drivers] {
    id                : string!
    name              : string!
    licenseNumber     : string!
    licenseClass      : "A" | "B" | "C" | "CDL-A" | "CDL-B" | "CDL-C" = "C"
    licenseExpiresAt  : string = ""
    hiredAt           : string = ""
    phone             : string = ""
    email             : string = ""
    status            : "active" | "on-leave" | "terminated" | "suspended" = "active"
    assignedVehicleId : string = ""
    pendingId         : string = ""
  }

  type DriverLoaded     = Event { data : [Driver], totalCount : number } "Fired when the driver collection finishes loading"
  type DriverLoadFailed = Event { error : string, code : string }        "Fired when the driver collection fails to load"

  trait DriverRoster -> Driver [interaction, collection] {
    config {
      title : string = "Drivers"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading drivers…" }] })
      DriverLoaded -> viewing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "truck" }, { type: "typography", content: "@config.title", variant: "h3" }, { type: "status-dot", status: "online", pulse: true, size: "md", label: "On duty" }, { type: "badge", label: "On Duty", variant: "default" }, { type: "button", label: "New Driver", variant: "primary", action: "CREATE" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "name", label: "Name", variant: "caption" }, { name: "licenseNumber", label: "License #", variant: "caption" }, { name: "licenseClass", label: "Class", variant: "badge" }, { name: "licenseExpiresAt", label: "Expires", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "assignedVehicleId", label: "Vehicle", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "View", event: "VIEW", variant: "secondary" }, { label: "Edit", event: "EDIT", variant: "secondary" }, { label: "Suspend", event: "SUSPEND", variant: "secondary" }, { label: "Reinstate", event: "REINSTATE", variant: "secondary" }, { label: "Terminate", event: "TERMINATE", variant: "danger" }, { label: "Assign Vehicle", event: "ASSIGN_VEHICLE", variant: "primary" }, { label: "Delete", event: "REQUEST_DELETE", variant: "danger" }] }] })
      DriverLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing {
      REFRESH -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Refreshing drivers…" }] })
      SEARCH -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Searching drivers…" }] })
      FILTER_STATUS -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Filtering drivers…" }] })
      SUSPEND -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "warning", message: "Driver suspended" })
      REINSTATE -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Driver reinstated" })
      TERMINATE -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "error", message: "Driver terminated" })
      ASSIGN_VEHICLE -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Vehicle assigned" })
      CREATE -> viewing
        (render-ui main { type: "alert", variant: "info", message: "Creating new driver" })
      VIEW -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Viewing driver" })
      EDIT -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Editing driver" })
      REQUEST_DELETE -> viewing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "warning", message: "Delete requested" })
    }
    state error {
      INIT -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      VIEW             { id : string!, source : string }
      EDIT             { id : string!, source : string }
      CREATE           { source : string }
      REQUEST_DELETE   { id : string!, source : string }
      SUSPEND          { id : string!, row : Driver }
      REINSTATE        { id : string!, row : Driver }
      TERMINATE        { id : string!, row : Driver }
      ASSIGN_VEHICLE   { id : string!, row : Driver }
      DriverLoaded     { data : [Driver], totalCount : number }
      DriverLoadFailed { error : string, code : string }
    }
    listens {
      VIEW             { id : string! }
      EDIT             { id : string! }
      CREATE           { source : string }
      REQUEST_DELETE   { id : string! }
      SUSPEND          { id : string! }
      REINSTATE        { id : string! }
      TERMINATE        { id : string! }
      ASSIGN_VEHICLE   { id : string! }
      REFRESH          { source : string }
      SEARCH           { query : string }
      FILTER_STATUS    { status : string }
      DriverLoaded     { data : [Driver], totalCount : number }
      DriverLoadFailed { error : string, code : string }
    }
  }
  page "/drivers" as DriverPage -> DriverRoster
}
