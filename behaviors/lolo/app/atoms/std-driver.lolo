app std-driver "1.1.0"
"std-driver — fleet driver primitive tracking license info, hire date, status, assigned vehicle. Lists drivers in `browsing`; opens detail in `viewing_single` with Suspend / Reinstate / Terminate / Assign Vehicle actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital DriverOrbital {
  entity Driver [persistent: drivers] {
    id                : string!
    name              : string!
    licenseNumber     : string!
    licenseClass      : "A" | "B" | "C" | "CDL-A" | "CDL-B" | "CDL-C" = "C"
    licenseExpiresAt  : string = ""
    hiredAt           : string = ""
    phone             : string = ""
    email             : string = ""
    status            : "active" | "on-leave" | "terminated" | "suspended" = "active"
    assignedVehicleId : string = ""
    pendingId         : string = ""
  }

  type DriverLoaded     = Event { data : [Driver], totalCount : number } "Fired when the driver collection finishes loading"
  type DriverLoadFailed = Event { error : string, code : string }        "Fired when the driver collection fails to load"

  trait DriverRoster -> Driver [interaction, collection] {
    config {
      title       : string   = "Drivers"
        @label "Section title"
        @description "Heading shown above the fleet driver roster"
        @tier "customization"
      fields      : [FieldSpec] = [
        { name: "name",              label: "Name",    variant: "caption" },
        { name: "licenseNumber",     label: "License", variant: "caption" },
        { name: "licenseClass",      label: "Class",   variant: "badge"   },
        { name: "licenseExpiresAt",  label: "Expires", variant: "caption" },
        { name: "status",            label: "Status",  variant: "badge"   },
        { name: "assignedVehicleId", label: "Vehicle", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Driver entity"
        @tier "customization"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_DRIVER", variant: "primary", icon: "arrow-right" },
        { label: "Suspend", event: "SUSPEND",     variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each driver row"
        @tier "customization"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading drivers…" }] })
      DriverLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total drivers", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "Active", value: "24", icon: "check-circle" }, { type: "stat-display", label: "On leave", value: "3", icon: "pause-circle" }, { type: "stat-display", label: "License expiring 30d", value: "4", icon: "alert-triangle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      DriverLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_DRIVER -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.licenseNumber @payload.row.licenseNumber)
        (set @entity.licenseClass @payload.row.licenseClass)
        (set @entity.licenseExpiresAt @payload.row.licenseExpiresAt)
        (set @entity.hiredAt @payload.row.hiredAt)
        (set @entity.phone @payload.row.phone)
        (set @entity.email @payload.row.email)
        (set @entity.status @payload.row.status)
        (set @entity.assignedVehicleId @payload.row.assignedVehicleId)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "user" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.licenseClass", variant: "primary" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "License #" }, { type: "typography", variant: "body", content: "@entity.licenseNumber" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Vehicle" }, { type: "typography", variant: "body", content: "@entity.assignedVehicleId" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Hired", value: "@entity.hiredAt", icon: "calendar" }, { type: "stat-display", label: "License expires", value: "@entity.licenseExpiresAt", icon: "calendar-x" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Assign Vehicle", variant: "primary", action: "ASSIGN_VEHICLE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Suspend", variant: "danger", action: "SUSPEND", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Reinstate", variant: "secondary", action: "REINSTATE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Terminate", variant: "danger", action: "TERMINATE", actionPayload: { id: "@entity.id" } }] }] })
      SUSPEND -> loading
        (set @entity.id @payload.id)
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Suspending driver…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading drivers…" }] })
      ASSIGN_VEHICLE -> loading
        (set @entity.id @payload.id)
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Assigning vehicle…" }] })
      SUSPEND -> loading
        (set @entity.id @payload.id)
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Suspending driver…" }] })
      REINSTATE -> loading
        (set @entity.id @payload.id)
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Reinstating driver…" }] })
      TERMINATE -> loading
        (set @entity.id @payload.id)
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Terminating driver…" }] })
    }
    state error {
      INIT -> loading
        (fetch Driver { emit: { success: "DriverLoaded", failure: "DriverLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_DRIVER      { id : string!, row : Driver }
      CLOSE_VIEW       { }
      ASSIGN_VEHICLE   { id : string! }
      SUSPEND          { id : string! }
      REINSTATE        { id : string! }
      TERMINATE        { id : string! }
      DriverLoaded     { data : [Driver], totalCount : number }
      DriverLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_DRIVER      { id : string!, row : Driver }
      CLOSE_VIEW       { }
      ASSIGN_VEHICLE   { id : string! }
      SUSPEND          { id : string! }
      REINSTATE        { id : string! }
      TERMINATE        { id : string! }
      DriverLoaded     { data : [Driver], totalCount : number }
      DriverLoadFailed { error : string, code : string }
    }
  }
  page "/drivers" as DriverPage -> DriverRoster
}
