app std-wizard-branching "2.0.0"
"std-wizard-branching — domain-specific N-step form wizard. Composes std-wizard with persisted WizardSubmission entity carrying form fields per step. Lights up std-applicant-form (ATS), std-application (HR), std-vendor-onboarding, intake forms in std-healthcare."

orbital WizardBranchingOrbital {
  uses Wizard from "std/behaviors/std-wizard"

  entity WizardSubmission [persistent: wizard_submissions] {
    id          : string!
    title       : string!
    description : string  = ""
    category    : "personal" | "business" | "internal" | "external" = "personal"
    priority    : "low" | "medium" | "high" | "urgent" = "medium"
    notes       : string  = ""
    submittedAt : string  = ""
  }

  trait WizardFlow = Wizard.traits.WizardForm -> WizardSubmission {
    config: {
      title: "Submission Wizard",
      steps: [
        { key: "details", label: "Your Details",   description: "Tell us about the request",    icon: "file-text",   fields: ["title", "description"] },
        { key: "context", label: "Context",        description: "Categorize and prioritize",    icon: "tag",         fields: ["category", "priority"] },
        { key: "review",  label: "Review & Submit", description: "Confirm your submission",      icon: "check-circle", fields: ["notes"] }
      ],
      currentFields: ["title", "description", "category", "priority", "notes"]
    }
  }

  page "/wizard-branching" as WizardBranchingPage -> WizardFlow
}
