app std-legal-hold "1.0.0"
"std-legal-hold — legal hold trigger, duration, and release approval; companion to std-matter and std-court-deadline."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital LegalHoldOrbital {
  entity LegalHold [persistent: legal_holds] {
    id                 : string!
    matterId           : string = ""
    triggeredBy        : string = ""
    triggeredAt        : string = ""
    expectedReleaseAt  : string = ""
    status             : "active" | "expiring" | "released" | "extended" = "active"
    affectedEntities   : [string] = []
    description        : string = ""
    createdAt          : string = ""
  }

  type LegalHoldLoaded     = Event { data : [LegalHold] }              "Fired when the legal hold collection finishes loading"
  type LegalHoldLoadFailed = Event { error : string, code : string }   "Fired when the legal hold collection fails to load"

  trait LegalHoldPipeline -> LegalHold [interaction, collection] {
    config {
      title       : string   = "Legal Holds"
        @label "Section title"
        @description "Heading shown above the legal hold list"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "matterId",          label: "Matter",   variant: "caption" },
        { name: "triggeredBy",       label: "Trigger",  variant: "caption" },
        { name: "status",            label: "Status",   variant: "badge"   },
        { name: "triggeredAt",       label: "Started",  variant: "caption" },
        { name: "expectedReleaseAt", label: "Releases", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the LegalHold entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_HOLD",    variant: "primary", icon: "arrow-right" },
        { label: "Release", event: "RELEASE_HOLD", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each legal hold row"
        @tier "presentation"
      triggeredBy : "litigation" | "regulatory-inquiry" | "internal-investigation" | "audit" = "litigation"
        @label "Trigger type"
        @description "Reason the legal hold was instituted."
        @tier "domain"
        @synonyms "hold reason, basis"
      holdDurationDays : number = 365
        @label "Default hold duration (days)"
        @description "Initial hold period before release-eligibility review."
        @tier "domain"
        @synonyms "retention period, hold length"
      releaseApprovalRoles : [string] = ["general-counsel","compliance-officer"]
        @label "Release approval roles"
        @description "Roles required to approve hold release. Compose std-approval-gate for the workflow."
        @tier "domain"
        @synonyms "release approvers"
      notifyRolesOnHold : [string] = ["records-manager","it-admin"]
        @label "Notify on hold (roles)"
        @description "Roles paged when a new hold activates. Compose std-notify-on-event for delivery."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch LegalHold { emit: { success: "LegalHoldLoaded", failure: "LegalHoldLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading legal holds…" }] })
      LegalHoldLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "lock" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total holds", value: "@payload.data.length", icon: "lock" }, { type: "stat-display", label: "Active", value: "23", icon: "shield" }, { type: "stat-display", label: "Expiring soon", value: "4", icon: "clock" }, { type: "stat-display", label: "Released YTD", value: "12", icon: "unlock" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      LegalHoldLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_HOLD -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.matterId @payload.row.matterId)
        (set @entity.triggeredBy @payload.row.triggeredBy)
        (set @entity.triggeredAt @payload.row.triggeredAt)
        (set @entity.expectedReleaseAt @payload.row.expectedReleaseAt)
        (set @entity.status @payload.row.status)
        (set @entity.description @payload.row.description)
        (set @entity.createdAt @payload.row.createdAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "lock" }, { type: "typography", content: "@entity.matterId", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Trigger" }, { type: "typography", variant: "body", content: "@entity.triggeredBy" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Started", value: "@entity.triggeredAt", icon: "calendar" }, { type: "stat-display", label: "Expected Release", value: "@entity.expectedReleaseAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Extend", variant: "primary", action: "EXTEND_HOLD", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Release", variant: "danger", action: "RELEASE_HOLD", actionPayload: { id: "@entity.id" } }] }] })
      RELEASE_HOLD -> loading
        (set @entity.id @payload.id)
        (fetch LegalHold { emit: { success: "LegalHoldLoaded", failure: "LegalHoldLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Releasing hold…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch LegalHold { emit: { success: "LegalHoldLoaded", failure: "LegalHoldLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading legal holds…" }] })
      EXTEND_HOLD -> loading
        (set @entity.id @payload.id)
        (fetch LegalHold { emit: { success: "LegalHoldLoaded", failure: "LegalHoldLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Extending hold…" }] })
      RELEASE_HOLD -> loading
        (set @entity.id @payload.id)
        (fetch LegalHold { emit: { success: "LegalHoldLoaded", failure: "LegalHoldLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Releasing hold…" }] })
    }
    state error {
      INIT -> loading
        (fetch LegalHold { emit: { success: "LegalHoldLoaded", failure: "LegalHoldLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_HOLD          { id : string!, row : LegalHold }
      CLOSE_VIEW         { }
      EXTEND_HOLD        { id : string!, row : LegalHold }
      RELEASE_HOLD       { id : string!, row : LegalHold }
      LegalHoldLoaded     { data : [LegalHold] }
      LegalHoldLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_HOLD          { id : string!, row : LegalHold }
      CLOSE_VIEW         { }
      EXTEND_HOLD        { id : string! }
      RELEASE_HOLD       { id : string! }
      LegalHoldLoaded     { data : [LegalHold] }
      LegalHoldLoadFailed { error : string, code : string }
    }
  }
  page "/legal-holds" as LegalHoldPage -> LegalHoldPipeline
}
