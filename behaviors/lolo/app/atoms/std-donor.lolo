app std-donor "1.1.0"
"std-donor — nonprofit donor primitive (person or org with lifetime giving total). Lists donors in `browsing`; opens donor detail in `viewing_single` with Thank / Solicit actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital DonorOrbital {
  entity Donor [persistent: donors] {
    id                 : string!
    name               : string!
    email              : string = ""
    phone              : string = ""
    donorType          : "individual" | "organization" | "foundation" | "anonymous" = "individual"
    lifetimeAmount     : number = 0
    firstDonationAt    : string = ""
    lastDonationAt     : string = ""
    preferredCampaign  : string = ""
    isRecurring        : boolean = false
  }

  type DonorLoaded     = Event { data : [Donor] }              "Fired when the donor collection finishes loading"
  type DonorLoadFailed = Event { error : string, code : string } "Fired when the donor collection fails to load"

  trait DonorRoster -> Donor [interaction, collection] {
    config {
      title       : string   = "Donors"
        @label "Section title"
        @description "Heading shown above the donor roster"
      fields      : [FieldSpec] = [
        { name: "name",           label: "Name",     variant: "h4"      },
        { name: "donorType",      label: "Type",     variant: "badge"   },
        { name: "email",          label: "Email",    variant: "body"    },
        { name: "lifetimeAmount", label: "Lifetime", variant: "caption" },
        { name: "lastDonationAt", label: "Last gift", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Donor entity"
      itemActions : [ItemAction] = [
        { label: "Open",  event: "OPEN_DONOR",  variant: "primary",   icon: "arrow-right" },
        { label: "Thank", event: "THANK_DONOR", variant: "secondary" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each donor row"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading donors…" }] })
      DonorLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "heart" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total donors", value: "@payload.data.length", icon: "heart" }, { type: "stat-display", label: "Recurring", value: "184", icon: "refresh-cw" }, { type: "stat-display", label: "Total lifetime", value: "$2.4M", icon: "dollar-sign" }, { type: "stat-display", label: "Avg gift", value: "$148", icon: "trending-up" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", itemActions: "@config.itemActions" }] })
      DonorLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_DONOR -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.email @payload.row.email)
        (set @entity.phone @payload.row.phone)
        (set @entity.donorType @payload.row.donorType)
        (set @entity.lifetimeAmount @payload.row.lifetimeAmount)
        (set @entity.firstDonationAt @payload.row.firstDonationAt)
        (set @entity.lastDonationAt @payload.row.lastDonationAt)
        (set @entity.preferredCampaign @payload.row.preferredCampaign)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "heart" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.donorType", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Preferred campaign" }, { type: "typography", variant: "body", content: "@entity.preferredCampaign" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Lifetime amount", value: "@entity.lifetimeAmount", icon: "dollar-sign" }, { type: "stat-display", label: "First donation", value: "@entity.firstDonationAt", icon: "calendar" }, { type: "stat-display", label: "Last donation", value: "@entity.lastDonationAt", icon: "calendar-check" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Thank Donor", variant: "primary", action: "THANK_DONOR", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Solicit", variant: "secondary", action: "SOLICIT_DONOR", actionPayload: { id: "@entity.id" } }] }] })
      THANK_DONOR -> loading
        (set @entity.id @payload.id)
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Sending thanks…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading donors…" }] })
      THANK_DONOR -> loading
        (set @entity.id @payload.id)
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Sending thanks…" }] })
      SOLICIT_DONOR -> loading
        (set @entity.id @payload.id)
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Soliciting donor…" }] })
    }
    state error {
      INIT -> loading
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_DONOR      { id : string!, row : Donor }
      CLOSE_VIEW      { }
      THANK_DONOR     { id : string! }
      SOLICIT_DONOR   { id : string! }
      DonorLoaded     { data : [Donor] }
      DonorLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_DONOR      { id : string!, row : Donor }
      CLOSE_VIEW      { }
      THANK_DONOR     { id : string! }
      SOLICIT_DONOR   { id : string! }
      DonorLoaded     { data : [Donor] }
      DonorLoadFailed { error : string, code : string }
    }
  }
  page "/donors" as DonorPage -> DonorRoster
}
