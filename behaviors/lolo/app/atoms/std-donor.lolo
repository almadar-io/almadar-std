app std-donor "1.0.0"
"std-donor — donor primitive: person or organization that has donated to a nonprofit, with lifetime giving total and contact info."

orbital DonorOrbital {
  entity Donor [persistent: donors] {
    id                 : string!
    name               : string!
    email              : string = ""
    phone              : string = ""
    donorType          : "individual" | "organization" | "foundation" | "anonymous" = "individual"
    lifetimeAmount     : number = 0
    firstDonationAt    : string = ""
    lastDonationAt     : string = ""
    preferredCampaign  : string = ""
    isRecurring        : boolean = false
  }

  type DonorLoaded     = Event { data : [Donor] }              "Fired when the donor collection finishes loading"
  type DonorLoadFailed = Event { error : string, code : string } "Fired when the donor collection fails to load"

  trait DonorRoster -> Donor [interaction, collection] {
    config {
      title : string = "Donors"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading donors…" }] })
      DonorLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "heart-handshake" }, { type: "typography", content: "@config.title", variant: "h3" }, { type: "avatar", name: "Top donor", src: "https://i.pravatar.cc/64?u=top-donor" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "flip-card", front: { type: "team-card", name: "Sarah Johnson", role: "Top recurring donor", bio: "Gives monthly since 2020", avatar: "https://i.pravatar.cc/120?u=sarah" }, back: { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", variant: "h4", content: "Lifetime giving" }, { type: "typography", variant: "body", content: "$24,500 across 48 gifts" }] } }, { type: "team-card", name: "Volunteer Team Lead", role: "Field coordinator", bio: "Leads our regional volunteer corps", avatar: "https://i.pravatar.cc/120?u=lead" }] }, { type: "team-organism",  }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "name", label: "Name", variant: "caption" }, { name: "email", label: "Email", variant: "caption" }, { name: "donorType", label: "Type", variant: "badge" }, { name: "lifetimeAmount", label: "Lifetime", variant: "caption" }, { name: "lastDonationAt", label: "Last Gift", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Thank", event: "THANK_DONOR", variant: "primary" }, { label: "Solicit", event: "SOLICIT_DONOR", variant: "ghost" }] }] })
      DonorLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      THANK_DONOR -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Thank-you sent" })
      SOLICIT_DONOR -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Solicitation queued" })
    }
    state error {
      INIT -> loading
        (fetch Donor { emit: { success: "DonorLoaded", failure: "DonorLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      THANK_DONOR     { id : string!, row : Donor }
      SOLICIT_DONOR   { id : string!, row : Donor }
      DonorLoaded     { data : [Donor] }
      DonorLoadFailed { error : string, code : string }
    }
    listens {
      THANK_DONOR     { id : string! }
      SOLICIT_DONOR   { id : string! }
      DonorLoaded     { data : [Donor] }
      DonorLoadFailed { error : string, code : string }
    }
  }
  page "/donors" as DonorPage -> DonorRoster
}
