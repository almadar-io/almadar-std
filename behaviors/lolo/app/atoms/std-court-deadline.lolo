app std-court-deadline "1.1.0"
"std-court-deadline — statutory filing deadline tied to a legal matter. Lists deadlines in `browsing`; opens detail in `viewing_single` with Complete / Extend actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

orbital CourtDeadlineOrbital {
  entity CourtDeadline [persistent: courtdeadlines] {
    id            : string!
    matterId      : string!
    title         : string!
    deadlineType  : "filing" | "response" | "discovery" | "hearing" | "trial" | "other" = "filing"
    dueAt         : string!
    jurisdiction  : string = ""
    assignedTo    : string = ""
    status        : "upcoming" | "completed" | "missed" | "extended" = "upcoming"
    reminderSent  : boolean = false
    notes         : string = ""
  }

  type CourtDeadlineLoaded     = Event { data : [CourtDeadline] }
  type CourtDeadlineLoadFailed = Event { error : string, code : string }

  trait CourtDeadlineDocket -> CourtDeadline [interaction, collection] {
    config {
      title       : string   = "Deadlines"
      fields      : [object] = [
        { name: "title",        label: "Title",        variant: "caption" },
        { name: "deadlineType", label: "Type",         variant: "badge"   },
        { name: "dueAt",        label: "Due",          variant: "caption" },
        { name: "jurisdiction", label: "Jurisdiction", variant: "caption" },
        { name: "assignedTo",   label: "Assigned",     variant: "caption" },
        { name: "status",       label: "Status",       variant: "badge"   }
      ]
      itemActions : [object] = [
        { label: "Open",     event: "OPEN_DEADLINE",  variant: "primary", icon: "arrow-right" },
        { label: "Complete", event: "MARK_COMPLETED", variant: "danger" }
      ]
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch CourtDeadline { emit: { success: "CourtDeadlineLoaded", failure: "CourtDeadlineLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading deadlines…" }] })
      CourtDeadlineLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar-clock" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total deadlines", value: "@payload.data.length", icon: "calendar-clock" }, { type: "stat-display", label: "Due this week", value: "7", icon: "alert-triangle" }, { type: "stat-display", label: "Completed", value: "84%", icon: "check-circle" }, { type: "stat-display", label: "Missed YTD", value: "2", icon: "x-circle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      CourtDeadlineLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_DEADLINE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.matterId @payload.row.matterId)
        (set @entity.title @payload.row.title)
        (set @entity.deadlineType @payload.row.deadlineType)
        (set @entity.dueAt @payload.row.dueAt)
        (set @entity.jurisdiction @payload.row.jurisdiction)
        (set @entity.assignedTo @payload.row.assignedTo)
        (set @entity.status @payload.row.status)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "calendar-clock" }, { type: "typography", content: "@entity.title", variant: "h3" }, { type: "badge", label: "@entity.deadlineType", variant: "primary" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Matter" }, { type: "typography", variant: "body", content: "@entity.matterId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Jurisdiction" }, { type: "typography", variant: "body", content: "@entity.jurisdiction" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Assigned to" }, { type: "typography", variant: "body", content: "@entity.assignedTo" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Due", value: "@entity.dueAt", icon: "calendar" }, { type: "stat-display", label: "Status", value: "@entity.status", icon: "tag" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Mark Complete", variant: "primary", action: "MARK_COMPLETED", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Extend", variant: "secondary", action: "EXTEND_DEADLINE", actionPayload: { id: "@entity.id" } }] }] })
      MARK_COMPLETED -> loading
        (set @entity.id @payload.id)
        (fetch CourtDeadline { emit: { success: "CourtDeadlineLoaded", failure: "CourtDeadlineLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Completing deadline…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch CourtDeadline { emit: { success: "CourtDeadlineLoaded", failure: "CourtDeadlineLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading deadlines…" }] })
      MARK_COMPLETED -> loading
        (set @entity.id @payload.id)
        (fetch CourtDeadline { emit: { success: "CourtDeadlineLoaded", failure: "CourtDeadlineLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Completing deadline…" }] })
      EXTEND_DEADLINE -> loading
        (set @entity.id @payload.id)
        (fetch CourtDeadline { emit: { success: "CourtDeadlineLoaded", failure: "CourtDeadlineLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Extending deadline…" }] })
    }
    state error {
      INIT -> loading
        (fetch CourtDeadline { emit: { success: "CourtDeadlineLoaded", failure: "CourtDeadlineLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_DEADLINE           { id : string!, row : CourtDeadline }
      CLOSE_VIEW              { }
      MARK_COMPLETED          { id : string! }
      EXTEND_DEADLINE         { id : string! }
      CourtDeadlineLoaded     { data : [CourtDeadline] }
      CourtDeadlineLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_DEADLINE           { id : string!, row : CourtDeadline }
      CLOSE_VIEW              { }
      MARK_COMPLETED          { id : string! }
      EXTEND_DEADLINE         { id : string! }
      CourtDeadlineLoaded     { data : [CourtDeadline] }
      CourtDeadlineLoadFailed { error : string, code : string }
    }
  }
  page "/deadlines" as CourtDeadlinePage -> CourtDeadlineDocket
}
