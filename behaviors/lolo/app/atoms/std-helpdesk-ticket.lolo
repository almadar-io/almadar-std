app std-helpdesk-ticket "1.0.0"
"std-helpdesk-ticket — support ticket lifecycle (new → open → pending → resolved → closed). Listens for SET_STATUS so siblings can drive automated transitions. Exposes Helpdesk-pattern knobs (slaTier, severity, response/resolution SLA, escalationMatrix, routingStrategy, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital TicketOrbital {
  entity Ticket [persistent: tickets] {
    id           : string!
    subject      : string!
    description  : string!
    requester    : string!
    assignedTo   : string
    priority     : "low" | "normal" | "high" | "urgent" = "normal"
    status       : "new" | "open" | "pending" | "resolved" | "closed" = "new"
    category     : string
    firstReplyAt : string
    resolvedAt   : string
    createdAt    : string
  }

  type TicketLoaded        = Event { data : [Ticket] }              "Fired when the ticket collection finishes loading"
  type TicketLoadFailed    = Event { error : string, code : string } "Fired when the ticket collection fails to load"

  trait TicketManage -> Ticket [interaction, collection] {
    config {
      title : string = "Tickets"
        @label "Section title"
        @description "Heading shown above the helpdesk tickets list"
        @tier "presentation"
      fields      : [FieldSpec] = [{ name: "subject", label: "Subject", variant: "caption" }, { name: "requester", label: "Requester", variant: "caption" }, { name: "priority", label: "Priority", variant: "badge" }, { name: "status", label: "Status", variant: "badge" }, { name: "assignedTo", label: "Assigned", variant: "caption" }, { name: "category", label: "Category", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Ticket entity"
        @tier "presentation"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_TICKET", variant: "primary", icon: "arrow-right" }, { label: "Close", event: "CLOSE", variant: "danger", icon: "x" }]
        @label "Row actions"
        @description "Buttons users can click on each ticket row"
        @tier "presentation"
      slaTier : "bronze" | "silver" | "gold" | "platinum" = "silver"
        @label "SLA tier"
        @description "Service-level tier from the customer's contract"
        @tier "domain"
        @synonyms "service level, support tier, plan"
      severity : "low" | "medium" | "high" | "critical" = "medium"
        @label "Severity"
        @description "Default severity for new tickets when not explicitly classified."
        @tier "domain"
        @synonyms "impact, urgency"
      responseTimeMinutes : number = 60
        @label "First-response SLA (min)"
        @description "Target minutes from ticket created to first agent reply."
        @tier "domain"
        @synonyms "first reply time, response time"
      resolutionSLAHours : number = 24
        @label "Resolution SLA (hours)"
        @description "Target hours from ticket created to resolved."
        @tier "domain"
        @synonyms "time to resolve"
      escalationMatrix : [string] = ["L1", "L2", "manager"]
        @label "Escalation matrix"
        @description "Ordered roles a ticket escalates through when SLA breaches."
        @tier "domain"
        @synonyms "escalation roles, escalation chain"
      firstReplyDeadline : number = 60
        @label "First-reply deadline (min)"
        @description "Hard deadline that triggers escalation if no agent has replied."
        @tier "domain"
      csatSurveySentAfterDays : number = 1
        @label "CSAT survey delay (days)"
        @description "Days after resolution before the satisfaction survey is sent. 0 = immediate."
        @tier "domain"
        @synonyms "customer satisfaction, survey delay"
      autoCloseInactiveDays : number = 7
        @label "Auto-close inactive (days)"
        @description "Days a 'resolved' ticket stays open for re-open before auto-closing."
        @tier "domain"
      categories : [string] = ["billing", "technical", "account", "general"]
        @label "Ticket categories"
        @description "Allowed category enum. Empty = uncategorized."
        @tier "domain"
        @synonyms "topics, queues"
      routingStrategy : "round-robin" | "skills" | "manual" | "load-balanced" = "skills"
        @label "Routing strategy"
        @description "How new tickets are assigned to agents."
        @tier "domain"
        @synonyms "assignment strategy, dispatch"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading tickets…" }] })
      TicketLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "life-buoy" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total tickets", value: "@payload.data.length", icon: "life-buoy" }, { type: "stat-display", label: "Urgent open", value: "9", icon: "alert-triangle" }, { type: "stat-display", label: "Pending", value: "14", icon: "clock" }, { type: "stat-display", label: "Resolved today", value: "47", icon: "check-circle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      TicketLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_TICKET -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.subject @payload.row.subject)
        (set @entity.description @payload.row.description)
        (set @entity.requester @payload.row.requester)
        (set @entity.assignedTo @payload.row.assignedTo)
        (set @entity.priority @payload.row.priority)
        (set @entity.status @payload.row.status)
        (set @entity.category @payload.row.category)
        (set @entity.firstReplyAt @payload.row.firstReplyAt)
        (set @entity.resolvedAt @payload.row.resolvedAt)
        (set @entity.createdAt @payload.row.createdAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "life-buoy" }, { type: "typography", content: "@entity.subject", variant: "h3" }, { type: "badge", label: "@entity.priority", variant: "primary" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Requester" }, { type: "typography", variant: "body", content: "@entity.requester" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Category" }, { type: "typography", variant: "body", content: "@entity.category" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Assigned to" }, { type: "typography", variant: "body", content: "@entity.assignedTo" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "First reply", value: "@entity.firstReplyAt", icon: "message-circle" }, { type: "stat-display", label: "Resolved", value: "@entity.resolvedAt", icon: "check" }, { type: "stat-display", label: "Created", value: "@entity.createdAt", icon: "calendar-plus" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Reply", variant: "primary", action: "REPLY", actionPayload: { id: "@entity.id", row: "@entity" } }, { type: "button", label: "Assign", variant: "secondary", action: "ASSIGN", actionPayload: { id: "@entity.id", assignedTo: "@entity.assignedTo", row: "@entity" } }, { type: "button", label: "Escalate", variant: "secondary", action: "ESCALATE", actionPayload: { id: "@entity.id", row: "@entity" } }, { type: "button", label: "Close", variant: "danger", action: "CLOSE", actionPayload: { id: "@entity.id", row: "@entity" } }] }] })
      CLOSE -> loading
        (set @entity.id @payload.id)
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Closing ticket…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update Ticket @entity { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating ticket status…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading tickets…" }] })
      REPLY -> loading
        (set @entity.id @payload.id)
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Sending reply…" }] })
      ASSIGN -> loading
        (set @entity.id @payload.id)
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Assigning ticket…" }] })
      ESCALATE -> loading
        (set @entity.id @payload.id)
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Escalating ticket…" }] })
      CLOSE -> loading
        (set @entity.id @payload.id)
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Closing ticket…" }] })
    }
    state error {
      INIT -> loading
        (fetch Ticket { emit: { success: "TicketLoaded", failure: "TicketLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_TICKET  { id : string!, row : Ticket }
      CLOSE_VIEW   { }
      REPLY        { id : string!, row : Ticket }
      ASSIGN       { id : string!, assignedTo : string!, row : Ticket }
      ESCALATE     { id : string!, row : Ticket }
      CLOSE        { id : string!, row : Ticket }
      TicketLoaded       { data : [Ticket] }
      TicketLoadFailed   { error : string, code : string }
    }
    listens {
      OPEN_TICKET  { id : string!, row : Ticket }
      CLOSE_VIEW   { }
      REPLY        { id : string!, row : Ticket }
      ASSIGN       { id : string!, assignedTo : string!, row : Ticket }
      ESCALATE     { id : string!, row : Ticket }
      CLOSE        { id : string!, row : Ticket }
      SET_STATUS   { entityId : string!, newStatus : string! }
      TicketLoaded       { data : [Ticket] }
      TicketLoadFailed   { error : string, code : string }
    }
  }
  page "/tickets" as TicketManagePage -> TicketManage
}
