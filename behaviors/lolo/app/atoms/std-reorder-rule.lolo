app std-reorder-rule "1.0.0"
"std-reorder-rule — automatic stock-replenishment rule for a SKU at a location. Owns a ReorderRule entity and a single manager trait that loads rules, renders them in a data-grid, and surfaces Enable / Disable actions per row."

orbital ReorderRuleOrbital {
  entity ReorderRule [persistent: reorderrules] {
    id           : string!
    sku          : string!
    locationId   : string = ""
    thresholdQty : number = 0
    reorderQty   : number = 0
    vendor       : string = ""
    leadTimeDays : number = 0
    isActive     : boolean = true
  }

  type ReorderRuleLoaded     = Event { data : [ReorderRule] }           "Fired when the reorder rule collection finishes loading"
  type ReorderRuleLoadFailed = Event { error : string, code : string }  "Fired when the reorder rule collection fails to load"

  trait ReorderRuleManager -> ReorderRule [interaction, collection] {
    config {
      title : string = "Reorder Rules"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading reorder rules…" }] })
      ReorderRuleLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat" }, { type: "typography", content: "@config.title", variant: "h3" }, { type: "badge", label: "Active", variant: "success" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "sku", label: "SKU", variant: "caption" }, { name: "locationId", label: "Location", variant: "caption" }, { name: "thresholdQty", label: "Threshold", variant: "caption" }, { name: "reorderQty", label: "Reorder Qty", variant: "caption" }, { name: "vendor", label: "Vendor", variant: "caption" }, { name: "isActive", label: "Active", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Enable", event: "ENABLE_RULE", variant: "primary", icon: "check" }, { label: "Disable", event: "DISABLE_RULE", variant: "danger", icon: "x" }] }] })
      ReorderRuleLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      ENABLE_RULE -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Reorder rule enabled" })
      DISABLE_RULE -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Reorder rule disabled" })
    }
    state error {
      INIT -> loading
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      ENABLE_RULE            { id : string! }
      DISABLE_RULE           { id : string! }
      ReorderRuleLoaded      { data : [ReorderRule] }
      ReorderRuleLoadFailed  { error : string, code : string }
    }
    listens {
      ENABLE_RULE            { id : string! }
      DISABLE_RULE           { id : string! }
      ReorderRuleLoaded      { data : [ReorderRule] }
      ReorderRuleLoadFailed  { error : string, code : string }
    }
  }
  page "/reorder-rules" as ReorderRulePage -> ReorderRuleManager
}
