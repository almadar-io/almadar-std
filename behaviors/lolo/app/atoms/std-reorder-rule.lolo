app std-reorder-rule "1.0.0"
"std-reorder-rule — automatic stock-replenishment rule per SKU/location. Lists rules in `browsing`; opens detail in `viewing_single` with Enable / Disable actions."

orbital ReorderRuleOrbital {
  entity ReorderRule [persistent: reorderrules] {
    id           : string!
    sku          : string!
    locationId   : string = ""
    thresholdQty : number = 0
    reorderQty   : number = 0
    vendor       : string = ""
    leadTimeDays : number = 0
    isActive     : boolean = true
  }

  type ReorderRuleLoaded     = Event { data : [ReorderRule] }           "Fired when the reorder rule collection finishes loading"
  type ReorderRuleLoadFailed = Event { error : string, code : string }  "Fired when the reorder rule collection fails to load"

  trait ReorderRuleManager -> ReorderRule [interaction, collection] {
    config {
      title : string = "Reorder Rules"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading reorder rules…" }] })
      ReorderRuleLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total rules", value: "@payload.data.length", icon: "repeat" }, { type: "stat-display", label: "Active", value: "47", icon: "check-circle" }, { type: "stat-display", label: "Triggered today", value: "9", icon: "zap" }, { type: "stat-display", label: "Avg lead time", value: "6.4d", icon: "clock" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "sku", label: "SKU", variant: "caption" }, { name: "locationId", label: "Location", variant: "caption" }, { name: "thresholdQty", label: "Threshold", variant: "caption" }, { name: "reorderQty", label: "Reorder Qty", variant: "caption" }, { name: "vendor", label: "Vendor", variant: "caption" }, { name: "leadTimeDays", label: "Lead (d)", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_RULE", variant: "primary", icon: "arrow-right" }, { label: "Disable", event: "DISABLE_RULE", variant: "danger" }] }] })
      ReorderRuleLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_RULE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.sku @payload.row.sku)
        (set @entity.locationId @payload.row.locationId)
        (set @entity.thresholdQty @payload.row.thresholdQty)
        (set @entity.reorderQty @payload.row.reorderQty)
        (set @entity.vendor @payload.row.vendor)
        (set @entity.leadTimeDays @payload.row.leadTimeDays)
        (set @entity.isActive @payload.row.isActive)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "repeat" }, { type: "typography", content: "@entity.sku", variant: "h3" }, { type: "badge", label: "Active", variant: "success" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Location" }, { type: "typography", variant: "body", content: "@entity.locationId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Vendor" }, { type: "typography", variant: "body", content: "@entity.vendor" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Threshold", value: "@entity.thresholdQty", icon: "alert-triangle" }, { type: "stat-display", label: "Reorder qty", value: "@entity.reorderQty", icon: "package" }, { type: "stat-display", label: "Lead time (d)", value: "@entity.leadTimeDays", icon: "clock" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Enable", variant: "primary", action: "ENABLE_RULE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Disable", variant: "danger", action: "DISABLE_RULE", actionPayload: { id: "@entity.id" } }] }] })
      ENABLE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Enabling rule…" }] })
      DISABLE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Disabling rule…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading reorder rules…" }] })
      ENABLE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Enabling rule…" }] })
      DISABLE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Disabling rule…" }] })
    }
    state error {
      INIT -> loading
        (fetch ReorderRule { emit: { success: "ReorderRuleLoaded", failure: "ReorderRuleLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_RULE              { id : string!, row : ReorderRule }
      CLOSE_VIEW             { }
      ENABLE_RULE            { id : string! }
      DISABLE_RULE           { id : string! }
      ReorderRuleLoaded      { data : [ReorderRule] }
      ReorderRuleLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_RULE              { id : string!, row : ReorderRule }
      CLOSE_VIEW             { }
      ENABLE_RULE            { id : string! }
      DISABLE_RULE           { id : string! }
      ReorderRuleLoaded      { data : [ReorderRule] }
      ReorderRuleLoadFailed  { error : string, code : string }
    }
  }
  page "/reorder-rules" as ReorderRulePage -> ReorderRuleManager
}
