app std-chart-of-accounts "1.2.0"
"std-chart-of-accounts — accounts catalog (asset/liability/equity/revenue/expense) with Activate / Deactivate actions. Exposes Financial-pattern knobs (currency, jurisdiction, retention)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital ChartOfAccountsOrbital {
  entity Account [persistent: accounts] {
    id         : string!
    code       : string!
    name       : string!
    type       : "asset" | "liability" | "equity" | "revenue" | "expense" = "asset"
    parentCode : string = ""
    isActive   : boolean = true
    balance    : number = 0
  }

  type AccountLoaded     = Event { data : [Account] }            "Fired when the chart of accounts collection finishes loading"
  type AccountLoadFailed = Event { error : string, code : string }  "Fired when the chart of accounts collection fails to load"

  trait AccountChart -> Account [interaction, collection] {
    config {
      title       : string   = "Chart of Accounts"
        @label "Section title"
        @description "Heading shown above the accounts list"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "code",       label: "Code",    variant: "caption" },
        { name: "name",       label: "Name",    variant: "caption" },
        { name: "type",       label: "Type",    variant: "badge"   },
        { name: "parentCode", label: "Parent",  variant: "caption" },
        { name: "balance",    label: "Balance", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Account entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",       event: "OPEN_ACCOUNT",       variant: "primary", icon: "arrow-right" },
        { label: "Deactivate", event: "DEACTIVATE_ACCOUNT", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each account row"
        @tier "presentation"
      currency        : string   = "USD"
        @label "Default currency"
        @description "ISO 4217 currency code (USD, EUR, GBP, …) for account balances."
        @tier "domain"
      taxStrategy     : "inclusive" | "exclusive" | "none" = "none"
        @label "Tax strategy"
        @description "How tax-related accounts treat their balances. inclusive/exclusive/none."
        @tier "domain"
      roundingMode    : "bankers" | "half-up" | "down" = "bankers"
        @label "Rounding mode"
        @description "Sub-cent rounding behavior for ledger postings."
        @tier "domain"
      gracePeriodDays : number   = 0
        @label "Grace period (days)"
        @description "Days a deactivated account may continue to accept postings. Declarative."
        @tier "domain"
      lateFeePolicy   : "none" | "flat" | "percent" = "none"
        @label "Late fee policy"
        @description "Per-account late fee policy (rarely used on COA). Declarative; wiring deferred."
        @tier "domain"
      lateFeeAmount   : number   = 0
        @label "Late fee amount"
        @description "Flat cash amount or percentage (per lateFeePolicy)."
        @tier "domain"
      complianceJurisdiction : string = ""
        @label "Compliance jurisdiction"
        @description "Drives chart structure + retention per locale: 'US-GAAP', 'EU-IFRS', 'UK-FRS', etc. Declarative."
        @tier "domain"
      retentionYears  : number   = 7
        @label "Retention (years)"
        @description "Years to keep account records for compliance."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Account { emit: { success: "AccountLoaded", failure: "AccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading accounts…" }] })
      AccountLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "book-open" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total accounts", value: "@payload.data.length", icon: "book-open" }, { type: "stat-display", label: "Active", value: "118", icon: "check-circle" }, { type: "stat-display", label: "Assets balance", value: "$2.4M", icon: "trending-up" }, { type: "stat-display", label: "Liabilities", value: "$840K", icon: "trending-down" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      AccountLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_ACCOUNT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.code @payload.row.code)
        (set @entity.name @payload.row.name)
        (set @entity.type @payload.row.type)
        (set @entity.parentCode @payload.row.parentCode)
        (set @entity.isActive @payload.row.isActive)
        (set @entity.balance @payload.row.balance)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "book-open" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.type", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Code" }, { type: "typography", variant: "body", content: "@entity.code" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Parent" }, { type: "typography", variant: "body", content: "@entity.parentCode" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Balance", value: "@entity.balance", icon: "dollar-sign" }, { type: "stat-display", label: "Type", value: "@entity.type", icon: "tag" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Activate", variant: "primary", action: "ACTIVATE_ACCOUNT", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Deactivate", variant: "danger", action: "DEACTIVATE_ACCOUNT", actionPayload: { id: "@entity.id" } }] }] })
      DEACTIVATE_ACCOUNT -> loading
        (set @entity.id @payload.id)
        (fetch Account { emit: { success: "AccountLoaded", failure: "AccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deactivating account…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Account { emit: { success: "AccountLoaded", failure: "AccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading accounts…" }] })
      ACTIVATE_ACCOUNT -> loading
        (set @entity.id @payload.id)
        (fetch Account { emit: { success: "AccountLoaded", failure: "AccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Activating account…" }] })
      DEACTIVATE_ACCOUNT -> loading
        (set @entity.id @payload.id)
        (fetch Account { emit: { success: "AccountLoaded", failure: "AccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deactivating account…" }] })
    }
    state error {
      INIT -> loading
        (fetch Account { emit: { success: "AccountLoaded", failure: "AccountLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ACCOUNT       { id : string!, row : Account }
      CLOSE_VIEW         { }
      ACTIVATE_ACCOUNT   { id : string! }
      DEACTIVATE_ACCOUNT { id : string! }
      AccountLoaded      { data : [Account] }
      AccountLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_ACCOUNT       { id : string!, row : Account }
      CLOSE_VIEW         { }
      ACTIVATE_ACCOUNT   { id : string! }
      DEACTIVATE_ACCOUNT { id : string! }
      AccountLoaded      { data : [Account] }
      AccountLoadFailed  { error : string, code : string }
    }
  }
  page "/accounts" as AccountPage -> AccountChart
}
