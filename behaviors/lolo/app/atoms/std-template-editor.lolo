app std-template-editor "1.1.0"
"std-template-editor — message template authoring primitive. Lists templates in `browsing`; opens detail in `viewing_single` with Edit / Save / Delete actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital MessageTemplateOrbital {
  entity MessageTemplate [persistent: messagetemplates] {
    id           : string!
    name         : string!
    channel      : "email" | "sms" = "email"
    subject      : string = ""
    body         : string = ""
    variables    : string = ""
    lastEditedAt : string = ""
  }

  type MessageTemplateLoaded     = Event { data : [MessageTemplate] }              "Fired when the templates collection finishes loading"
  type MessageTemplateLoadFailed = Event { error : string, code : string }         "Fired when the templates collection fails to load"

  trait MessageTemplateEditor -> MessageTemplate [interaction, collection] {
    config {
      title : string = "Templates"
        @label "Section title"
        @description "Heading shown above the message template list"
      fields      : [FieldSpec] = [{ name: "name", label: "Name", variant: "caption" }, { name: "channel", label: "Channel", variant: "badge" }, { name: "subject", label: "Subject", variant: "caption" }, { name: "lastEditedAt", label: "Updated", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Message Template entity"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_TEMPLATE", variant: "primary", icon: "arrow-right" }, { label: "Delete", event: "DELETE_TEMPLATE", variant: "danger" }]
        @label "Row actions"
        @description "Buttons users can click on each template row"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch MessageTemplate { emit: { success: "MessageTemplateLoaded", failure: "MessageTemplateLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading templates…" }] })
      MessageTemplateLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total templates", value: "@payload.data.length", icon: "file-text" }, { type: "stat-display", label: "Email", value: "32", icon: "mail" }, { type: "stat-display", label: "SMS", value: "14", icon: "message-square" }, { type: "stat-display", label: "Edited 7d", value: "9", icon: "edit" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      MessageTemplateLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_TEMPLATE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.channel @payload.row.channel)
        (set @entity.subject @payload.row.subject)
        (set @entity.body @payload.row.body)
        (set @entity.variables @payload.row.variables)
        (set @entity.lastEditedAt @payload.row.lastEditedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "file-text" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.channel", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Subject" }, { type: "typography", variant: "body", content: "@entity.subject" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Body" }, { type: "typography", variant: "body", content: "@entity.body" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Variables" }, { type: "typography", variant: "body", content: "@entity.variables" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Channel", value: "@entity.channel", icon: "send" }, { type: "stat-display", label: "Last edited", value: "@entity.lastEditedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Edit", variant: "primary", action: "EDIT_TEMPLATE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Save", variant: "secondary", action: "SAVE_TEMPLATE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Delete", variant: "danger", action: "DELETE_TEMPLATE", actionPayload: { id: "@entity.id" } }] }] })
      DELETE_TEMPLATE -> loading
        (set @entity.id @payload.id)
        (fetch MessageTemplate { emit: { success: "MessageTemplateLoaded", failure: "MessageTemplateLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting template…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch MessageTemplate { emit: { success: "MessageTemplateLoaded", failure: "MessageTemplateLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading templates…" }] })
      EDIT_TEMPLATE -> loading
        (set @entity.id @payload.id)
        (fetch MessageTemplate { emit: { success: "MessageTemplateLoaded", failure: "MessageTemplateLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading editor…" }] })
      SAVE_TEMPLATE -> loading
        (set @entity.id @payload.id)
        (fetch MessageTemplate { emit: { success: "MessageTemplateLoaded", failure: "MessageTemplateLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Saving template…" }] })
      DELETE_TEMPLATE -> loading
        (set @entity.id @payload.id)
        (fetch MessageTemplate { emit: { success: "MessageTemplateLoaded", failure: "MessageTemplateLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting template…" }] })
    }
    state error {
      INIT -> loading
        (fetch MessageTemplate { emit: { success: "MessageTemplateLoaded", failure: "MessageTemplateLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_TEMPLATE              { id : string!, row : MessageTemplate }
      CLOSE_VIEW                 { }
      EDIT_TEMPLATE              { id : string! }
      SAVE_TEMPLATE              { id : string! }
      DELETE_TEMPLATE            { id : string! }
      MessageTemplateLoaded      { data : [MessageTemplate] }
      MessageTemplateLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_TEMPLATE              { id : string!, row : MessageTemplate }
      CLOSE_VIEW                 { }
      EDIT_TEMPLATE              { id : string! }
      SAVE_TEMPLATE              { id : string! }
      DELETE_TEMPLATE            { id : string! }
      MessageTemplateLoaded      { data : [MessageTemplate] }
      MessageTemplateLoadFailed  { error : string, code : string }
    }
  }
  page "/templates" as MessageTemplatePage -> MessageTemplateEditor
}
