app std-dunning "1.2.0"
"std-dunning — failed-payment escalation ladder. Lists / escalates / resolves / suspends dunning cases. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes Financial-pattern knobs."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital DunningCaseOrbital {
  entity DunningCase [persistent: dunningcases] {
    id             : string!
    subscriptionId : string!
    customerId     : string!
    severity       : "soft" | "urgent" | "final" = "soft"
    attemptNumber  : number = 1
    attemptsTotal  : number = 4
    failedAt       : string
    nextRetryAt    : string
    amountDue      : number
    currency       : string = "USD"
    resolvedAt     : string
    status         : "open" | "resolved" | "suspended" = "open"
  }

  type DunningCaseLoaded       = Event { data : [DunningCase] }              "Fired when the dunning-case collection finishes loading"
  type DunningCaseLoadFailed   = Event { error : string, code : string }     "Fired when the dunning-case collection fails to load"
  type DunningCaseUpdated      = Event { row : DunningCase }                 "Fired after a dunning case's status persists"
  type DunningCaseUpdateFailed = Event { error : string, code : string }     "Fired when a dunning case's status update fails to persist"

  trait DunningEscalate -> DunningCase [interaction, collection] {
    config {
      title       : string   = "Dunning Cases"
        @label "Section title"
        @description "Heading shown above the failed-payment cases"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "subscriptionId", label: "Subscription", variant: "caption" },
        { name: "customerId",     label: "Customer",     variant: "caption" },
        { name: "severity",       label: "Severity",     variant: "badge"   },
        { name: "attemptNumber",  label: "Attempt",      variant: "caption" },
        { name: "amountDue",      label: "Amount Due",   variant: "caption" },
        { name: "status",         label: "Status",       variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Dunning Case entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_CASE", variant: "primary", icon: "arrow-right" },
        { label: "Suspend", event: "SUSPEND",   variant: "danger",  icon: "ban" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each case row"
        @tier "presentation"
      currency        : string   = "USD"
        @label "Default currency"
        @description "ISO 4217 currency code (USD, EUR, GBP, …) for amounts displayed on dunning cases."
        @tier "domain"
      taxStrategy     : "inclusive" | "exclusive" | "none" = "none"
        @label "Tax strategy"
        @description "inclusive = tax baked into amounts; exclusive = tax added on top; none = no tax."
        @tier "domain"
      roundingMode    : "bankers" | "half-up" | "down" = "half-up"
        @label "Rounding mode"
        @description "Sub-cent rounding behavior for amount calculations."
        @tier "domain"
      gracePeriodDays : number   = 7
        @label "Grace period (days)"
        @description "Days after failure before escalation severity rises. Wire via sibling std-lifecycle rule."
        @tier "domain"
      lateFeePolicy   : "none" | "flat" | "percent" = "none"
        @label "Late fee policy"
        @description "How late fees compute on overdue cases. Declarative; wiring deferred."
        @tier "domain"
      lateFeeAmount   : number   = 0
        @label "Late fee amount"
        @description "Flat cash amount or percentage (per lateFeePolicy)."
        @tier "domain"
      complianceJurisdiction : string = ""
        @label "Compliance jurisdiction"
        @description "Drives debt-collection regulations per locale: 'US-CA', 'EU-DE', 'UK', etc. Declarative."
        @tier "domain"
      retentionYears  : number   = 7
        @label "Retention (years)"
        @description "Years to keep dunning records for compliance."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading dunning cases…" }] })
      DunningCaseLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Open cases", value: "@payload.data.length", icon: "alert-triangle" }, { type: "stat-display", label: "Recovered", value: "18", icon: "check-circle" }, { type: "stat-display", label: "Suspended", value: "3", icon: "ban" }, { type: "stat-display", label: "Recovery rate", value: "62%", icon: "trending-up" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      DunningCaseLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_CASE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.subscriptionId @payload.row.subscriptionId)
        (set @entity.customerId @payload.row.customerId)
        (set @entity.severity @payload.row.severity)
        (set @entity.attemptNumber @payload.row.attemptNumber)
        (set @entity.attemptsTotal @payload.row.attemptsTotal)
        (set @entity.failedAt @payload.row.failedAt)
        (set @entity.nextRetryAt @payload.row.nextRetryAt)
        (set @entity.amountDue @payload.row.amountDue)
        (set @entity.currency @payload.row.currency)
        (set @entity.resolvedAt @payload.row.resolvedAt)
        (set @entity.status @payload.row.status)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "alert-triangle" }, { type: "typography", content: "@entity.subscriptionId", variant: "h3" }, { type: "badge", label: "@entity.severity", variant: "primary" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Customer" }, { type: "typography", variant: "body", content: "@entity.customerId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Currency" }, { type: "typography", variant: "body", content: "@entity.currency" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Failed at" }, { type: "typography", variant: "body", content: "@entity.failedAt" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Next retry" }, { type: "typography", variant: "body", content: "@entity.nextRetryAt" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Amount due", value: "@entity.amountDue", icon: "dollar-sign" }, { type: "stat-display", label: "Attempt", value: "@entity.attemptNumber", icon: "repeat" }, { type: "stat-display", label: "Total attempts", value: "@entity.attemptsTotal", icon: "list" }, { type: "stat-display", label: "Resolved at", value: "@entity.resolvedAt", icon: "check-circle" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Escalate", variant: "primary", action: "ESCALATE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Resolve", variant: "secondary", action: "RESOLVE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Suspend", variant: "danger", action: "SUSPEND", actionPayload: { id: "@entity.id" } }] }] })
      SUSPEND -> loading
        (set @entity.id @payload.id)
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Suspending service…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update DunningCase @entity { emit: { success: "DunningCaseUpdated", failure: "DunningCaseUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating case status…" }] })
      DunningCaseUpdated -> loading
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
      DunningCaseUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading dunning cases…" }] })
      ESCALATE -> loading
        (set @entity.id @payload.id)
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Escalating case…" }] })
      RESOLVE -> loading
        (set @entity.id @payload.id)
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Resolving case…" }] })
      SUSPEND -> loading
        (set @entity.id @payload.id)
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Suspending service…" }] })
    }
    state error {
      INIT -> loading
        (fetch DunningCase { emit: { success: "DunningCaseLoaded", failure: "DunningCaseLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_CASE  { id : string!, row : DunningCase }
      CLOSE_VIEW { }
      ESCALATE   { id : string! }
      RESOLVE    { id : string! }
      SUSPEND    { id : string! }
      DunningCaseLoaded       { data : [DunningCase] }
      DunningCaseLoadFailed   { error : string, code : string }
      DunningCaseUpdated      { row : DunningCase }
      DunningCaseUpdateFailed { error : string, code : string }
    }
    listens {
      OPEN_CASE  { id : string!, row : DunningCase }
      CLOSE_VIEW { }
      ESCALATE   { id : string! }
      RESOLVE    { id : string! }
      SUSPEND    { id : string! }
      SET_STATUS { entityId : string!, newStatus : string! }
      DunningCaseLoaded       { data : [DunningCase] }
      DunningCaseLoadFailed   { error : string, code : string }
      DunningCaseUpdated      { row : DunningCase }
      DunningCaseUpdateFailed { error : string, code : string }
    }
  }
  page "/dunningcases/escalate" as DunningEscalatePage -> DunningEscalate
}
