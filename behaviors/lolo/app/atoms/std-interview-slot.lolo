app std-interview-slot "1.2.0"
"std-interview-slot — scheduled interview between applicant and interviewers. Listens for SET_STATUS so sibling std-lifecycle can drive automated transitions. Exposes Scheduling/Booking + HR knobs (bookingWindowDays, leadTimeMinutes, backgroundCheckRequired, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital InterviewSlotOrbital {
  entity InterviewSlot [persistent: interviewslots] {
    id              : string!
    applicantId     : string!
    applicantName   : string = ""
    interviewerName : string = ""
    scheduledAt     : string!
    durationMinutes : number = 60
    format          : "phone" | "video" | "onsite" = "video"
    status          : "scheduled" | "completed" | "cancelled" | "no_show" = "scheduled"
    notes           : string = ""
  }

  type InterviewSlotLoaded     = Event { data : [InterviewSlot] }         "Fired when the interview-slot collection finishes loading"
  type InterviewSlotLoadFailed = Event { error : string, code : string }  "Fired when the interview-slot collection fails to load"

  trait InterviewSlotSchedule -> InterviewSlot [interaction, collection] {
    config {
      title       : string   = "Interviews"
        @label "Section title"
        @description "Heading shown above the interview schedule"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "applicantName",   label: "Applicant",   variant: "caption" },
        { name: "interviewerName", label: "Interviewer", variant: "caption" },
        { name: "scheduledAt",     label: "Scheduled",   variant: "caption" },
        { name: "format",          label: "Format",      variant: "badge"   },
        { name: "status",          label: "Status",      variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Interview Slot entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",   event: "OPEN_INTERVIEW",   variant: "primary", icon: "arrow-right" },
        { label: "Cancel", event: "CANCEL_INTERVIEW", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each interview row"
        @tier "presentation"
      bookingWindowDays : number = 30
        @label "Booking window (days)"
        @description "How far in advance applicants can schedule interviews."
        @tier "domain"
      leadTimeMinutes : number = 60
        @label "Lead time (minutes)"
        @description "Minimum minutes before start time that a new booking is accepted."
        @tier "domain"
      bookingHours : string = "09:00-17:00"
        @label "Booking hours"
        @description "Daily window during which interviews can be scheduled (HH:MM-HH:MM)."
        @tier "domain"
      blackoutDates : [string] = []
        @label "Blackout dates"
        @description "ISO dates blocked from booking (e.g. holidays). Compose std-lifecycle to enforce."
        @tier "domain"
      noShowGracePeriodMinutes : number = 15
        @label "No-show grace (minutes)"
        @description "Minutes after scheduledAt before the slot auto-marks no_show. Wire via std-lifecycle."
        @tier "domain"
      rescheduleWindowHours : number = 24
        @label "Reschedule window (hours)"
        @description "Hours before scheduledAt during which the applicant can self-reschedule."
        @tier "domain"
      maxReschedules : number = 2
        @label "Max reschedules"
        @description "Hard cap on reschedule count per interview slot."
        @tier "domain"
      cancellationPolicy : "free" | "partial-refund" | "no-refund" = "free"
        @label "Cancellation policy"
        @description "Refund treatment when a slot is cancelled inside the reschedule window."
        @tier "domain"
      backgroundCheckRequired : boolean = false
        @label "Background check required"
        @description "Block COMPLETE_INTERVIEW until a background check is on file."
        @tier "domain"
      eVerifyRequired : boolean = false
        @label "E-Verify required"
        @description "US I-9 / E-Verify gate. Block downstream offer until verification passes."
        @tier "domain"
      i9DocumentsRequired : boolean = false
        @label "I-9 documents required"
        @description "Require I-9 supporting documents before accepting an offer downstream."
        @tier "domain"
      anonymizeOnRejection : boolean = false
        @label "Anonymize on rejection"
        @description "When true, scrub applicant PII on rejection. Pair with std-data-erasure."
        @tier "domain"
      retentionAfterRejectionDays : number = 730
        @label "Retention after rejection (days)"
        @description "Days to keep rejected interview records. Default 730 (2 years) EEOC typical."
        @tier "domain"
      equalOpportunityTrackingEnabled : boolean = false
        @label "Equal opportunity tracking"
        @description "Capture demographic data separately for EEO reporting (sibling collection)."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch InterviewSlot { emit: { success: "InterviewSlotLoaded", failure: "InterviewSlotLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading interviews…" }] })
      InterviewSlotLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Scheduled", value: "@payload.data.length", icon: "calendar" }, { type: "stat-display", label: "Today", value: "9", icon: "clock" }, { type: "stat-display", label: "Completed this week", value: "37", icon: "check-circle" }, { type: "stat-display", label: "No-show rate", value: "6%", icon: "alert-triangle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      InterviewSlotLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_INTERVIEW -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.applicantId @payload.row.applicantId)
        (set @entity.applicantName @payload.row.applicantName)
        (set @entity.interviewerName @payload.row.interviewerName)
        (set @entity.scheduledAt @payload.row.scheduledAt)
        (set @entity.durationMinutes @payload.row.durationMinutes)
        (set @entity.format @payload.row.format)
        (set @entity.status @payload.row.status)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "calendar" }, { type: "typography", content: "@entity.applicantName", variant: "h3" }, { type: "badge", label: "@entity.format", variant: "primary" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Interviewer" }, { type: "typography", variant: "body", content: "@entity.interviewerName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Applicant ID" }, { type: "typography", variant: "body", content: "@entity.applicantId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Scheduled", value: "@entity.scheduledAt", icon: "calendar" }, { type: "stat-display", label: "Duration (min)", value: "@entity.durationMinutes", icon: "clock" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Complete", variant: "primary", action: "COMPLETE_INTERVIEW", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Cancel", variant: "danger", action: "CANCEL_INTERVIEW", actionPayload: { id: "@entity.id" } }] }] })
      CANCEL_INTERVIEW -> loading
        (set @entity.id @payload.id)
        (fetch InterviewSlot { emit: { success: "InterviewSlotLoaded", failure: "InterviewSlotLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling interview…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update InterviewSlot @entity { emit: { success: "InterviewSlotLoaded", failure: "InterviewSlotLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating interview status…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch InterviewSlot { emit: { success: "InterviewSlotLoaded", failure: "InterviewSlotLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading interviews…" }] })
      COMPLETE_INTERVIEW -> loading
        (set @entity.id @payload.id)
        (fetch InterviewSlot { emit: { success: "InterviewSlotLoaded", failure: "InterviewSlotLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Completing interview…" }] })
      CANCEL_INTERVIEW -> loading
        (set @entity.id @payload.id)
        (fetch InterviewSlot { emit: { success: "InterviewSlotLoaded", failure: "InterviewSlotLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling interview…" }] })
    }
    state error {
      INIT -> loading
        (fetch InterviewSlot { emit: { success: "InterviewSlotLoaded", failure: "InterviewSlotLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_INTERVIEW           { id : string!, row : InterviewSlot }
      CLOSE_VIEW               { }
      COMPLETE_INTERVIEW       { id : string! }
      CANCEL_INTERVIEW         { id : string! }
      InterviewSlotLoaded      { data : [InterviewSlot] }
      InterviewSlotLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_INTERVIEW           { id : string!, row : InterviewSlot }
      CLOSE_VIEW               { }
      COMPLETE_INTERVIEW       { id : string! }
      CANCEL_INTERVIEW         { id : string! }
      SET_STATUS               { entityId : string!, newStatus : string! }
      InterviewSlotLoaded      { data : [InterviewSlot] }
      InterviewSlotLoadFailed  { error : string, code : string }
    }
  }
  page "/interviews" as InterviewSlotPage -> InterviewSlotSchedule
}
