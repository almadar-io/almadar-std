app std-work-order "1.0.0"
"std-work-order — field-service work order lifecycle (created → assigned → en-route → on-site → completed). Owns a WorkOrder entity and a single dispatch trait that loads the queue, renders it in a data-grid, and persists status transitions back to the row."

orbital WorkOrderOrbital {
  entity WorkOrder [persistent: workorders] {
    id           : string!
    customerName : string!
    serviceType  : string!
    address      : string!
    priority     : "low" | "normal" | "high" | "urgent" = "normal"
    status       : "created" | "assigned" | "en-route" | "on-site" | "completed" | "cancelled" = "created"
    assignedTo   : string
    scheduledAt  : string
    etaMinutes   : number
    notes        : string
    createdAt    : string
  }

  type WorkOrderLoaded        = Event { data : [WorkOrder] }              "Fired when the work order collection finishes loading"
  type WorkOrderLoadFailed    = Event { error : string, code : string }   "Fired when the work order collection fails to load"
  type WorkOrderUpdated       = Event { row : WorkOrder }                 "Fired after a work order's status persists (assign / travel / arrive / complete / cancel)"
  type WorkOrderUpdateFailed  = Event { error : string, code : string }   "Fired when a work order's status update fails to persist"

  trait WorkOrderManage -> WorkOrder [interaction, collection] {
    config {
      title : string = "Work Orders"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch WorkOrder { emit: { success: "WorkOrderLoaded", failure: "WorkOrderLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading work orders…" }] })
      WorkOrderLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "clipboard-list" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "customerName", label: "Customer", variant: "label" }, { name: "serviceType", label: "Service", variant: "caption" }, { name: "address", label: "Address", variant: "caption" }, { name: "priority", label: "Priority", variant: "badge" }, { name: "status", label: "Status", variant: "badge" }, { name: "assignedTo", label: "Assigned", variant: "caption" }, { name: "etaMinutes", label: "ETA (min)", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Assign", event: "ASSIGN", variant: "primary", icon: "user-plus" }, { label: "Start Travel", event: "START_TRAVEL", variant: "secondary", icon: "navigation" }, { label: "Arrive", event: "ARRIVE", variant: "secondary", icon: "map-pin" }, { label: "Complete", event: "COMPLETE", variant: "primary", icon: "check" }, { label: "Cancel", event: "CANCEL", variant: "destructive", icon: "x" }] }] })
      WorkOrderLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      ASSIGN -> browsing
        (set @entity.id @payload.id)
        (set @entity.assignedTo @payload.assignedTo)
        (set @entity.status "assigned")
        (persist update WorkOrder @entity { emit: { success: "WorkOrderUpdated", failure: "WorkOrderUpdateFailed" } })
      START_TRAVEL -> browsing
        (set @entity.id @payload.id)
        (set @entity.etaMinutes @payload.etaMinutes)
        (set @entity.status "en-route")
        (persist update WorkOrder @entity { emit: { success: "WorkOrderUpdated", failure: "WorkOrderUpdateFailed" } })
      ARRIVE -> browsing
        (set @entity.id @payload.id)
        (set @entity.status "on-site")
        (persist update WorkOrder @entity { emit: { success: "WorkOrderUpdated", failure: "WorkOrderUpdateFailed" } })
      COMPLETE -> browsing
        (set @entity.id @payload.id)
        (set @entity.notes @payload.notes)
        (set @entity.status "completed")
        (persist update WorkOrder @entity { emit: { success: "WorkOrderUpdated", failure: "WorkOrderUpdateFailed" } })
      CANCEL -> browsing
        (set @entity.id @payload.id)
        (set @entity.notes @payload.notes)
        (set @entity.status "cancelled")
        (persist update WorkOrder @entity { emit: { success: "WorkOrderUpdated", failure: "WorkOrderUpdateFailed" } })
      WorkOrderUpdated -> loading
        (fetch WorkOrder { emit: { success: "WorkOrderLoaded", failure: "WorkOrderLoadFailed" } })
      WorkOrderUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state error {
      INIT -> loading
        (fetch WorkOrder { emit: { success: "WorkOrderLoaded", failure: "WorkOrderLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      ASSIGN       { id : string!, assignedTo : string!, row : WorkOrder }
      START_TRAVEL { id : string!, etaMinutes : number!, row : WorkOrder }
      ARRIVE       { id : string!, row : WorkOrder }
      COMPLETE     { id : string!, notes : string, row : WorkOrder }
      CANCEL       { id : string!, notes : string, row : WorkOrder }
      WorkOrderLoaded       { data : [WorkOrder] }
      WorkOrderLoadFailed   { error : string, code : string }
      WorkOrderUpdated      { row : WorkOrder }
      WorkOrderUpdateFailed { error : string, code : string }
    }
    listens {
      ASSIGN       { id : string!, assignedTo : string!, row : WorkOrder }
      START_TRAVEL { id : string!, etaMinutes : number!, row : WorkOrder }
      ARRIVE       { id : string!, row : WorkOrder }
      COMPLETE     { id : string!, notes : string, row : WorkOrder }
      CANCEL       { id : string!, notes : string, row : WorkOrder }
      WorkOrderLoaded       { data : [WorkOrder] }
      WorkOrderLoadFailed   { error : string, code : string }
      WorkOrderUpdated      { row : WorkOrder }
      WorkOrderUpdateFailed { error : string, code : string }
    }
  }
  page "/workorders/manage" as WorkOrderManagePage -> WorkOrderManage
}
