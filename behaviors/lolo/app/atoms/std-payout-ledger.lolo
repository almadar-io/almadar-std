app std-payout-ledger "1.1.0"
"std-payout-ledger — marketplace vendor payout atom. Lists payouts in `browsing`; opens detail in `viewing_single` with Withdraw / Mark Paid actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital PayoutOrbital {
  entity Payout [persistent: payouts] {
    id                : string!
    vendorId          : string!
    amount            : number!
    currency          : string = "USD"
    status            : "pending" | "processing" | "paid" | "failed" = "pending"
    bankAccountMasked : string
    requestedAt       : string
    paidAt            : string
    notes             : string
  }

  type PayoutLoaded          = Event { data : [Payout] }                "Fired when the payout collection finishes loading"
  type PayoutLoadFailed      = Event { error : string, code : string }  "Fired when the payout collection fails to load"

  trait PayoutLedger -> Payout [interaction, collection] {
    config {
      title             : string   = "Payouts"
        @label "Section title"
        @description "Heading shown above the vendor payout ledger"
      minimumWithdrawal : number   = 50
        @label "Minimum withdrawal"
        @description "Smallest amount a vendor can request to cash out"
      fields            : [FieldSpec] = [
        { name: "vendorId",          label: "Vendor",    variant: "caption" },
        { name: "amount",            label: "Amount",    variant: "caption" },
        { name: "currency",          label: "Currency",  variant: "badge"   },
        { name: "status",            label: "Status",    variant: "badge"   },
        { name: "bankAccountMasked", label: "Bank",      variant: "caption" },
        { name: "requestedAt",       label: "Requested", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Payout entity"
      itemActions       : [ItemAction] = [
        { label: "Open",     event: "OPEN_PAYOUT",      variant: "primary", icon: "arrow-right" },
        { label: "Withdraw", event: "REQUEST_WITHDRAW", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each payout row"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Payout { emit: { success: "PayoutLoaded", failure: "PayoutLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading payouts…" }] })
      PayoutLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wallet" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total payouts", value: "@payload.data.length", icon: "wallet" }, { type: "stat-display", label: "Pending", value: "12", icon: "clock" }, { type: "stat-display", label: "Paid this month", value: "$48,200", icon: "check-circle" }, { type: "stat-display", label: "Minimum", value: "@config.minimumWithdrawal", icon: "dollar-sign" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      PayoutLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_PAYOUT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.vendorId @payload.row.vendorId)
        (set @entity.amount @payload.row.amount)
        (set @entity.currency @payload.row.currency)
        (set @entity.status @payload.row.status)
        (set @entity.bankAccountMasked @payload.row.bankAccountMasked)
        (set @entity.requestedAt @payload.row.requestedAt)
        (set @entity.paidAt @payload.row.paidAt)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "wallet" }, { type: "typography", content: "@entity.vendorId", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Bank" }, { type: "typography", variant: "body", content: "@entity.bankAccountMasked" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Amount", value: "@entity.amount", icon: "dollar-sign" }, { type: "stat-display", label: "Requested", value: "@entity.requestedAt", icon: "calendar" }, { type: "stat-display", label: "Paid", value: "@entity.paidAt", icon: "check-circle" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Withdraw", variant: "primary", action: "REQUEST_WITHDRAW", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Mark Paid", variant: "secondary", action: "MARK_PAID", actionPayload: { id: "@entity.id" } }] }] })
      REQUEST_WITHDRAW -> loading
        (set @entity.id @payload.id)
        (fetch Payout { emit: { success: "PayoutLoaded", failure: "PayoutLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Requesting withdrawal…" }] })
      MARK_PAID -> loading
        (set @entity.id @payload.id)
        (fetch Payout { emit: { success: "PayoutLoaded", failure: "PayoutLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking paid…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Payout { emit: { success: "PayoutLoaded", failure: "PayoutLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading payouts…" }] })
      REQUEST_WITHDRAW -> loading
        (set @entity.id @payload.id)
        (fetch Payout { emit: { success: "PayoutLoaded", failure: "PayoutLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Requesting withdrawal…" }] })
      MARK_PAID -> loading
        (set @entity.id @payload.id)
        (fetch Payout { emit: { success: "PayoutLoaded", failure: "PayoutLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking paid…" }] })
    }
    state error {
      INIT -> loading
        (fetch Payout { emit: { success: "PayoutLoaded", failure: "PayoutLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_PAYOUT          { id : string!, row : Payout }
      CLOSE_VIEW           { }
      REQUEST_WITHDRAW     { id : string! }
      MARK_PAID            { id : string! }
      PayoutLoaded         { data : [Payout] }
      PayoutLoadFailed     { error : string, code : string }
    }
    listens {
      OPEN_PAYOUT          { id : string!, row : Payout }
      CLOSE_VIEW           { }
      REQUEST_WITHDRAW     { id : string! }
      MARK_PAID            { id : string! }
      PayoutLoaded         { data : [Payout] }
      PayoutLoadFailed     { error : string, code : string }
    }
  }
  page "/payouts/ledger" as PayoutLedgerPage -> PayoutLedger
}
