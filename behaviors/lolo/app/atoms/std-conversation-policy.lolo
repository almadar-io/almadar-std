app std-conversation-policy "1.0.0"
"std-conversation-policy — chat/realtime governance: retention, e2ee, moderation mode, edit/delete windows."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital ConversationPolicyOrbital {
  entity ConversationPolicy [persistent: conversation_policies] {
    id          : string!
    name        : string!
    description : string = ""
    appliesTo   : string = ""
    status      : "active" | "archived" = "active"
    createdAt   : string = ""
  }

  type ConversationPolicyLoaded     = Event { data : [ConversationPolicy] }              "Fired when the conversation policy collection finishes loading"
  type ConversationPolicyLoadFailed = Event { error : string, code : string }            "Fired when the conversation policy collection fails to load"

  trait ConversationPolicyManage -> ConversationPolicy [interaction, collection] {
    config {
      title       : string   = "Conversation Policies"
        @label "Section title"
        @description "Heading shown above the conversation policies list"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "name",      label: "Policy",     variant: "caption" },
        { name: "appliesTo", label: "Applies to", variant: "caption" },
        { name: "status",    label: "Status",     variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Conversation Policy entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_POLICY",    variant: "primary", icon: "arrow-right" },
        { label: "Archive", event: "ARCHIVE_POLICY", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each policy row"
        @tier "presentation"
      retentionDays : number = 365
        @label "Message retention (days)"
        @description "Days to keep messages before lifecycle deletion. Compose std-data-erasure for cleanup."
        @tier "domain"
        @synonyms "history retention"
      e2eeRequired : boolean = false
        @label "E2EE required"
        @description "When true, conversations must be end-to-end encrypted."
        @tier "domain"
        @synonyms "end-to-end encryption, encrypted chat"
      moderationMode : "off" | "post-hoc" | "pre-publish" | "human-only" = "post-hoc"
        @label "Moderation mode"
        @description "post-hoc = scan after send; pre-publish = scan before send (delay); human-only = no AI scan."
        @tier "domain"
      editWindowMinutes : number = 15
        @label "Edit window (minutes)"
        @description "Minutes after send a user can edit a message. 0 = no editing."
        @tier "domain"
      deleteWindowMinutes : number = 1440
        @label "Delete window (minutes)"
        @description "Minutes after send a user can delete a message. 0 = no deletion. 1440 = 24 hours."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch ConversationPolicy { emit: { success: "ConversationPolicyLoaded", failure: "ConversationPolicyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading conversation policies…" }] })
      ConversationPolicyLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-square" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total policies", value: "@payload.data.length", icon: "message-square" }, { type: "stat-display", label: "Active", value: "8", icon: "check-circle" }, { type: "stat-display", label: "E2EE channels", value: "3", icon: "lock" }, { type: "stat-display", label: "Archived", value: "2", icon: "archive" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      ConversationPolicyLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_POLICY -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.description @payload.row.description)
        (set @entity.appliesTo @payload.row.appliesTo)
        (set @entity.status @payload.row.status)
        (set @entity.createdAt @payload.row.createdAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "message-square" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Applies to" }, { type: "typography", variant: "body", content: "@entity.appliesTo" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Archive", variant: "danger", action: "ARCHIVE_POLICY", actionPayload: { id: "@entity.id" } }] }] })
      ARCHIVE_POLICY -> loading
        (set @entity.id @payload.id)
        (fetch ConversationPolicy { emit: { success: "ConversationPolicyLoaded", failure: "ConversationPolicyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving policy…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch ConversationPolicy { emit: { success: "ConversationPolicyLoaded", failure: "ConversationPolicyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading conversation policies…" }] })
      ARCHIVE_POLICY -> loading
        (set @entity.id @payload.id)
        (fetch ConversationPolicy { emit: { success: "ConversationPolicyLoaded", failure: "ConversationPolicyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving policy…" }] })
    }
    state error {
      INIT -> loading
        (fetch ConversationPolicy { emit: { success: "ConversationPolicyLoaded", failure: "ConversationPolicyLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_POLICY                    { id : string!, row : ConversationPolicy }
      CLOSE_VIEW                     { }
      ARCHIVE_POLICY                 { id : string!, row : ConversationPolicy }
      ConversationPolicyLoaded       { data : [ConversationPolicy] }
      ConversationPolicyLoadFailed   { error : string, code : string }
    }
    listens {
      OPEN_POLICY                    { id : string!, row : ConversationPolicy }
      CLOSE_VIEW                     { }
      ARCHIVE_POLICY                 { id : string! }
      ConversationPolicyLoaded       { data : [ConversationPolicy] }
      ConversationPolicyLoadFailed   { error : string, code : string }
    }
  }
  page "/conversation-policies" as ConversationPolicyPage -> ConversationPolicyManage
}
