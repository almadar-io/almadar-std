app std-submittal "1.2.0"
"std-submittal — construction submittal lifecycle. Listens for SET_STATUS so std-lifecycle can auto-escalate SLA breaches. Exposes Service/Operations knobs (responseTimeMinutes, resolutionSLAHours, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital SubmittalOrbital {
  entity Submittal [persistent: submittals] {
    id              : string!
    submittalNumber : string!
    specSection     : string = ""
    title           : string!
    contractor      : string = ""
    reviewer        : string = ""
    status          : "draft" | "submitted" | "in-review" | "approved" | "rejected" | "revise-resubmit" = "draft"
    revisionNumber  : number = 0
    submittedAt     : string = ""
    reviewedAt      : string = ""
    comments        : string = ""
    pendingId       : string = ""
  }

  type SubmittalLoaded     = Event { data : [Submittal], totalCount : number } "Fired when the submittal collection finishes loading"
  type SubmittalLoadFailed = Event { error : string, code : string }           "Fired when the submittal collection fails to load"

  trait SubmittalReview -> Submittal [interaction, collection] {
    config {
      title : string = "Submittals"
        @label "Section title"
        @description "Heading shown above the submittal review list"
        @tier "presentation"
      fields      : [FieldSpec] = [{ name: "submittalNumber", label: "Number", variant: "caption" }, { name: "specSection", label: "Spec Section", variant: "caption" }, { name: "title", label: "Title", variant: "caption" }, { name: "contractor", label: "Contractor", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "revisionNumber", label: "Rev", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Submittal entity"
        @tier "presentation"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_SUBMITTAL", variant: "primary", icon: "arrow-right" }, { label: "Delete", event: "REQUEST_DELETE", variant: "danger" }]
        @label "Row actions"
        @description "Buttons users can click on each submittal row"
        @tier "presentation"
      serviceAreaRadius : number = 0
        @label "Service area radius (mi)"
        @description "Project-site distance limit for assignable reviewers. Zero = no restriction."
        @tier "domain"
      serviceZones : [string] = []
        @label "Service zones"
        @description "Named project zones for routing submittals to the right reviewer pool."
        @tier "domain"
      dispatchStrategy : "nearest" | "round-robin" | "manual" = "manual"
        @label "Dispatch strategy"
        @description "How reviewers are assigned to incoming submittals."
        @tier "domain"
      skillsRequired : [string] = []
        @label "Required skills"
        @description "Discipline tags a reviewer must hold (e.g. 'structural', 'mep', 'arch')."
        @tier "domain"
      responseTimeMinutes : number = 1440
        @label "Response time SLA (min)"
        @description "Target minutes from submittal received to first acknowledgement (default 1 day)."
        @tier "domain"
      resolutionSLAHours : number = 240
        @label "Resolution SLA (hours)"
        @description "Target hours from receipt to approved/rejected (default 10 business days). Compose std-lifecycle to escalate."
        @tier "domain"
      escalationThresholdHours : number = 336
        @label "Escalation threshold (hours)"
        @description "Hours after which a stalled submittal auto-escalates (default 14 days)."
        @tier "domain"
      customerVisibleStatuses : [string] = ["submitted", "in-review", "approved", "rejected", "revise-resubmit"]
        @label "Customer-visible statuses"
        @description "Subset of statuses contractors see in their portal."
        @tier "domain"
      requirePhotoOnComplete : boolean = false
        @label "Require photo on complete"
        @description "Block APPROVE unless a marked-up reviewer image is attached."
        @tier "domain"
      requireSignatureOnComplete : boolean = false
        @label "Require reviewer signature on complete"
        @description "Block APPROVE unless reviewer signature is captured (compose std-signature-capture)."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading submittals…" }] })
      SubmittalLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total submittals", value: "@payload.data.length", icon: "file-text" }, { type: "stat-display", label: "In review", value: "18", icon: "search" }, { type: "stat-display", label: "Approved", value: "62", icon: "check-circle" }, { type: "stat-display", label: "Revise & resubmit", value: "7", icon: "rotate-cw" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      SubmittalLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_SUBMITTAL -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.submittalNumber @payload.row.submittalNumber)
        (set @entity.specSection @payload.row.specSection)
        (set @entity.title @payload.row.title)
        (set @entity.contractor @payload.row.contractor)
        (set @entity.reviewer @payload.row.reviewer)
        (set @entity.status @payload.row.status)
        (set @entity.revisionNumber @payload.row.revisionNumber)
        (set @entity.submittedAt @payload.row.submittedAt)
        (set @entity.reviewedAt @payload.row.reviewedAt)
        (set @entity.comments @payload.row.comments)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "file-text" }, { type: "typography", content: "@entity.title", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Number" }, { type: "typography", variant: "body", content: "@entity.submittalNumber" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Spec section" }, { type: "typography", variant: "body", content: "@entity.specSection" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Contractor" }, { type: "typography", variant: "body", content: "@entity.contractor" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Reviewer" }, { type: "typography", variant: "body", content: "@entity.reviewer" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Comments" }, { type: "typography", variant: "body", content: "@entity.comments" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Revision", value: "@entity.revisionNumber", icon: "rotate-cw" }, { type: "stat-display", label: "Submitted", value: "@entity.submittedAt", icon: "calendar" }, { type: "stat-display", label: "Reviewed", value: "@entity.reviewedAt", icon: "calendar-check" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Approve", variant: "primary", action: "APPROVE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Reject", variant: "danger", action: "REJECT", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Revise", variant: "secondary", action: "REQUEST_REVISION", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Delete", variant: "danger", action: "REQUEST_DELETE", actionPayload: { id: "@entity.id" } }] }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting submittal…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update Submittal @entity { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating submittal status…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading submittals…" }] })
      APPROVE -> loading
        (set @entity.id @payload.id)
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Approving submittal…" }] })
      REJECT -> loading
        (set @entity.id @payload.id)
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Rejecting submittal…" }] })
      REQUEST_REVISION -> loading
        (set @entity.id @payload.id)
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Requesting revision…" }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting submittal…" }] })
    }
    state error {
      INIT -> loading
        (fetch Submittal { emit: { success: "SubmittalLoaded", failure: "SubmittalLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_SUBMITTAL      { id : string!, row : Submittal }
      CLOSE_VIEW          { }
      APPROVE             { id : string! }
      REJECT              { id : string! }
      REQUEST_REVISION    { id : string! }
      REQUEST_DELETE      { id : string! }
      SubmittalLoaded     { data : [Submittal], totalCount : number }
      SubmittalLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_SUBMITTAL      { id : string!, row : Submittal }
      CLOSE_VIEW          { }
      APPROVE             { id : string! }
      REJECT              { id : string! }
      REQUEST_REVISION    { id : string! }
      REQUEST_DELETE      { id : string! }
      SET_STATUS          { entityId : string!, newStatus : string! }
      SubmittalLoaded     { data : [Submittal], totalCount : number }
      SubmittalLoadFailed { error : string, code : string }
    }
  }
  page "/submittals" as SubmittalPage -> SubmittalReview
}
