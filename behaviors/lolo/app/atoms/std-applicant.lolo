app std-applicant "1.0.0"
"std-applicant — job applicant primitive tracking a person who applied to a job, their current pipeline stage, and basic info."

orbital ApplicantOrbital {
  entity Applicant [persistent: applicants] {
    id         : string!
    name       : string!
    email      : string = ""
    phone      : string = ""
    jobId      : string = ""
    resumeUrl  : string = ""
    stage      : "applied" | "screening" | "interview" | "offer" | "hired" | "rejected" = "applied"
    notes      : string = ""
    appliedAt  : string = ""
  }

  type ApplicantLoaded     = Event { data : [Applicant] }              "Fired when the applicant collection finishes loading"
  type ApplicantLoadFailed = Event { error : string, code : string }   "Fired when the applicant collection fails to load"

  trait ApplicantPipeline -> Applicant [interaction, collection] {
    config {
      title : string = "Applicants"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading applicants…" }] })
      ApplicantLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "name", label: "Name", variant: "caption" }, { name: "email", label: "Email", variant: "caption" }, { name: "jobId", label: "Job", variant: "caption" }, { name: "stage", label: "Stage", variant: "badge" }, { name: "appliedAt", label: "Applied", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Advance", event: "ADVANCE_STAGE", variant: "primary" }, { label: "Reject", event: "REJECT_APPLICANT", variant: "danger" }] }] })
      ApplicantLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      ADVANCE_STAGE -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Applicant advanced" })
      REJECT_APPLICANT -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Applicant rejected" })
    }
    state error {
      INIT -> loading
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      ADVANCE_STAGE       { id : string!, row : Applicant }
      REJECT_APPLICANT    { id : string!, row : Applicant }
      ApplicantLoaded     { data : [Applicant] }
      ApplicantLoadFailed { error : string, code : string }
    }
    listens {
      ADVANCE_STAGE       { id : string! }
      REJECT_APPLICANT    { id : string! }
      ApplicantLoaded     { data : [Applicant] }
      ApplicantLoadFailed { error : string, code : string }
    }
  }
  page "/applicants" as ApplicantPage -> ApplicantPipeline
}
