app std-applicant "1.1.0"
"std-applicant — job applicant primitive tracking a person who applied to a job, their pipeline stage, and basic info. Lists applicants in `browsing`; opens applicant detail in `viewing_single` with Advance / Reject actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

orbital ApplicantOrbital {
  entity Applicant [persistent: applicants] {
    id         : string!
    name       : string!
    email      : string = ""
    phone      : string = ""
    jobId      : string = ""
    resumeUrl  : string = ""
    stage      : "applied" | "screening" | "interview" | "offer" | "hired" | "rejected" = "applied"
    notes      : string = ""
    appliedAt  : string = ""
  }

  type ApplicantLoaded     = Event { data : [Applicant] }              "Fired when the applicant collection finishes loading"
  type ApplicantLoadFailed = Event { error : string, code : string }   "Fired when the applicant collection fails to load"

  trait ApplicantPipeline -> Applicant [interaction, collection] {
    config {
      title       : string   = "Applicants"
        @label "Section title"
        @description "Heading shown above the applicant pipeline"
      fields      : [object] = [
        { name: "name",      label: "Name",    variant: "caption" },
        { name: "email",     label: "Email",   variant: "caption" },
        { name: "jobId",     label: "Job",     variant: "caption" },
        { name: "stage",     label: "Stage",   variant: "badge"   },
        { name: "appliedAt", label: "Applied", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Applicant entity"
      itemActions : [object] = [
        { label: "Open",   event: "OPEN_APPLICANT",   variant: "primary", icon: "arrow-right" },
        { label: "Reject", event: "REJECT_APPLICANT", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each applicant row"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading applicants…" }] })
      ApplicantLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total applicants", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "In interview", value: "18", icon: "message-square" }, { type: "stat-display", label: "Offers out", value: "5", icon: "send" }, { type: "stat-display", label: "Hired this month", value: "9", icon: "check-circle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      ApplicantLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_APPLICANT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.email @payload.row.email)
        (set @entity.phone @payload.row.phone)
        (set @entity.jobId @payload.row.jobId)
        (set @entity.resumeUrl @payload.row.resumeUrl)
        (set @entity.stage @payload.row.stage)
        (set @entity.notes @payload.row.notes)
        (set @entity.appliedAt @payload.row.appliedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "user" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.stage", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Job" }, { type: "typography", variant: "body", content: "@entity.jobId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Applied", value: "@entity.appliedAt", icon: "calendar" }, { type: "stat-display", label: "Resume", value: "@entity.resumeUrl", icon: "file-text" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Advance Stage", variant: "primary", action: "ADVANCE_STAGE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Reject", variant: "danger", action: "REJECT_APPLICANT", actionPayload: { id: "@entity.id" } }] }] })
      REJECT_APPLICANT -> loading
        (set @entity.id @payload.id)
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Rejecting applicant…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading applicants…" }] })
      ADVANCE_STAGE -> loading
        (set @entity.id @payload.id)
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Advancing applicant…" }] })
      REJECT_APPLICANT -> loading
        (set @entity.id @payload.id)
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Rejecting applicant…" }] })
    }
    state error {
      INIT -> loading
        (fetch Applicant { emit: { success: "ApplicantLoaded", failure: "ApplicantLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_APPLICANT      { id : string!, row : Applicant }
      CLOSE_VIEW          { }
      ADVANCE_STAGE       { id : string!, row : Applicant }
      REJECT_APPLICANT    { id : string!, row : Applicant }
      ApplicantLoaded     { data : [Applicant] }
      ApplicantLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_APPLICANT      { id : string!, row : Applicant }
      CLOSE_VIEW          { }
      ADVANCE_STAGE       { id : string! }
      REJECT_APPLICANT    { id : string! }
      ApplicantLoaded     { data : [Applicant] }
      ApplicantLoadFailed { error : string, code : string }
    }
  }
  page "/applicants" as ApplicantPage -> ApplicantPipeline
}
