app std-help-article "1.2.0"
"std-help-article — public help center article (title, body, category, status, view count). Listens for SET_STATUS so std-lifecycle can drive transitions. Exposes Content/Knowledge knobs (visibilityScope, keepVersions, enabledLocales, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital HelpArticleOrbital {
  entity HelpArticle [persistent: helparticles] {
    id               : string!
    title            : string!
    slug             : string!
    body             : string = ""
    summary          : string = ""
    categoryId       : string = ""
    categoryName     : string = ""
    author           : string = ""
    status           : "draft" | "published" | "archived" | "needs-update" = "draft"
    viewCount        : number = 0
    helpfulCount     : number = 0
    notHelpfulCount  : number = 0
    publishedAt      : string = ""
    updatedAt        : string = ""
    pendingId        : string = ""
  }

  type HelpArticleLoaded       = Event { data : [HelpArticle], totalCount : number } "Fired when the help article collection finishes loading"
  type HelpArticleLoadFailed   = Event { message : string }                           "Fired when the help article collection fails to load"
  type HelpArticleUpdated      = Event { row : HelpArticle }                          "Fired after a help article's status persists (SET_STATUS / lifecycle)"
  type HelpArticleUpdateFailed = Event { message : string }                           "Fired when a help article's status update fails to persist"

  trait HelpArticleManage -> HelpArticle [interaction, collection] {
    config {
      title       : string   = "Help Articles"
        @label "Section title"
        @description "Heading shown above the help articles list"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "title",        label: "Title",     variant: "caption" },
        { name: "slug",         label: "Slug",      variant: "caption" },
        { name: "categoryName", label: "Category",  variant: "caption" },
        { name: "author",       label: "Author",    variant: "caption" },
        { name: "status",       label: "Status",    variant: "badge"   },
        { name: "viewCount",    label: "Views",     variant: "caption" },
        { name: "publishedAt",  label: "Published", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Help Article entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_ARTICLE", variant: "primary", icon: "arrow-right" },
        { label: "Archive", event: "ARCHIVE",      variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each article row"
        @tier "presentation"
      visibilityScope          : "public" | "internal" | "customer" = "public"
        @label "Visibility scope"
        @description "Who can read published articles: public web, internal staff, signed-in customers."
        @tier "domain"
      scheduledPublishEnabled  : boolean = false
        @label "Scheduled publish"
        @description "Allow authors to schedule publish in the future. v1.2 declarative."
        @tier "domain"
      keepVersions             : number  = 10
        @label "Versions to retain"
        @description "How many revisions to keep per article. v1.2 declarative."
        @tier "domain"
      allowRollback            : boolean = true
        @label "Allow rollback"
        @description "Permit reverting an article to a prior retained version."
        @tier "domain"
      seoEnabled               : boolean = true
        @label "SEO meta enabled"
        @description "Emit canonical tags + meta description for indexing."
        @tier "domain"
      enabledLocales           : [string] = ["en"]
        @label "Enabled locales"
        @description "Locales the article can be translated into."
        @tier "domain"
      defaultLocale            : string  = "en"
        @label "Default locale"
        @description "Locale used when no translation is available for the reader's preferred language."
        @tier "domain"
      draftAutosaveSeconds     : number  = 30
        @label "Draft autosave interval (s)"
        @description "Seconds between draft autosaves in the editor."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch HelpArticle { emit: { success: "HelpArticleLoaded", failure: "HelpArticleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading help articles…" }] })
      HelpArticleLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "book-open" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total articles", value: "@payload.data.length", icon: "book-open" }, { type: "stat-display", label: "Published", value: "184", icon: "check-circle" }, { type: "stat-display", label: "Drafts", value: "12", icon: "edit" }, { type: "stat-display", label: "Avg helpful rate", value: "87%", icon: "thumbs-up" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      HelpArticleLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.message" })
    }
    state browsing {
      OPEN_ARTICLE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.title @payload.row.title)
        (set @entity.slug @payload.row.slug)
        (set @entity.summary @payload.row.summary)
        (set @entity.categoryName @payload.row.categoryName)
        (set @entity.author @payload.row.author)
        (set @entity.status @payload.row.status)
        (set @entity.viewCount @payload.row.viewCount)
        (set @entity.helpfulCount @payload.row.helpfulCount)
        (set @entity.notHelpfulCount @payload.row.notHelpfulCount)
        (set @entity.publishedAt @payload.row.publishedAt)
        (set @entity.updatedAt @payload.row.updatedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "book-open" }, { type: "typography", content: "@entity.title", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Slug" }, { type: "typography", variant: "body", content: "@entity.slug" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Category" }, { type: "typography", variant: "body", content: "@entity.categoryName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Author" }, { type: "typography", variant: "body", content: "@entity.author" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Summary" }, { type: "typography", variant: "body", content: "@entity.summary" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Views", value: "@entity.viewCount", icon: "eye" }, { type: "stat-display", label: "Helpful", value: "@entity.helpfulCount", icon: "thumbs-up" }, { type: "stat-display", label: "Not helpful", value: "@entity.notHelpfulCount", icon: "thumbs-down" }, { type: "stat-display", label: "Published", value: "@entity.publishedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Publish", variant: "primary", action: "PUBLISH", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Archive", variant: "danger", action: "ARCHIVE", actionPayload: { id: "@entity.id" } }] }] })
      ARCHIVE -> loading
        (set @entity.id @payload.id)
        (fetch HelpArticle { emit: { success: "HelpArticleLoaded", failure: "HelpArticleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving article…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update HelpArticle @entity { emit: { success: "HelpArticleUpdated", failure: "HelpArticleUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating article status…" }] })
      HelpArticleUpdated -> loading
        (fetch HelpArticle { emit: { success: "HelpArticleLoaded", failure: "HelpArticleLoadFailed" } })
      HelpArticleUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.message" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch HelpArticle { emit: { success: "HelpArticleLoaded", failure: "HelpArticleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading help articles…" }] })
      PUBLISH -> loading
        (set @entity.id @payload.id)
        (fetch HelpArticle { emit: { success: "HelpArticleLoaded", failure: "HelpArticleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Publishing article…" }] })
      ARCHIVE -> loading
        (set @entity.id @payload.id)
        (fetch HelpArticle { emit: { success: "HelpArticleLoaded", failure: "HelpArticleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving article…" }] })
    }
    state error {
      INIT -> loading
        (fetch HelpArticle { emit: { success: "HelpArticleLoaded", failure: "HelpArticleLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ARTICLE            { id : string!, row : HelpArticle }
      CLOSE_VIEW              { }
      PUBLISH                 { id : string! }
      ARCHIVE                 { id : string! }
      HelpArticleLoaded       { data : [HelpArticle], totalCount : number }
      HelpArticleLoadFailed   { message : string }
      HelpArticleUpdated      { row : HelpArticle }
      HelpArticleUpdateFailed { message : string }
    }
    listens {
      OPEN_ARTICLE            { id : string!, row : HelpArticle }
      CLOSE_VIEW              { }
      PUBLISH                 { id : string! }
      ARCHIVE                 { id : string! }
      SET_STATUS              { entityId : string!, newStatus : string! }
      HelpArticleLoaded       { data : [HelpArticle], totalCount : number }
      HelpArticleLoadFailed   { message : string }
      HelpArticleUpdated      { row : HelpArticle }
      HelpArticleUpdateFailed { message : string }
    }
  }
  page "/help-articles" as HelpArticlePage -> HelpArticleManage
}
