app std-warehouse "1.0.0"
"std-warehouse — physical or logical storage location where stock lives. Used by inventory and retail to scope stock counts."

orbital WarehouseOrbital {
  entity Warehouse [persistent: warehouses] {
    id        : string!
    name      : string!
    code      : string = ""
    address   : string = ""
    type      : "warehouse" | "store" | "transit" = "warehouse"
    isActive  : boolean = true
    totalSkus : number = 0
  }

  type WarehouseLoaded     = Event { data : [Warehouse] }              "Fired when the warehouse collection finishes loading"
  type WarehouseLoadFailed = Event { error : string, code : string }   "Fired when the warehouse collection fails to load"

  trait WarehouseDirectory -> Warehouse [interaction, collection] {
    config {
      title : string = "Locations"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Warehouse { emit: { success: "WarehouseLoaded", failure: "WarehouseLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading locations…" }] })
      WarehouseLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "warehouse" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "tabs", items: [{ id: "warehouses", label: "Warehouses" }, { id: "bins", label: "Bins" }, { id: "zones", label: "Zones" }], activeTab: "warehouses" }, { type: "grid", cols: 3, gap: "md", children: [{ type: "resource-counter", icon: "package", label: "Total SKUs", value: 0, max: 10000, color: "text-emerald-400", size: "md" }, { type: "resource-counter", icon: "boxes", label: "Pallets", value: 320, max: 500, color: "text-blue-400", size: "md" }, { type: "enemy-plate", name: "Low-stock alert: SKU-4421", health: 4, maxHealth: 100, level: 1, effects: [{ icon: "alert-triangle", label: "Below reorder" }] }] }, { type: "grid", cols: 4, gap: "sm", children: [{ type: "item-slot", icon: "package", label: "Bin A-01", quantity: 12, rarity: "common", size: "md", selected: false, empty: false }, { type: "item-slot", icon: "package", label: "Bin A-02", quantity: 8, rarity: "uncommon", size: "md", selected: false, empty: false }, { type: "item-slot", icon: "package", label: "Bin A-03", quantity: 0, rarity: "common", size: "md", selected: false, empty: true }, { type: "item-slot", icon: "package", label: "Bin A-04", quantity: 3, rarity: "rare", size: "md", selected: true, empty: false }] }, { type: "powerup-slots", active: [{ id: "fastpick", icon: "zap", label: "Fast Pick" }, { id: "scan", icon: "scan", label: "Auto Scan" }], maxSlots: 4 }, { type: "crafting-recipe", inputs: [{ icon: "package", label: "Part A", required: 2, available: 2 }, { icon: "package", label: "Part B", required: 1, available: 1 }], output: { icon: "box", label: "Kit 01", rarity: "rare" }, canCraft: true }, { type: "file-tree", tree: [{ name: "Warehouse 01", path: "/wh01", type: "dir", children: [{ name: "Aisle A", path: "/wh01/a", type: "dir", children: [{ name: "Bin A-01", path: "/wh01/a/01", type: "file" }, { name: "Bin A-02", path: "/wh01/a/02", type: "file" }] }, { name: "Aisle B", path: "/wh01/b", type: "dir", children: [{ name: "Bin B-01", path: "/wh01/b/01", type: "file" }] }] }], indent: 16 }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "code", label: "Code", variant: "caption" }, { name: "name", label: "Name", variant: "caption" }, { name: "type", label: "Type", variant: "badge" }, { name: "totalSkus", label: "SKUs", variant: "caption" }, { name: "isActive", label: "Active", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_WAREHOUSE", variant: "primary", icon: "arrow-right" }] }] })
      WarehouseLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_WAREHOUSE -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Opened location" })
    }
    state error {
      INIT -> loading
        (fetch Warehouse { emit: { success: "WarehouseLoaded", failure: "WarehouseLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_WAREHOUSE       { id : string! }
      WarehouseLoaded      { data : [Warehouse] }
      WarehouseLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_WAREHOUSE       { id : string! }
      WarehouseLoaded      { data : [Warehouse] }
      WarehouseLoadFailed  { error : string, code : string }
    }
  }
  page "/warehouses" as WarehousePage -> WarehouseDirectory
}
