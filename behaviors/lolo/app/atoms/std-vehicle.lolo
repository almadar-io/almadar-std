app std-vehicle "1.1.0"
"std-vehicle — fleet vehicle primitive. Lists vehicles in `browsing` with fleet stats + map view; opens vehicle detail in `viewing_single` (VIN, plate, make/model, odometer, status, driver) with Assign Driver / Maintenance / Retire actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

orbital VehicleOrbital {
  entity Vehicle [persistent: vehicles] {
    id               : string!
    vin              : string!
    licensePlate     : string!
    make             : string = ""
    model            : string = ""
    year             : number = 2020
    vehicleType      : "car" | "truck" | "van" | "trailer" | "motorcycle" = "car"
    odometer         : number = 0
    fuelType         : "gasoline" | "diesel" | "electric" | "hybrid" = "gasoline"
    status           : "active" | "maintenance" | "retired" | "in-transit" = "active"
    assignedDriverId : string = ""
    pendingId        : string = ""
  }

  type VehicleLoaded     = Event { data : [Vehicle], totalCount : number }   "Fired when the vehicle collection finishes loading"
  type VehicleLoadFailed = Event { error : string, code : string }           "Fired when the vehicle collection fails to load"

  trait VehicleFleet -> Vehicle [interaction, collection] {
    config {
      title : string = "Fleet"
        @label "Section title"
        @description "Heading shown above the fleet vehicle list"
      fields      : [object] = [{ name: "licensePlate", label: "Plate", variant: "caption" }, { name: "make", label: "Make", variant: "caption" }, { name: "model", label: "Model", variant: "caption" }, { name: "year", label: "Year", variant: "caption" }, { name: "vehicleType", label: "Type", variant: "badge" }, { name: "odometer", label: "Odometer", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Vehicle entity"
      itemActions : [object] = [{ label: "Open", event: "OPEN_VEHICLE", variant: "primary", icon: "arrow-right" }, { label: "Retire", event: "RETIRE", variant: "danger" }]
        @label "Row actions"
        @description "Buttons users can click on each vehicle row"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Vehicle { emit: { success: "VehicleLoaded", failure: "VehicleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading vehicles…" }] })
      VehicleLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "truck" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total vehicles", value: "@payload.data.length", icon: "truck" }, { type: "stat-display", label: "Active", value: "18", icon: "check-circle" }, { type: "stat-display", label: "In maintenance", value: "3", icon: "wrench" }, { type: "stat-display", label: "Avg odometer", value: "62,401 mi", icon: "gauge" }] }, { type: "map-view", markers: [], height: "240px", zoom: 10 }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      VehicleLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_VEHICLE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.vin @payload.row.vin)
        (set @entity.licensePlate @payload.row.licensePlate)
        (set @entity.make @payload.row.make)
        (set @entity.model @payload.row.model)
        (set @entity.year @payload.row.year)
        (set @entity.vehicleType @payload.row.vehicleType)
        (set @entity.odometer @payload.row.odometer)
        (set @entity.fuelType @payload.row.fuelType)
        (set @entity.status @payload.row.status)
        (set @entity.assignedDriverId @payload.row.assignedDriverId)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VEHICLE" }, { type: "icon", name: "truck" }, { type: "typography", content: "@entity.licensePlate", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "VIN" }, { type: "typography", variant: "body", content: "@entity.vin" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Make / Model" }, { type: "typography", variant: "body", content: "@entity.make" }, { type: "typography", variant: "body", content: "@entity.model" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Driver" }, { type: "typography", variant: "body", content: "@entity.assignedDriverId" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Odometer", value: "@entity.odometer", icon: "gauge" }, { type: "stat-display", label: "Year", value: "@entity.year", icon: "calendar" }, { type: "stat-display", label: "Type", value: "@entity.vehicleType", icon: "tag" }, { type: "stat-display", label: "Fuel", value: "@entity.fuelType", icon: "droplet" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Assign Driver", variant: "primary", action: "ASSIGN_DRIVER", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Mark Maintenance", variant: "secondary", action: "MARK_MAINTENANCE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Retire", variant: "danger", action: "RETIRE", actionPayload: { id: "@entity.id" } }] }] })
      RETIRE -> loading
        (set @entity.id @payload.id)
        (fetch Vehicle { emit: { success: "VehicleLoaded", failure: "VehicleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Retiring vehicle…" }] })
    }
    state viewing_single {
      CLOSE_VEHICLE -> loading
        (fetch Vehicle { emit: { success: "VehicleLoaded", failure: "VehicleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading vehicles…" }] })
      ASSIGN_DRIVER -> loading
        (set @entity.id @payload.id)
        (fetch Vehicle { emit: { success: "VehicleLoaded", failure: "VehicleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Assigning driver…" }] })
      MARK_MAINTENANCE -> loading
        (set @entity.id @payload.id)
        (fetch Vehicle { emit: { success: "VehicleLoaded", failure: "VehicleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating vehicle…" }] })
      RETIRE -> loading
        (set @entity.id @payload.id)
        (fetch Vehicle { emit: { success: "VehicleLoaded", failure: "VehicleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Retiring vehicle…" }] })
    }
    state error {
      INIT -> loading
        (fetch Vehicle { emit: { success: "VehicleLoaded", failure: "VehicleLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_VEHICLE      { id : string!, row : Vehicle }
      CLOSE_VEHICLE     { }
      ASSIGN_DRIVER     { id : string! }
      MARK_MAINTENANCE  { id : string! }
      RETIRE            { id : string! }
      VehicleLoaded     { data : [Vehicle], totalCount : number }
      VehicleLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_VEHICLE      { id : string!, row : Vehicle }
      CLOSE_VEHICLE     { }
      ASSIGN_DRIVER     { id : string! }
      MARK_MAINTENANCE  { id : string! }
      RETIRE            { id : string! }
      VehicleLoaded     { data : [Vehicle], totalCount : number }
      VehicleLoadFailed { error : string, code : string }
    }
  }
  page "/vehicles" as VehiclePage -> VehicleFleet
}
