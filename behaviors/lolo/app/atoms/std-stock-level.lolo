app std-stock-level "1.2.0"
"std-stock-level — on-hand quantity primitive for a SKU at a location. Lists stock rows; detail offers Adjust / Recount. Exposes Inventory/Logistics knobs (lowStockThreshold, reorderPoint, multiLocationEnabled, …) for the questionnaire."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital StockLevelOrbital {
  entity StockLevel [persistent: stocklevels] {
    id           : string!
    sku          : string!
    productName  : string = ""
    locationId   : string = ""
    onHand       : number = 0
    reserved     : number = 0
    reorderPoint : number = 0
    lastCounted  : string = ""
  }

  type StockLevelLoaded     = Event { data : [StockLevel] }            "Fired when the stock level collection finishes loading"
  type StockLevelLoadFailed = Event { error : string, code : string }  "Fired when the stock level collection fails to load"

  trait StockLevelLedger -> StockLevel [interaction, collection] {
    config {
      title : string = "Stock Levels"
        @label "Section title"
        @description "Heading shown above the inventory stock list"
        @tier "customization"
      fields      : [FieldSpec] = [{ name: "sku", label: "SKU", variant: "caption" }, { name: "productName", label: "Product", variant: "caption" }, { name: "locationId", label: "Location", variant: "caption" }, { name: "onHand", label: "On Hand", variant: "caption" }, { name: "reorderPoint", label: "Reorder At", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Stock Level entity"
        @tier "advanced"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_STOCK", variant: "primary", icon: "arrow-right" }, { label: "Adjust", event: "ADJUST_STOCK", variant: "danger" }]
        @label "Row actions"
        @description "Buttons users can click on each SKU row"
        @tier "customization"
      lowStockThreshold       : number  = 10
        @label "Low-stock threshold"
        @description "Default on-hand quantity below which a SKU is flagged as low. v1.2 declarative; surfaced for downstream std-notify composition."
        @tier "essential"
      reorderPoint            : number  = 5
        @label "Default reorder point"
        @description "Default reorder trigger applied to new stock rows when their per-row reorderPoint isn't set."
        @tier "essential"
      safetyStockDays         : number  = 7
        @label "Safety stock (days)"
        @description "Days of expected demand to keep as buffer above the reorder point."
        @tier "customization"
      defaultWarehouse        : string  = ""
        @label "Default warehouse"
        @description "Warehouse used when a row doesn't specify a location."
        @tier "customization"
      multiLocationEnabled    : boolean = false
        @label "Multi-location"
        @description "Track on-hand stock across multiple warehouses."
        @tier "customization"
      serialTrackingEnabled   : boolean = false
        @label "Serial tracking"
        @description "Track individual serial numbers per unit. v1.2 declarative."
        @tier "customization"
      lotTrackingEnabled      : boolean = false
        @label "Lot tracking"
        @description "Track lot/batch numbers per receipt. v1.2 declarative."
        @tier "customization"
      expiryTrackingEnabled   : boolean = false
        @label "Expiry tracking"
        @description "Track expiry dates and surface near-expiry rows. v1.2 declarative."
        @tier "customization"
      hazmatEnabled           : boolean = false
        @label "Hazmat-classified inventory"
        @description "Flag hazmat SKUs for handling/storage compliance."
        @tier "advanced"
      cycleCountFrequencyDays : number  = 30
        @label "Cycle count cadence (days)"
        @description "Days between scheduled inventory cycle counts. v1.2 declarative; wire via sibling std-lifecycle when available."
        @tier "advanced"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch StockLevel { emit: { success: "StockLevelLoaded", failure: "StockLevelLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading stock levels…" }] })
      StockLevelLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "package" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total SKUs", value: "@payload.data.length", icon: "package" }, { type: "stat-display", label: "Below reorder", value: "12", icon: "alert-triangle" }, { type: "stat-display", label: "Total on hand", value: "8,420", icon: "boxes" }, { type: "stat-display", label: "Reserved", value: "1,260", icon: "lock" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      StockLevelLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_STOCK -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.sku @payload.row.sku)
        (set @entity.productName @payload.row.productName)
        (set @entity.locationId @payload.row.locationId)
        (set @entity.onHand @payload.row.onHand)
        (set @entity.reserved @payload.row.reserved)
        (set @entity.reorderPoint @payload.row.reorderPoint)
        (set @entity.lastCounted @payload.row.lastCounted)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "package" }, { type: "typography", content: "@entity.productName", variant: "h3" }, { type: "badge", label: "@entity.sku", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Location" }, { type: "typography", variant: "body", content: "@entity.locationId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Last counted" }, { type: "typography", variant: "body", content: "@entity.lastCounted" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "On hand", value: "@entity.onHand", icon: "boxes" }, { type: "stat-display", label: "Reserved", value: "@entity.reserved", icon: "lock" }, { type: "stat-display", label: "Reorder at", value: "@entity.reorderPoint", icon: "alert-triangle" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Adjust", variant: "primary", action: "ADJUST_STOCK", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Recount", variant: "secondary", action: "RECOUNT", actionPayload: { id: "@entity.id" } }] }] })
      ADJUST_STOCK -> loading
        (set @entity.id @payload.id)
        (fetch StockLevel { emit: { success: "StockLevelLoaded", failure: "StockLevelLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Adjusting stock…" }] })
      RECOUNT -> loading
        (set @entity.id @payload.id)
        (fetch StockLevel { emit: { success: "StockLevelLoaded", failure: "StockLevelLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Recounting stock…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch StockLevel { emit: { success: "StockLevelLoaded", failure: "StockLevelLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading stock levels…" }] })
      ADJUST_STOCK -> loading
        (set @entity.id @payload.id)
        (fetch StockLevel { emit: { success: "StockLevelLoaded", failure: "StockLevelLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Adjusting stock…" }] })
      RECOUNT -> loading
        (set @entity.id @payload.id)
        (fetch StockLevel { emit: { success: "StockLevelLoaded", failure: "StockLevelLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Recounting stock…" }] })
    }
    state error {
      INIT -> loading
        (fetch StockLevel { emit: { success: "StockLevelLoaded", failure: "StockLevelLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_STOCK           { id : string!, row : StockLevel }
      CLOSE_VIEW           { }
      ADJUST_STOCK         { id : string! }
      RECOUNT              { id : string! }
      StockLevelLoaded     { data : [StockLevel] }
      StockLevelLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_STOCK           { id : string!, row : StockLevel }
      CLOSE_VIEW           { }
      ADJUST_STOCK         { id : string! }
      RECOUNT              { id : string! }
      StockLevelLoaded     { data : [StockLevel] }
      StockLevelLoadFailed { error : string, code : string }
    }
  }
  page "/stock" as StockLevelPage -> StockLevelLedger
}
