app std-email-broadcast "1.2.0"
"std-email-broadcast — send an email blast to a segment of contacts using a chosen template. Lists broadcasts; detail offers Send / Cancel. Listens for SET_STATUS so std-lifecycle can drive transitions. Exposes Communication knobs (sendsPerHour, gdprConsentRequired, unsubscribe link, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital EmailBroadcastOrbital {
  entity EmailBroadcast [persistent: emailbroadcasts] {
    id              : string!
    name            : string!
    subject         : string = ""
    segmentId       : string = ""
    templateId      : string = ""
    status          : "draft" | "scheduled" | "sending" | "sent" | "failed" = "draft"
    scheduledAt     : string = ""
    recipientCount  : number = 0
    sentCount       : number = 0
  }

  type EmailBroadcastLoaded       = Event { data : [EmailBroadcast] }         "Fired when the broadcast collection finishes loading"
  type EmailBroadcastLoadFailed   = Event { error : string, code : string }   "Fired when the broadcast collection fails to load"
  type EmailBroadcastUpdated      = Event { row : EmailBroadcast }            "Fired after a broadcast row's status persists (SET_STATUS / lifecycle)"
  type EmailBroadcastUpdateFailed = Event { error : string, code : string }   "Fired when a broadcast row's status update fails to persist"

  trait EmailBroadcastBroadcast -> EmailBroadcast [interaction, collection] {
    config {
      title       : string   = "Email Broadcasts"
        @label "Section title"
        @description "Heading shown above the email blast list"
        @tier "customization"
      fields      : [FieldSpec] = [
        { name: "name",           label: "Name",       variant: "caption" },
        { name: "subject",        label: "Subject",    variant: "caption" },
        { name: "status",         label: "Status",     variant: "badge"   },
        { name: "recipientCount", label: "Recipients", variant: "caption" },
        { name: "sentCount",      label: "Sent",       variant: "caption" },
        { name: "scheduledAt",    label: "Scheduled",  variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Email Broadcast entity"
        @tier "customization"
      itemActions : [ItemAction] = [
        { label: "Open",   event: "OPEN_BROADCAST",   variant: "primary", icon: "arrow-right" },
        { label: "Cancel", event: "CANCEL_BROADCAST", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each broadcast row"
        @tier "customization"
      sendsPerHour              : number  = 1000
        @label "Sends per hour"
        @description "Cap on outbound messages per hour for throttling. v1.2 declarative; wire via ESP rate limiter."
        @tier "customization"
      respectQuietHours         : boolean = true
        @label "Respect quiet hours"
        @description "Suppress delivery during recipient-local quiet hours when known. v1.2 declarative."
        @tier "customization"
      suppressionListEnabled    : boolean = true
        @label "Honor suppression list"
        @description "Skip recipients on the global suppression / bounce list."
        @tier "customization"
      frequencyCapPerWeek       : number  = 5
        @label "Frequency cap (per week)"
        @description "Max messages a recipient can receive across all broadcasts in a 7-day window. v1.2 declarative."
        @tier "customization"
      gdprConsentRequired       : boolean = true
        @label "GDPR consent required"
        @description "Require explicit marketing consent before delivery to EU/UK recipients."
        @tier "customization"
      trackOpens                : boolean = true
        @label "Track opens"
        @description "Embed a tracking pixel to record open events."
        @tier "advanced"
      trackClicks               : boolean = true
        @label "Track clicks"
        @description "Wrap outbound links for click attribution."
        @tier "advanced"
      includeUnsubscribeLink    : boolean = true
        @label "Include unsubscribe link"
        @description "Append a CAN-SPAM/GDPR-compliant unsubscribe link to every message."
        @tier "essential"
      physicalAddressFooter     : string  = ""
        @label "Physical address footer"
        @description "CAN-SPAM-required postal address appended to every broadcast."
        @tier "essential"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch EmailBroadcast { emit: { success: "EmailBroadcastLoaded", failure: "EmailBroadcastLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading broadcasts…" }] })
      EmailBroadcastLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "mail" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total broadcasts", value: "@payload.data.length", icon: "mail" }, { type: "stat-display", label: "Sent this month", value: "23", icon: "send" }, { type: "stat-display", label: "Open rate", value: "41%", icon: "eye" }, { type: "stat-display", label: "Click rate", value: "12%", icon: "mouse-pointer" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      EmailBroadcastLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_BROADCAST -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.subject @payload.row.subject)
        (set @entity.segmentId @payload.row.segmentId)
        (set @entity.templateId @payload.row.templateId)
        (set @entity.status @payload.row.status)
        (set @entity.scheduledAt @payload.row.scheduledAt)
        (set @entity.recipientCount @payload.row.recipientCount)
        (set @entity.sentCount @payload.row.sentCount)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "mail" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Subject" }, { type: "typography", variant: "body", content: "@entity.subject" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Segment" }, { type: "typography", variant: "body", content: "@entity.segmentId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Template" }, { type: "typography", variant: "body", content: "@entity.templateId" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Recipients", value: "@entity.recipientCount", icon: "users" }, { type: "stat-display", label: "Sent", value: "@entity.sentCount", icon: "send" }, { type: "stat-display", label: "Scheduled", value: "@entity.scheduledAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Send Now", variant: "primary", action: "SEND", actionPayload: { id: "@entity.id", broadcastId: "@entity.id" } }, { type: "button", label: "Cancel", variant: "danger", action: "CANCEL_BROADCAST", actionPayload: { id: "@entity.id" } }] }] })
      CANCEL_BROADCAST -> loading
        (set @entity.id @payload.id)
        (fetch EmailBroadcast { emit: { success: "EmailBroadcastLoaded", failure: "EmailBroadcastLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling broadcast…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update EmailBroadcast @entity { emit: { success: "EmailBroadcastUpdated", failure: "EmailBroadcastUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating broadcast status…" }] })
      EmailBroadcastUpdated -> loading
        (fetch EmailBroadcast { emit: { success: "EmailBroadcastLoaded", failure: "EmailBroadcastLoadFailed" } })
      EmailBroadcastUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch EmailBroadcast { emit: { success: "EmailBroadcastLoaded", failure: "EmailBroadcastLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading broadcasts…" }] })
      SEND -> loading
        (set @entity.id @payload.broadcastId)
        (fetch EmailBroadcast { emit: { success: "EmailBroadcastLoaded", failure: "EmailBroadcastLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Sending broadcast…" }] })
      CANCEL_BROADCAST -> loading
        (set @entity.id @payload.id)
        (fetch EmailBroadcast { emit: { success: "EmailBroadcastLoaded", failure: "EmailBroadcastLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling broadcast…" }] })
    }
    state error {
      INIT -> loading
        (fetch EmailBroadcast { emit: { success: "EmailBroadcastLoaded", failure: "EmailBroadcastLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_BROADCAST             { id : string!, row : EmailBroadcast }
      CLOSE_VIEW                 { }
      SEND                       { broadcastId : string! }
      CANCEL_BROADCAST           { id : string! }
      EmailBroadcastLoaded       { data : [EmailBroadcast] }
      EmailBroadcastLoadFailed   { error : string, code : string }
      EmailBroadcastUpdated      { row : EmailBroadcast }
      EmailBroadcastUpdateFailed { error : string, code : string }
    }
    listens {
      OPEN_BROADCAST             { id : string!, row : EmailBroadcast }
      CLOSE_VIEW                 { }
      SEND                       { broadcastId : string! }
      CANCEL_BROADCAST           { id : string! }
      SET_STATUS                 { entityId : string!, newStatus : string! }
      EmailBroadcastLoaded       { data : [EmailBroadcast] }
      EmailBroadcastLoadFailed   { error : string, code : string }
      EmailBroadcastUpdated      { row : EmailBroadcast }
      EmailBroadcastUpdateFailed { error : string, code : string }
    }
  }
  page "/broadcasts" as EmailBroadcastPage -> EmailBroadcastBroadcast
}
