app std-matter "1.0.0"
"std-matter — legal matter primitive: a single legal case (litigation, contract review, immigration filing) with client, status, lead attorney, and billing reference."

orbital MatterOrbital {
  entity Matter [persistent: matters] {
    id            : string!
    matterNumber  : string!
    title         : string!
    clientName    : string!
    practiceArea  : "litigation" | "transactional" | "regulatory" | "ip" | "immigration" | "family" | "other" = "other"
    leadAttorney  : string = ""
    status        : "open" | "active" | "on_hold" | "closed" | "archived" = "open"
    openedAt      : string = ""
    closedAt      : string = ""
    notes         : string = ""
  }

  type MatterLoaded     = Event { data : [Matter] }                "Fired when the matter collection finishes loading"
  type MatterLoadFailed = Event { error : string, code : string }  "Fired when the matter collection fails to load"

  trait MatterDocket -> Matter [interaction, collection] {
    config {
      title : string = "Matters"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Matter { emit: { success: "MatterLoaded", failure: "MatterLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading matters…" }] })
      MatterLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "feature-detail-page-template", entity: { id: "matter-overview", title: "Matter Overview", subtitle: "Litigation, contracts, and regulatory cases" } }, { type: "breadcrumb", items: [{ label: "Court" }, { label: "Cases" }, { label: "Matter" }] }, { type: "wizard-progress", steps: [{ id: "intake", label: "Intake" }, { id: "discovery", label: "Discovery" }, { id: "pretrial", label: "Pre-Trial" }, { id: "trial", label: "Trial" }, { id: "closed", label: "Closed" }], currentStep: 1 }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "scale" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "file-tree", tree: [{ name: "Pleadings", children: [{ name: "Complaint.pdf" }, { name: "Answer.pdf" }] }, { name: "Discovery", children: [{ name: "Interrogatories.pdf" }, { name: "Depositions", children: [{ name: "Smith.pdf" }] }] }, { name: "Motions", children: [{ name: "Motion-to-Dismiss.pdf" }] }] }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "accordion", items: [{ id: "facts", title: "Facts of the Case", content: "Plaintiff alleges breach of contract dated 2025-08-01." }, { id: "issues", title: "Legal Issues", content: "Material breach, damages calculation, statute of limitations." }, { id: "strategy", title: "Strategy", content: "Motion practice followed by summary judgment." }] }, { type: "law-reference-tooltip", reference: { citation: "Fed. R. Civ. P. 12(b)(6)", title: "Failure to State a Claim" }, position: "top", children: [{ type: "typography", content: "Rule 12(b)(6) motion pending" }] }] }] }, { type: "document-viewer", title: "Complaint.pdf", documentType: "pdf", src: "/docs/complaint.pdf", currentPage: 1, totalPages: 24, showToolbar: true }, { type: "doc-pagination", prev: { label: "Previous Page", action: "DOC_PREV" }, next: { label: "Next Page", action: "DOC_NEXT" } }, { type: "quest-tracker", quests: [{ id: "answer-due", title: "File Answer", status: "active", deadline: "2026-06-15" }, { id: "discovery-cutoff", title: "Discovery Cutoff", status: "pending", deadline: "2026-08-01" }, { id: "pretrial-brief", title: "Pretrial Brief", status: "pending", deadline: "2026-09-15" }], activeQuestId: "answer-due" }, { type: "behavior-view", data: { initial: "intake", states: ["intake", "discovery", "pretrial", "trial", "closed"], current: "discovery" } }, { type: "feature-renderer", features: [{ id: "courthouse", type: "venue", label: "Superior Court" }, { id: "judge", type: "person", label: "Hon. J. Carter" }, { id: "opposing", type: "party", label: "Opposing Counsel" }] }, { type: "content-renderer", content: "Status conference scheduled. All parties to appear. Discovery is ongoing.", direction: "ltr" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "matterNumber", label: "Matter #", variant: "caption" }, { name: "title", label: "Title", variant: "caption" }, { name: "clientName", label: "Client", variant: "caption" }, { name: "practiceArea", label: "Practice", variant: "badge" }, { name: "leadAttorney", label: "Lead", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Close", event: "CLOSE_MATTER", variant: "primary" }, { label: "Hold", event: "HOLD_MATTER", variant: "ghost" }, { label: "Reopen", event: "REOPEN_MATTER", variant: "ghost" }] }] })
      MatterLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      CLOSE_MATTER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Matter closed" })
      HOLD_MATTER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Matter on hold" })
      REOPEN_MATTER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Matter reopened" })
    }
    state error {
      INIT -> loading
        (fetch Matter { emit: { success: "MatterLoaded", failure: "MatterLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      CLOSE_MATTER     { id : string!, row : Matter }
      HOLD_MATTER      { id : string!, row : Matter }
      REOPEN_MATTER    { id : string!, row : Matter }
      MatterLoaded     { data : [Matter] }
      MatterLoadFailed { error : string, code : string }
    }
    listens {
      CLOSE_MATTER     { id : string! }
      HOLD_MATTER      { id : string! }
      REOPEN_MATTER    { id : string! }
      MatterLoaded     { data : [Matter] }
      MatterLoadFailed { error : string, code : string }
    }
  }
  page "/matters" as MatterPage -> MatterDocket
}
