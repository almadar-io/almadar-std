app std-matter "1.0.0"
"std-matter — legal matter primitive: a single legal case (litigation, contract review, immigration filing) with client, status, lead attorney, and billing reference."

orbital MatterOrbital {
  entity Matter [persistent: matters] {
    id            : string!
    matterNumber  : string!
    title         : string!
    clientName    : string!
    practiceArea  : "litigation" | "transactional" | "regulatory" | "ip" | "immigration" | "family" | "other" = "other"
    leadAttorney  : string = ""
    status        : "open" | "active" | "on_hold" | "closed" | "archived" = "open"
    openedAt      : string = ""
    closedAt      : string = ""
    notes         : string = ""
  }

  type MatterLoaded     = Event { data : [Matter] }                "Fired when the matter collection finishes loading"
  type MatterLoadFailed = Event { error : string, code : string }  "Fired when the matter collection fails to load"

  trait MatterDocket -> Matter [interaction, collection] {
    config {
      title : string = "Matters"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Matter { emit: { success: "MatterLoaded", failure: "MatterLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading matters…" }] })
      MatterLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "scale" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "matterNumber", label: "Matter #", variant: "caption" }, { name: "title", label: "Title", variant: "caption" }, { name: "clientName", label: "Client", variant: "caption" }, { name: "practiceArea", label: "Practice", variant: "badge" }, { name: "leadAttorney", label: "Lead", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Close", event: "CLOSE_MATTER", variant: "primary" }, { label: "Hold", event: "HOLD_MATTER", variant: "ghost" }, { label: "Reopen", event: "REOPEN_MATTER", variant: "ghost" }] }] })
      MatterLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      CLOSE_MATTER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Matter closed" })
      HOLD_MATTER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Matter on hold" })
      REOPEN_MATTER -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Matter reopened" })
    }
    state error {
      INIT -> loading
        (fetch Matter { emit: { success: "MatterLoaded", failure: "MatterLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      CLOSE_MATTER     { id : string!, row : Matter }
      HOLD_MATTER      { id : string!, row : Matter }
      REOPEN_MATTER    { id : string!, row : Matter }
      MatterLoaded     { data : [Matter] }
      MatterLoadFailed { error : string, code : string }
    }
    listens {
      CLOSE_MATTER     { id : string! }
      HOLD_MATTER      { id : string! }
      REOPEN_MATTER    { id : string! }
      MatterLoaded     { data : [Matter] }
      MatterLoadFailed { error : string, code : string }
    }
  }
  page "/matters" as MatterPage -> MatterDocket
}
