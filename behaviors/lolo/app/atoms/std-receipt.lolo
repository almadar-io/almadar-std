app std-receipt "1.2.0"
"std-receipt — receipt primitive with Email / Reprint actions. Exposes Financial-pattern knobs (currency, taxStrategy, jurisdiction, retention)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital ReceiptOrbital {
  entity Receipt [persistent: receipts] {
    id              : string!
    receiptNumber   : string!
    recipientName   : string = ""
    recipientEmail  : string = ""
    transactionId   : string = ""
    transactionType : "purchase" | "refund" | "donation" | "service" = "purchase"
    subtotal        : number = 0
    tax             : number = 0
    total           : number = 0
    lineItemsJson   : string = ""
    issuedAt        : string = ""
    isEmailed       : boolean = false
  }

  type ReceiptLoaded     = Event { data : [Receipt] }                 "Fired when the receipt collection finishes loading"
  type ReceiptLoadFailed = Event { error : string, code : string }    "Fired when the receipt collection fails to load"

  trait ReceiptIssuer -> Receipt [interaction, collection] {
    config {
      title       : string   = "Receipts"
        @label "Section title"
        @description "Heading shown above the receipts list"
        @tier "customization"
      fields      : [FieldSpec] = [
        { name: "receiptNumber",   label: "Receipt #", variant: "caption" },
        { name: "recipientName",   label: "Recipient", variant: "caption" },
        { name: "transactionType", label: "Type",      variant: "badge"   },
        { name: "total",           label: "Total",     variant: "caption" },
        { name: "issuedAt",        label: "Issued",    variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Receipt entity"
        @tier "advanced"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_RECEIPT",    variant: "primary", icon: "arrow-right" },
        { label: "Reprint", event: "REPRINT_RECEIPT", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each receipt row"
        @tier "customization"
      currency        : string   = "USD"
        @label "Default currency"
        @description "ISO 4217 currency code (USD, EUR, GBP, …) for receipt amounts."
        @tier "essential"
      taxStrategy     : "inclusive" | "exclusive" | "none" = "exclusive"
        @label "Tax strategy"
        @description "inclusive = tax baked into line items; exclusive = tax added on top; none = no tax."
        @tier "customization"
      roundingMode    : "bankers" | "half-up" | "down" = "half-up"
        @label "Rounding mode"
        @description "Sub-cent rounding behavior for receipt totals."
        @tier "advanced"
      gracePeriodDays : number   = 0
        @label "Grace period (days)"
        @description "Days a receipt is considered editable before locked. Declarative."
        @tier "customization"
      lateFeePolicy   : "none" | "flat" | "percent" = "none"
        @label "Late fee policy"
        @description "Rarely applies to receipts. Declarative; wiring deferred."
        @tier "customization"
      lateFeeAmount   : number   = 0
        @label "Late fee amount"
        @description "Flat cash amount or percentage (per lateFeePolicy)."
        @tier "customization"
      complianceJurisdiction : string = ""
        @label "Compliance jurisdiction"
        @description "Drives receipt format + tax rules per locale: 'US-CA', 'EU-DE', 'UK', etc. Declarative."
        @tier "advanced"
      retentionYears  : number   = 7
        @label "Retention (years)"
        @description "Years to keep receipts for compliance."
        @tier "advanced"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Receipt { emit: { success: "ReceiptLoaded", failure: "ReceiptLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading receipts…" }] })
      ReceiptLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "receipt" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total receipts", value: "@payload.data.length", icon: "receipt" }, { type: "stat-display", label: "Issued today", value: "23", icon: "calendar" }, { type: "stat-display", label: "Revenue", value: "$12,840", icon: "dollar-sign" }, { type: "stat-display", label: "Emailed", value: "92%", icon: "mail" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      ReceiptLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_RECEIPT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.receiptNumber @payload.row.receiptNumber)
        (set @entity.recipientName @payload.row.recipientName)
        (set @entity.recipientEmail @payload.row.recipientEmail)
        (set @entity.transactionId @payload.row.transactionId)
        (set @entity.transactionType @payload.row.transactionType)
        (set @entity.subtotal @payload.row.subtotal)
        (set @entity.tax @payload.row.tax)
        (set @entity.total @payload.row.total)
        (set @entity.lineItemsJson @payload.row.lineItemsJson)
        (set @entity.issuedAt @payload.row.issuedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "receipt" }, { type: "typography", content: "@entity.receiptNumber", variant: "h3" }, { type: "badge", label: "@entity.transactionType", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Recipient" }, { type: "typography", variant: "body", content: "@entity.recipientName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Email" }, { type: "typography", variant: "body", content: "@entity.recipientEmail" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Transaction" }, { type: "typography", variant: "body", content: "@entity.transactionId" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Subtotal", value: "@entity.subtotal", icon: "dollar-sign" }, { type: "stat-display", label: "Tax", value: "@entity.tax", icon: "percent" }, { type: "stat-display", label: "Total", value: "@entity.total", icon: "dollar-sign" }, { type: "stat-display", label: "Issued", value: "@entity.issuedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Email", variant: "primary", action: "EMAIL_RECEIPT", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Reprint", variant: "secondary", action: "REPRINT_RECEIPT", actionPayload: { id: "@entity.id" } }] }] })
      EMAIL_RECEIPT -> loading
        (set @entity.id @payload.id)
        (fetch Receipt { emit: { success: "ReceiptLoaded", failure: "ReceiptLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Emailing receipt…" }] })
      REPRINT_RECEIPT -> loading
        (set @entity.id @payload.id)
        (fetch Receipt { emit: { success: "ReceiptLoaded", failure: "ReceiptLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Reprinting receipt…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Receipt { emit: { success: "ReceiptLoaded", failure: "ReceiptLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading receipts…" }] })
      EMAIL_RECEIPT -> loading
        (set @entity.id @payload.id)
        (fetch Receipt { emit: { success: "ReceiptLoaded", failure: "ReceiptLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Emailing receipt…" }] })
      REPRINT_RECEIPT -> loading
        (set @entity.id @payload.id)
        (fetch Receipt { emit: { success: "ReceiptLoaded", failure: "ReceiptLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Reprinting receipt…" }] })
    }
    state error {
      INIT -> loading
        (fetch Receipt { emit: { success: "ReceiptLoaded", failure: "ReceiptLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_RECEIPT      { id : string!, row : Receipt }
      CLOSE_VIEW        { }
      EMAIL_RECEIPT     { id : string! }
      REPRINT_RECEIPT   { id : string! }
      ReceiptLoaded     { data : [Receipt] }
      ReceiptLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_RECEIPT      { id : string!, row : Receipt }
      CLOSE_VIEW        { }
      EMAIL_RECEIPT     { id : string! }
      REPRINT_RECEIPT   { id : string! }
      ReceiptLoaded     { data : [Receipt] }
      ReceiptLoadFailed { error : string, code : string }
    }
  }
  page "/receipts" as ReceiptPage -> ReceiptIssuer
}
