app std-vendor-onboarding "1.1.0"
"std-vendor-onboarding — marketplace vendor multi-step KYC + bank-link wizard. Exposes HR knobs (backgroundCheckRequired, eVerifyRequired, anonymizeOnRejection, …)."

orbital VendorOnboardingOrbital {
  entity Vendor [persistent: vendors] {
    id                : string!
    businessName      : string!
    legalName         : string
    ein               : string
    bankRoutingMasked : string
    bankAcctMasked    : string
    identityDocUrl    : string
    currentStep       : "business-info" | "tax-id" | "bank-link" | "identity-verify" | "review" | "submitted" = "business-info"
    submittedAt       : string
    createdAt         : string
  }

  type VendorLoaded       = Event { data : [Vendor] }                     "Fired when the vendor record finishes loading"
  type VendorLoadFailed   = Event { error : string, code : string }       "Fired when the vendor record fails to load"
  type VendorUpdated      = Event { id : string }                         "Fired after a step persist succeeds"
  type VendorUpdateFailed = Event { error : string, code : string }       "Fired when a step persist fails"
  type VendorSubmitted    = Event { id : string }                         "Fired after final submission persists"
  type VendorSubmitFailed = Event { error : string, code : string }       "Fired when final submission fails"

  trait VendorOnboard -> Vendor [interaction, instance] {
    config {
      backgroundCheckRequired : boolean = true
        @label "Background check required"
        @description "Block SUBMIT until a background check on the vendor is on file."
        @tier "domain"
      eVerifyRequired : boolean = false
        @label "E-Verify required"
        @description "US E-Verify gate. Block SUBMIT until verification passes."
        @tier "domain"
      i9DocumentsRequired : boolean = false
        @label "I-9 documents required"
        @description "Require I-9 supporting documents (relevant for sole-proprietor vendors)."
        @tier "domain"
      anonymizeOnRejection : boolean = false
        @label "Anonymize on rejection"
        @description "When true, scrub vendor PII on rejected applications. Pair with std-data-erasure."
        @tier "domain"
      retentionAfterRejectionDays : number = 1825
        @label "Retention after rejection (days)"
        @description "Days to keep rejected vendor onboarding records. Default 1825 (5 years) typical KYC retention."
        @tier "domain"
      equalOpportunityTrackingEnabled : boolean = false
        @label "Equal opportunity tracking"
        @description "Capture supplier diversity / EEO data separately (sibling collection)."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Vendor { emit: { success: "VendorLoaded", failure: "VendorLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [
          { type: "spinner" },
          { type: "typography", variant: "caption", color: "muted", content: "Loading vendor application…" }
        ] })
      VendorLoaded -> business-info
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user" }, { type: "typography", content: "Vendor Onboarding", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "form-section", mode: "create", submitEvent: "NEXT_STEP", cancelEvent: "INIT", fields: ["businessName", "legalName"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 5, showBack: false, showNext: true, showComplete: false, onNext: "NEXT_STEP" }
        ] })
      VendorLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state business-info {
      NEXT_STEP -> tax-id
        (set @entity.businessName @payload.data.businessName)
        (set @entity.legalName @payload.data.legalName)
        (set @entity.currentStep "tax-id")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Tax ID", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT_STEP", cancelEvent: "BACK_STEP", fields: ["ein"] },
          { type: "wizard-navigation", currentStep: 1, totalSteps: 5, showBack: true, showNext: true, showComplete: false, onBack: "BACK_STEP", onNext: "NEXT_STEP" }
        ] })
    }
    state tax-id {
      NEXT_STEP -> bank-link
        (set @entity.ein @payload.data.ein)
        (set @entity.currentStep "bank-link")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Bank Link", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 2 },
          { type: "divider" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT_STEP", cancelEvent: "BACK_STEP", fields: ["bankRoutingMasked", "bankAcctMasked"] },
          { type: "wizard-navigation", currentStep: 2, totalSteps: 5, showBack: true, showNext: true, showComplete: false, onBack: "BACK_STEP", onNext: "NEXT_STEP" }
        ] })
      BACK_STEP -> business-info
        (set @entity.currentStep "business-info")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user" }, { type: "typography", content: "Business Info", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT_STEP", cancelEvent: "INIT", fields: ["businessName", "legalName"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 5, showBack: false, showNext: true, showComplete: false, onNext: "NEXT_STEP" }
        ] })
    }
    state bank-link {
      NEXT_STEP -> identity-verify
        (set @entity.bankRoutingMasked @payload.data.bankRoutingMasked)
        (set @entity.bankAcctMasked @payload.data.bankAcctMasked)
        (set @entity.currentStep "identity-verify")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Identity Verification", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 3 },
          { type: "divider" },
          { type: "typography", variant: "body", color: "muted", content: "Upload a government-issued ID to verify your identity." },
          { type: "upload-drop-zone", accept: "image/*", maxSize: 10485760, maxFiles: 2, label: "Drop ID document here", description: "or click to browse", icon: "credit-card", action: "UPLOAD_IDENTITY" },
          { type: "wizard-navigation", currentStep: 3, totalSteps: 5, showBack: true, showNext: true, showComplete: false, onBack: "BACK_STEP", onNext: "NEXT_STEP" }
        ] })
      BACK_STEP -> tax-id
        (set @entity.currentStep "tax-id")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Tax ID", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT_STEP", cancelEvent: "BACK_STEP", fields: ["ein"] },
          { type: "wizard-navigation", currentStep: 1, totalSteps: 5, showBack: true, showNext: true, showComplete: false, onBack: "BACK_STEP", onNext: "NEXT_STEP" }
        ] })
    }
    state identity-verify {
      UPLOAD_IDENTITY -> identity-verify
        (set @entity.identityDocUrl @payload.url)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Identity Verification", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 3 },
          { type: "divider" },
          { type: "alert", variant: "success", message: "Identity document uploaded." },
          { type: "stack", direction: "vertical", gap: "sm", children: [
            { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Document URL" }, { type: "typography", variant: "body", content: "@entity.identityDocUrl" }] }
          ] },
          { type: "wizard-navigation", currentStep: 3, totalSteps: 5, showBack: true, showNext: true, showComplete: false, onBack: "BACK_STEP", onNext: "NEXT_STEP" }
        ] })
      NEXT_STEP -> review
        (set @entity.currentStep "review")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Review", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 4 },
          { type: "divider" },
          { type: "stack", direction: "vertical", gap: "sm", children: [
            { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Business Name" }, { type: "typography", variant: "body", content: "@entity.businessName" }] },
            { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Legal Name" }, { type: "typography", variant: "body", content: "@entity.legalName" }] },
            { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "EIN" }, { type: "typography", variant: "body", content: "@entity.ein" }] },
            { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Bank Routing" }, { type: "typography", variant: "body", content: "@entity.bankRoutingMasked" }] },
            { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Bank Account" }, { type: "typography", variant: "body", content: "@entity.bankAcctMasked" }] },
            { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Identity Doc" }, { type: "typography", variant: "body", content: "@entity.identityDocUrl" }] }
          ] },
          { type: "divider" },
          { type: "simple-grid", cols: 2, children: [
            { type: "stat-display", label: "Business", value: "@entity.businessName", icon: "user" },
            { type: "stat-display", label: "EIN", value: "@entity.ein", icon: "credit-card" }
          ] },
          { type: "wizard-navigation", currentStep: 4, totalSteps: 5, showBack: true, showNext: false, showComplete: true, onBack: "BACK_STEP", onComplete: "SUBMIT" }
        ] })
      BACK_STEP -> bank-link
        (set @entity.currentStep "bank-link")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Bank Link", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 2 },
          { type: "divider" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT_STEP", cancelEvent: "BACK_STEP", fields: ["bankRoutingMasked", "bankAcctMasked"] },
          { type: "wizard-navigation", currentStep: 2, totalSteps: 5, showBack: true, showNext: true, showComplete: false, onBack: "BACK_STEP", onNext: "NEXT_STEP" }
        ] })
    }
    state review {
      SUBMIT -> submitted
        (set @entity.currentStep "submitted")
        (set @entity.submittedAt @payload.submittedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "max-w-2xl mx-auto w-full py-12", children: [
          { type: "icon", name: "check-circle", color: "success" },
          { type: "typography", variant: "h3", content: "Application Submitted" },
          { type: "typography", variant: "body", color: "muted", content: "Thanks. We will review your vendor application and email you within 2 business days." }
        ] })
      BACK_STEP -> identity-verify
        (set @entity.currentStep "identity-verify")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-2xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "credit-card" }, { type: "typography", content: "Identity Verification", variant: "h3" }] },
          { type: "wizard-progress", steps: ["Business", "Tax ID", "Bank", "Identity", "Review"], currentStep: 3 },
          { type: "divider" },
          { type: "upload-drop-zone", accept: "image/*", maxSize: 10485760, maxFiles: 2, label: "Drop ID document here", description: "or click to browse", icon: "credit-card", action: "UPLOAD_IDENTITY" },
          { type: "wizard-navigation", currentStep: 3, totalSteps: 5, showBack: true, showNext: true, showComplete: false, onBack: "BACK_STEP", onNext: "NEXT_STEP" }
        ] })
    }
    state submitted {
      INIT -> loading
        (fetch Vendor { emit: { success: "VendorLoaded", failure: "VendorLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch Vendor { emit: { success: "VendorLoaded", failure: "VendorLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      NEXT_STEP { data : object, currentStep : number, totalSteps : number }
      BACK_STEP { currentStep : number, totalSteps : number }
      SUBMIT { submittedAt : string, currentStep : number, totalSteps : number }
      UPLOAD_IDENTITY { url : string! }
      VendorLoaded
      VendorLoadFailed
    }
    listens {
      NEXT_STEP { data : object, currentStep : number, totalSteps : number }
      BACK_STEP { currentStep : number, totalSteps : number }
      SUBMIT { submittedAt : string, currentStep : number, totalSteps : number }
      UPLOAD_IDENTITY { url : string! }
      VendorLoadFailed { error : string, code : string }
      VendorPersistor.VendorUpdated -> INIT
      VendorPersistor.VendorSubmitted -> INIT
    }
  }

  ;; Coordinator: persists each step transition + final submission.
  trait VendorPersistor -> Vendor [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_UPDATE -> idle
        (persist update Vendor @payload.data { emit: { success: "VendorUpdated", failure: "VendorUpdateFailed" } })
      DO_SUBMIT -> idle
        (persist update Vendor @payload.data { emit: { success: "VendorSubmitted", failure: "VendorSubmitFailed" } })
    }
    emits {
      VendorUpdated      -> external { id : string! }
      VendorUpdateFailed -> external { error : string, code : string }
      VendorSubmitted    -> external { id : string! }
      VendorSubmitFailed -> external { error : string, code : string }
    }
    listens {
      DO_UPDATE { data : Vendor! }
      DO_SUBMIT { data : Vendor! }
      VendorOnboard.NEXT_STEP -> DO_UPDATE
      VendorOnboard.SUBMIT    -> DO_SUBMIT
    }
  }

  page "/vendor-onboarding" as VendorOnboardingPage -> VendorOnboard, VendorPersistor
}
