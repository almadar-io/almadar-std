app std-class-roster "1.2.0"
"std-class-roster — members enrolled in a class session. Listens for SET_STATUS so sibling std-lifecycle can auto-transition. Exposes Scheduling/Booking + HR knobs (bookingWindowDays, noShowGracePeriodMinutes, anonymizeOnRejection, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital ClassRosterOrbital {
  entity RosterEntry [persistent: rosterentries] {
    id           : string!
    sessionId    : string!
    memberId     : string!
    memberName   : string = ""
    enrolledAt   : string = ""
    checkedInAt  : string = ""
    status       : "enrolled" | "checked_in" | "no_show" | "waitlist" = "enrolled"
    notes        : string = ""
  }

  type RosterEntryLoaded     = Event { data : [RosterEntry] }            "Fired when the roster collection finishes loading"
  type RosterEntryLoadFailed = Event { error : string, code : string }   "Fired when the roster collection fails to load"

  trait RosterEntryRoster -> RosterEntry [interaction, collection] {
    config {
      title       : string   = "Class Roster"
        @label "Section title"
        @description "Heading shown above the class roster"
        @tier "customization"
      fields      : [FieldSpec] = [
        { name: "memberName",  label: "Member",     variant: "caption" },
        { name: "sessionId",   label: "Session",    variant: "caption" },
        { name: "status",      label: "Status",     variant: "badge"   },
        { name: "checkedInAt", label: "Checked In", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Roster Entry entity"
        @tier "customization"
      itemActions : [ItemAction] = [
        { label: "Open",     event: "OPEN_ENTRY",   variant: "primary",   icon: "arrow-right" },
        { label: "Check In", event: "CHECK_IN",     variant: "secondary" },
        { label: "No Show",  event: "MARK_NO_SHOW", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each enrolled member"
        @tier "customization"
      bookingWindowDays : number = 30
        @label "Booking window (days)"
        @description "How far in advance members can enroll in a class."
        @tier "customization"
      leadTimeMinutes : number = 15
        @label "Lead time (minutes)"
        @description "Minimum minutes before class start that a new enrollment is accepted."
        @tier "customization"
      bookingHours : string = "06:00-22:00"
        @label "Booking hours"
        @description "Daily window during which enrollments can be made (HH:MM-HH:MM)."
        @tier "customization"
      blackoutDates : [string] = []
        @label "Blackout dates"
        @description "ISO dates blocked from booking (e.g. holidays). Compose std-lifecycle to enforce."
        @tier "customization"
      noShowGracePeriodMinutes : number = 10
        @label "No-show grace (minutes)"
        @description "Minutes after class start before the entry auto-marks no_show. Wire via std-lifecycle."
        @tier "customization"
      rescheduleWindowHours : number = 4
        @label "Reschedule window (hours)"
        @description "Hours before class start during which the member can self-reschedule."
        @tier "customization"
      maxReschedules : number = 3
        @label "Max reschedules"
        @description "Hard cap on reschedule count per enrollment."
        @tier "advanced"
      cancellationPolicy : "free" | "partial-refund" | "no-refund" = "free"
        @label "Cancellation policy"
        @description "Refund treatment when an enrollment is cancelled inside the reschedule window."
        @tier "customization"
      backgroundCheckRequired : boolean = false
        @label "Background check required"
        @description "Block CHECK_IN until a background check is on file (e.g. youth programs)."
        @tier "customization"
      eVerifyRequired : boolean = false
        @label "E-Verify required"
        @description "US I-9 / E-Verify gate (relevant for instructor rosters)."
        @tier "customization"
      i9DocumentsRequired : boolean = false
        @label "I-9 documents required"
        @description "Require I-9 supporting documents (instructor rosters)."
        @tier "customization"
      anonymizeOnRejection : boolean = false
        @label "Anonymize on rejection"
        @description "When true, scrub member PII on no_show / removal. Pair with std-data-erasure."
        @tier "customization"
      retentionAfterRejectionDays : number = 730
        @label "Retention after rejection (days)"
        @description "Days to keep no_show / removed roster entries."
        @tier "advanced"
      equalOpportunityTrackingEnabled : boolean = false
        @label "Equal opportunity tracking"
        @description "Capture demographic data separately for EEO reporting (sibling collection)."
        @tier "advanced"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading roster…" }] })
      RosterEntryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Enrolled", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "Checked in", value: "14", icon: "check-circle" }, { type: "stat-display", label: "No shows", value: "3", icon: "user-x" }, { type: "stat-display", label: "Waitlist", value: "5", icon: "clock" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      RosterEntryLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_ENTRY -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.sessionId @payload.row.sessionId)
        (set @entity.memberId @payload.row.memberId)
        (set @entity.memberName @payload.row.memberName)
        (set @entity.enrolledAt @payload.row.enrolledAt)
        (set @entity.checkedInAt @payload.row.checkedInAt)
        (set @entity.status @payload.row.status)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "user" }, { type: "typography", content: "@entity.memberName", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Session" }, { type: "typography", variant: "body", content: "@entity.sessionId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Enrolled at", value: "@entity.enrolledAt", icon: "calendar" }, { type: "stat-display", label: "Checked in at", value: "@entity.checkedInAt", icon: "check-circle" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Check In", variant: "primary", action: "CHECK_IN", actionPayload: { id: "@entity.id" } }, { type: "button", label: "No Show", variant: "danger", action: "MARK_NO_SHOW", actionPayload: { id: "@entity.id" } }] }] })
      CHECK_IN -> loading
        (set @entity.id @payload.id)
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Checking in…" }] })
      MARK_NO_SHOW -> loading
        (set @entity.id @payload.id)
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking no-show…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update RosterEntry @entity { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating roster entry status…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading roster…" }] })
      CHECK_IN -> loading
        (set @entity.id @payload.id)
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Checking in…" }] })
      MARK_NO_SHOW -> loading
        (set @entity.id @payload.id)
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking no-show…" }] })
    }
    state error {
      INIT -> loading
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ENTRY             { id : string!, row : RosterEntry }
      CLOSE_VIEW             { }
      CHECK_IN               { id : string! }
      MARK_NO_SHOW           { id : string! }
      RosterEntryLoaded      { data : [RosterEntry] }
      RosterEntryLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_ENTRY             { id : string!, row : RosterEntry }
      CLOSE_VIEW             { }
      CHECK_IN               { id : string! }
      MARK_NO_SHOW           { id : string! }
      SET_STATUS             { entityId : string!, newStatus : string! }
      RosterEntryLoaded      { data : [RosterEntry] }
      RosterEntryLoadFailed  { error : string, code : string }
    }
  }
  page "/roster" as RosterEntryPage -> RosterEntryRoster
}
