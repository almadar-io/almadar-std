app std-class-roster "1.0.0"
"std-class-roster — list of members enrolled in a specific class session, with attendance tracking. Owns a RosterEntry entity and a single roster trait that loads entries, renders them in a data-grid, and surfaces Check In / No Show per row."

orbital ClassRosterOrbital {
  entity RosterEntry [persistent: rosterentries] {
    id           : string!
    sessionId    : string!
    memberId     : string!
    memberName   : string = ""
    enrolledAt   : string = ""
    checkedInAt  : string = ""
    status       : "enrolled" | "checked_in" | "no_show" | "waitlist" = "enrolled"
    notes        : string = ""
  }

  type RosterEntryLoaded     = Event { data : [RosterEntry] }            "Fired when the roster collection finishes loading"
  type RosterEntryLoadFailed = Event { error : string, code : string }   "Fired when the roster collection fails to load"

  trait RosterEntryRoster -> RosterEntry [interaction, collection] {
    config {
      title : string = "Class Roster"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading roster…" }] })
      RosterEntryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "memberName", label: "Member", variant: "caption" }, { name: "sessionId", label: "Session", variant: "caption" }, { name: "status", label: "Status", variant: "caption" }, { name: "checkedInAt", label: "Checked In", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Check In", event: "CHECK_IN", variant: "primary" }, { label: "No Show", event: "MARK_NO_SHOW", variant: "ghost" }] }] })
      RosterEntryLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      CHECK_IN -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Checked in" })
      MARK_NO_SHOW -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Marked no-show" })
    }
    state error {
      INIT -> loading
        (fetch RosterEntry { emit: { success: "RosterEntryLoaded", failure: "RosterEntryLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      CHECK_IN               { id : string! }
      MARK_NO_SHOW           { id : string! }
      RosterEntryLoaded      { data : [RosterEntry] }
      RosterEntryLoadFailed  { error : string, code : string }
    }
    listens {
      CHECK_IN               { id : string! }
      MARK_NO_SHOW           { id : string! }
      RosterEntryLoaded      { data : [RosterEntry] }
      RosterEntryLoadFailed  { error : string, code : string }
    }
  }
  page "/roster" as RosterEntryPage -> RosterEntryRoster
}
