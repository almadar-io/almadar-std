app std-checkin "1.1.0"
"std-checkin — arrival check-in atom listing recorded check-ins (qr or geo). Lists check-ins in `browsing`; opens detail in `viewing_single` with Verify / Revoke actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital CheckinOrbital {
  entity Checkin [persistent: checkins] {
    id          : string!
    mode        : "geo" | "qr" = "geo"
    targetId    : string!
    targetType  : string!
    userId      : string
    lat         : number
    lng         : number
    qrCode      : string
    verified    : boolean = false
    checkedInAt : string
  }

  type CheckinLoaded     = Event { data : [Checkin] }                    "Fired when the check-in collection finishes loading"
  type CheckinLoadFailed = Event { error : string, code : string }       "Fired when the check-in collection fails to load"

  trait CheckinScan -> Checkin [interaction, collection] {
    config {
      mode        : string   = "geo"
        @label "Check-in mode"
        @description "How attendees check in (geo location or QR code)"
        @tier "customization"
      title       : string   = "Check-ins"
        @label "Section title"
        @description "Heading shown above the check-in list"
        @tier "customization"
      fields      : [FieldSpec] = [
        { name: "targetType",  label: "Type",   variant: "badge"   },
        { name: "targetId",    label: "Target", variant: "caption" },
        { name: "userId",      label: "User",   variant: "caption" },
        { name: "mode",        label: "Mode",   variant: "badge"   },
        { name: "checkedInAt", label: "When",   variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Check-in entity"
        @tier "customization"
      itemActions : [ItemAction] = [
        { label: "Open",   event: "OPEN_CHECKIN",   variant: "primary", icon: "arrow-right" },
        { label: "Revoke", event: "REVOKE_CHECKIN", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each check-in row"
        @tier "customization"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Checkin { emit: { success: "CheckinLoaded", failure: "CheckinLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading check-ins…" }] })
      CheckinLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map-pin" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total check-ins", value: "@payload.data.length", icon: "map-pin" }, { type: "stat-display", label: "Verified", value: "92%", icon: "check-circle" }, { type: "stat-display", label: "Today", value: "47", icon: "calendar" }, { type: "stat-display", label: "Sites covered", value: "18", icon: "globe" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      CheckinLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_CHECKIN -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.mode @payload.row.mode)
        (set @entity.targetId @payload.row.targetId)
        (set @entity.targetType @payload.row.targetType)
        (set @entity.userId @payload.row.userId)
        (set @entity.lat @payload.row.lat)
        (set @entity.lng @payload.row.lng)
        (set @entity.qrCode @payload.row.qrCode)
        (set @entity.verified @payload.row.verified)
        (set @entity.checkedInAt @payload.row.checkedInAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "map-pin" }, { type: "typography", content: "@entity.targetId", variant: "h3" }, { type: "badge", label: "@entity.mode", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Target type" }, { type: "typography", variant: "body", content: "@entity.targetType" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "User" }, { type: "typography", variant: "body", content: "@entity.userId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "QR code" }, { type: "typography", variant: "body", content: "@entity.qrCode" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Latitude", value: "@entity.lat", icon: "map" }, { type: "stat-display", label: "Longitude", value: "@entity.lng", icon: "map" }, { type: "stat-display", label: "Checked in", value: "@entity.checkedInAt", icon: "clock" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Verify", variant: "primary", action: "VERIFY_CHECKIN", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Revoke", variant: "danger", action: "REVOKE_CHECKIN", actionPayload: { id: "@entity.id" } }] }] })
      REVOKE_CHECKIN -> loading
        (set @entity.id @payload.id)
        (fetch Checkin { emit: { success: "CheckinLoaded", failure: "CheckinLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Revoking check-in…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Checkin { emit: { success: "CheckinLoaded", failure: "CheckinLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading check-ins…" }] })
      VERIFY_CHECKIN -> loading
        (set @entity.id @payload.id)
        (fetch Checkin { emit: { success: "CheckinLoaded", failure: "CheckinLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Verifying check-in…" }] })
      REVOKE_CHECKIN -> loading
        (set @entity.id @payload.id)
        (fetch Checkin { emit: { success: "CheckinLoaded", failure: "CheckinLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Revoking check-in…" }] })
    }
    state error {
      INIT -> loading
        (fetch Checkin { emit: { success: "CheckinLoaded", failure: "CheckinLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_CHECKIN      { id : string!, row : Checkin }
      CLOSE_VIEW        { }
      VERIFY_CHECKIN    { id : string! }
      REVOKE_CHECKIN    { id : string! }
      CheckinLoaded     { data : [Checkin] }
      CheckinLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_CHECKIN      { id : string!, row : Checkin }
      CLOSE_VIEW        { }
      VERIFY_CHECKIN    { id : string! }
      REVOKE_CHECKIN    { id : string! }
      CheckinLoaded     { data : [Checkin] }
      CheckinLoadFailed { error : string, code : string }
    }
  }
  page "/checkins" as CheckinScanPage -> CheckinScan
}
