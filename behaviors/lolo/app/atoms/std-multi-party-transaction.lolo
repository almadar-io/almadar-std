app std-multi-party-transaction "1.0.0"
"std-multi-party-transaction — domain-specific buyer/seller escrow flow. Composes std-two-sided-flow with persisted MarketTransaction entity (amount, currency, buyerId, sellerId, listingId). Lights up std-marketplace, std-ecommerce checkout, std-listings offer+accept."

orbital MultiPartyTransactionOrbital {
  uses Flow from "std/behaviors/std-two-sided-flow"

  entity MarketTransaction [persistent: market_transactions] {
    id          : string!
    title       : string!
    amount      : number  = 0
    currency    : "USD" | "EUR" | "GBP" | "SAR" | "AED" = "USD"
    buyerId     : string  = ""
    sellerId    : string  = ""
    listingId   : string  = ""
    action      : string  = ""
    notes       : string  = ""
    createdAt   : string  = ""
  }

  trait MarketEscrow = Flow.traits.TwoSidedTransaction -> MarketTransaction {
    config: {
      title:           "Marketplace Transaction",
      partyALabel:     "Buyer",
      partyAIcon:      "shopping-cart",
      partyAAction:    "Fund Escrow",
      partyAActionIcon: "credit-card",
      partyBLabel:     "Seller",
      partyBIcon:      "package",
      partyBAction:    "Ship Item",
      partyBActionIcon: "truck",
      releaseLabel:    "Release Funds",
      releaseIcon:     "unlock",
      disputeLabel:    "Open Dispute",
      disputeIcon:     "alert-triangle",
      cancelLabel:     "Cancel Transaction",
      cancelIcon:      "x"
    }
  }

  page "/multi-party-transaction" as MultiPartyTransactionPage -> MarketEscrow
}
