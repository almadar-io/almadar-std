app std-customer-account "1.2.0"
"std-customer-account — retail customer profile with loyalty points, store credit and Grant Points / Issue Credit / Ban actions. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes CRM-pattern knobs."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital CustomerAccountOrbital {
  entity CustomerAccount [persistent: customeraccounts] {
    id : string!
    name : string!
    email : string = ""
    phone : string = ""
    loyaltyPoints : number = 0
    storeCreditAmount : number = 0
    totalSpent : number = 0
    joinedAt : string = ""
    lastVisitAt : string = ""
    status : "active" | "inactive" | "banned" = "active"
  }
  type CustomerAccountLoaded       = Event { data : [CustomerAccount] }
  type CustomerAccountLoadFailed   = Event { error : string, code : string }
  type CustomerAccountUpdated      = Event { row : CustomerAccount }              "Fired after a customer's status persists"
  type CustomerAccountUpdateFailed = Event { error : string, code : string }      "Fired when a customer's status update fails to persist"

  trait CustomerAccountDirectory -> CustomerAccount [interaction, collection] {
    config {
      title       : string   = "Customers"
        @label "Section title"
        @description "Heading shown above the customer directory"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "name",          label: "Name",        variant: "caption" },
        { name: "email",         label: "Email",       variant: "caption" },
        { name: "phone",         label: "Phone",       variant: "caption" },
        { name: "loyaltyPoints", label: "Points",      variant: "caption" },
        { name: "totalSpent",    label: "Total Spent", variant: "caption" },
        { name: "status",        label: "Status",      variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Customer entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open", event: "OPEN_CUSTOMER", variant: "primary", icon: "arrow-right" },
        { label: "Ban",  event: "BAN_CUSTOMER",  variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each customer row"
        @tier "presentation"
      healthScoreThresholdAlert : number = 50
        @label "Health score threshold"
        @description "Customers with health score below this trigger an alert. Declarative; wire via sibling std-notify."
        @tier "domain"
      renewalReminderDaysBefore : [number] = [30, 7, 1]
        @label "Renewal reminder days-before"
        @description "Days before subscription renewal to send reminders. Declarative; wire via sibling std-reminder-scheduler."
        @tier "domain"
      archiveInactiveAfterDays : number = 365
        @label "Archive inactive after (days)"
        @description "Days of inactivity before customer is auto-archived. Declarative; wire via sibling std-lifecycle."
        @tier "domain"
      consentTrackingEnabled : boolean = true
        @label "Track consent"
        @description "Whether to record marketing/data-processing consent on the customer profile. Declarative."
        @tier "domain"
      defaultRetentionYears : number = 7
        @label "Customer record retention (years)"
        @description "Years to keep a closed customer profile before deletion. Compose std-lifecycle + std-data-erasure to enforce."
        @tier "domain"
        @synonyms "keep customer for, GDPR retention"
      gdprConsentRequired : boolean = true
        @label "GDPR consent required"
        @description "When true, customer profiles require explicit GDPR-compliant consent before storing PII. Drives consent-capture UI."
        @tier "domain"
        @synonyms "GDPR opt-in, data processing consent"
      lifecycleStagePolicy : "linear" | "branching" | "none" = "linear"
        @label "Lifecycle stage policy"
        @description "linear = standard lead→customer→inactive progression; branching = supports parallel sub-stages; none = free-form status."
        @tier "domain"
        @synonyms "customer journey, stage progression"
      contactFrequencyCapPerWeek : number = 5
        @label "Contact frequency cap (per week)"
        @description "Maximum outbound contacts (email/SMS/call) per customer per week. 0 = uncapped."
        @tier "domain"
        @synonyms "outreach cap, contact limit"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading customers…" }] })
      CustomerAccountLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total customers", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "Active", value: "1,284", icon: "check-circle" }, { type: "stat-display", label: "Loyalty members", value: "76%", icon: "award" }, { type: "stat-display", label: "Avg lifetime value", value: "$412", icon: "dollar-sign" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      CustomerAccountLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_CUSTOMER -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.email @payload.row.email)
        (set @entity.phone @payload.row.phone)
        (set @entity.loyaltyPoints @payload.row.loyaltyPoints)
        (set @entity.storeCreditAmount @payload.row.storeCreditAmount)
        (set @entity.totalSpent @payload.row.totalSpent)
        (set @entity.joinedAt @payload.row.joinedAt)
        (set @entity.lastVisitAt @payload.row.lastVisitAt)
        (set @entity.status @payload.row.status)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "user" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Loyalty points", value: "@entity.loyaltyPoints", icon: "award" }, { type: "stat-display", label: "Store credit", value: "@entity.storeCreditAmount", icon: "credit-card" }, { type: "stat-display", label: "Total spent", value: "@entity.totalSpent", icon: "dollar-sign" }, { type: "stat-display", label: "Last visit", value: "@entity.lastVisitAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Grant Points", variant: "primary", action: "GRANT_POINTS", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Issue Credit", variant: "secondary", action: "GRANT_CREDIT", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Ban", variant: "danger", action: "BAN_CUSTOMER", actionPayload: { id: "@entity.id" } }] }] })
      BAN_CUSTOMER -> loading
        (set @entity.id @payload.id)
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Banning customer…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update CustomerAccount @entity { emit: { success: "CustomerAccountUpdated", failure: "CustomerAccountUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating customer status…" }] })
      CustomerAccountUpdated -> loading
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
      CustomerAccountUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading customers…" }] })
      GRANT_POINTS -> loading
        (set @entity.id @payload.id)
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Granting points…" }] })
      GRANT_CREDIT -> loading
        (set @entity.id @payload.id)
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Issuing store credit…" }] })
      BAN_CUSTOMER -> loading
        (set @entity.id @payload.id)
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Banning customer…" }] })
    }
    state error {
      INIT -> loading
        (fetch CustomerAccount { emit: { success: "CustomerAccountLoaded", failure: "CustomerAccountLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }

    emits {
      OPEN_CUSTOMER { id : string!, row : CustomerAccount }
      CLOSE_VIEW    { }
      GRANT_POINTS  { id : string! }
      GRANT_CREDIT  { id : string! }
      BAN_CUSTOMER  { id : string! }
      CustomerAccountLoaded       { data : [CustomerAccount] }
      CustomerAccountLoadFailed   { error : string, code : string }
      CustomerAccountUpdated      { row : CustomerAccount }
      CustomerAccountUpdateFailed { error : string, code : string }
    }
    listens {
      OPEN_CUSTOMER { id : string!, row : CustomerAccount }
      CLOSE_VIEW    { }
      GRANT_POINTS  { id : string! }
      GRANT_CREDIT  { id : string! }
      BAN_CUSTOMER  { id : string! }
      SET_STATUS    { entityId : string!, newStatus : string! }
      CustomerAccountLoaded       { data : [CustomerAccount] }
      CustomerAccountLoadFailed   { error : string, code : string }
      CustomerAccountUpdated      { row : CustomerAccount }
      CustomerAccountUpdateFailed { error : string, code : string }
    }
  }
  page "/customers" as CustomerAccountPage -> CustomerAccountDirectory
}
