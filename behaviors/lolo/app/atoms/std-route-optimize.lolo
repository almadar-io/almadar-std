app std-route-optimize "1.1.0"
"std-route-optimize — multi-stop route ordering for technician dispatch. Lists routes in `browsing`; opens detail in `viewing_single` with Optimize / Reset actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital RouteOptimizeOrbital {
  entity Route [persistent: routes] {
    id                   : string!
    technicianId         : string
    originLat            : number
    originLng            : number
    stops                : [string]
    totalDistanceKm      : number
    totalDurationMinutes : number
    optimizedAt          : string
  }

  type RouteLoaded     = Event { data : [Route] }                "Fired when the route collection finishes loading"
  type RouteLoadFailed = Event { error : string, code : string } "Fired when the route collection fails to load"

  trait RouteOptimize -> Route [interaction, collection] {
    config {
      title       : string   = "Routes"
        @label "Section title"
        @description "Heading shown above the technician route list"
      fields      : [FieldSpec] = [
        { name: "technicianId",         label: "Technician",     variant: "caption" },
        { name: "totalDistanceKm",      label: "Distance (km)",  variant: "caption" },
        { name: "totalDurationMinutes", label: "Duration (min)", variant: "caption" },
        { name: "optimizedAt",          label: "Optimized",      variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Route entity"
      itemActions : [ItemAction] = [
        { label: "Open",     event: "OPEN_ROUTE", variant: "primary", icon: "arrow-right" },
        { label: "Optimize", event: "OPTIMIZE",   variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each route row"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading routes…" }] })
      RouteLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total routes", value: "@payload.data.length", icon: "map" }, { type: "stat-display", label: "Optimized today", value: "14", icon: "check-circle" }, { type: "stat-display", label: "Total distance", value: "1,284 km", icon: "navigation" }, { type: "stat-display", label: "Avg duration", value: "92 min", icon: "clock" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      RouteLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_ROUTE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.technicianId @payload.row.technicianId)
        (set @entity.originLat @payload.row.originLat)
        (set @entity.originLng @payload.row.originLng)
        (set @entity.totalDistanceKm @payload.row.totalDistanceKm)
        (set @entity.totalDurationMinutes @payload.row.totalDurationMinutes)
        (set @entity.optimizedAt @payload.row.optimizedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "map" }, { type: "typography", content: "@entity.technicianId", variant: "h3" }, { type: "badge", label: "Optimized", variant: "success" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Origin lat" }, { type: "typography", variant: "body", content: "@entity.originLat" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Origin lng" }, { type: "typography", variant: "body", content: "@entity.originLng" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Distance (km)", value: "@entity.totalDistanceKm", icon: "navigation" }, { type: "stat-display", label: "Duration (min)", value: "@entity.totalDurationMinutes", icon: "clock" }, { type: "stat-display", label: "Last optimized", value: "@entity.optimizedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Optimize", variant: "primary", action: "OPTIMIZE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Reset", variant: "danger", action: "RESET_ROUTE", actionPayload: { id: "@entity.id" } }] }] })
      OPTIMIZE -> loading
        (set @entity.id @payload.id)
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Optimizing route…" }] })
      RESET_ROUTE -> loading
        (set @entity.id @payload.id)
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Resetting route…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading routes…" }] })
      OPTIMIZE -> loading
        (set @entity.id @payload.id)
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Optimizing route…" }] })
      RESET_ROUTE -> loading
        (set @entity.id @payload.id)
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Resetting route…" }] })
    }
    state error {
      INIT -> loading
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ROUTE       { id : string!, row : Route }
      CLOSE_VIEW       { }
      OPTIMIZE         { id : string! }
      RESET_ROUTE      { id : string! }
      RouteLoaded      { data : [Route] }
      RouteLoadFailed  { error : string, code : string }
    }
    listens {
      OPEN_ROUTE       { id : string!, row : Route }
      CLOSE_VIEW       { }
      OPTIMIZE         { id : string! }
      RESET_ROUTE      { id : string! }
      RouteLoaded      { data : [Route] }
      RouteLoadFailed  { error : string, code : string }
    }
  }
  page "/routes/optimize" as RouteOptimizePage -> RouteOptimize
}
