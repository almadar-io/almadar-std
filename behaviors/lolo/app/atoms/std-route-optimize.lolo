app std-route-optimize "1.0.0"
"std-route-optimize — multi-stop route ordering for technician dispatch. Owns a Route entity (origin coords + ordered stops + totals); OPTIMIZE invokes the route-optimize service to reorder stops, then persists the updated row and emits RouteUpdated for downstream listeners."

orbital RouteOptimizeOrbital {
  entity Route [persistent: routes] {
    id                   : string!
    technicianId         : string
    originLat            : number
    originLng            : number
    stops                : [string]
    totalDistanceKm      : number
    totalDurationMinutes : number
    optimizedAt          : string
  }

  type RouteLoaded            = Event { data : [Route] }                    "Fired when the route collection finishes loading"
  type RouteLoadFailed        = Event { error : string, code : string }     "Fired when the route collection fails to load"
  type RouteOptimized         = Event { row : Route }                       "Fired after the route-optimize service returns a reordered route"
  type RouteOptimizeFailed    = Event { error : string, code : string }     "Fired when the route-optimize service call fails"
  type RouteUpdated           = Event { row : Route }                       "Fired after a route row persists (post-optimize)"

  trait RouteOptimize -> Route [interaction, collection] {
    config {
      title : string = "Routes"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading routes…" }] })
      RouteLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "map" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "technicianId", label: "Technician", variant: "caption" }, { name: "stops", label: "Stops", variant: "caption" }, { name: "totalDistanceKm", label: "Distance (km)", variant: "caption" }, { name: "totalDurationMinutes", label: "Duration (min)", variant: "caption" }, { name: "optimizedAt", label: "Optimized", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Optimize", event: "OPTIMIZE", variant: "primary", icon: "route" }] }] })
      RouteLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPTIMIZE -> optimizing
        (set @entity.id @payload.routeId)
        (call-service route-optimize "optimize" { routeId: @entity.id } { emit: { success: "RouteOptimized", failure: "RouteOptimizeFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Optimizing route…" }] })
      RouteUpdated -> browsing
        (render-ui main { type: "alert", variant: "success", message: "Route updated" })
    }
    state optimizing {
      RouteOptimized -> browsing
        (persist update Route @payload.row { emit: { success: "RouteUpdated", failure: "RouteOptimizeFailed" } })
      RouteOptimizeFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state error {
      INIT -> loading
        (fetch Route { emit: { success: "RouteLoaded", failure: "RouteLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPTIMIZE             { routeId : string! }
      RouteLoaded          { data : [Route] }
      RouteLoadFailed      { error : string, code : string }
      RouteOptimized       { row : Route }
      RouteOptimizeFailed  { error : string, code : string }
      RouteUpdated         { row : Route }
    }
    listens {
      OPTIMIZE             { routeId : string! }
      RouteLoaded          { data : [Route] }
      RouteLoadFailed      { error : string, code : string }
      RouteOptimized       { row : Route }
      RouteOptimizeFailed  { error : string, code : string }
      RouteUpdated         { row : Route }
    }
  }
  page "/routes/optimize" as RouteOptimizePage -> RouteOptimize
}
