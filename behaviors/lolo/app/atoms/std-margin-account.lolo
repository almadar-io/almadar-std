app std-margin-account "1.0.0"
"std-margin-account — margin account leverage and call thresholds for trading apps."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital MarginAccountOrbital {
  entity MarginAccount [persistent: margin_accounts] {
    id                  : string!
    accountHolderId     : string!
    equityUSD           : number
    marginUsedUSD       : number
    marginAvailableUSD  : number
    status              : "good-standing" | "warning" | "margin-call" | "liquidated" = "good-standing"
    lastCallAt          : string
    createdAt           : string
  }

  type MarginAccountLoaded        = Event { data : [MarginAccount] }              "Fired when the margin account collection finishes loading"
  type MarginAccountLoadFailed    = Event { error : string, code : string }       "Fired when the margin account collection fails to load"

  trait MarginAccountManage -> MarginAccount [interaction, collection] {
    config {
      title : string = "Margin Accounts"
        @label "Section title"
        @description "Heading shown above the margin account list"
        @tier "presentation"
      fields      : [FieldSpec] = [{ name: "accountHolderId", label: "Holder", variant: "caption" }, { name: "equityUSD", label: "Equity", variant: "caption" }, { name: "marginUsedUSD", label: "Used", variant: "caption" }, { name: "marginAvailableUSD", label: "Available", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "lastCallAt", label: "Last Call", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the MarginAccount entity"
        @tier "presentation"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_ACCOUNT", variant: "primary", icon: "arrow-right" }, { label: "Issue Call", event: "ISSUE_CALL", variant: "danger", icon: "alert-triangle" }]
        @label "Row actions"
        @description "Buttons users can click on each margin account row"
        @tier "presentation"
      marginLeverage : "2x" | "4x" | "10x" | "20x" = "2x"
        @label "Margin leverage"
        @description "Maximum leverage ratio permitted (regulatory + risk-appetite driven)."
        @tier "domain"
        @synonyms "leverage ratio, max leverage"
      marginCallThresholdPct : number = 30
        @label "Margin call threshold (%)"
        @description "Equity percentage at which margin call is issued."
        @tier "domain"
        @synonyms "maintenance margin"
      forcedLiquidationThresholdPct : number = 20
        @label "Forced liquidation threshold (%)"
        @description "Equity percentage at which positions are auto-liquidated to cover the loan."
        @tier "domain"
        @synonyms "liquidation trigger"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch MarginAccount { emit: { success: "MarginAccountLoaded", failure: "MarginAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading margin accounts…" }] })
      MarginAccountLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "trending-up" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total accounts", value: "@payload.data.length", icon: "trending-up" }, { type: "stat-display", label: "Good standing", value: "184", icon: "check-circle" }, { type: "stat-display", label: "Warning", value: "12", icon: "alert-triangle" }, { type: "stat-display", label: "Margin calls", value: "3", icon: "phone" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      MarginAccountLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_ACCOUNT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.accountHolderId @payload.row.accountHolderId)
        (set @entity.equityUSD @payload.row.equityUSD)
        (set @entity.marginUsedUSD @payload.row.marginUsedUSD)
        (set @entity.marginAvailableUSD @payload.row.marginAvailableUSD)
        (set @entity.status @payload.row.status)
        (set @entity.lastCallAt @payload.row.lastCallAt)
        (set @entity.createdAt @payload.row.createdAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "trending-up" }, { type: "typography", content: "@entity.accountHolderId", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Equity", value: "@entity.equityUSD", icon: "dollar-sign" }, { type: "stat-display", label: "Margin Used", value: "@entity.marginUsedUSD", icon: "dollar-sign" }, { type: "stat-display", label: "Margin Available", value: "@entity.marginAvailableUSD", icon: "dollar-sign" }] }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Last Call" }, { type: "typography", variant: "body", content: "@entity.lastCallAt" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Created" }, { type: "typography", variant: "body", content: "@entity.createdAt" }] }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Issue Call", variant: "danger", action: "ISSUE_CALL", actionPayload: { id: "@entity.id", row: "@entity" } }, { type: "button", label: "Liquidate", variant: "danger", action: "LIQUIDATE", actionPayload: { id: "@entity.id", row: "@entity" } }] }] })
      ISSUE_CALL -> loading
        (set @entity.id @payload.id)
        (fetch MarginAccount { emit: { success: "MarginAccountLoaded", failure: "MarginAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Issuing margin call…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch MarginAccount { emit: { success: "MarginAccountLoaded", failure: "MarginAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading margin accounts…" }] })
      ISSUE_CALL -> loading
        (set @entity.id @payload.id)
        (fetch MarginAccount { emit: { success: "MarginAccountLoaded", failure: "MarginAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Issuing margin call…" }] })
      LIQUIDATE -> loading
        (set @entity.id @payload.id)
        (fetch MarginAccount { emit: { success: "MarginAccountLoaded", failure: "MarginAccountLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Liquidating positions…" }] })
    }
    state error {
      INIT -> loading
        (fetch MarginAccount { emit: { success: "MarginAccountLoaded", failure: "MarginAccountLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ACCOUNT { id : string!, row : MarginAccount }
      CLOSE_VIEW   { }
      ISSUE_CALL   { id : string!, row : MarginAccount }
      LIQUIDATE    { id : string!, row : MarginAccount }
      MarginAccountLoaded       { data : [MarginAccount] }
      MarginAccountLoadFailed   { error : string, code : string }
    }
    listens {
      OPEN_ACCOUNT { id : string!, row : MarginAccount }
      CLOSE_VIEW   { }
      ISSUE_CALL   { id : string!, row : MarginAccount }
      LIQUIDATE    { id : string!, row : MarginAccount }
      MarginAccountLoaded       { data : [MarginAccount] }
      MarginAccountLoadFailed   { error : string, code : string }
    }
  }
  page "/margin-accounts/manage" as MarginAccountManagePage -> MarginAccountManage
}
