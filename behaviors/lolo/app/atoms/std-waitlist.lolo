app std-waitlist "1.0.0"
"std-waitlist — sorted queue with auto-promote-on-cancel. Owns a WaitlistEntry entity (one row per (targetId, userId)); JOIN appends a waiting entry, PROMOTE flips status to promoted, CANCEL flips status to cancelled and emits WaitlistEntryCancelled so a parent molecule can promote the next waiting entry."

orbital WaitlistOrbital {
  entity WaitlistEntry [persistent: waitlistentries] {
    id          : string!
    targetId    : string!
    targetType  : string!
    userId      : string!
    position    : number!
    status      : "waiting" | "promoted" | "cancelled" | "expired" = "waiting"
    joinedAt    : string
    promotedAt  : string
    notifiedAt  : string
  }

  type WaitlistEntryLoaded     = Event { data : [WaitlistEntry] }            "Fired when the waitlist collection finishes loading"
  type WaitlistEntryLoadFailed = Event { error : string, code : string }     "Fired when the waitlist collection fails to load"
  type WaitlistEntryJoined     = Event { row : WaitlistEntry }               "Fired after a new waitlist entry persists successfully"
  type WaitlistEntryPromoted   = Event { row : WaitlistEntry }               "Fired after a waitlist entry is promoted (status -> promoted)"
  type WaitlistEntryCancelled  = Event { row : WaitlistEntry }               "Fired after a waitlist entry is cancelled; parent molecules can listen and promote the next waiting entry"
  type WaitlistEntryFailed     = Event { error : string, code : string }     "Fired when a waitlist entry write fails to persist"

  trait WaitlistManage -> WaitlistEntry [interaction, collection] {
    config {
      title : string = "Waitlist"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading waitlist…" }] })
      WaitlistEntryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "position", label: "#", variant: "badge" }, { name: "userId", label: "User", variant: "caption" }, { name: "targetType", label: "Type", variant: "badge" }, { name: "status", label: "Status", variant: "badge" }, { name: "joinedAt", label: "Joined", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Promote", event: "PROMOTE", variant: "primary", icon: "arrow-up" }, { label: "Cancel", event: "CANCEL", variant: "destructive", icon: "x" }] }, { type: "button", label: "Join Waitlist", action: "JOIN", variant: "secondary", icon: "user-plus" }] })
      WaitlistEntryLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      JOIN -> loading
        (set @entity.targetId @payload.targetId)
        (set @entity.userId @payload.userId)
        (persist create WaitlistEntry @entity { emit: { success: "WaitlistEntryJoined", failure: "WaitlistEntryFailed" } })
      PROMOTE -> loading
        (set @entity.id @payload.entryId)
        (set @entity.status "promoted")
        (persist update WaitlistEntry @entity { emit: { success: "WaitlistEntryPromoted", failure: "WaitlistEntryFailed" } })
      CANCEL -> loading
        (set @entity.id @payload.entryId)
        (set @entity.status "cancelled")
        (persist update WaitlistEntry @entity { emit: { success: "WaitlistEntryCancelled", failure: "WaitlistEntryFailed" } })
      WaitlistEntryJoined -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
      WaitlistEntryPromoted -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
      WaitlistEntryCancelled -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
      WaitlistEntryFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state error {
      INIT -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      JOIN     { targetId : string!, userId : string! }
      PROMOTE  { entryId : string!, row : WaitlistEntry }
      CANCEL   { entryId : string!, row : WaitlistEntry }
      WaitlistEntryLoaded     { data : [WaitlistEntry] }
      WaitlistEntryLoadFailed { error : string, code : string }
      WaitlistEntryJoined     { row : WaitlistEntry }
      WaitlistEntryPromoted   { row : WaitlistEntry }
      WaitlistEntryCancelled  { row : WaitlistEntry }
      WaitlistEntryFailed     { error : string, code : string }
    }
    listens {
      JOIN     { targetId : string!, userId : string! }
      PROMOTE  { entryId : string!, row : WaitlistEntry }
      CANCEL   { entryId : string!, row : WaitlistEntry }
      WaitlistEntryLoaded     { data : [WaitlistEntry] }
      WaitlistEntryLoadFailed { error : string, code : string }
      WaitlistEntryJoined     { row : WaitlistEntry }
      WaitlistEntryPromoted   { row : WaitlistEntry }
      WaitlistEntryCancelled  { row : WaitlistEntry }
      WaitlistEntryFailed     { error : string, code : string }
    }
  }
  page "/waitlistentries/manage" as WaitlistManagePage -> WaitlistManage
}
