app std-waitlist "1.2.0"
"std-waitlist — sorted queue with auto-promote-on-cancel. Listens for SET_STATUS so std-lifecycle can auto-expire. Exposes Scheduling/Booking knobs (bookingWindowDays, leadTimeMinutes, cancellationPolicy, …)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital WaitlistOrbital {
  entity WaitlistEntry [persistent: waitlistentries] {
    id          : string!
    targetId    : string!
    targetType  : string!
    userId      : string!
    position    : number!
    status      : "waiting" | "promoted" | "cancelled" | "expired" = "waiting"
    joinedAt    : string
    promotedAt  : string
    notifiedAt  : string
  }

  type WaitlistEntryLoaded     = Event { data : [WaitlistEntry] }            "Fired when the waitlist collection finishes loading"
  type WaitlistEntryLoadFailed = Event { error : string, code : string }     "Fired when the waitlist collection fails to load"

  trait WaitlistManage -> WaitlistEntry [interaction, collection] {
    config {
      title : string = "Waitlist"
        @label "Section title"
        @description "Heading shown above the waitlist queue"
        @tier "customization"
      fields      : [FieldSpec] = [{ name: "position", label: "#", variant: "badge" }, { name: "userId", label: "User", variant: "caption" }, { name: "targetType", label: "Type", variant: "badge" }, { name: "status", label: "Status", variant: "badge" }, { name: "joinedAt", label: "Joined", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Waitlist Entry entity"
        @tier "advanced"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_ENTRY", variant: "primary", icon: "arrow-right" }, { label: "Cancel", event: "CANCEL", variant: "danger", icon: "x" }]
        @label "Row actions"
        @description "Buttons users can click on each waitlist entry"
        @tier "customization"
      bookingWindowDays : number = 30
        @label "Booking window (days)"
        @description "How far in advance users can join the waitlist."
        @tier "customization"
      leadTimeMinutes : number = 0
        @label "Lead time (minutes)"
        @description "Minutes before target availability that the waitlist still accepts joins."
        @tier "customization"
      bookingHours : string = "00:00-23:59"
        @label "Booking hours"
        @description "Daily window during which waitlist joins are accepted (HH:MM-HH:MM)."
        @tier "customization"
      blackoutDates : [string] = []
        @label "Blackout dates"
        @description "ISO dates blocked from joining the waitlist."
        @tier "customization"
      noShowGracePeriodMinutes : number = 60
        @label "No-show grace (minutes)"
        @description "Minutes after promotion notice before the entry auto-expires if not claimed. Wire via std-lifecycle."
        @tier "customization"
      rescheduleWindowHours : number = 24
        @label "Reschedule window (hours)"
        @description "Hours during which a user can defer their promoted slot."
        @tier "customization"
      maxReschedules : number = 1
        @label "Max reschedules"
        @description "Hard cap on deferral count per waitlist entry."
        @tier "advanced"
      cancellationPolicy : "free" | "partial-refund" | "no-refund" = "free"
        @label "Cancellation policy"
        @description "Refund treatment when a waitlist entry is cancelled after a deposit."
        @tier "customization"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading waitlist…" }] })
      WaitlistEntryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total entries", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "Waiting", value: "126", icon: "hourglass" }, { type: "stat-display", label: "Promoted 7d", value: "24", icon: "arrow-up" }, { type: "stat-display", label: "Avg wait time", value: "3d", icon: "clock" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      WaitlistEntryLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_ENTRY -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.targetId @payload.row.targetId)
        (set @entity.targetType @payload.row.targetType)
        (set @entity.userId @payload.row.userId)
        (set @entity.position @payload.row.position)
        (set @entity.status @payload.row.status)
        (set @entity.joinedAt @payload.row.joinedAt)
        (set @entity.promotedAt @payload.row.promotedAt)
        (set @entity.notifiedAt @payload.row.notifiedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "users" }, { type: "typography", content: "@entity.userId", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Target" }, { type: "typography", variant: "body", content: "@entity.targetId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Target type" }, { type: "typography", variant: "body", content: "@entity.targetType" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Position", value: "@entity.position", icon: "hash" }, { type: "stat-display", label: "Joined", value: "@entity.joinedAt", icon: "calendar" }, { type: "stat-display", label: "Promoted", value: "@entity.promotedAt", icon: "arrow-up" }, { type: "stat-display", label: "Notified", value: "@entity.notifiedAt", icon: "bell" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Promote", variant: "primary", action: "PROMOTE", actionPayload: { entryId: "@entity.id", row: "@entity" } }, { type: "button", label: "Cancel", variant: "danger", action: "CANCEL", actionPayload: { entryId: "@entity.id", row: "@entity" } }] }] })
      CANCEL -> loading
        (set @entity.id @payload.entryId)
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling entry…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update WaitlistEntry @entity { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating waitlist entry status…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading waitlist…" }] })
      PROMOTE -> loading
        (set @entity.id @payload.entryId)
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Promoting entry…" }] })
      CANCEL -> loading
        (set @entity.id @payload.entryId)
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Cancelling entry…" }] })
    }
    state error {
      INIT -> loading
        (fetch WaitlistEntry { emit: { success: "WaitlistEntryLoaded", failure: "WaitlistEntryLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ENTRY { id : string!, row : WaitlistEntry }
      CLOSE_VIEW { }
      PROMOTE    { entryId : string!, row : WaitlistEntry }
      CANCEL     { entryId : string!, row : WaitlistEntry }
      WaitlistEntryLoaded     { data : [WaitlistEntry] }
      WaitlistEntryLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_ENTRY { id : string!, row : WaitlistEntry }
      CLOSE_VIEW { }
      PROMOTE    { entryId : string!, row : WaitlistEntry }
      CANCEL     { entryId : string!, row : WaitlistEntry }
      SET_STATUS { entityId : string!, newStatus : string! }
      WaitlistEntryLoaded     { data : [WaitlistEntry] }
      WaitlistEntryLoadFailed { error : string, code : string }
    }
  }
  page "/waitlistentries/manage" as WaitlistManagePage -> WaitlistManage
}
