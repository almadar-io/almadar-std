app std-campaign-goal "1.2.0"
"std-campaign-goal — nonprofit fundraising campaign with Launch / End actions. Listens for SET_STATUS so std-lifecycle can drive automated transitions. Exposes CRM-pattern knobs."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital CampaignGoalOrbital {
  entity CampaignGoal [persistent: campaigngoals] {
    id            : string!
    name          : string!
    description   : string = ""
    targetAmount  : number = 0
    raisedAmount  : number = 0
    donorCount    : number = 0
    startDate     : string = ""
    endDate       : string = ""
    status        : "draft" | "active" | "achieved" | "ended" = "draft"
  }

  type CampaignGoalLoaded       = Event { data : [CampaignGoal] }            "Fired when the campaign collection finishes loading"
  type CampaignGoalLoadFailed   = Event { error : string, code : string }    "Fired when the campaign collection fails to load"
  type CampaignGoalUpdated      = Event { row : CampaignGoal }               "Fired after a campaign's status persists"
  type CampaignGoalUpdateFailed = Event { error : string, code : string }    "Fired when a campaign's status update fails to persist"

  trait CampaignGoalTracker -> CampaignGoal [interaction, collection] {
    config {
      title       : string   = "Campaigns"
        @label "Section title"
        @description "Heading shown above the fundraising campaign list"
        @tier "presentation"
      fields      : [FieldSpec] = [
        { name: "name",         label: "Name",   variant: "caption" },
        { name: "targetAmount", label: "Target", variant: "caption" },
        { name: "raisedAmount", label: "Raised", variant: "caption" },
        { name: "donorCount",   label: "Donors", variant: "caption" },
        { name: "status",       label: "Status", variant: "badge"   }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Campaign entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open", event: "OPEN_CAMPAIGN", variant: "primary", icon: "arrow-right" },
        { label: "End",  event: "END_CAMPAIGN",  variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each campaign row"
        @tier "presentation"
      healthScoreThresholdAlert : number = 25
        @label "Health score threshold (% of target)"
        @description "Alert when raisedAmount/targetAmount drops below this with deadline approaching. Declarative; wire via sibling std-notify."
        @tier "domain"
      renewalReminderDaysBefore : [number] = [30, 7, 1]
        @label "Reminder days-before endDate"
        @description "Days before campaign endDate to ping major donors / followers. Declarative; wire via sibling std-reminder-scheduler."
        @tier "domain"
      archiveInactiveAfterDays : number = 180
        @label "Archive after end (days)"
        @description "Days after endDate before an ended campaign is archived. Declarative; wire via sibling std-lifecycle."
        @tier "domain"
      consentTrackingEnabled : boolean = true
        @label "Track consent"
        @description "Whether donor outreach honors opt-in consent records. Declarative."
        @tier "domain"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading campaigns…" }] })
      CampaignGoalLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "target" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Campaigns", value: "@payload.data.length", icon: "target" }, { type: "stat-display", label: "Active", value: "6", icon: "play-circle" }, { type: "stat-display", label: "Total raised", value: "$482K", icon: "dollar-sign" }, { type: "stat-display", label: "Donors", value: "1,240", icon: "users" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      CampaignGoalLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_CAMPAIGN -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.description @payload.row.description)
        (set @entity.targetAmount @payload.row.targetAmount)
        (set @entity.raisedAmount @payload.row.raisedAmount)
        (set @entity.donorCount @payload.row.donorCount)
        (set @entity.startDate @payload.row.startDate)
        (set @entity.endDate @payload.row.endDate)
        (set @entity.status @payload.row.status)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "target" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Target", value: "@entity.targetAmount", icon: "target" }, { type: "stat-display", label: "Raised", value: "@entity.raisedAmount", icon: "dollar-sign" }, { type: "stat-display", label: "Donors", value: "@entity.donorCount", icon: "users" }, { type: "stat-display", label: "Ends", value: "@entity.endDate", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Launch", variant: "primary", action: "LAUNCH_CAMPAIGN", actionPayload: { id: "@entity.id" } }, { type: "button", label: "End", variant: "danger", action: "END_CAMPAIGN", actionPayload: { id: "@entity.id" } }] }] })
      END_CAMPAIGN -> loading
        (set @entity.id @payload.id)
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Ending campaign…" }] })
      SET_STATUS -> loading
        (set @entity.id @payload.entityId)
        (set @entity.status @payload.newStatus)
        (persist update CampaignGoal @entity { emit: { success: "CampaignGoalUpdated", failure: "CampaignGoalUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Updating campaign status…" }] })
      CampaignGoalUpdated -> loading
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
      CampaignGoalUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading campaigns…" }] })
      LAUNCH_CAMPAIGN -> loading
        (set @entity.id @payload.id)
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Launching campaign…" }] })
      END_CAMPAIGN -> loading
        (set @entity.id @payload.id)
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Ending campaign…" }] })
    }
    state error {
      INIT -> loading
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_CAMPAIGN             { id : string!, row : CampaignGoal }
      CLOSE_VIEW                { }
      LAUNCH_CAMPAIGN           { id : string! }
      END_CAMPAIGN              { id : string! }
      CampaignGoalLoaded        { data : [CampaignGoal] }
      CampaignGoalLoadFailed    { error : string, code : string }
      CampaignGoalUpdated       { row : CampaignGoal }
      CampaignGoalUpdateFailed  { error : string, code : string }
    }
    listens {
      OPEN_CAMPAIGN             { id : string!, row : CampaignGoal }
      CLOSE_VIEW                { }
      LAUNCH_CAMPAIGN           { id : string! }
      END_CAMPAIGN              { id : string! }
      SET_STATUS                { entityId : string!, newStatus : string! }
      CampaignGoalLoaded        { data : [CampaignGoal] }
      CampaignGoalLoadFailed    { error : string, code : string }
      CampaignGoalUpdated       { row : CampaignGoal }
      CampaignGoalUpdateFailed  { error : string, code : string }
    }
  }
  page "/campaigns" as CampaignGoalPage -> CampaignGoalTracker
}
