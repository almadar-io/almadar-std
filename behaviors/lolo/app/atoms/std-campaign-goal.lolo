app std-campaign-goal "1.0.0"
"std-campaign-goal — nonprofit fundraising campaign primitive with a target dollar amount, running raised total, donor count, deadline, and status. Browses campaigns in a data-grid with Launch / End row actions."

orbital CampaignGoalOrbital {
  entity CampaignGoal [persistent: campaigngoals] {
    id            : string!
    name          : string!
    description   : string = ""
    targetAmount  : number = 0
    raisedAmount  : number = 0
    donorCount    : number = 0
    startDate     : string = ""
    endDate       : string = ""
    status        : "draft" | "active" | "achieved" | "ended" = "draft"
  }

  type CampaignGoalLoaded     = Event { data : [CampaignGoal] }            "Fired when the campaign collection finishes loading"
  type CampaignGoalLoadFailed = Event { error : string, code : string }    "Fired when the campaign collection fails to load"

  trait CampaignGoalTracker -> CampaignGoal [interaction, collection] {
    config {
      title : string = "Campaigns"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading campaigns…" }] })
      CampaignGoalLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "hero-section", tag: "Campaign", tagVariant: "primary", title: "Help us reach our goal", titleAccent: "@config.title", subtitle: "Every gift moves the needle. Join thousands of donors making impact possible.", primaryAction: { label: "Donate Now", action: "LAUNCH_CAMPAIGN", variant: "primary" }, secondaryAction: { label: "Learn More", action: "VIEW_STORY", variant: "ghost" } }, { type: "stack", direction: "horizontal", gap: "lg", justify: "around", children: [{ type: "animated-counter", value: 482000, duration: 1500, prefix: "$", suffix: " raised" }, { type: "animated-counter", value: 1240, duration: 1500, suffix: " donors" }, { type: "animated-counter", value: 87, duration: 1500, suffix: "% of goal" }] }, { type: "progress-bar", value: 87, max: 100, color: "primary", showPercentage: true }, { type: "animated-reveal", trigger: "scroll", animation: "fade-up", children: [{ type: "typewriter-text", text: "Together, we change lives.", speed: 60 }] }, { type: "content-section", background: "alt", padding: "lg", children: [{ type: "typography", variant: "h3", content: "Choose your donation tier" }, { type: "pricing-grid", plans: [{ name: "Supporter", price: "$25", description: "Provides one week of meals", features: ["Tax receipt", "Thank-you email"], cta: { label: "Give $25", action: "LAUNCH_CAMPAIGN" } }, { name: "Advocate", price: "$100", description: "Funds a child's school supplies for a year", features: ["Tax receipt", "Personalized note", "Quarterly update"], cta: { label: "Give $100", action: "LAUNCH_CAMPAIGN" }, highlighted: true }, { name: "Champion", price: "$500", description: "Sponsors a community clean-water station", features: ["Tax receipt", "Recognition in newsletter", "Site-visit invite"], cta: { label: "Give $500", action: "LAUNCH_CAMPAIGN" } }] }] }, { type: "content-section", background: "default", padding: "md", children: [{ type: "typography", variant: "h3", content: "Impact in pictures" }, { type: "media-gallery", data: [{ id: "i1", imageUrl: "https://picsum.photos/seed/campaign1/800/600", name: "Clean water delivery" }, { id: "i2", imageUrl: "https://picsum.photos/seed/campaign2/800/600", name: "School supplies handout" }, { id: "i3", imageUrl: "https://picsum.photos/seed/campaign3/800/600", name: "Community meal program" }, { id: "i4", imageUrl: "https://picsum.photos/seed/campaign4/800/600", name: "Volunteer team" }] }] }, { type: "lightbox", isOpen: false, images: [{ src: "https://picsum.photos/seed/campaign1/1200/800", alt: "Impact", caption: "Clean water" }], currentIndex: 0, showCounter: true }, { type: "social-proof", variant: "quotes", items: [{ quote: "This nonprofit changed my family's life.", author: "Maria S.", role: "Beneficiary" }, { quote: "Every dollar I give I can see in the field.", author: "James W.", role: "Recurring donor" }, { quote: "Transparent, honest, and effective.", author: "Lina P.", role: "Volunteer" }] }, { type: "community-links", heading: "Stay connected", github: { url: "https://github.com/example" }, discord: { url: "https://discord.gg/example" }, twitter: { url: "https://twitter.com/example" } }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "target" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "name", label: "Name", variant: "caption" }, { name: "targetAmount", label: "Target", variant: "caption" }, { name: "raisedAmount", label: "Raised", variant: "caption" }, { name: "donorCount", label: "Donors", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Launch", event: "LAUNCH_CAMPAIGN", variant: "primary" }, { label: "End", event: "END_CAMPAIGN", variant: "danger" }] }] })
      CampaignGoalLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      LAUNCH_CAMPAIGN -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "success", message: "Campaign launched" })
      END_CAMPAIGN -> browsing
        (set @entity.id @payload.id)
        (render-ui main { type: "alert", variant: "info", message: "Campaign ended" })
    }
    state error {
      INIT -> loading
        (fetch CampaignGoal { emit: { success: "CampaignGoalLoaded", failure: "CampaignGoalLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      LAUNCH_CAMPAIGN         { id : string! }
      END_CAMPAIGN            { id : string! }
      CampaignGoalLoaded      { data : [CampaignGoal] }
      CampaignGoalLoadFailed  { error : string, code : string }
    }
    listens {
      LAUNCH_CAMPAIGN         { id : string! }
      END_CAMPAIGN            { id : string! }
      CampaignGoalLoaded      { data : [CampaignGoal] }
      CampaignGoalLoadFailed  { error : string, code : string }
    }
  }
  page "/campaigns" as CampaignGoalPage -> CampaignGoalTracker
}
