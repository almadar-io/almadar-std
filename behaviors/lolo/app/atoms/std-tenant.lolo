app std-tenant "1.1.0"
"std-tenant — person/company occupying a leased unit. Lists tenants in `browsing`; opens tenant detail (name, contact, lease, move-in/out dates, status) in `viewing_single` with Activate / Move Out actions. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital TenantOrbital {
  entity Tenant [persistent: tenants] {
    id : string!
    name : string!
    email : string = ""
    phone : string = ""
    leaseId : string = ""
    moveInDate : string = ""
    moveOutDate : string = ""
    status : "current" | "former" | "prospective" = "prospective"
    notes : string = ""
  }
  type TenantLoaded = Event { data : [Tenant] }
  type TenantLoadFailed = Event { error : string, code : string }

  trait TenantDirectory -> Tenant [interaction, collection] {
    config {
      title : string = "Tenants"
        @label "Section title"
        @description "Heading shown above the tenant directory"
        @tier "customization"
      fields      : [FieldSpec] = [{ name: "name", label: "Name", variant: "h4" }, { name: "email", label: "Email", variant: "body" }, { name: "phone", label: "Phone", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "moveInDate", label: "Move-In", variant: "caption" }]
        @label "Columns to show"
        @description "Each column maps to one field on the Tenant entity"
        @tier "advanced"
      itemActions : [ItemAction] = [{ label: "Open", event: "OPEN_TENANT", variant: "primary", icon: "arrow-right" }, { label: "Move Out", event: "MOVE_OUT", variant: "danger" }]
        @label "Row actions"
        @description "Buttons users can click on each tenant row"
        @tier "customization"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Tenant { emit: { success: "TenantLoaded", failure: "TenantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading tenants…" }] })
      TenantLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "users" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total tenants", value: "@payload.data.length", icon: "users" }, { type: "stat-display", label: "Current", value: "42", icon: "check-circle" }, { type: "stat-display", label: "Prospective", value: "8", icon: "user-plus" }, { type: "stat-display", label: "Former", value: "120", icon: "user-minus" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", itemActions: "@config.itemActions" }] })
      TenantLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", title: "Failed to load tenants", message: "@payload.error" })
    }
    state browsing {
      OPEN_TENANT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.email @payload.row.email)
        (set @entity.phone @payload.row.phone)
        (set @entity.leaseId @payload.row.leaseId)
        (set @entity.moveInDate @payload.row.moveInDate)
        (set @entity.moveOutDate @payload.row.moveOutDate)
        (set @entity.status @payload.row.status)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_TENANT" }, { type: "icon", name: "user" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Phone" }, { type: "typography", variant: "body", content: "@entity.phone" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Lease" }, { type: "typography", variant: "body", content: "@entity.leaseId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Move-In", value: "@entity.moveInDate", icon: "calendar" }, { type: "stat-display", label: "Move-Out", value: "@entity.moveOutDate", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Activate", variant: "primary", action: "ACTIVATE_TENANT", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Move Out", variant: "danger", action: "MOVE_OUT", actionPayload: { id: "@entity.id" } }] }] })
      MOVE_OUT -> loading
        (set @entity.id @payload.id)
        (fetch Tenant { emit: { success: "TenantLoaded", failure: "TenantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Recording move-out…" }] })
    }
    state viewing_single {
      CLOSE_TENANT -> loading
        (fetch Tenant { emit: { success: "TenantLoaded", failure: "TenantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading tenants…" }] })
      ACTIVATE_TENANT -> loading
        (set @entity.id @payload.id)
        (fetch Tenant { emit: { success: "TenantLoaded", failure: "TenantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Activating tenant…" }] })
      MOVE_OUT -> loading
        (set @entity.id @payload.id)
        (fetch Tenant { emit: { success: "TenantLoaded", failure: "TenantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Recording move-out…" }] })
    }
    state error {
      INIT -> loading
        (fetch Tenant { emit: { success: "TenantLoaded", failure: "TenantLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }

    emits {
      OPEN_TENANT { id : string!, row : Tenant }
      CLOSE_TENANT { }
      ACTIVATE_TENANT { id : string! }
      MOVE_OUT { id : string! }
      TenantLoaded { data : [Tenant] }
      TenantLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_TENANT { id : string!, row : Tenant }
      CLOSE_TENANT { }
      ACTIVATE_TENANT { id : string! }
      MOVE_OUT { id : string! }
      TenantLoaded { data : [Tenant] }
      TenantLoadFailed { error : string, code : string }
    }
  }
  page "/tenants" as TenantPage -> TenantDirectory
}
