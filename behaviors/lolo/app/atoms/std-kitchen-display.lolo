app std-kitchen-display "1.1.0"
"std-kitchen-display — restaurant POS kitchen display system. Owns a KitchenTicket entity (one row per kitchen-bound order) and a single management trait that loads pending tickets, renders them in a data-grid with Mark Preparing / Ready / Served actions, and persists status + aging back to the row. Agents tune the list shape via `config.fields` + `config.itemActions`."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }

orbital KitchenTicketOrbital {
  entity KitchenTicket [persistent: kitchentickets] {
    id          : string!
    orderId     : string!
    tableLabel  : string
    serverName  : string
    itemsJson   : string
    status      : "pending" | "preparing" | "ready" | "served" = "pending"
    aging       : "fresh" | "normal" | "aging" | "overdue" = "fresh"
    receivedAt  : string
    readyAt     : string
    servedAt    : string
  }

  type KitchenTicketLoaded       = Event { data : [KitchenTicket] }            "Fired when the kitchen ticket collection finishes loading"
  type KitchenTicketLoadFailed   = Event { error : string, code : string }     "Fired when the kitchen ticket collection fails to load"
  type KitchenTicketUpdated      = Event { row : KitchenTicket }               "Fired after a ticket's status persists (preparing / ready / served)"
  type KitchenTicketUpdateFailed = Event { error : string, code : string }     "Fired when a ticket's status update fails to persist"

  trait KitchenTicketManage -> KitchenTicket [interaction, collection] {
    config {
      title          : string   = "Kitchen Display"
        @label "Section title"
        @description "Heading shown above the kitchen ticket board"
        @tier "customization"
      overdueMinutes : number   = 20
        @label "Overdue threshold (min)"
        @description "Tickets older than this flip to the overdue aging tier"
        @tier "advanced"
      fields         : [FieldSpec] = [
        { name: "orderId",    label: "Order",    variant: "caption" },
        { name: "tableLabel", label: "Table",    variant: "caption" },
        { name: "serverName", label: "Server",   variant: "caption" },
        { name: "status",     label: "Status",   variant: "badge"   },
        { name: "aging",      label: "Aging",    variant: "badge"   },
        { name: "receivedAt", label: "Received", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the Kitchen Ticket entity"
        @tier "customization"
      itemActions    : [ItemAction] = [
        { label: "Open",        event: "OPEN_TICKET", variant: "primary", icon: "arrow-right" },
        { label: "Mark Served", event: "MARK_SERVED", variant: "danger",  icon: "utensils" }
      ]
        @label "Row actions"
        @description "Buttons users can click on each ticket row"
        @tier "customization"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch KitchenTicket { emit: { success: "KitchenTicketLoaded", failure: "KitchenTicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading kitchen tickets…" }] })
      KitchenTicketLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "chef-hat" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Open tickets", value: "@payload.data.length", icon: "chef-hat" }, { type: "stat-display", label: "Preparing", value: "8", icon: "flame" }, { type: "stat-display", label: "Ready", value: "3", icon: "check-circle" }, { type: "stat-display", label: "Avg prep (min)", value: "14", icon: "clock" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: "@config.fields", cols: 1, gap: "sm", itemActions: "@config.itemActions" }] })
      KitchenTicketLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_TICKET -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.orderId @payload.row.orderId)
        (set @entity.tableLabel @payload.row.tableLabel)
        (set @entity.serverName @payload.row.serverName)
        (set @entity.itemsJson @payload.row.itemsJson)
        (set @entity.status @payload.row.status)
        (set @entity.aging @payload.row.aging)
        (set @entity.receivedAt @payload.row.receivedAt)
        (set @entity.readyAt @payload.row.readyAt)
        (set @entity.servedAt @payload.row.servedAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "chef-hat" }, { type: "typography", content: "@entity.orderId", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "primary" }, { type: "badge", label: "@entity.aging", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Table" }, { type: "typography", variant: "body", content: "@entity.tableLabel" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Server" }, { type: "typography", variant: "body", content: "@entity.serverName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Items" }, { type: "typography", variant: "body", content: "@entity.itemsJson" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Received", value: "@entity.receivedAt", icon: "clock" }, { type: "stat-display", label: "Ready at", value: "@entity.readyAt", icon: "check-circle" }, { type: "stat-display", label: "Served at", value: "@entity.servedAt", icon: "utensils" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Mark Preparing", variant: "secondary", action: "MARK_PREPARING", actionPayload: { ticketId: "@entity.id" } }, { type: "button", label: "Mark Ready", variant: "primary", action: "MARK_READY", actionPayload: { ticketId: "@entity.id", readyAt: "now" } }, { type: "button", label: "Mark Served", variant: "primary", action: "MARK_SERVED", actionPayload: { ticketId: "@entity.id", servedAt: "now" } }] }] })
      MARK_SERVED -> loading
        (set @entity.id @payload.ticketId)
        (set @entity.status "served")
        (set @entity.servedAt @payload.servedAt)
        (persist update KitchenTicket @entity { emit: { success: "KitchenTicketUpdated", failure: "KitchenTicketUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking ticket served…" }] })
      KitchenTicketUpdated -> loading
        (fetch KitchenTicket { emit: { success: "KitchenTicketLoaded", failure: "KitchenTicketLoadFailed" } })
      KitchenTicketUpdateFailed -> browsing
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch KitchenTicket { emit: { success: "KitchenTicketLoaded", failure: "KitchenTicketLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading kitchen tickets…" }] })
      MARK_PREPARING -> loading
        (set @entity.id @payload.ticketId)
        (set @entity.status "preparing")
        (persist update KitchenTicket @entity { emit: { success: "KitchenTicketUpdated", failure: "KitchenTicketUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking ticket preparing…" }] })
      MARK_READY -> loading
        (set @entity.id @payload.ticketId)
        (set @entity.status "ready")
        (set @entity.readyAt @payload.readyAt)
        (persist update KitchenTicket @entity { emit: { success: "KitchenTicketUpdated", failure: "KitchenTicketUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking ticket ready…" }] })
      MARK_SERVED -> loading
        (set @entity.id @payload.ticketId)
        (set @entity.status "served")
        (set @entity.servedAt @payload.servedAt)
        (persist update KitchenTicket @entity { emit: { success: "KitchenTicketUpdated", failure: "KitchenTicketUpdateFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Marking ticket served…" }] })
    }
    state error {
      INIT -> loading
        (fetch KitchenTicket { emit: { success: "KitchenTicketLoaded", failure: "KitchenTicketLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_TICKET    { id : string!, row : KitchenTicket }
      CLOSE_VIEW     { }
      MARK_PREPARING { ticketId : string!, row : KitchenTicket }
      MARK_READY     { ticketId : string!, readyAt : string!, row : KitchenTicket }
      MARK_SERVED    { ticketId : string!, servedAt : string!, row : KitchenTicket }
      KitchenTicketLoaded       { data : [KitchenTicket] }
      KitchenTicketLoadFailed   { error : string, code : string }
      KitchenTicketUpdated      { row : KitchenTicket }
      KitchenTicketUpdateFailed { error : string, code : string }
    }
    listens {
      OPEN_TICKET    { id : string!, row : KitchenTicket }
      CLOSE_VIEW     { }
      MARK_PREPARING { ticketId : string!, row : KitchenTicket }
      MARK_READY     { ticketId : string!, readyAt : string!, row : KitchenTicket }
      MARK_SERVED    { ticketId : string!, servedAt : string!, row : KitchenTicket }
      KitchenTicketLoaded       { data : [KitchenTicket] }
      KitchenTicketLoadFailed   { error : string, code : string }
      KitchenTicketUpdated      { row : KitchenTicket }
      KitchenTicketUpdateFailed { error : string, code : string }
    }
  }
  page "/kitchentickets/manage" as KitchenTicketManagePage -> KitchenTicketManage
}
