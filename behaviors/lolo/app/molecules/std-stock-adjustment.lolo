app std-stock-adjustment "1.0.0"
"Tracks stock-level adjustments as deltas to onHand per sku/warehouse"

orbital StockAdjustmentOrbital {
  uses StockLevel    from "std/behaviors/std-stock-level"
  uses Warehouse     from "std/behaviors/std-warehouse"
  uses Modal         from "std/behaviors/std-modal"
  uses Confirmation  from "std/behaviors/std-confirmation"

  entity StockAdjustment [persistent: stockadjustments] {
    id            : string!
    stockLevelId  : string!
    sku           : string = ""
    warehouseId   : string = ""
    warehouseName : string = ""
    quantityDelta : number = 0
    reason        : "manual" | "damaged" | "transfer_in" | "transfer_out" | "shrinkage" | "recount" = "manual"
    adjustedBy    : string = ""
    adjustedAt    : string = ""
    notes         : string = ""
    pendingId     : string = ""
  }

  type StockAdjustmentLoaded     = Event { data : [StockAdjustment] }            "Fired when the stock-adjustment collection finishes loading"
  type StockAdjustmentLoadFailed = Event { error : string, code : string }       "Fired when the stock-adjustment collection fails to load"

  trait StockAdjustmentBrowse -> StockAdjustment [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch StockAdjustment { emit: { success: "StockAdjustmentLoaded", failure: "StockAdjustmentLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading adjustments…" }] })
      StockAdjustmentLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "sliders" }, { type: "typography", content: "Stock Adjustments", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total adjustments", value: "@payload.data.length", icon: "sliders" }, { type: "stat-display", label: "Net delta", value: "+184", icon: "trending-up" }, { type: "stat-display", label: "This week", value: "26", icon: "calendar" }, { type: "stat-display", label: "Shrinkage flags", value: "4", icon: "alert-triangle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "sku", label: "SKU", variant: "caption" }, { name: "warehouseName", label: "Warehouse", variant: "caption" }, { name: "quantityDelta", label: "Delta", variant: "caption" }, { name: "reason", label: "Reason", variant: "badge" }, { name: "adjustedAt", label: "Adjusted At", variant: "caption" }, { name: "adjustedBy", label: "By", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_ADJUSTMENT", variant: "primary", icon: "arrow-right" }, { label: "Delete", event: "REQUEST_DELETE", variant: "danger" }] }] })
      StockAdjustmentLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_ADJUSTMENT -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.stockLevelId @payload.row.stockLevelId)
        (set @entity.sku @payload.row.sku)
        (set @entity.warehouseId @payload.row.warehouseId)
        (set @entity.warehouseName @payload.row.warehouseName)
        (set @entity.quantityDelta @payload.row.quantityDelta)
        (set @entity.reason @payload.row.reason)
        (set @entity.adjustedBy @payload.row.adjustedBy)
        (set @entity.adjustedAt @payload.row.adjustedAt)
        (set @entity.notes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "sliders" }, { type: "typography", content: "@entity.sku", variant: "h3" }, { type: "badge", label: "@entity.reason", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Warehouse" }, { type: "typography", variant: "body", content: "@entity.warehouseName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Adjusted by" }, { type: "typography", variant: "body", content: "@entity.adjustedBy" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Delta", value: "@entity.quantityDelta", icon: "trending-up" }, { type: "stat-display", label: "Adjusted at", value: "@entity.adjustedAt", icon: "calendar" }, { type: "stat-display", label: "Reason", value: "@entity.reason", icon: "tag" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Delete", variant: "danger", action: "REQUEST_DELETE", actionPayload: { id: "@entity.id", row: "@entity" } }] }] })
      CREATE -> loading
        (fetch StockAdjustment { emit: { success: "StockAdjustmentLoaded", failure: "StockAdjustmentLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Opening new adjustment…" }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch StockAdjustment { emit: { success: "StockAdjustmentLoaded", failure: "StockAdjustmentLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Removing adjustment…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch StockAdjustment { emit: { success: "StockAdjustmentLoaded", failure: "StockAdjustmentLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading adjustments…" }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch StockAdjustment { emit: { success: "StockAdjustmentLoaded", failure: "StockAdjustmentLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Removing adjustment…" }] })
    }
    state error {
      INIT -> loading
        (fetch StockAdjustment { emit: { success: "StockAdjustmentLoaded", failure: "StockAdjustmentLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_ADJUSTMENT { id : string!, row : StockAdjustment }
      CLOSE_VIEW      { }
      CREATE          { }
      REQUEST_DELETE  { id : string!, row : StockAdjustment }
      StockAdjustmentLoaded     { data : [StockAdjustment] }
      StockAdjustmentLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_ADJUSTMENT { id : string!, row : StockAdjustment }
      CLOSE_VIEW      { }
      CREATE          { }
      REQUEST_DELETE  { id : string!, row : StockAdjustment }
      StockAdjustmentLoaded     { data : [StockAdjustment] }
      StockAdjustmentLoadFailed { error : string, code : string }
      StockAdjustmentPersistor.ADJUSTMENT_CREATED -> INIT
      StockAdjustmentPersistor.ADJUSTMENT_DELETED -> INIT
    }
  }

  trait StockAdjustmentCreate = Modal.traits.ModalRecordModal -> StockAdjustment {
    config: {
      icon: "plus-circle",
      title: "New Adjustment",
      mode: "create",
      fields: ["sku", "warehouseId", "quantityDelta", "reason", "notes"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      StockAdjustmentBrowse.CREATE -> CREATE
      CREATE { id : string, row : StockAdjustment }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait StockAdjustmentDelete = Confirmation.traits.ConfirmActionConfirmation -> StockAdjustment {
    config: {
      icon: "alert-triangle",
      title: "Delete Adjustment",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      StockAdjustmentBrowse.REQUEST_DELETE -> DELETE
      DELETE { id : string, row : StockAdjustment }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait StockAdjustmentPersistor -> StockAdjustment [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create StockAdjustment @payload.data { emit: { success: "ADJUSTMENT_CREATED" } })
      DO_DELETE -> idle
        (persist delete StockAdjustment @payload.id { emit: { success: "ADJUSTMENT_DELETED" } })
    }
    emits {
      ADJUSTMENT_CREATED -> external { id : string }
      ADJUSTMENT_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_DELETE { id : string }
      StockAdjustmentCreate.SAVE           -> DO_CREATE
      StockAdjustmentDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/stock-adjustments" as StockAdjustmentPage -> StockAdjustmentBrowse, StockAdjustmentCreate, StockAdjustmentDelete, StockAdjustmentPersistor
}
