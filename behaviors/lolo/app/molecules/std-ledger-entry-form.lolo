app std-ledger-entry-form "1.0.0"
"Tracks balanced journal-entry pairs (debit + credit) before persisting LedgerEntry rows"

orbital JournalTransactionOrbital {
  uses LedgerEntry   from "std/behaviors/std-ledger-entry"
  uses Account       from "std/behaviors/std-chart-of-accounts"
  uses Modal         from "std/behaviors/std-modal"
  uses Confirmation  from "std/behaviors/std-confirmation"

  entity JournalTransaction [persistent: journaltransactions] {
    id                : string!
    transactionDate   : string!
    description       : string = ""
    debitAccountId    : string = ""
    debitAccountName  : string = ""
    creditAccountId   : string = ""
    creditAccountName : string = ""
    amount            : number = 0
    referenceType     : "manual" | "invoice" | "bill" | "payment" = "manual"
    referenceId       : string = ""
    isPosted          : boolean = false
    pendingId         : string = ""
  }

  type JournalTransactionLoaded     = Event { data : [JournalTransaction] }       "Fired when the journal-transaction collection finishes loading"
  type JournalTransactionLoadFailed = Event { error : string, code : string }     "Fired when the journal-transaction collection fails to load"

  trait JournalTransactionBrowse -> JournalTransaction [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading transactions…" }] })
      JournalTransactionLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "book-open" }, { type: "typography", content: "Journal Transactions", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total entries", value: "@payload.data.length", icon: "book-open" }, { type: "stat-display", label: "Posted", value: "84", icon: "check-circle" }, { type: "stat-display", label: "Draft", value: "12", icon: "edit" }, { type: "stat-display", label: "Net amount", value: "$248,500", icon: "dollar-sign" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "transactionDate", label: "Date", variant: "caption" }, { name: "description", label: "Description", variant: "caption" }, { name: "debitAccountName", label: "Debit", variant: "caption" }, { name: "creditAccountName", label: "Credit", variant: "caption" }, { name: "amount", label: "Amount", variant: "caption" }, { name: "referenceType", label: "Type", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_TRANSACTION", variant: "primary", icon: "arrow-right" }, { label: "Delete", event: "REQUEST_DELETE", variant: "danger" }] }] })
      JournalTransactionLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_TRANSACTION -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.transactionDate @payload.row.transactionDate)
        (set @entity.description @payload.row.description)
        (set @entity.debitAccountId @payload.row.debitAccountId)
        (set @entity.debitAccountName @payload.row.debitAccountName)
        (set @entity.creditAccountId @payload.row.creditAccountId)
        (set @entity.creditAccountName @payload.row.creditAccountName)
        (set @entity.amount @payload.row.amount)
        (set @entity.referenceType @payload.row.referenceType)
        (set @entity.referenceId @payload.row.referenceId)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "book-open" }, { type: "typography", content: "@entity.description", variant: "h3" }, { type: "badge", label: "@entity.referenceType", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Debit Account" }, { type: "typography", variant: "body", content: "@entity.debitAccountName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Credit Account" }, { type: "typography", variant: "body", content: "@entity.creditAccountName" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Reference" }, { type: "typography", variant: "body", content: "@entity.referenceId" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Amount", value: "@entity.amount", icon: "dollar-sign" }, { type: "stat-display", label: "Date", value: "@entity.transactionDate", icon: "calendar" }, { type: "stat-display", label: "Type", value: "@entity.referenceType", icon: "tag" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Post Transaction", variant: "primary", action: "POST_TRANSACTION", actionPayload: { id: "@entity.id", row: "@entity" } }, { type: "button", label: "Delete", variant: "danger", action: "REQUEST_DELETE", actionPayload: { id: "@entity.id", row: "@entity" } }] }] })
      CREATE -> loading
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Opening new transaction…" }] })
      POST_TRANSACTION -> loading
        (set @entity.id @payload.id)
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Posting transaction…" }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Removing transaction…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading transactions…" }] })
      POST_TRANSACTION -> loading
        (set @entity.id @payload.id)
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Posting transaction…" }] })
      REQUEST_DELETE -> loading
        (set @entity.id @payload.id)
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Removing transaction…" }] })
    }
    state error {
      INIT -> loading
        (fetch JournalTransaction { emit: { success: "JournalTransactionLoaded", failure: "JournalTransactionLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_TRANSACTION { id : string!, row : JournalTransaction }
      CLOSE_VIEW       { }
      CREATE           { }
      POST_TRANSACTION { id : string!, row : JournalTransaction }
      REQUEST_DELETE   { id : string!, row : JournalTransaction }
      JournalTransactionLoaded     { data : [JournalTransaction] }
      JournalTransactionLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_TRANSACTION { id : string!, row : JournalTransaction }
      CLOSE_VIEW       { }
      CREATE           { }
      POST_TRANSACTION { id : string!, row : JournalTransaction }
      REQUEST_DELETE   { id : string!, row : JournalTransaction }
      JournalTransactionLoaded     { data : [JournalTransaction] }
      JournalTransactionLoadFailed { error : string, code : string }
      JournalTransactionPersistor.TRANSACTION_CREATED -> INIT
      JournalTransactionPersistor.TRANSACTION_POSTED  -> INIT
      JournalTransactionPersistor.TRANSACTION_DELETED -> INIT
    }
  }

  trait JournalTransactionCreate = Modal.traits.ModalRecordModal -> JournalTransaction {
    config: {
      icon: "plus-circle",
      title: "New Transaction",
      mode: "create",
      fields: ["transactionDate", "description", "debitAccountId", "creditAccountId", "amount", "referenceType", "referenceId"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      JournalTransactionBrowse.CREATE -> CREATE
      CREATE { id : string, row : JournalTransaction }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait JournalTransactionDelete = Confirmation.traits.ConfirmActionConfirmation -> JournalTransaction {
    config: {
      icon: "alert-triangle",
      title: "Delete Transaction",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      JournalTransactionBrowse.REQUEST_DELETE -> DELETE
      DELETE { id : string, row : JournalTransaction }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait JournalTransactionPersistor -> JournalTransaction [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create JournalTransaction @payload.data { emit: { success: "TRANSACTION_CREATED" } })
      DO_POST -> idle
        (persist update JournalTransaction @payload.id { emit: { success: "TRANSACTION_POSTED" } })
      DO_DELETE -> idle
        (persist delete JournalTransaction @payload.id { emit: { success: "TRANSACTION_DELETED" } })
    }
    emits {
      TRANSACTION_CREATED -> external { id : string }
      TRANSACTION_POSTED  -> external { id : string }
      TRANSACTION_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_POST   { id : string }
      DO_DELETE { id : string }
      JournalTransactionCreate.SAVE                  -> DO_CREATE
      JournalTransactionBrowse.POST_TRANSACTION      -> DO_POST
      JournalTransactionDelete.CONFIRM_DELETE        -> DO_DELETE
    }
  }

  page "/journal-transactions" as JournalTransactionPage -> JournalTransactionBrowse, JournalTransactionCreate, JournalTransactionDelete, JournalTransactionPersistor
}
