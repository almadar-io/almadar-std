app std-cart "1.0.0"
"std-cart — shopping cart molecule composing CartItemCartBrowse + Modal-driven add + Confirmation-driven remove + persistor coordinator."

orbital CartItemOrbital {
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Modal        from "std/behaviors/std-modal"

  entity CartItem [persistent: cartitems] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
    pendingId   : string = ""
  }

  type CartItemLoaded     = Event { data : [CartItem] }          "Fired when the cart collection finishes loading; payload.data holds the CartItem list"
  type CartItemLoadFailed = Event { error : string, code : string } "Fired when the cart collection fails to load"

  trait CartItemCartBrowse -> CartItem [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch CartItem { emit: { success: "CartItemLoaded", failure: "CartItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading cart…" }] })
      CartItemLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "shopping-cart" }, { type: "typography", content: "Shopping Cart", variant: "h3" }] }, { type: "button", label: "Add Item", action: "ADD_ITEM", variant: "primary", icon: "plus" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Items in cart", value: "@payload.data.length", icon: "shopping-cart" }, { type: "stat-display", label: "Active", value: "3", icon: "check-circle" }, { type: "stat-display", label: "Pending", value: "1", icon: "clock" }, { type: "stat-display", label: "Saved for later", value: "5", icon: "bookmark" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", itemActions: [{ label: "Remove", event: "REQUEST_REMOVE", variant: "danger" }], fields: [{ name: "name", label: "Name", variant: "caption", icon: "shopping-cart" }, { name: "description", label: "Description", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }], cols: 1, gap: "sm" }] })
      CartItemLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      INIT -> loading
        (fetch CartItem { emit: { success: "CartItemLoaded", failure: "CartItemLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch CartItem { emit: { success: "CartItemLoaded", failure: "CartItemLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      ADD_ITEM
      REQUEST_REMOVE { id : string!, row : CartItem }
      CartItemLoaded
      CartItemLoadFailed
    }
    listens {
      CartItemLoadFailed { error : string, code : string }
      CartItemPersistor.ITEM_CREATED  -> INIT
      CartItemPersistor.ITEM_DELETED  -> INIT
    }
  }

  trait CartItemAddItem = Modal.traits.ModalRecordModal -> CartItem {
    config: {
      icon: "plus-circle",
      title: "Add Item",
      openButtonLabel: "Add Item",
      fields: ["name", "description", "status"],
      mode: "create"
    }
    events {
      OPEN: ADD_ITEM
    }
    listens {
      CartItemCartBrowse.ADD_ITEM -> ADD_ITEM
      ADD_ITEM { id : string, row : CartItem }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait CartItemRemoveConfirm = Confirmation.traits.ConfirmActionConfirmation -> CartItem {
    config: {
      icon: "alert-triangle",
      title: "Remove Item",
      alertMessage: "Are you sure you want to remove this item from your cart?",
      confirmLabel: "Remove"
    }
    events {
      REQUEST: REQUEST_REMOVE
      CONFIRM: CONFIRM_REMOVE
    }
    listens {
      CartItemCartBrowse.REQUEST_REMOVE -> REQUEST_REMOVE
      REQUEST_REMOVE { id : string, row : CartItem }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait CartItemPersistor -> CartItem [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create CartItem @payload.data { emit: { success: "ITEM_CREATED" } })
      DO_DELETE -> idle
        (persist delete CartItem @payload.id { emit: { success: "ITEM_DELETED" } })
    }
    emits {
      ITEM_CREATED -> external { id : string }
      ITEM_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_DELETE { id : string }
      CartItemAddItem.SAVE           -> DO_CREATE
      CartItemRemoveConfirm.CONFIRM_REMOVE -> DO_DELETE
    }
  }

  page "/cart" as CartItemPage -> CartItemCartBrowse, CartItemAddItem, CartItemRemoveConfirm, CartItemPersistor
}
