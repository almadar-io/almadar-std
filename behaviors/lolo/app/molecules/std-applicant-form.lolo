app std-applicant-form "1.0.0"
"std-applicant-form — unified applicant intake: capture applicant + first interview slot atomically."

orbital ApplicationIntakeOrbital {
  uses Applicant     from "std/behaviors/std-applicant"
  uses InterviewSlot from "std/behaviors/std-interview-slot"
  uses Modal         from "std/behaviors/std-modal"
  uses Confirmation  from "std/behaviors/std-confirmation"

  entity ApplicationIntake [persistent: applicationintakes] {
    id                : string!
    applicantName     : string!
    applicantEmail    : string = ""
    applicantPhone    : string = ""
    jobId             : string = ""
    resumeUrl         : string = ""
    firstInterviewAt  : string = ""
    interviewerName   : string = ""
    interviewFormat   : "phone" | "video" | "onsite" = "video"
    status            : "draft" | "submitted" | "interviewing" | "completed" = "draft"
    notes             : string = ""
    pendingId         : string = ""
  }

  type ApplicationIntakeLoaded     = Event { data : [ApplicationIntake] }       "Fired when the intake collection finishes loading"
  type ApplicationIntakeLoadFailed = Event { error : string, code : string }    "Fired when the intake collection fails to load"

  trait ApplicationIntakeBrowse -> ApplicationIntake [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch ApplicationIntake { emit: { success: "ApplicationIntakeLoaded", failure: "ApplicationIntakeLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading applications…" }] })
      ApplicationIntakeLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", content: "Applicant Intake", variant: "h3" }] }, { type: "button", label: "New Application", action: "CREATE", variant: "primary", icon: "plus" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total applications", value: "@payload.data.length", icon: "user-plus" }, { type: "stat-display", label: "Submitted", value: "18", icon: "send" }, { type: "stat-display", label: "Interviewing", value: "7", icon: "calendar" }, { type: "stat-display", label: "Completed", value: "24", icon: "check-circle" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", itemActions: [{ label: "Edit", event: "REQUEST_EDIT", variant: "ghost" }, { label: "Delete", event: "REQUEST_DELETE", variant: "danger" }], fields: [{ name: "applicantName", label: "Applicant", variant: "caption", icon: "user" }, { name: "applicantEmail", label: "Email", variant: "caption" }, { name: "jobId", label: "Job", variant: "caption" }, { name: "firstInterviewAt", label: "First Interview", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }], cols: 1, gap: "sm" }] })
      ApplicationIntakeLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      INIT -> loading
        (fetch ApplicationIntake { emit: { success: "ApplicationIntakeLoaded", failure: "ApplicationIntakeLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch ApplicationIntake { emit: { success: "ApplicationIntakeLoaded", failure: "ApplicationIntakeLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      CREATE
      REQUEST_EDIT   { id : string!, row : ApplicationIntake }
      REQUEST_DELETE { id : string!, row : ApplicationIntake }
      ApplicationIntakeLoaded
      ApplicationIntakeLoadFailed
    }
    listens {
      ApplicationIntakeLoadFailed { error : string, code : string }
      ApplicationIntakePersistor.INTAKE_CREATED -> INIT
      ApplicationIntakePersistor.INTAKE_UPDATED -> INIT
      ApplicationIntakePersistor.INTAKE_DELETED -> INIT
    }
  }

  trait ApplicationIntakeCreate = Modal.traits.ModalRecordModal -> ApplicationIntake {
    config: {
      icon: "user-plus",
      title: "New Application",
      fields: ["applicantName", "applicantEmail", "applicantPhone", "jobId", "resumeUrl", "firstInterviewAt", "interviewerName", "interviewFormat"],
      mode: "create"
    }
    events {
      OPEN: CREATE
    }
    listens {
      ApplicationIntakeBrowse.CREATE -> CREATE
      CREATE { id : string, row : ApplicationIntake }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ApplicationIntakeEdit = Modal.traits.ModalRecordModal -> ApplicationIntake {
    config: {
      icon: "pencil",
      title: "Edit Application",
      fields: ["applicantName", "applicantEmail", "applicantPhone", "jobId", "resumeUrl", "firstInterviewAt", "interviewerName", "interviewFormat"],
      mode: "edit"
    }
    events {
      OPEN: EDIT
    }
    listens {
      ApplicationIntakeBrowse.REQUEST_EDIT -> EDIT
      EDIT { id : string, row : ApplicationIntake }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait ApplicationIntakeDelete = Confirmation.traits.ConfirmActionConfirmation -> ApplicationIntake {
    config: {
      icon: "alert-triangle",
      title: "Delete Application",
      alertMessage: "Are you sure you want to delete this application?",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      ApplicationIntakeBrowse.REQUEST_DELETE -> DELETE
      DELETE { id : string, row : ApplicationIntake }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait ApplicationIntakePersistor -> ApplicationIntake [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create ApplicationIntake @payload.data { emit: { success: "INTAKE_CREATED" } })
      DO_UPDATE -> idle
        (persist update ApplicationIntake @payload.data { emit: { success: "INTAKE_UPDATED" } })
      DO_DELETE -> idle
        (persist delete ApplicationIntake @payload.id { emit: { success: "INTAKE_DELETED" } })
    }
    emits {
      INTAKE_CREATED -> external { id : string }
      INTAKE_UPDATED -> external { id : string }
      INTAKE_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_UPDATE { data : object! }
      DO_DELETE { id : string }
      ApplicationIntakeCreate.SAVE          -> DO_CREATE
      ApplicationIntakeEdit.SAVE            -> DO_UPDATE
      ApplicationIntakeDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/intakes" as ApplicationIntakePage -> ApplicationIntakeBrowse, ApplicationIntakeCreate, ApplicationIntakeEdit, ApplicationIntakeDelete, ApplicationIntakePersistor
}
