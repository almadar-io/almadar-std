app std-approval-chain "2.0.0"
"std-approval-chain — domain-specific N-step approval workflow. Composes std-step-flow with persisted ApprovalRequest entity carrying domain fields (requestType, amount, requester). Lights up std-legal-case, std-ap-bill, std-change-order, std-application (hr-portal) — each rebinds std-step-flow + sets its own `config.steps` array."

orbital ApprovalChainOrbital {
  uses Flow from "std/behaviors/std-step-flow"

  entity ApprovalRequest [persistent: approval_requests] {
    id          : string!
    title       : string!
    description : string  = ""
    requestType : "expense" | "purchase" | "leave" | "policy" | "contract" = "expense"
    amount      : number  = 0
    requester   : string  = ""
    submittedAt : string  = ""
  }

  trait ApprovalReview = Flow.traits.StepFlowReview -> ApprovalRequest {
    config: {
      title: "Approval Request",
      steps: [
        { key: "manager",   label: "Manager Review",     description: "Direct manager reviews the request and verifies budget impact", icon: "user-check" },
        { key: "finance",   label: "Finance Approval",   description: "Finance team checks compliance with company policy",            icon: "calculator" },
        { key: "executive", label: "Executive Sign-off", description: "Final executive approval before commitment",                    icon: "shield-check" }
      ]
    }
  }

  page "/approval-chain" as ApprovalChainPage -> ApprovalReview
}
