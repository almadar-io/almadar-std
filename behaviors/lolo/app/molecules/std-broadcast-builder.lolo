app std-broadcast-builder "1.0.0"
"std-broadcast-builder composes EmailBroadcast + Segment + TemplateEditor + Modal + Confirmation into a unified broadcast-building UI"

orbital BroadcastBuilderOrbital {
  uses EmailBroadcast  from "std/behaviors/std-email-broadcast"
  uses Segment         from "std/behaviors/std-segment"
  uses TemplateEditor  from "std/behaviors/std-template-editor"
  uses Modal           from "std/behaviors/std-modal"
  uses Confirmation    from "std/behaviors/std-confirmation"

  entity BroadcastDraft [persistent: broadcastdrafts] {
    id           : string!
    name         : string!
    segmentId    : string = ""
    segmentName  : string = ""
    templateId   : string = ""
    templateName : string = ""
    subject      : string = ""
    scheduledAt  : string = ""
    status       : "draft" | "ready" | "sent" = "draft"
    pendingId    : string = ""
  }

  type BroadcastDraftLoaded     = Event { data : [BroadcastDraft] }            "Fired when the broadcast-draft collection finishes loading"
  type BroadcastDraftLoadFailed = Event { error : string, code : string }      "Fired when the broadcast-draft collection fails to load"

  trait BroadcastDraftBrowse -> BroadcastDraft [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch BroadcastDraft { emit: { success: "BroadcastDraftLoaded", failure: "BroadcastDraftLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading broadcasts…" }] })
      BroadcastDraftLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "send" }, { type: "typography", content: "Broadcasts", variant: "h2" }] }, { type: "button", label: "New Broadcast", action: "CREATE", variant: "primary", icon: "plus" }] }, { type: "stats-grid", columns: 4, stats: [{ label: "Sent this month", value: "128" }, { label: "Open rate", value: "42%" }, { label: "Click rate", value: "11%" }, { label: "Bounce rate", value: "0.8%" }] }, { type: "wizard-progress", steps: [{ id: "audience", title: "Audience" }, { id: "template", title: "Template" }, { id: "schedule", title: "Schedule" }, { id: "review", title: "Review" }, { id: "send", title: "Send" }], currentStep: 2 }, { type: "progress-dots", count: 5, currentIndex: 2, size: "md" }, { type: "tabbed-container", defaultTab: "drafts", tabs: [{ id: "drafts", label: "Drafts", content: "Broadcast drafts awaiting completion." }, { id: "scheduled", label: "Scheduled", content: "Queued for future delivery." }, { id: "sent", label: "Sent", content: "Delivered broadcasts and reports." }] }, { type: "cta-banner", title: "Boost engagement with segmented broadcasts", subtitle: "Target the right cohort at the right time.", background: "gradient", align: "center" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "feature-card", title: "Audience segmentation", description: "Reach the contacts most likely to convert.", icon: "users", linkLabel: "View segments" }, { type: "feature-card", title: "Template library", description: "Reusable email and SMS templates.", icon: "file-text", linkLabel: "Open library" }, { type: "feature-card", title: "Send-time scheduling", description: "Pick send windows that match recipient time zones.", icon: "clock", linkLabel: "Schedule" }] }, { type: "install-box", command: "npx almadar broadcast --new", label: "Author a broadcast from the CLI" }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Delete", event: "REQUEST_DELETE", variant: "danger" }], fields: [{ name: "name", label: "Name", variant: "h4", icon: "send" }, { name: "subject", label: "Subject", variant: "body" }, { name: "segmentName", label: "Segment", variant: "caption" }, { name: "templateName", label: "Template", variant: "caption" }, { name: "scheduledAt", label: "Scheduled", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }] }] })
      BroadcastDraftLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load broadcasts" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch BroadcastDraft { emit: { success: "BroadcastDraftLoaded", failure: "BroadcastDraftLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch BroadcastDraft { emit: { success: "BroadcastDraftLoaded", failure: "BroadcastDraftLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      CREATE
      REQUEST_DELETE { id : string!, row : BroadcastDraft }
      BroadcastDraftLoaded
      BroadcastDraftLoadFailed
    }
    listens {
      BroadcastDraftLoadFailed { error : string, code : string }
      BroadcastDraftPersistor.DRAFT_CREATED -> INIT
      BroadcastDraftPersistor.DRAFT_DELETED -> INIT
    }
  }

  trait BroadcastDraftCreate = Modal.traits.ModalRecordModal -> BroadcastDraft {
    config: {
      icon: "plus-circle",
      title: "New Broadcast",
      mode: "create",
      fields: ["name", "segmentId", "templateId", "subject", "scheduledAt"]
    }
    events {
      OPEN: CREATE
    }
    listens {
      BroadcastDraftBrowse.CREATE -> CREATE
      CREATE { id : string, row : BroadcastDraft }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  trait BroadcastDraftDelete = Confirmation.traits.ConfirmActionConfirmation -> BroadcastDraft {
    config: {
      icon: "alert-triangle",
      title: "Delete Draft",
      alertMessage: "This will discard the draft.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      BroadcastDraftBrowse.REQUEST_DELETE -> DELETE
      DELETE { id : string, row : BroadcastDraft }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  trait BroadcastDraftPersistor -> BroadcastDraft [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create BroadcastDraft @payload.data { emit: { success: "DRAFT_CREATED" } })
      DO_DELETE -> idle
        (persist delete BroadcastDraft @payload.id { emit: { success: "DRAFT_DELETED" } })
    }
    emits {
      DRAFT_CREATED -> external { id : string }
      DRAFT_DELETED -> external { id : string }
    }
    listens {
      DO_CREATE { data : object! }
      DO_DELETE { id : string }
      BroadcastDraftCreate.SAVE           -> DO_CREATE
      BroadcastDraftDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/broadcast-builder" as BroadcastBuilderPage -> BroadcastDraftBrowse, BroadcastDraftCreate, BroadcastDraftDelete, BroadcastDraftPersistor
}
