app std-form-builder "1.0.0"
"std-form-builder — survey form composer with list/detail browse + sidebar question and rules editors."

orbital FormBuilderOrbital {
  entity Survey [persistent: surveys] {
    id            : string!
    title         : string!
    description   : string
    questionsJson : string
    rulesJson     : string
    status        : "draft" | "published" = "draft"
    createdAt     : string
  }

  type SurveyLoaded         = Event { data : [Survey] }                "Fired when the survey collection finishes loading"
  type SurveyLoadFailed     = Event { error : string, code : string }  "Fired when the survey collection fails to load"
  type SurveyCreated        = Event { row : Survey }                   "Fired after a new survey is persisted"
  type SurveyUpdated        = Event { row : Survey }                   "Fired after an existing survey is updated"
  type SurveyPublished      = Event { id : string }                    "Fired after a survey is marked published"

  trait SurveyManage -> Survey [interaction, collection] {
    config {
      title : string = "Survey Builder"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch Survey { emit: { success: "SurveyLoaded", failure: "SurveyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading surveys…" }] })
      SurveyLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clipboard-list" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total surveys", value: "@payload.data.length", icon: "clipboard-list" }, { type: "stat-display", label: "Drafts", value: "5", icon: "edit" }, { type: "stat-display", label: "Published", value: "12", icon: "send" }, { type: "stat-display", label: "Responses today", value: "284", icon: "users" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "title", label: "Title", variant: "caption" }, { name: "description", label: "Description", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "createdAt", label: "Created", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_SURVEY", variant: "primary", icon: "arrow-right" }, { label: "Publish", event: "PUBLISH", variant: "secondary", icon: "send" }] }] })
      SurveyLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_SURVEY -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.title @payload.row.title)
        (set @entity.description @payload.row.description)
        (set @entity.questionsJson @payload.row.questionsJson)
        (set @entity.rulesJson @payload.row.rulesJson)
        (set @entity.status @payload.row.status)
        (set @entity.createdAt @payload.row.createdAt)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "clipboard-list" }, { type: "typography", content: "@entity.title", variant: "h3" }, { type: "badge", label: "@entity.status", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Survey ID" }, { type: "typography", variant: "body", content: "@entity.id" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Created", value: "@entity.createdAt", icon: "calendar" }, { type: "stat-display", label: "Status", value: "@entity.status", icon: "activity" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Publish", variant: "primary", action: "PUBLISH", actionPayload: { id: "@entity.id", surveyId: "@entity.id", row: "@entity" } }, { type: "button", label: "New Survey", variant: "secondary", action: "CREATE", actionPayload: { id: "@entity.id", data: "@entity" } }] }] })
      CREATE -> loading
        (persist create Survey @payload.data { emit: { success: "SurveyCreated", failure: "SurveyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Creating survey…" }] })
      PUBLISH -> loading
        (set @entity.id @payload.surveyId)
        (set @entity.status "published")
        (persist update Survey @entity { emit: { success: "SurveyPublished", failure: "SurveyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Publishing survey…" }] })
      SurveyCreated -> loading
        (fetch Survey { emit: { success: "SurveyLoaded", failure: "SurveyLoadFailed" } })
      SurveyUpdated -> loading
        (fetch Survey { emit: { success: "SurveyLoaded", failure: "SurveyLoadFailed" } })
      SurveyPublished -> loading
        (fetch Survey { emit: { success: "SurveyLoaded", failure: "SurveyLoadFailed" } })
      SurveyLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch Survey { emit: { success: "SurveyLoaded", failure: "SurveyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading surveys…" }] })
      PUBLISH -> loading
        (set @entity.id @payload.id)
        (set @entity.status "published")
        (persist update Survey @entity { emit: { success: "SurveyPublished", failure: "SurveyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Publishing survey…" }] })
      CREATE -> loading
        (persist create Survey @payload.data { emit: { success: "SurveyCreated", failure: "SurveyLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Creating survey…" }] })
    }
    state error {
      INIT -> loading
        (fetch Survey { emit: { success: "SurveyLoaded", failure: "SurveyLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_SURVEY     { id : string!, row : Survey }
      CLOSE_VIEW      { }
      CREATE          { id : string!, data : object! }
      PUBLISH         { id : string!, surveyId : string!, row : Survey }
      SurveyLoaded     { data : [Survey] }
      SurveyLoadFailed { error : string, code : string }
      SurveyCreated    { row : Survey }
      SurveyUpdated    { row : Survey }
      SurveyPublished  { id : string! }
    }
    listens {
      OPEN_SURVEY     { id : string!, row : Survey }
      CLOSE_VIEW      { }
      CREATE          { id : string!, data : object! }
      PUBLISH         { id : string!, surveyId : string!, row : Survey }
      SurveyLoaded     { data : [Survey] }
      SurveyLoadFailed { error : string, code : string }
      SurveyCreated    { row : Survey }
      SurveyUpdated    { row : Survey }
      SurveyPublished  { id : string! }
      SurveyQuestions.QuestionsChanged -> INIT
      SurveyBranching.RulesChanged     -> INIT
    }
  }

  trait SurveyQuestions -> Survey [interaction, instance] {
    config {
      title : string = "Survey questions"
    }
    initial: idle
    state idle {
      INIT -> idle
        (fetch Survey { emit: { success: "SurveyHydrated", failure: "QuestionsSaveFailed" } })
        (render-ui sidebar { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-checks" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "Questions JSON", value: @entity.questionsJson, action: "EDIT_QUESTIONS_JSON" }, { type: "button", label: "Save questions", action: "SAVE_QUESTIONS", variant: "primary", icon: "save" }] })
      EDIT_QUESTIONS_JSON -> idle
        (set @entity.questionsJson @payload.value)
      SAVE_QUESTIONS -> idle
        (persist update Survey @entity { emit: { success: "QuestionsChanged", failure: "QuestionsSaveFailed" } })
      SurveyHydrated -> idle
      QuestionsChanged -> idle
      QuestionsSaveFailed -> idle
        (render-ui sidebar { type: "alert", variant: "error", message: "@payload.error" })
    }
    emits {
      EDIT_QUESTIONS_JSON { value : string! }
      SAVE_QUESTIONS
      SurveyHydrated      { data : [Survey] }
      QuestionsChanged    -> external { id : string! }
      QuestionsSaveFailed { error : string, code : string }
    }
    listens {
      EDIT_QUESTIONS_JSON { value : string! }
      SAVE_QUESTIONS
      SurveyHydrated      { data : [Survey] }
      QuestionsChanged    { id : string! }
      QuestionsSaveFailed { error : string, code : string }
    }
  }

  trait SurveyBranching -> Survey [interaction, instance] {
    config {
      title : string = "Branching rules"
    }
    initial: idle
    state idle {
      INIT -> idle
        (fetch Survey { emit: { success: "SurveyHydrated", failure: "RulesSaveFailed" } })
        (render-ui sidebar { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "git-branch" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "Rules JSON", value: @entity.rulesJson, action: "EDIT_RULES_JSON" }, { type: "button", label: "Save rules", action: "SAVE_RULES", variant: "primary", icon: "save" }] })
      EDIT_RULES_JSON -> idle
        (set @entity.rulesJson @payload.value)
      SAVE_RULES -> idle
        (persist update Survey @entity { emit: { success: "RulesChanged", failure: "RulesSaveFailed" } })
      SurveyHydrated -> idle
      RulesChanged -> idle
      RulesSaveFailed -> idle
        (render-ui sidebar { type: "alert", variant: "error", message: "@payload.error" })
    }
    emits {
      EDIT_RULES_JSON { value : string! }
      SAVE_RULES
      SurveyHydrated  { data : [Survey] }
      RulesChanged    -> external { id : string! }
      RulesSaveFailed { error : string, code : string }
    }
    listens {
      EDIT_RULES_JSON { value : string! }
      SAVE_RULES
      SurveyHydrated  { data : [Survey] }
      RulesChanged    { id : string! }
      RulesSaveFailed { error : string, code : string }
    }
  }

  page "/survey-builder" as FormBuilderPage -> SurveyManage, SurveyQuestions, SurveyBranching
}
