app std-agent-session "1.0.0"
"std-agent-session as a Function"
orbital AgentSessionOrbital {
    type AgentSessionLoaded = Event { data : [AgentSession] } "Fired when AgentSession finishes loading; payload.data holds the sessions"

    type AgentSessionLoadFailed = Event { error : string, code : string } "Fired when AgentSession fails to load"

    type AgentSessionSaved = Event { id : string } "Fired when a new session is persisted"

    type AgentSessionSaveFailed = Event { error : string, code : string } "Fired when persisting a session fails"

    type AgentSessionUpdated = Event { id : string } "Fired when a session is updated"

    type AgentSessionUpdateFailed = Event { error : string, code : string } "Fired when updating a session fails"

  entity AgentSession [persistent: agentsessions] {
    id : string!
    name : string @description "A user-defined identifier for the session." @synonyms "identifier, sessionName, title"
    description : string @description "A textual explanation of the session's purpose or content." @synonyms "summary, details, notes, explanation"
    status : "active" | "inactive" | "pending" | "forked" | "ended" @description "Current operational state of the session." @synonyms "state, condition, mode" = active
    createdAt : string
    sessionId : string @description "Unique identifier for a session." @synonyms "session ID, session identifier" = ""
    parentId : string @description "Reference to the parent entity's identifier." @synonyms "parent, reference, source" = ""
    label : string @description "A user-friendly identifier for the session." @synonyms "title, identifier, display name" = ""
  }

  trait AgentSessionBrowse -> AgentSession [interaction, collection] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch AgentSession {
          emit: { failure: AgentSessionLoadFailed, success: AgentSessionLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading sessions…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      AgentSessionLoaded -> browsing
        (render-ui main {
          children: [{
            align: center
            children: [{ name: terminal, type: icon }, {
              content: "AgentSession Manager"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            entity: ?data
            fields: [{
              icon: terminal
              label: "Session ID"
              name: sessionId
              variant: h4
            }, {
              label: Status
              name: status
              variant: badge
            }, {
              label: Label
              name: label
              variant: caption
            }]
            itemActions: [{
              event: FORK
              icon: git-branch
              label: Fork
              variant: secondary
            }, {
              event: LABEL
              icon: tag
              label: Label
              variant: secondary
            }, {
              event: END
              icon: square
              label: End
              variant: ghost
            }]
            type: data-grid
          }]
          className: "max-w-5xl mx-auto w-full"
          direction: vertical
          gap: lg
          type: stack
        })
      AgentSessionLoadFailed -> error
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load sessions"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state browsing {
      INIT -> loading
        (fetch AgentSession {
          emit: { failure: AgentSessionLoadFailed, success: AgentSessionLoaded }
        })
        (render-ui main { type: spinner })
      AgentSessionLoaded -> browsing
        (render-ui main {
          children: [{
            align: center
            children: [{ name: terminal, type: icon }, {
              content: "AgentSession Manager"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            entity: ?data
            fields: [{
              icon: terminal
              label: "Session ID"
              name: sessionId
              variant: h4
            }, {
              label: Status
              name: status
              variant: badge
            }, {
              label: Label
              name: label
              variant: caption
            }]
            itemActions: [{
              event: FORK
              icon: git-branch
              label: Fork
              variant: secondary
            }, {
              event: LABEL
              icon: tag
              label: Label
              variant: secondary
            }, {
              event: END
              icon: square
              label: End
              variant: ghost
            }]
            type: data-grid
          }]
          className: "max-w-5xl mx-auto w-full"
          direction: vertical
          gap: lg
          type: stack
        })
      AgentSessionLoadFailed -> error
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load sessions"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state error {
      INIT -> loading
        (fetch AgentSession {
          emit: { failure: AgentSessionLoadFailed, success: AgentSessionLoaded }
        })
        (render-ui main { type: spinner })
    }

    emits {
      FORK {
        id : string!
        row : AgentSession
      }
      LABEL {
        id : string!
        row : AgentSession
      }
      END {
        id : string!
        row : AgentSession
      }
      AgentSessionLoaded
      AgentSessionLoadFailed
      AgentSessionUpdated
      AgentSessionUpdateFailed
      AgentSessionSaved
      AgentSessionSaveFailed
    }

    listens {
      AgentSessionAgent.FORKED -> INIT
      AgentSessionLabel.LABELED -> INIT
      AgentSessionAgent.ENDED -> INIT
      AgentSessionLoadFailed {
        error : string
        code : string
      }
      AgentSessionUpdateFailed {
        error : string
        code : string
      }
      AgentSessionSaveFailed {
        error : string
        code : string
      }
    }
  }

  trait AgentSessionLabel -> AgentSession [interaction, instance] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch AgentSession {
          emit: { failure: AgentSessionLoadFailed, success: AgentSessionLoaded }
        })
      LABEL -> open
        (render-ui modal {
          children: [{
            children: [{ name: tag, type: icon }, {
              content: "Label Session"
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            cancelEvent: CLOSE
            entity: ?row
            fields: (label)
            mode: edit
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
      SAVE -> closed
        (persist update AgentSession ?data {
          emit: { failure: AgentSessionUpdateFailed, success: AgentSessionUpdated }
        })
        (emit LABELED { id: ?data.id })
        (render-ui modal null)
        (render-ui main { type: box })
    }

    emits {
      LABELED -> external {
        id : string!
      }
      AgentSessionLoaded
      AgentSessionLoadFailed
      AgentSessionUpdated
      AgentSessionUpdateFailed
    }

    listens {
      LABEL {
        id : string!
        row : AgentSession
      }
      SAVE {
        data : AgentSession
      }
      AgentSessionLoadFailed {
        error : string
        code : string
      }
      AgentSessionBrowse.LABEL -> LABEL
    }
  }

  trait AgentSessionAgent -> AgentSession [interaction, collection] {
    initial: active

    state active {
      INIT -> active
        (fetch AgentSession {
          emit: { failure: AgentSessionLoadFailed, success: AgentSessionLoaded }
        })
        (render-ui main {
          description: "Session is ready"
          icon: git-branch
          title: Session
          type: empty-state
        })
      FORK -> forked
        (agent/fork)
        (persist create AgentSession {
          createdAt: @now
          parentId: ?row.id
          status: forked
        } {
          emit: { failure: AgentSessionSaveFailed, success: AgentSessionSaved }
        })
        (emit FORKED { sessionId: ?row.id })
      DO_LABEL -> active
        (agent/label ?data.label)
      END -> ended
        (persist update AgentSession { id: ?row.id, status: ended } {
          emit: { failure: AgentSessionUpdateFailed, success: AgentSessionUpdated }
        })
        (emit ENDED { sessionId: ?row.id })
    }

    state forked {
      FORK -> forked
        (agent/fork)
        (persist create AgentSession {
          createdAt: @now
          parentId: ?row.id
          status: forked
        } {
          emit: { failure: AgentSessionSaveFailed, success: AgentSessionSaved }
        })
        (emit FORKED { sessionId: ?row.id })
      END -> ended
        (persist update AgentSession { id: ?row.id, status: ended } {
          emit: { failure: AgentSessionUpdateFailed, success: AgentSessionUpdated }
        })
        (emit ENDED { sessionId: ?row.id })
    }

    state ended {
      INIT -> active
        (fetch AgentSession {
          emit: { failure: AgentSessionLoadFailed, success: AgentSessionLoaded }
        })
        (render-ui main {
          description: "Session is ready"
          icon: git-branch
          title: Session
          type: empty-state
        })
      FORK -> forked
        (agent/fork)
        (persist create AgentSession {
          createdAt: @now
          parentId: ?row.id
          status: forked
        } {
          emit: { failure: AgentSessionSaveFailed, success: AgentSessionSaved }
        })
        (emit FORKED { sessionId: ?row.id })
      END -> ended
        (persist update AgentSession { id: ?row.id, status: ended } {
          emit: { failure: AgentSessionUpdateFailed, success: AgentSessionUpdated }
        })
        (emit ENDED { sessionId: ?row.id })
    }

    emits {
      ENDED -> external {
        sessionId : string!
      }
      FORKED -> external {
        sessionId : string!
      }
      AgentSessionLoaded
      AgentSessionLoadFailed
      AgentSessionSaved
      AgentSessionSaveFailed
      AgentSessionUpdated
      AgentSessionUpdateFailed
    }

    listens {
      FORK {
        id : string!
        row : AgentSession
      }
      END {
        id : string!
        row : AgentSession
      }
      DO_LABEL {
        data : AgentSession
      }
      AgentSessionLoadFailed {
        error : string
        code : string
      }
      AgentSessionBrowse.FORK -> FORK
      AgentSessionBrowse.END -> END
    }
  }

  page "/agentsessions" as AgentSessionPage -> AgentSessionBrowse, AgentSessionLabel, AgentSessionAgent
}