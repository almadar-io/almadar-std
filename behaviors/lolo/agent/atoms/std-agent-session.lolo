app std-agent-session "1.0.0"
"std-agent-session as a Function"

orbital AgentSessionOrbital {
  entity AgentSession [persistent: agentsessions] {
    id          : string!
    name        : string @description "A user-defined identifier for the session." @synonyms "identifier, sessionName, title"
    description : string @description "A textual explanation of the session's purpose or content." @synonyms "summary, details, notes, explanation"
    status      : "active" | "inactive" | "pending" | "forked" | "ended" @description "Current operational state of the session." @synonyms "state, condition, mode" = "active"
    createdAt   : string
    sessionId   : string @description "Unique identifier for a session." @synonyms "session ID, session identifier" = ""
    parentId    : string @description "Reference to the parent entity's identifier." @synonyms "parent, reference, source" = ""
    label       : string @description "A user-friendly identifier for the session." @synonyms "title, identifier, display name" = ""
  }

  type AgentSessionLoaded        = Event { data : [AgentSession] }        "Fired when AgentSession finishes loading; payload.data holds the sessions"
  type AgentSessionLoadFailed    = Event { error : string, code : string } "Fired when AgentSession fails to load"
  type AgentSessionSaved         = Event { id : string }                   "Fired when a new session is persisted"
  type AgentSessionSaveFailed    = Event { error : string, code : string } "Fired when persisting a session fails"
  type AgentSessionUpdated       = Event { id : string }                   "Fired when a session is updated"
  type AgentSessionUpdateFailed  = Event { error : string, code : string } "Fired when updating a session fails"

  trait AgentSessionBrowse -> AgentSession [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch AgentSession { emit: { success: "AgentSessionLoaded", failure: "AgentSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading sessions…" }] })
      AgentSessionLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "terminal" }, { type: "typography", content: "AgentSession Manager", variant: "h2" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Fork", event: "FORK", variant: "secondary", icon: "git-branch" }, { label: "Label", event: "LABEL", variant: "secondary", icon: "tag" }, { label: "End", event: "END", variant: "ghost", icon: "square" }], fields: [{ name: "sessionId", label: "Session ID", variant: "h4", icon: "terminal" }, { name: "status", label: "Status", variant: "badge" }, { name: "label", label: "Label", variant: "caption" }] }] })
      AgentSessionLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load sessions" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch AgentSession { emit: { success: "AgentSessionLoaded", failure: "AgentSessionLoadFailed" } })
        (render-ui main { type: "spinner" })
      AgentSessionLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "terminal" }, { type: "typography", content: "AgentSession Manager", variant: "h2" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Fork", event: "FORK", variant: "secondary", icon: "git-branch" }, { label: "Label", event: "LABEL", variant: "secondary", icon: "tag" }, { label: "End", event: "END", variant: "ghost", icon: "square" }], fields: [{ name: "sessionId", label: "Session ID", variant: "h4", icon: "terminal" }, { name: "status", label: "Status", variant: "badge" }, { name: "label", label: "Label", variant: "caption" }] }] })
      AgentSessionLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load sessions" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state error {
      INIT -> loading
        (fetch AgentSession { emit: { success: "AgentSessionLoaded", failure: "AgentSessionLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      FORK { id : string!, row : AgentSession }
      LABEL { id : string!, row : AgentSession }
      END { id : string!, row : AgentSession }
      AgentSessionLoaded
      AgentSessionLoadFailed
      AgentSessionUpdated
      AgentSessionUpdateFailed
      AgentSessionSaved
      AgentSessionSaveFailed
    }
    listens {
      AgentSessionAgent.FORKED -> INIT
      AgentSessionLabel.LABELED -> INIT
      AgentSessionAgent.ENDED -> INIT
      AgentSessionLoadFailed { error : string, code : string }
      AgentSessionUpdateFailed { error : string, code : string }
      AgentSessionSaveFailed { error : string, code : string }
    }
  }

  trait AgentSessionLabel -> AgentSession [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch AgentSession { emit: { success: "AgentSessionLoaded", failure: "AgentSessionLoadFailed" } })
      LABEL -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "tag" }, { type: "typography", content: "Label Session", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["label"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
      SAVE -> closed
        (persist update AgentSession @payload.data { emit: { success: "AgentSessionUpdated", failure: "AgentSessionUpdateFailed" } })
        (emit LABELED { id: "@payload.data.id" })
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    emits {
      LABELED -> external { id : string! }
      AgentSessionLoaded
      AgentSessionLoadFailed
      AgentSessionUpdated
      AgentSessionUpdateFailed
    }
    listens {
      LABEL { id : string!, row : AgentSession }
      SAVE { data : AgentSession }
      AgentSessionLoadFailed { error : string, code : string }
      AgentSessionBrowse.LABEL -> LABEL
    }
  }

  trait AgentSessionAgent -> AgentSession [interaction, collection] {
    initial: active
    state active {
      INIT -> active
        (fetch AgentSession { emit: { success: "AgentSessionLoaded", failure: "AgentSessionLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "git-branch", title: "Session", description: "Session is ready" })
      FORK -> forked
        (agent/fork)
        (persist create AgentSession { status: "forked", parentId: "@payload.row.id", createdAt: "@now" } { emit: { success: "AgentSessionSaved", failure: "AgentSessionSaveFailed" } })
        (emit FORKED { sessionId: "@payload.row.id" })
      DO_LABEL -> active
        (agent/label @payload.data.label)
      END -> ended
        (persist update AgentSession { id: "@payload.row.id", status: "ended" } { emit: { success: "AgentSessionUpdated", failure: "AgentSessionUpdateFailed" } })
        (emit ENDED { sessionId: "@payload.row.id" })
    }
    state forked {
      FORK -> forked
        (agent/fork)
        (persist create AgentSession { status: "forked", parentId: "@payload.row.id", createdAt: "@now" } { emit: { success: "AgentSessionSaved", failure: "AgentSessionSaveFailed" } })
        (emit FORKED { sessionId: "@payload.row.id" })
      END -> ended
        (persist update AgentSession { id: "@payload.row.id", status: "ended" } { emit: { success: "AgentSessionUpdated", failure: "AgentSessionUpdateFailed" } })
        (emit ENDED { sessionId: "@payload.row.id" })
    }
    state ended {
      INIT -> active
        (fetch AgentSession { emit: { success: "AgentSessionLoaded", failure: "AgentSessionLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "git-branch", title: "Session", description: "Session is ready" })
      FORK -> forked
        (agent/fork)
        (persist create AgentSession { status: "forked", parentId: "@payload.row.id", createdAt: "@now" } { emit: { success: "AgentSessionSaved", failure: "AgentSessionSaveFailed" } })
        (emit FORKED { sessionId: "@payload.row.id" })
      END -> ended
        (persist update AgentSession { id: "@payload.row.id", status: "ended" } { emit: { success: "AgentSessionUpdated", failure: "AgentSessionUpdateFailed" } })
        (emit ENDED { sessionId: "@payload.row.id" })
    }
    emits {
      ENDED -> external { sessionId : string! }
      FORKED -> external { sessionId : string! }
      AgentSessionLoaded
      AgentSessionLoadFailed
      AgentSessionSaved
      AgentSessionSaveFailed
      AgentSessionUpdated
      AgentSessionUpdateFailed
    }
    listens {
      FORK { id : string!, row : AgentSession }
      END { id : string!, row : AgentSession }
      DO_LABEL { data : AgentSession }
      AgentSessionLoadFailed { error : string, code : string }
      AgentSessionBrowse.FORK -> FORK
      AgentSessionBrowse.END -> END
    }
  }

  page "/agentsessions" as AgentSessionPage -> AgentSessionBrowse, AgentSessionLabel, AgentSessionAgent
}
