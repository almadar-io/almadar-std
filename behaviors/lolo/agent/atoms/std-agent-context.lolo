app std-agent-context "1.0.0"
"Wraps llm/token-count + llm/compact — context window management."
orbital AgentContextOrbital {

  entity ContextWindow [runtime] {
    tokenCount : number = 0
    beforeTokens : number = 0
    afterTokens : number = 0
    status : "idle" | "counted" | "compacted" = idle
  }

  trait ContextCounter -> ContextWindow [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.tokenCount 0)
        (set @entity.status idle)
      COUNT -> counting
        (set @entity.status idle)
        (llm/token-count { emit: { success: TOKEN_COUNTED, failure: COUNT_FAILED } })
    }

    state counting {
      TOKEN_COUNTED -> counted
        (set @entity.tokenCount ?result)
        (set @entity.status counted)
        (emit COUNTED { tokenCount: @entity.tokenCount })
      COUNT_FAILED -> idle
        (set @entity.tokenCount 0)
        (set @entity.status idle)
    }

    state counted {
      INIT -> counted
        (set @entity.status counted)
      RESET -> idle
        (set @entity.tokenCount 0)
        (set @entity.status idle)
    }

    emits {
      COUNTED {
        tokenCount : number!
      }
      TOKEN_COUNTED {
        result : number!
      }
    }

    listens {
      COUNT
    }
  }

  trait ContextCompactor -> ContextWindow [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.beforeTokens 0)
        (set @entity.afterTokens 0)
        (set @entity.status idle)
      COMPACT -> counting_before
        (set @entity.status idle)
        (llm/token-count { emit: { success: BEFORE_COUNTED, failure: COMPACT_COUNT_FAILED } })
    }

    state counting_before {
      BEFORE_COUNTED -> compacting
        (set @entity.beforeTokens ?result)
        (llm/compact { emit: { success: COMPACTED_OK, failure: COMPACT_FAILED } })
      COMPACT_COUNT_FAILED -> idle
        (set @entity.beforeTokens 0)
        (set @entity.afterTokens 0)
        (set @entity.status idle)
    }

    state compacting {
      COMPACTED_OK -> counting_after
        (llm/token-count { emit: { success: AFTER_COUNTED, failure: COMPACT_COUNT_FAILED } })
      COMPACT_FAILED -> idle
        (set @entity.beforeTokens 0)
        (set @entity.afterTokens 0)
        (set @entity.status idle)
    }

    state counting_after {
      AFTER_COUNTED -> compacted
        (set @entity.afterTokens ?result)
        (set @entity.status compacted)
        (emit COMPACTED { before: @entity.beforeTokens, after: @entity.afterTokens })
      COMPACT_COUNT_FAILED -> idle
        (set @entity.beforeTokens 0)
        (set @entity.afterTokens 0)
        (set @entity.status idle)
    }

    state compacted {
      INIT -> compacted
        (set @entity.status compacted)
      RESET -> idle
        (set @entity.beforeTokens 0)
        (set @entity.afterTokens 0)
        (set @entity.status idle)
    }

    emits {
      COMPACTED {
        before : number!
        after : number!
      }
      BEFORE_COUNTED {
        result : number!
      }
      AFTER_COUNTED {
        result : number!
      }
    }

    listens {
      COMPACT
    }
  }

  trait ContextListener -> ContextWindow [lifecycle, instance] {
    initial: waiting

    state waiting {
      INIT -> waiting
        (set @entity.status idle)
      COUNTED -> active
        (set @entity.status counted)
      COMPACTED -> active
        (set @entity.status compacted)
      RESET -> waiting
        (set @entity.status idle)
    }

    state active {
      INIT -> active
        (set @entity.status idle)
      RESET -> waiting
        (set @entity.status idle)
    }

    listens {
      ContextCounter.COUNTED -> COUNTED
      ContextCompactor.COMPACTED -> COMPACTED
      RESET
    }
  }

  page "/agent-context" as AgentContextPage -> ContextCounter, ContextCompactor, ContextListener
}
