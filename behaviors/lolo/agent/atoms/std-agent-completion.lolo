app std-agent-completion "1.0.1"
"std-agent-completion as a Function"
orbital AgentCompletionOrbital {
    type AgentCompletionLoaded = Event AgentCompletion "Fired when AgentCompletion finishes loading"

    type AgentCompletionLoadFailed = Event { message : string } "Fired when AgentCompletion fails to load"

    type AgentCompletionSaved = Event { id : string }

    type AgentCompletionSaveFailed = Event { error : string, code : string }

  entity AgentCompletion [persistent: agentcompletions] {
    id : string
    name : string @description "A user-facing identifier for the completion." @synonyms "label, identifier, title"
    description : string @description "A textual explanation of the completion's purpose." @synonyms "explanation, details, notes"
    status : "idle" | "generating" | "completed" | "error" @description "Current operational state of the process." @synonyms "state, condition, progress" = idle
    createdAt : string
    prompt : string @description "The text used as input to generate a completion." @synonyms "query, input, request" = ""
    response : string @description "The output or result generated by the agent." @synonyms "result, output, answer, value" = ""
    provider : string @description "Identifies the source of the completion data." @synonyms "source, origin, provider" = anthropic
    model : string @description "The underlying model used for generating completions." @synonyms "algorithm, engine, technique" = claude-sonnet-4-20250514
    error : string @description "Details about any errors encountered during processing." @synonyms "failure, problem, issue, fault" = ""
    message : string @description "The text content of the completion message." @synonyms "content, text, body" = ""
    notificationType : "info" | "success" | "warning" | "error" @description "Indicates the type of notification generated." @synonyms "type, level, category" = info
  }

  trait AgentCompletionModal -> @rebindable AgentCompletion [interaction, instance] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.model claude-sonnet-4-20250514)
        (set @entity.provider anthropic)
        (fetch AgentCompletion {
          emit: { failure: AgentCompletionLoadFailed, success: AgentCompletionLoaded }
        })
        (render-ui main {
          children: [{
            children: [{
              children: [{ name: sparkles, type: icon }, {
                content: AgentCompletion
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: GENERATE
              icon: sparkles
              label: Open
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            description: "Click Open to view details in a modal overlay."
            icon: sparkles
            title: "Nothing open"
            type: empty-state
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      GENERATE -> open
        (render-ui modal {
          children: [{
            children: [{ name: sparkles, type: icon }, {
              content: AgentCompletion
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{ label: @entity.provider, type: badge }, { label: @entity.model, type: badge }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (prompt)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch AgentCompletion {
          emit: { failure: AgentCompletionLoadFailed, success: AgentCompletionLoaded }
        })
        (render-ui main {
          children: [{
            children: [{
              children: [{ name: sparkles, type: icon }, {
                content: AgentCompletion
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: GENERATE
              icon: sparkles
              label: Open
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            description: "Click Open to view details in a modal overlay."
            icon: sparkles
            title: "Nothing open"
            type: empty-state
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      SAVE -> closed
        (persist create AgentCompletion ?data {
          emit: { failure: AgentCompletionSaveFailed, success: AgentCompletionSaved }
        })
        (render-ui modal null)
        (emit GENERATED)
        (fetch AgentCompletion {
          emit: { failure: AgentCompletionLoadFailed, success: AgentCompletionLoaded }
        })
        (render-ui main {
          children: [{
            children: [{
              children: [{ name: sparkles, type: icon }, {
                content: AgentCompletion
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: GENERATE
              icon: sparkles
              label: Open
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            description: "Click Open to view details in a modal overlay."
            icon: sparkles
            title: "Nothing open"
            type: empty-state
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    emits {
      GENERATED -> external {
        id : string
      }
      AgentCompletionLoaded
      AgentCompletionLoadFailed
      AgentCompletionSaved
      AgentCompletionSaveFailed
    }

    listens {
      SAVE {
        data : object!
      }
      AgentCompletionLoadFailed {
        message : string
      }
      AgentCompletionSaveFailed {
        error : string
        code : string
      }
    }
  }

  trait AgentCompletionNotification -> AgentCompletion [interaction, instance] {
    initial: hidden

    state hidden {
      INIT -> hidden
        (fetch AgentCompletion {
          emit: { failure: AgentCompletionLoadFailed, success: AgentCompletionLoaded }
        })
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: sparkles, type: icon }, {
                content: "AgentCompletion Status"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: HIDE
              icon: x
              label: Dismiss
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            message: @entity.message
            type: alert
            variant: @entity.notificationType
          }, { type: toast-slot }, {
            message: @entity.message
            type: alert
            variant: warning
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state visible {
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: sparkles, type: icon }, {
                content: "AgentCompletion Status"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: HIDE
              icon: x
              label: Dismiss
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            message: @entity.message
            type: alert
            variant: @entity.notificationType
          }, { type: toast-slot }, {
            message: @entity.message
            type: alert
            variant: warning
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      HIDE -> hidden
        (set @entity.message "")
    }

    emits {
      AgentCompletionLoaded
      AgentCompletionLoadFailed
    }

    listens {
      SHOW {
        message : string!
        notificationType : "info" | "success" | "warning" | "error"
      }
      AgentCompletionLoadFailed {
        message : string
      }
    }
  }

  trait AgentCompletionAgent -> AgentCompletion [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch AgentCompletion {
          emit: { failure: AgentCompletionLoadFailed, success: AgentCompletionLoaded }
        })
        (render-ui main {
          description: "Completion is ready"
          icon: sparkles
          title: Completion
          type: empty-state
        })
      DO_GENERATE -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
      GENERATED -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
    }

    state generating {
      DO_GENERATE -> completed
        (set @entity.response ?data.prompt)
        (set @entity.status completed)
        (emit SHOW {
          message: "Completion ready"
          notificationType: success
        })
      RESET -> error when ["=", @entity.status, generating]
        (set @entity.status error)
        (set @entity.error "Generation was cancelled")
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.prompt "")
    }

    state error {
      RETRY -> generating when ["=", @entity.status, error]
        (set @entity.status generating)
        (set @entity.error "")
        (agent/generate @entity.prompt)
      RESET -> idle
        (set @entity.status idle)
        (set @entity.error "")
    }

    emits {
      SHOW -> internal {
        message : string!
        notificationType : "info" | "success" | "warning" | "error"
      }
      AgentCompletionLoaded
      AgentCompletionLoadFailed
    }

    listens {
      AgentCompletionModal.GENERATED -> GENERATED
      DO_GENERATE {
        data : object!
      }
      AgentCompletionLoadFailed {
        message : string
      }
    }
  }

  page "/agentcompletions" as AgentCompletionPage -> AgentCompletionModal, AgentCompletionNotification, AgentCompletionAgent
}