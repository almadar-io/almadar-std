app std-agent-completion "1.0.0"
"Wraps llm/generate — takes a prompt, returns generated text."
orbital AgentCompletionOrbital {

  entity Completion [runtime] {
    prompt : string = ""
    response : string = ""
    status : "idle" | "generating" | "done" | "error" = idle
  }

  trait CompletionGeneration -> Completion [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.status idle)
        (set @entity.prompt "")
        (set @entity.response "")
      GENERATE -> generating
        (set @entity.prompt ?prompt)
        (set @entity.status generating)
        (set @entity.response (llm/generate @entity.prompt))
        (set @entity.status done)
        (emit COMPLETED { response: @entity.response })
    }

    state generating {
      INIT -> generating
    }

    state done {
      RESET -> idle
        (set @entity.response "")
        (set @entity.status idle)
    }

    emits {
      COMPLETED {
        response : string!
      }
        @description "Fired when generation completes, carrying the response."
    }

    listens {
      GENERATE {
        prompt : string!
      }
    }
  }

  page "/agent-completion" as AgentCompletionPage -> CompletionGeneration
}
