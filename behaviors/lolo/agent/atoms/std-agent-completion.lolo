app std-agent-completion "1.0.0"
"Wraps llm/generate — takes a prompt, returns generated text."
orbital AgentCompletionOrbital {

  entity Completion [runtime] {
    prompt : string = ""
    response : string = ""
    status : "idle" | "done" = idle
  }

  trait CompletionGeneration -> Completion [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.prompt "")
        (set @entity.response "")
        (set @entity.status idle)
      GENERATE -> done
        (set @entity.prompt ?prompt)
        (set @entity.response (llm/generate @entity.prompt))
        (set @entity.status done)
        (emit COMPLETED { response: @entity.response })
    }

    state done {
      INIT -> done
        (set @entity.status done)
      RESET -> idle
        (set @entity.response "")
        (set @entity.prompt "")
        (set @entity.status idle)
    }

    emits {
      COMPLETED {
        response : string!
      }
    }

    listens {
      GENERATE {
        prompt : string!
      }
    }
  }

  trait CompletionReady -> Completion [lifecycle, instance] {
    initial: waiting

    state waiting {
      INIT -> waiting
        (set @entity.status idle)
      COMPLETED -> ready
        (set @entity.status done)
    }

    state ready {
      INIT -> ready
        (set @entity.status done)
      RESET -> waiting
        (set @entity.status idle)
    }

    listens {
      CompletionGeneration.COMPLETED -> COMPLETED
      RESET
    }
  }

  page "/agent-completion" as AgentCompletionPage -> CompletionGeneration, CompletionReady
}
