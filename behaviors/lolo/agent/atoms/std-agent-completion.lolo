app std-agent-completion "1.0.0"
"std-agent-completion as a Function"

orbital AgentCompletionOrbital {
  entity AgentCompletion [persistent: agentcompletions] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    prompt : string = ""
    response : string = ""
    provider : string = "anthropic"
    model : string = "claude-sonnet-4-20250514"
    error : string = ""
    message : string = ""
    notificationType : string = "info"
  }

  type AgentCompletionLoaded     = Event AgentCompletion                  "Fired when AgentCompletion finishes loading"
  type AgentCompletionLoadFailed = Event { message : string } "Fired when AgentCompletion fails to load"
  type AgentCompletionSaved = Event { id : string }
  type AgentCompletionSaveFailed = Event { error : string, code : string }
  trait AgentCompletionModal -> AgentCompletion [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (ref AgentCompletion)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "AgentCompletion", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      GENERATE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "AgentCompletion", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.provider" }, { type: "badge", label: "@entity.model" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["prompt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (ref AgentCompletion)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "AgentCompletion", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      SAVE -> closed
        (persist create AgentCompletion @payload.data { emit: { success: "AgentCompletionSaved", failure: "AgentCompletionSaveFailed" } })
        (render-ui modal null)
        (emit GENERATED)
        (ref AgentCompletion)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "AgentCompletion", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
    }
    emits {
      GENERATED external { id: string }
    }
    listens {
      SAVE { data : object! }
          AgentCompletionLoadFailed { message : string }
    
      AgentCompletionSaveFailed { error : string, code : string }
    }
    emits: [AgentCompletionLoaded, AgentCompletionLoadFailed, AgentCompletionSaved, AgentCompletionSaveFailed]
  }
  trait AgentCompletionNotification -> AgentCompletion [interaction, instance] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch AgentCompletion { emit: { success: "AgentCompletionLoaded", failure: "AgentCompletionLoadFailed" } })
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "AgentCompletion Status", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "AgentCompletion Status", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
      HIDE -> hidden
        (set @entity.message "")
    }
    listens {
      SHOW { message : string!, notificationType : string }
          AgentCompletionLoadFailed { message : string }
    }
    emits: [AgentCompletionLoaded, AgentCompletionLoadFailed]
  }
  trait AgentCompletionAgent -> AgentCompletion [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentCompletion { emit: { success: "AgentCompletionLoaded", failure: "AgentCompletionLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "sparkles", title: "Completion", description: "Completion is ready" })
      DO_GENERATE -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
      GENERATED -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
    }
    state generating {
      DO_GENERATE -> completed
        (set @entity.response @payload.data.prompt)
        (set @entity.status completed)
        (emit SHOW)
      RESET -> error when (= @entity.status generating)
        (set @entity.status error)
        (set @entity.error "Generation was cancelled")
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.prompt "")
    }
    state error {
      RETRY -> generating when (= @entity.status error)
        (set @entity.status generating)
        (set @entity.error "")
        (agent/generate @entity.prompt)
      RESET -> idle
        (set @entity.status idle)
        (set @entity.error "")
    }
    emits {
      SHOW internal { response: string }
    }
    listens {
      AgentCompletionModal GENERATED -> GENERATED
      DO_GENERATE { data : object! }
          AgentCompletionLoadFailed { message : string }
    }
    emits: [AgentCompletionLoaded, AgentCompletionLoadFailed]
  }
  page "/agentcompletions" as AgentCompletionPage -> AgentCompletionModal, AgentCompletionNotification, AgentCompletionAgent
}