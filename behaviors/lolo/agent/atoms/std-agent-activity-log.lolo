app std-agent-activity-log "1.0.0"
"std-agent-activity-log as a Function"

orbital AgentActivityLogOrbital {
  entity AgentActivityLog [persistent: agentactivitylogs] {
    id          : string!
    name        : string
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
    action      : string = ""
    detail      : string = ""
    timestamp   : string = ""
    duration    : number = 0
    icon        : string = "circle"
  }

  type AgentActivityLogLoaded       = Event { data : [AgentActivityLog] }      "Fired when the AgentActivityLog collection finishes loading; payload.data holds the list"
  type AgentActivityLogLoadFailed   = Event { error : string, code : string }  "Fired when the AgentActivityLog collection fails to load"
  type AgentActivityLogSaved        = Event { id : string }                    "Fired when a LOG_ENTRY persist succeeds"
  type AgentActivityLogSaveFailed   = Event { error : string, code : string }  "Fired when a LOG_ENTRY persist fails"
  type AgentActivityLogDeleted      = Event { id : string }                    "Fired when CLEAR deletes activity log rows"
  type AgentActivityLogDeleteFailed = Event { error : string, code : string }  "Fired when CLEAR fails to delete"

  trait AgentActivityLogLog -> AgentActivityLog [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch AgentActivityLog { emit: { success: "AgentActivityLogLoaded", failure: "AgentActivityLogLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading activity log…" }] })
      AgentActivityLogLoaded -> logging
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "activity" }, { type: "typography", content: "Activity Log", variant: "h2" }] }, { type: "button", label: "Clear", action: "CLEAR", variant: "ghost", icon: "trash" }] }, { type: "divider" }, { type: "timeline", fields: [], entity: @payload.data }] })
      AgentActivityLogLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load activity log" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state logging {
      LOG_ENTRY -> persisting
        (persist create AgentActivityLog { action: "@payload.action", detail: "@payload.detail", status: "@payload.status", timestamp: "@now" } { emit: { success: "AgentActivityLogSaved", failure: "AgentActivityLogSaveFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Recording entry…" }] })
      CLEAR -> deleting
        (persist delete AgentActivityLog { emit: { success: "AgentActivityLogDeleted", failure: "AgentActivityLogDeleteFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Clearing activity log…" }] })
    }
    state persisting {
      AgentActivityLogSaved -> loading
        (fetch AgentActivityLog { emit: { success: "AgentActivityLogLoaded", failure: "AgentActivityLogLoadFailed" } })
        (render-ui main { type: "spinner" })
      AgentActivityLogSaveFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to record entry" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state deleting {
      AgentActivityLogDeleted -> loading
        (fetch AgentActivityLog { emit: { success: "AgentActivityLogLoaded", failure: "AgentActivityLogLoadFailed" } })
        (render-ui main { type: "spinner" })
      AgentActivityLogDeleteFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to clear activity log" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state error {
      INIT -> loading
        (fetch AgentActivityLog { emit: { success: "AgentActivityLogLoaded", failure: "AgentActivityLogLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits: [AgentActivityLogLoaded, AgentActivityLogLoadFailed, AgentActivityLogSaved, AgentActivityLogSaveFailed, AgentActivityLogDeleted, AgentActivityLogDeleteFailed]
    listens {
      LOG_ENTRY { action : string, detail : string, status : string }
      AgentActivityLogLoadFailed { error : string, code : string }
      AgentActivityLogSaveFailed { error : string, code : string }
      AgentActivityLogDeleteFailed { error : string, code : string }
    }
  }

  page "/agentactivitylogs" as AgentActivityLogPage -> AgentActivityLogLog
}
