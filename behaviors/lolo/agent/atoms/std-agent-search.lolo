app std-agent-search "1.0.0"
"std-agent-search as a Function"
orbital AgentSearchOrbital {
    type AgentSearchLoaded = Event { data : [AgentSearch] } "Fired when AgentSearch finishes loading; payload.data holds the list"

    type AgentSearchLoadFailed = Event { error : string, code : string } "Fired when AgentSearch fails to load"

  entity AgentSearch [persistent: agentsearchs] {
    id : string!
    name : string @description "The identifier or title for the agent." @synonyms "title, label, identifier"
    description : string @description "A textual explanation of the search." @synonyms "summary, details, explanation"
    status : "active" | "inactive" | "pending" @description "Indicates the current operational state of the search." @synonyms "state, condition, operationalStatus" = active
    createdAt : string
    query : string @description "The search term or criteria used for the request." @synonyms "term, searchString, criteria, keyword" = ""
    results : [string] @description "The data returned as a result of the search." @synonyms "output, data, response" = []
    language : string @description "The language used for the search query." @synonyms "locale, languageCode, languageTag" = ""
    resultCount : number @description "The total number of results found." @synonyms "count, total, size" = 0
  }

  trait AgentSearchBrowse -> @rebindable AgentSearch [interaction, collection] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch AgentSearch {
          emit: { failure: AgentSearchLoadFailed, success: AgentSearchLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading searches…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      AgentSearchLoaded -> browsing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: search, type: icon }, {
                content: AgentSearch
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              children: [{
                action: SEARCH
                icon: search
                label: Search
                type: button
                variant: primary
              }, {
                action: CLEAR
                icon: x
                label: Clear
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              type: stack
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            entity: ?data
            fields: [{
              icon: search
              label: Query
              name: query
              variant: h4
            }, {
              colorMap: {
                active: success
                archived: neutral
                cancelled: error
                completed: success
                disabled: neutral
                done: success
                draft: warning
                error: error
                failed: error
                inactive: neutral
                pending: warning
                scheduled: warning
              }
              label: Language
              name: language
              variant: badge
            }, {
              label: "Result Count"
              name: resultCount
              variant: caption
            }]
            itemActions: [{
              event: VIEW
              label: View
              variant: ghost
            }]
            type: data-grid
          }]
          className: "max-w-5xl mx-auto w-full"
          direction: vertical
          gap: lg
          type: stack
        })
      AgentSearchLoadFailed -> error
        (render-ui main {
          align: center
          children: [{
            color: error
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load searches"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state browsing {
      INIT -> loading
        (fetch AgentSearch {
          emit: { failure: AgentSearchLoadFailed, success: AgentSearchLoaded }
        })
        (render-ui main { type: spinner })
    }

    state error {
      INIT -> loading
        (fetch AgentSearch {
          emit: { failure: AgentSearchLoadFailed, success: AgentSearchLoaded }
        })
        (render-ui main { type: spinner })
    }

    emits {
      SEARCH
      CLEAR
      AgentSearchLoaded
      AgentSearchLoadFailed
    }

    listens {
      AgentSearchAgent.SEARCHED -> INIT
      VIEW {
        id : string!
        row : AgentSearch
      }
      AgentSearchLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait AgentSearchAgent -> AgentSearch [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch AgentSearch {
          emit: { failure: AgentSearchLoadFailed, success: AgentSearchLoaded }
        })
        (render-ui main {
          description: "Code Search is ready"
          icon: search
          title: "Code Search"
          type: empty-state
        })
      SEARCH -> searching
        (agent/search-code ?query ?language)
    }

    state searching {
      SEARCH -> results
        (fetch AgentSearch {
          emit: { failure: AgentSearchLoadFailed, success: AgentSearchLoaded }
        })
        (emit SEARCHED { query: ?query, resultCount: 0 })
    }

    state results {
      SEARCH -> searching
        (agent/search-code ?query ?language)
      CLEAR -> idle
    }

    emits {
      SEARCHED -> external {
        query : string!
        resultCount : number
      }
      AgentSearchLoaded
      AgentSearchLoadFailed
    }

    listens {
      SEARCH {
        query : string!
        language : string
      }
      AgentSearchLoadFailed {
        error : string
        code : string
      }
      AgentSearchBrowse.SEARCH -> SEARCH
      AgentSearchBrowse.CLEAR -> CLEAR
    }
  }

  page "/agentsearchs" as AgentSearchPage -> AgentSearchBrowse, AgentSearchAgent
}