app std-agent-tool-call "1.0.0"
"std-agent-tool-call as a Function"
orbital AgentToolCallOrbital {
    type AgentToolCallLoaded = Event AgentToolCall "Fired when AgentToolCall finishes loading"

    type AgentToolCallLoadFailed = Event { message : string } "Fired when AgentToolCall fails to load"

    type AgentToolCallSaved = Event { id : string }

    type AgentToolCallSaveFailed = Event { error : string, code : string }

  entity AgentToolCall [persistent: agenttoolcalls] {
    id : string
    name : string @description "A human-readable identifier for the tool call." @synonyms "label, identifier, title"
    description : string @description "A human-readable explanation of the call's purpose." @synonyms "explanation, summary, notes"
    status : "idle" | "executing" | "completed" | "failed" @description "Current operational state of the process." @synonyms "state, condition, phase" = idle
    createdAt : string
    toolName : string @description "The identifier of the tool used." @synonyms "tool, identifier, reference" = ""
    args : string @description "Input parameters passed to the function." @synonyms "parameters, input, arguments" = ""
    result : string @description "The outcome of the operation." @synonyms "output, value, response" = ""
    error : string @description "Details about any error encountered during execution." @synonyms "failure, problem, issue, fault" = ""
    duration : number @description "Time elapsed for the operation, typically in milliseconds." @synonyms "elapsed, time, length" = 0
    action : string @description "The specific operation performed." @synonyms "operation, task, verb" = ""
    detail : string @description "Provides additional information or context about the call." @synonyms "notes, remarks, specifics, details" = ""
    timestamp : string @description "The date and time when the event occurred." @synonyms "date, time, when" = ""
  }

  trait AgentToolCallModal -> @rebindable AgentToolCall [interaction, instance] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch AgentToolCall {
          emit: { failure: AgentToolCallLoadFailed, success: AgentToolCallLoaded }
        })
        (render-ui main {
          children: [{
            children: [{
              children: [{ name: wrench, type: icon }, {
                content: "Invoke Tool"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: INVOKE
              icon: wrench
              label: Open
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            description: "Click Open to view details in a modal overlay."
            icon: wrench
            title: "Nothing open"
            type: empty-state
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      INVOKE -> open
        (render-ui modal {
          children: [{
            children: [{ name: wrench, type: icon }, {
              content: "Invoke Tool"
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            cancelEvent: CLOSE
            fields: (toolName args)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch AgentToolCall {
          emit: { failure: AgentToolCallLoadFailed, success: AgentToolCallLoaded }
        })
        (render-ui main {
          children: [{
            children: [{
              children: [{ name: wrench, type: icon }, {
                content: "Invoke Tool"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: INVOKE
              icon: wrench
              label: Open
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            description: "Click Open to view details in a modal overlay."
            icon: wrench
            title: "Nothing open"
            type: empty-state
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      SAVE -> closed
        (persist create AgentToolCall ?data {
          emit: { failure: AgentToolCallSaveFailed, success: AgentToolCallSaved }
        })
        (render-ui modal null)
        (emit INVOKED)
        (fetch AgentToolCall {
          emit: { failure: AgentToolCallLoadFailed, success: AgentToolCallLoaded }
        })
        (render-ui main {
          children: [{
            children: [{
              children: [{ name: wrench, type: icon }, {
                content: "Invoke Tool"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: INVOKE
              icon: wrench
              label: Open
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            description: "Click Open to view details in a modal overlay."
            icon: wrench
            title: "Nothing open"
            type: empty-state
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    emits {
      INVOKED -> external {
        id : string
      }
      AgentToolCallLoaded
      AgentToolCallLoadFailed
      AgentToolCallSaved
      AgentToolCallSaveFailed
    }

    listens {
      SAVE {
        data : object!
      }
      AgentToolCallLoadFailed {
        message : string
      }
      AgentToolCallSaveFailed {
        error : string
        code : string
      }
    }
  }

  trait AgentToolCallAgent -> AgentToolCall [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch AgentToolCall {
          emit: { failure: AgentToolCallLoadFailed, success: AgentToolCallLoaded }
        })
        (render-ui main {
          description: "Tool Call is ready"
          icon: wrench
          title: "Tool Call"
          type: empty-state
        })
      DO_INVOKE -> executing
        (set @entity.toolName ?data.toolName)
        (set @entity.args ?data.args)
        (set @entity.status executing)
        (emit TOOL_STARTED)
        (emit LOG_ENTRY)
        (agent/invoke ?data.toolName ?data.args)
      INVOKED -> executing
        (set @entity.status executing)
        (emit TOOL_STARTED)
        (emit LOG_ENTRY)
        (agent/invoke @entity.toolName @entity.args)
    }

    state executing {
      DO_INVOKE -> completed
        (set @entity.status completed)
        (set @entity.result ?data.result)
        (emit TOOL_COMPLETED)
        (emit LOG_ENTRY)
      CANCEL -> failed when ["=", @entity.status, executing]
        (set @entity.status failed)
        (set @entity.error Cancelled)
        (emit TOOL_COMPLETED)
      CANCEL -> idle
        (set @entity.status idle)
        (emit TOOL_COMPLETED)
    }

    state completed {
      DO_INVOKE -> executing
        (set @entity.toolName ?data.toolName)
        (set @entity.args ?data.args)
        (set @entity.status executing)
        (emit TOOL_STARTED)
        (emit LOG_ENTRY)
        (agent/invoke ?data.toolName ?data.args)
    }

    state failed {
      DO_INVOKE -> executing
        (set @entity.toolName ?data.toolName)
        (set @entity.args ?data.args)
        (set @entity.status executing)
        (emit TOOL_STARTED)
        (emit LOG_ENTRY)
        (agent/invoke ?data.toolName ?data.args)
    }

    emits {
      TOOL_STARTED -> internal {
        toolName : string
      }
      TOOL_COMPLETED -> internal {
        toolName : string
        result : string
      }
      LOG_ENTRY -> internal {
        action : string
        detail : string
        status : string
      }
      AgentToolCallLoaded
      AgentToolCallLoadFailed
    }

    listens {
      AgentToolCallModal.INVOKED -> INVOKED
      DO_INVOKE {
        data : object!
      }
      AgentToolCallLoadFailed {
        message : string
      }
    }
  }

  page "/agenttoolcalls" as AgentToolCallPage -> AgentToolCallModal, AgentToolCallAgent
}