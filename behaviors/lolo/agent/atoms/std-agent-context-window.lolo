app std-agent-context-window "1.0.0"
"std-agent-context-window as a Function"
orbital AgentContextWindowOrbital {
    type AgentContextWindowLoaded = Event AgentContextWindow "Fired when AgentContextWindow finishes loading"

    type AgentContextWindowLoadFailed = Event { message : string } "Fired when AgentContextWindow fails to load"

  entity AgentContextWindow [persistent: agentcontextwindows] {
    id : string
    name : string @description "A human-readable identifier for the context window." @synonyms "label, identifier, title"
    description : string @description "A textual explanation of the context window's purpose." @synonyms "explanation, details, notes, information"
    status : "active" | "inactive" | "pending" @description "Current operational state of the component." @synonyms "state, condition, operationalStatus" = active
    createdAt : string
    tokenCount : number @description "The number of tokens currently in use." @synonyms "count, quantity, size" = 0
    maxTokens : number @description "The maximum number of tokens allowed." @synonyms "limit, maximum, cap" = 200000
    usage : number @description "Represents the current usage of the context window." @synonyms "count, current, utilization" = 0
    lastCompactedAt : string @description "Timestamp of the last compaction event." @synonyms "lastModified, updated, compactionTime" = ""
    current : number @description "The current value of a numerical measurement." @synonyms "value, amount, level, reading" = 0
    max : number @description "The maximum allowable value for this context." @synonyms "limit, maximum, upper bound" = 200000
    threshold : number @description "The point at which an action is triggered." @synonyms "limit, boundary, trigger" = 0.85
    message : string @description "The text content of the message." @synonyms "content, text, body" = ""
    notificationType : "info" | "success" | "warning" | "error" @description "Indicates the type of notification generated." @synonyms "type, alert, level" = info
  }

  trait AgentContextWindowGauge -> @rebindable AgentContextWindow [interaction, instance] {
    initial: normal

    state normal {
      INIT -> normal
        (set @entity.max 200000)
        (fetch AgentContextWindow {
          emit: { failure: AgentContextWindowLoadFailed, success: AgentContextWindowLoaded }
        })
        (render-ui main {
          children: [{
            align: center
            children: [{ name: gauge, type: icon }, {
              content: "Token Usage"
              type: typography
              variant: h2
            }, {
              label: Normal
              type: badge
              variant: default
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            max: @entity.max
            type: progress-bar
            value: @entity.current
          }, {
            children: [{
              label: "Tokens Used"
              type: stat-display
              value: @entity.current
            }, {
              label: "Max Tokens"
              type: stat-display
              value: @entity.max
            }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            action: RESET
            icon: rotate-ccw
            label: Reset
            type: button
            variant: ghost
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      UPDATE -> normal when ["<", ["/", ?current, @entity.max], 0.85]
        (set @entity.current ?current)
        (render-ui main {
          children: [{
            align: center
            children: [{ name: gauge, type: icon }, {
              content: "Token Usage"
              type: typography
              variant: h2
            }, {
              label: Normal
              type: badge
              variant: default
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            max: @entity.max
            type: progress-bar
            value: @entity.current
          }, {
            children: [{
              label: "Tokens Used"
              type: stat-display
              value: @entity.current
            }, {
              label: "Max Tokens"
              type: stat-display
              value: @entity.max
            }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            action: RESET
            icon: rotate-ccw
            label: Reset
            type: button
            variant: ghost
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      UPDATE -> warning when (and [">=", ["/", ?current, @entity.max], 0.85] ["<", ["/", ?current, @entity.max], 0.95])
        (set @entity.current ?current)
        (render-ui main {
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "Token Usage"
              type: typography
              variant: h2
            }, {
              label: Warning
              type: badge
              variant: warning
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            message: "Token usage approaching limit. Consider compacting."
            type: alert
            variant: warning
          }, {
            max: @entity.max
            type: progress-bar
            value: @entity.current
          }, {
            children: [{
              label: "Tokens Used"
              type: stat-display
              value: @entity.current
            }, {
              label: "Max Tokens"
              type: stat-display
              value: @entity.max
            }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            children: [{
              action: COMPACT
              icon: minimize-2
              label: Compact
              type: button
              variant: primary
            }, {
              action: RESET
              icon: rotate-ccw
              label: Reset
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: sm
            type: stack
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      UPDATE -> critical when [">=", ["/", ?current, @entity.max], 0.95]
        (set @entity.current ?current)
        (render-ui main {
          children: [{
            align: center
            children: [{ name: alert-octagon, type: icon }, {
              content: "Token Usage"
              type: typography
              variant: h2
            }, {
              label: Critical
              type: badge
              variant: danger
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            message: "Token usage critical. Compact immediately to avoid truncation."
            type: alert
            variant: error
          }, {
            max: @entity.max
            type: progress-bar
            value: @entity.current
          }, {
            children: [{
              label: "Tokens Used"
              type: stat-display
              value: @entity.current
            }, {
              label: "Max Tokens"
              type: stat-display
              value: @entity.max
