      UPDATE -> normal when ["<", ["/", ?current, @entity.max], 0.85]
        (set @entity.current ?current)
        (render-ui main {
          children: [{
            align: center
            children: [{ name: gauge, type: icon }, {
              content: "Token Usage"
              type: typography
              variant: h2
            }, {
              label: Normal
              type: badge
