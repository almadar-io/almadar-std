app std-agent-context-window "1.0.0"
"std-agent-context-window as a Function"

orbital AgentContextWindowOrbital {
  entity AgentContextWindow [persistent: agentcontextwindows] {
    id : string
    name : string @description "A human-readable identifier for the context window." @synonyms "label, identifier, title"
    description : string @description "A textual explanation of the context window's purpose." @synonyms "explanation, details, notes, information"
    status : "active" | "inactive" | "pending" @description "Current operational state of the component." @synonyms "state, condition, operationalStatus" = "active"
    createdAt : string
    tokenCount : number @description "The number of tokens currently in use." @synonyms "count, quantity, size" = 0
    maxTokens : number @description "The maximum number of tokens allowed." @synonyms "limit, maximum, cap" = 200000
    usage : number @description "Represents the current usage of the context window." @synonyms "count, current, utilization" = 0
    lastCompactedAt : string @description "Timestamp of the last compaction event." @synonyms "lastModified, updated, compactionTime" = ""
    current : number @description "The current value of a numerical measurement." @synonyms "value, amount, level, reading" = 0
    max : number @description "The maximum allowable value for this context." @synonyms "limit, maximum, upper bound" = 200000
    threshold : number @description "The point at which an action is triggered." @synonyms "limit, boundary, trigger" = 0.85
    message : string @description "The text content of the message." @synonyms "content, text, body" = ""
    notificationType : "info" | "success" | "warning" | "error" @description "Indicates the type of notification generated." @synonyms "type, alert, level" = "info"
  }

  type AgentContextWindowLoaded     = Event AgentContextWindow                  "Fired when AgentContextWindow finishes loading"
  type AgentContextWindowLoadFailed = Event { message : string } "Fired when AgentContextWindow fails to load"
  trait AgentContextWindowGauge -> AgentContextWindow [interaction, instance] {
    initial: normal
    state normal {
      INIT -> normal
        (set @entity.max 200000)
        (fetch AgentContextWindow { emit: { success: "AgentContextWindowLoaded", failure: "AgentContextWindowLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      UPDATE -> normal when (< (/ @payload.current @entity.max) 0.85)
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      UPDATE -> warning when (and (>= (/ @payload.current @entity.max) 0.85) (< (/ @payload.current @entity.max) 0.95))
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Warning", variant: "warning" }] }, { type: "divider" }, { type: "alert", variant: "warning", message: "Token usage approaching limit. Consider compacting." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      UPDATE -> critical when (>= (/ @payload.current @entity.max) 0.95)
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-octagon"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Critical", variant: "danger" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Token usage critical. Compact immediately to avoid truncation." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact Now", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      COMPACT -> normal
        (agent/compact)
        (set @entity.lastCompactedAt @now)
        (agent/token-count)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      RESET -> normal
        (set @entity.current 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
    }
    state warning {
      UPDATE -> warning when (and (>= (/ @payload.current @entity.max) 0.85) (< (/ @payload.current @entity.max) 0.95))
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Warning", variant: "warning" }] }, { type: "divider" }, { type: "alert", variant: "warning", message: "Token usage approaching limit. Consider compacting." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      UPDATE -> critical when (>= (/ @payload.current @entity.max) 0.95)
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-octagon"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Critical", variant: "danger" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Token usage critical. Compact immediately to avoid truncation." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact Now", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      UPDATE -> normal when (< (/ @payload.current @entity.max) 0.85)
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      COMPACT -> normal
        (agent/compact)
        (set @entity.lastCompactedAt @now)
        (agent/token-count)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      RESET -> normal
        (set @entity.current 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
    }
    state critical {
      UPDATE -> critical when (>= (/ @payload.current @entity.max) 0.95)
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-octagon"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Critical", variant: "danger" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Token usage critical. Compact immediately to avoid truncation." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact Now", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      UPDATE -> warning when (and (>= (/ @payload.current @entity.max) 0.85) (< (/ @payload.current @entity.max) 0.95))
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Warning", variant: "warning" }] }, { type: "divider" }, { type: "alert", variant: "warning", message: "Token usage approaching limit. Consider compacting." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      UPDATE -> normal when (< (/ @payload.current @entity.max) 0.85)
        (set @entity.current @payload.current)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      COMPACT -> normal
        (agent/compact)
        (set @entity.lastCompactedAt @now)
        (agent/token-count)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      RESET -> normal
        (set @entity.current 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
    }
    emits {
      COMPACT
      AgentContextWindowLoaded
      AgentContextWindowLoadFailed
    }
    listens {
      UPDATE { current : number! }
          AgentContextWindowLoadFailed { message : string }
    }
  }
  trait AgentContextWindowNotification -> AgentContextWindow [interaction, instance] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch AgentContextWindow { emit: { success: "AgentContextWindowLoaded", failure: "AgentContextWindowLoadFailed" } })
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "layers"}, { type: "typography", content: "Context Window Alert", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "layers"}, { type: "typography", content: "Context Window Alert", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
      HIDE -> hidden
        (set @entity.message "")
    }
emits {
      AgentContextWindowLoaded
      AgentContextWindowLoadFailed
    }

        listens {
      SHOW { message : string!, notificationType : "info" | "success" | "warning" | "error" }
          AgentContextWindowLoadFailed { message : string }
    }
  }
  trait AgentContextWindowAgent -> AgentContextWindow [interaction, instance] {
    initial: normal
    state normal {
      INIT -> normal
        (set @entity.maxTokens 200000)
        (set @entity.tokenCount 0)
        (fetch AgentContextWindow { emit: { success: "AgentContextWindowLoaded", failure: "AgentContextWindowLoadFailed" } })
        (agent/token-count)
        (agent/context-usage)
        (render-ui main { type: "empty-state", icon: "layers", title: "Context Window", description: "Context Window is ready" })
      UPDATE_TOKENS -> normal when (< (/ @entity.tokenCount @entity.maxTokens) 0.85)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
      UPDATE_TOKENS -> approaching_limit when (and (>= (/ @entity.tokenCount @entity.maxTokens) 0.85) (< (/ @entity.tokenCount @entity.maxTokens) 1))
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
        (emit SHOW { message: "Token usage approaching limit", notificationType: "warning" })
    }
    state approaching_limit {
      UPDATE_TOKENS -> at_limit when (>= (/ @entity.tokenCount @entity.maxTokens) 1)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage 100)
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
        (emit SHOW { message: "Token usage at limit. Compact required.", notificationType: "error" })
      COMPACT -> normal
        (agent/compact)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.lastCompactedAt @now)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
      UPDATE_TOKENS -> approaching_limit when (and (>= (/ @entity.tokenCount @entity.maxTokens) 0.85) (< (/ @entity.tokenCount @entity.maxTokens) 1))
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
    }
    state at_limit {
      COMPACT -> normal
        (agent/compact)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.lastCompactedAt @now)
        (set @entity.usage (* (/ @entity.tokenCount @entity.maxTokens) 100))
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
    }
    emits {
      SHOW -> internal { message: string!, notificationType: "info" | "success" | "warning" | "error" }
      UPDATE -> internal { current: number, max: number }
      AgentContextWindowLoaded
      AgentContextWindowLoadFailed
    }
    listens {
      AgentContextWindowLoadFailed { message : string }
      AgentContextWindowGauge.COMPACT -> COMPACT
    }
  }
  page "/agentcontextwindows" as AgentContextWindowPage -> AgentContextWindowGauge, AgentContextWindowNotification, AgentContextWindowAgent
}