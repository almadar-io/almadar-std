            children: [{ name: alert-triangle, type: icon }, {
              content: "Token Usage"
              type: typography
              variant: h2
            }, {
              label: Warning
              type: badge
              variant: warning
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            message: "Token usage approaching limit. Consider compacting."
            type: alert
            variant: warning
          }, {
            max: @entity.max
