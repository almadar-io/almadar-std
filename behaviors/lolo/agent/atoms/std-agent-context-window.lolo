          }, {
            action: RESET
            icon: rotate-ccw
            label: Reset
            type: button
            variant: ghost
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state warning {
      UPDATE -> warning when (and [">=", ["/", ?current, @entity.max], 0.85] ["<", ["/", ?current, @entity.max], 0.95])
        (set @entity.current ?current)
        (render-ui main {
