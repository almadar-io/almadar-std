  trait AgentContextWindowNotification -> AgentContextWindow [interaction, instance] {
    initial: hidden

    state hidden {
      INIT -> hidden
        (fetch AgentContextWindow {
          emit: { failure: AgentContextWindowLoadFailed, success: AgentContextWindowLoaded }
        })
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: layers, type: icon }, {
                content: "Context Window Alert"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: HIDE
              icon: x
              label: Dismiss
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            message: @entity.message
            type: alert
            variant: @entity.notificationType
          }, { type: toast-slot }, {
            message: @entity.message
            type: alert
            variant: warning
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state visible {
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: layers, type: icon }, {
                content: "Context Window Alert"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: HIDE
              icon: x
              label: Dismiss
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            message: @entity.message
            type: alert
            variant: @entity.notificationType
          }, { type: toast-slot }, {
            message: @entity.message
            type: alert
            variant: warning
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      HIDE -> hidden
        (set @entity.message "")
    }

    emits {
      AgentContextWindowLoaded
      AgentContextWindowLoadFailed
    }

    listens {
      SHOW {
        message : string!
        notificationType : "info" | "success" | "warning" | "error"
      }
      AgentContextWindowLoadFailed {
        message : string
      }
    }
  }

  trait AgentContextWindowAgent -> AgentContextWindow [interaction, instance] {
    initial: normal

    state normal {
      INIT -> normal
        (set @entity.maxTokens 200000)
        (set @entity.tokenCount 0)
        (fetch AgentContextWindow {
          emit: { failure: AgentContextWindowLoadFailed, success: AgentContextWindowLoaded }
        })
        (agent/token-count)
        (agent/context-usage)
        (render-ui main {
          description: "Context Window is ready"
          icon: layers
          title: "Context Window"
          type: empty-state
        })
      UPDATE_TOKENS -> normal when ["<", ["/", @entity.tokenCount, @entity.maxTokens], 0.85]
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage ["*", ["/", @entity.tokenCount, @entity.maxTokens], 100])
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
      UPDATE_TOKENS -> approaching_limit when (and [">=", ["/", @entity.tokenCount, @entity.maxTokens], 0.85] ["<", ["/", @entity.tokenCount, @entity.maxTokens], 1])
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage ["*", ["/", @entity.tokenCount, @entity.maxTokens], 100])
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
        (emit SHOW {
          message: "Token usage approaching limit"
          notificationType: warning
        })
    }

    state approaching_limit {
      UPDATE_TOKENS -> at_limit when [">=", ["/", @entity.tokenCount, @entity.maxTokens], 1]
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage 100)
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
        (emit SHOW {
          message: "Token usage at limit. Compact required."
          notificationType: error
        })
      COMPACT -> normal
        (agent/compact)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.lastCompactedAt @now)
        (set @entity.usage ["*", ["/", @entity.tokenCount, @entity.maxTokens], 100])
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
      UPDATE_TOKENS -> approaching_limit when (and [">=", ["/", @entity.tokenCount, @entity.maxTokens], 0.85] ["<", ["/", @entity.tokenCount, @entity.maxTokens], 1])
        (agent/token-count)
        (agent/context-usage)
        (set @entity.usage ["*", ["/", @entity.tokenCount, @entity.maxTokens], 100])
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
    }

    state at_limit {
      COMPACT -> normal
        (agent/compact)
        (agent/token-count)
        (agent/context-usage)
        (set @entity.lastCompactedAt @now)
        (set @entity.usage ["*", ["/", @entity.tokenCount, @entity.maxTokens], 100])
        (set @entity.current @entity.tokenCount)
        (emit UPDATE { current: @entity.tokenCount, max: @entity.maxTokens })
    }

    emits {
      SHOW -> internal {
        message : string!
        notificationType : "info" | "success" | "warning" | "error"
      }
      UPDATE -> internal {
        current : number
        max : number
      }
      AgentContextWindowLoaded
      AgentContextWindowLoadFailed
    }

    listens {
      AgentContextWindowLoadFailed {
        message : string
      }
      AgentContextWindowGauge.COMPACT -> COMPACT
    }
  }

  page "/agentcontextwindows" as AgentContextWindowPage -> AgentContextWindowGauge, AgentContextWindowNotification, AgentContextWindowAgent
}