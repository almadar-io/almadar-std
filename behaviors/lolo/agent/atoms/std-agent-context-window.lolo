            message: "Token usage critical. Compact immediately to avoid truncation."
            type: alert
            variant: error
          }, {
            max: @entity.max
            type: progress-bar
            value: @entity.current
          }, {
            children: [{
              label: "Tokens Used"
              type: stat-display
              value: @entity.current
            }, {
              label: "Max Tokens"
              type: stat-display
              value: @entity.max
            }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            children: [{
