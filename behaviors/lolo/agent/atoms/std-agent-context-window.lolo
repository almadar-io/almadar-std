              type: stat-display
              value: @entity.max
            }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            action: RESET
            icon: rotate-ccw
            label: Reset
            type: button
            variant: ghost
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      RESET -> normal
        (set @entity.current 0)
        (render-ui main {
          children: [{
            align: center
            children: [{ name: gauge, type: icon }, {
              content: "Token Usage"
              type: typography
              variant: h2
            }, {
              label: Normal
              type: badge
              variant: default
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            max: @entity.max
            type: progress-bar
            value: @entity.current
          }, {
            children: [{
              label: "Tokens Used"
              type: stat-display
              value: @entity.current
            }, {
              label: "Max Tokens"
              type: stat-display
              value: @entity.max
            }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            action: RESET
            icon: rotate-ccw
            label: Reset
            type: button
            variant: ghost
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state critical {
      UPDATE -> critical when [">=", ["/", ?current, @entity.max], 0.95]
        (set @entity.current ?current)
        (render-ui main {
          children: [{
