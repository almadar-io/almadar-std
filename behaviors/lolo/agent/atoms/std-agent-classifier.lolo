app std-agent-classifier "1.0.0"
"std-agent-classifier as a Function"

orbital AgentClassifierOrbital {
  entity AgentClassifier [persistent: agentclassifiers] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    input : string = ""
    category : string = ""
    confidence : number = 0
    model : string = "claude-sonnet-4-20250514"
    message : string = ""
    notificationType : "info" | "success" | "warning" | "error" = "info"
  }

  type AgentClassifierLoaded     = Event AgentClassifier                  "Fired when AgentClassifier finishes loading"
  type AgentClassifierLoadFailed = Event { message : string } "Fired when AgentClassifier fails to load"
  type AgentClassifierSaved = Event { id : string }
  type AgentClassifierSaveFailed = Event { error : string, code : string }
  trait AgentClassifierModal -> AgentClassifier [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (ref AgentClassifier)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "AgentClassifier", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      CLASSIFY -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "AgentClassifier", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "typography", variant: "caption", content: "Categories:" }, { type: "badge", label: "positive", variant: "secondary" }, { type: "badge", label: "negative", variant: "secondary" }, { type: "badge", label: "neutral", variant: "secondary" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["input"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (ref AgentClassifier)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "AgentClassifier", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      SAVE -> closed
        (persist create AgentClassifier @payload.data { emit: { success: "AgentClassifierSaved", failure: "AgentClassifierSaveFailed" } })
        (render-ui modal null)
        (emit CLASSIFIED)
        (ref AgentClassifier)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "AgentClassifier", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
    }
    emits {
      CLASSIFIED external { id: string }
    }
    listens {
      SAVE { data : object! }
          AgentClassifierLoadFailed { message : string }
    
      AgentClassifierSaveFailed { error : string, code : string }
    }
    emits: [AgentClassifierLoaded, AgentClassifierLoadFailed, AgentClassifierSaved, AgentClassifierSaveFailed]
  }
  trait AgentClassifierNotification -> AgentClassifier [interaction, instance] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch AgentClassifier { emit: { success: "AgentClassifierLoaded", failure: "AgentClassifierLoadFailed" } })
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "AgentClassifier Result", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "AgentClassifier Result", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
      HIDE -> hidden
        (set @entity.message "")
    }
    listens {
      SHOW { message : string!, notificationType : "info" | "success" | "warning" | "error" }
          AgentClassifierLoadFailed { message : string }
    }
    emits: [AgentClassifierLoaded, AgentClassifierLoadFailed]
  }
  trait AgentClassifierAgent -> AgentClassifier [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentClassifier { emit: { success: "AgentClassifierLoaded", failure: "AgentClassifierLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "tag", title: "Classifier", description: "Classifier is ready" })
      DO_CLASSIFY -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "positive, negative, neutral" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
      CLASSIFIED -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "positive, negative, neutral" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
    }
    state classifying {
      DO_CLASSIFY -> classified
        (set @entity.category @payload.data.input)
        (emit SHOW { message: "Classification complete", notificationType: "success" })
    }
    state classified {
      RESET -> idle
        (set @entity.input "")
        (set @entity.category "")
        (set @entity.confidence 0)
    }
    emits {
      SHOW internal { message: string!, notificationType: "info" | "success" | "warning" | "error" }
    }
    listens {
      AgentClassifierModal CLASSIFIED -> CLASSIFIED
      DO_CLASSIFY { data : object! }
          AgentClassifierLoadFailed { message : string }
    }
    emits: [AgentClassifierLoaded, AgentClassifierLoadFailed]
  }
  page "/agentclassifiers" as AgentClassifierPage -> AgentClassifierModal, AgentClassifierNotification, AgentClassifierAgent
}