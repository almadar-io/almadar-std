app std-agent-step-progress "1.0.0"
"std-agent-step-progress as a Function"

orbital AgentStepProgressOrbital {
  entity AgentStepProgress [runtime] {
    id : string
    name : string @description "A descriptive label for the progress step." @synonyms "label, title, identifier"
    description : string @description "A textual explanation of the step's purpose or details." @synonyms "details, explanation, notes, summary"
    status : "active" | "inactive" | "pending" @description "Indicates the current operational state of the process." @synonyms "state, condition, operationalStatus" = "active"
    createdAt : string
    currentStep : number @description "The numerical value representing the current step." @synonyms "step, progress, count" = 0
    totalSteps : number @description "The total number of steps in the process." @synonyms "count, size, length, quantity" = 4
  }

  type AgentStepProgressLoaded     = Event AgentStepProgress                  "Fired when AgentStepProgress finishes loading"
  type AgentStepProgressLoadFailed = Event { message : string } "Fired when AgentStepProgress fails to load"
  trait AgentStepProgressProgress -> @rebindable AgentStepProgress [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.totalSteps 4)
        (fetch AgentStepProgress { emit: { success: "AgentStepProgressLoaded", failure: "AgentStepProgressLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] })
      START -> in_progress
        (set @entity.status in_progress)
        (set @entity.currentStep 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "loader"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "In Progress", variant: "warning" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "stat-display", label: "Current Step", value: "@entity.currentStep" }, { type: "stat-display", label: "Total Steps", value: "@entity.totalSteps" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Advance", action: "ADVANCE", variant: "primary", icon: "chevron-right" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] })
    }
    state in_progress {
      ADVANCE -> in_progress when (< @entity.currentStep @entity.totalSteps)
        (set @entity.currentStep (+ @entity.currentStep 1))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "loader"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "In Progress", variant: "warning" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "stat-display", label: "Current Step", value: "@entity.currentStep" }, { type: "stat-display", label: "Total Steps", value: "@entity.totalSteps" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Advance", action: "ADVANCE", variant: "primary", icon: "chevron-right" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      COMPLETE -> completed
        (set @entity.status completed)
        (set @entity.currentStep @entity.totalSteps)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "Completed", variant: "success" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.totalSteps", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "alert", variant: "success", message: "All steps completed successfully." }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAIL -> failed
        (set @entity.status failed)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "Failed", variant: "danger" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "alert", variant: "error", message: "Pipeline failed at the current step." }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "stat-display", label: "Failed At Step", value: "@entity.currentStep" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] })
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] })
    }
    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "AgentStepProgress", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Initialize" }, { id: "1", title: "Process" }, { id: "2", title: "Validate" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] })
    }
emits {
      AgentStepProgressLoaded
      AgentStepProgressLoadFailed
    }

        listens {
      AgentStepProgressLoadFailed { message : string }
    }
  }
  page "/agentstepprogresss" as AgentStepProgressPage -> AgentStepProgressProgress
}