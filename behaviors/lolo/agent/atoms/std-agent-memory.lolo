app std-agent-memory "1.0.0"
"std-agent-memory as a Function"
orbital AgentMemoryOrbital {
    type AgentMemoryLoaded = Event { data : [AgentMemory] } "Fired when the AgentMemory collection finishes loading; payload.data holds the list"

    type AgentMemoryLoadFailed = Event { error : string, code : string } "Fired when the AgentMemory collection fails to load"

    type AgentMemorySaved = Event { id : string } "Fired when a new memory is persisted"

    type AgentMemorySaveFailed = Event { error : string, code : string } "Fired when persisting a memory fails"

    type Memorized = Event { id : string } "Fired after an agent memory is created"

    type Pinned = Event { id : string } "Fired after a memory is pinned"

    type Forgot = Event { id : string } "Fired after a memory is forgotten"

    type Reinforced = Event { id : string } "Fired after a memory is reinforced"

    type Decayed = Event { id : string } "Fired after the decay sweep completes"

  entity AgentMemory [persistent: agentmemorys] {
    id : string!
    name : string @description "A human-readable identifier for the memory." @synonyms "label, identifier, title"
    description : string @description "A textual explanation of the memory's purpose or contents." @synonyms "details, notes, explanation, summary"
    status : "active" | "inactive" | "pending" @description "Current operational state of the component." @synonyms "state, condition, operational_status" = active
    createdAt : string
    content : string @description "The data stored within the memory." @synonyms "data, value, payload" = ""
    category : string @description "Classification or type of the memory data." @synonyms "type, kind, class" = general
    strength : number @description "A numerical value representing the intensity or magnitude." @synonyms "value, magnitude, level, intensity" = 1
    pinned : boolean @description "Indicates whether the item is marked as important." @synonyms "flagged, marked, important" = false
    scope : "session" | "persistent" | "shared" @description "Indicates the data's lifecycle and accessibility." @synonyms "lifetime, access, persistence" = session
    lastAccessedAt : string @description "Timestamp of the last access to the data." @synonyms "accessed, last modified, updated" = ""
  }

  trait AgentMemoryBrowse -> @rebindable AgentMemory [interaction, collection] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch AgentMemory {
          emit: { failure: AgentMemoryLoadFailed, success: AgentMemoryLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading memories…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      AgentMemoryLoaded -> browsing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: brain, type: icon }, {
                content: "AgentMemory Manager"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              children: [{
                action: MEMORIZE
                icon: plus
                label: Memorize
                type: button
                variant: primary
              }, {
                action: RECALL
                icon: search
                label: Recall
                type: button
                variant: secondary
              }, {
                action: DECAY
                icon: clock
                label: "Decay All"
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              type: stack
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            entity: ?data
            fields: [{
              icon: brain
              label: Content
              name: content
              variant: h4
            }, {
              label: Category
              name: category
              variant: badge
            }, {
              label: Strength
              name: strength
              variant: caption
            }]
            itemActions: [{
              event: PIN
              label: Pin
              variant: ghost
            }, {
              event: REINFORCE
              label: Reinforce
              variant: ghost
            }, {
              event: FORGET
              label: Forget
              variant: danger
            }]
            type: data-grid
          }]
          className: "max-w-5xl mx-auto w-full"
          direction: vertical
          gap: lg
          type: stack
        })
      AgentMemoryLoadFailed -> error
        (render-ui main {
          align: center
          children: [{
            color: error
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load memories"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state browsing {
      INIT -> loading
        (fetch AgentMemory {
          emit: { failure: AgentMemoryLoadFailed, success: AgentMemoryLoaded }
        })
        (render-ui main { type: spinner })
    }

    state error {
      INIT -> loading
        (fetch AgentMemory {
          emit: { failure: AgentMemoryLoadFailed, success: AgentMemoryLoaded }
        })
        (render-ui main { type: spinner })
    }

    emits {
      MEMORIZE
      RECALL
      DECAY
      PIN {
        id : string!
        row : AgentMemory
      }
      REINFORCE {
        id : string!
        row : AgentMemory
      }
      FORGET {
        id : string!
        row : AgentMemory
      }
      AgentMemoryLoaded
      AgentMemoryLoadFailed
    }

    listens {
      AgentMemoryAgent.MEMORIZED -> INIT
      AgentMemoryCreate.MEMORY_CREATED -> INIT
      AgentMemoryAgent.PINNED -> INIT
      AgentMemoryAgent.FORGOT -> INIT
      AgentMemoryAgent.REINFORCED -> INIT
      AgentMemoryAgent.DECAYED -> INIT
      PIN {
        id : string!
        row : AgentMemory
      }
      REINFORCE {
        id : string!
        row : AgentMemory
      }
      FORGET {
        id : string!
        row : AgentMemory
      }
      AgentMemoryLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait AgentMemoryCreate -> AgentMemory [interaction, instance] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch AgentMemory {
          emit: { failure: AgentMemoryLoadFailed, success: AgentMemoryLoaded }
        })
      MEMORIZE -> open
        (render-ui modal {
          children: [{
            children: [{ name: plus-circle, type: icon }, {
              content: Memorize
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            cancelEvent: CLOSE
            fields: (content category scope)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
        (notify Cancelled info)
      SAVE -> closed
        (persist create AgentMemory ?data {
          emit: { failure: AgentMemorySaveFailed, success: AgentMemorySaved }
        })
        (emit MEMORY_CREATED { id: ?data.id })
        (render-ui modal null)
        (render-ui main { type: box })
    }

    emits {
      MEMORY_CREATED -> external {
        id : string!
      }
      AgentMemoryLoaded
      AgentMemoryLoadFailed
      AgentMemorySaved
      AgentMemorySaveFailed
    }

    listens {
      SAVE {
        data : AgentMemory
      }
      AgentMemoryBrowse.MEMORIZE -> MEMORIZE
    }
  }

  trait AgentMemoryAgent -> AgentMemory [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch AgentMemory {
          emit: { failure: AgentMemoryLoadFailed, success: AgentMemoryLoaded }
        })
        (render-ui main {
          description: "Memory is ready"
          icon: brain
          title: Memory
          type: empty-state
        })
      DO_MEMORIZE -> active
        (agent/memorize ?data.content ?data.category)
        (persist create AgentMemory ?data {
          emit: { failure: AgentMemorySaveFailed, success: AgentMemorySaved }
        })
        (emit MEMORIZED { id: ?data.id })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED {
          id: ""
        })
      MEMORIZED -> active
        (fetch AgentMemory {
          emit: { failure: AgentMemoryLoadFailed, success: AgentMemoryLoaded }
        })
    }

    state active {
      RECALL -> active
        (agent/recall ?query)
      PIN -> active when (not (agent/is-pinned ?id))
        (agent/pin ?id)
        (emit PINNED { id: ?id })
      FORGET -> idle
        (agent/forget ?id)
        (emit FORGOT { id: ?id })
      REINFORCE -> active
        (agent/reinforce ?id)
        (emit REINFORCED { id: ?id })
      DECAY -> active
        (agent/decay)
        (emit DECAYED {
          id: ""
        })
    }

    emits {
      FORGOT -> external {
        id : string!
      }
      REINFORCED -> external {
        id : string!
      }
      DECAYED -> external {
        id : string!
      }
      PINNED -> external {
        id : string!
      }
      MEMORIZED -> external {
        id : string!
      }
      AgentMemoryLoaded
      AgentMemoryLoadFailed
      AgentMemorySaved
      AgentMemorySaveFailed
    }

    listens {
      DO_MEMORIZE {
        data : AgentMemory
      }
      RECALL {
        query : string!
      }
      PIN {
        id : string!
      }
      FORGET {
        id : string!
      }
      REINFORCE {
        id : string!
      }
      MEMORIZED {
        data : AgentMemory
      }
      AgentMemoryBrowse.RECALL -> RECALL
      AgentMemoryBrowse.DECAY -> DECAY
      AgentMemoryBrowse.PIN -> PIN
      AgentMemoryBrowse.REINFORCE -> REINFORCE
      AgentMemoryBrowse.FORGET -> FORGET
    }
  }

  page "/agentmemorys" as AgentMemoryPage -> AgentMemoryBrowse, AgentMemoryCreate, AgentMemoryAgent
}