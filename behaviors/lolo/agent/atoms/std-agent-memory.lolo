app std-agent-memory "1.0.0"
"std-agent-memory as a Function"

orbital AgentMemoryOrbital {
  entity AgentMemory [persistent: agentmemorys] {
    id             : string!
    name           : string @description "A human-readable identifier for the memory." @synonyms "label, identifier, title"
    description    : string @description "A textual explanation of the memory's purpose or contents." @synonyms "details, notes, explanation, summary"
    status         : "active" | "inactive" | "pending" @description "Current operational state of the component." @synonyms "state, condition, operational_status" = "active"
    createdAt      : string
    content        : string @description "The data stored within the memory." @synonyms "data, value, payload" = ""
    category       : string @description "Classification or type of the memory data." @synonyms "type, kind, class" = "general"
    strength       : number @description "A numerical value representing the intensity or magnitude." @synonyms "value, magnitude, level, intensity" = 1
    pinned         : boolean @description "Indicates whether the item is marked as important." @synonyms "flagged, marked, important" = false
    scope          : "session" | "persistent" | "shared" @description "Indicates the data's lifecycle and accessibility." @synonyms "lifetime, access, persistence" = "session"
    lastAccessedAt : string @description "Timestamp of the last access to the data." @synonyms "accessed, last modified, updated" = ""
  }

  type AgentMemoryLoaded     = Event { data : [AgentMemory] }        "Fired when the AgentMemory collection finishes loading; payload.data holds the list"
  type AgentMemoryLoadFailed = Event { error : string, code : string } "Fired when the AgentMemory collection fails to load"
  type AgentMemorySaved      = Event { id : string }                  "Fired when a new memory is persisted"
  type AgentMemorySaveFailed = Event { error : string, code : string } "Fired when persisting a memory fails"
  type Memorized             = Event { id : string }                  "Fired after an agent memory is created"
  type Pinned                = Event { id : string }                  "Fired after a memory is pinned"
  type Forgot                = Event { id : string }                  "Fired after a memory is forgotten"
  type Reinforced            = Event { id : string }                  "Fired after a memory is reinforced"
  type Decayed               = Event { id : string }                  "Fired after the decay sweep completes"

  trait AgentMemoryBrowse -> AgentMemory [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading memories…" }] })
      AgentMemoryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain" }, { type: "typography", content: "AgentMemory Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Memorize", action: "MEMORIZE", variant: "primary", icon: "plus" }, { type: "button", label: "Recall", action: "RECALL", variant: "secondary", icon: "search" }, { type: "button", label: "Decay All", action: "DECAY", variant: "ghost", icon: "clock" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Pin", event: "PIN", variant: "ghost" }, { label: "Reinforce", event: "REINFORCE", variant: "ghost" }, { label: "Forget", event: "FORGET", variant: "danger" }], fields: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge" }, { name: "strength", label: "Strength", variant: "caption" }] }] })
      AgentMemoryLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load memories" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      MEMORIZE
      RECALL
      DECAY
      PIN { id : string!, row : AgentMemory }
      REINFORCE { id : string!, row : AgentMemory }
      FORGET { id : string!, row : AgentMemory }
      AgentMemoryLoaded
      AgentMemoryLoadFailed
    }
    listens {
      AgentMemoryAgent.MEMORIZED -> INIT
      AgentMemoryCreate.MEMORY_CREATED -> INIT
      AgentMemoryAgent.PINNED -> INIT
      AgentMemoryAgent.FORGOT -> INIT
      AgentMemoryAgent.REINFORCED -> INIT
      AgentMemoryAgent.DECAYED -> INIT
      PIN { id : string!, row : AgentMemory }
      REINFORCE { id : string!, row : AgentMemory }
      FORGET { id : string!, row : AgentMemory }
      AgentMemoryLoadFailed { error : string, code : string }
    }
  }
  trait AgentMemoryCreate -> AgentMemory [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
      MEMORIZE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle" }, { type: "typography", content: "Memorize", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["content", "category", "scope"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create AgentMemory @payload.data { emit: { success: "AgentMemorySaved", failure: "AgentMemorySaveFailed" } })
        (emit MEMORY_CREATED { id: "@payload.data.id" })
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    emits {
      MEMORY_CREATED -> external { id : string! }
      AgentMemoryLoaded
      AgentMemoryLoadFailed
      AgentMemorySaved
      AgentMemorySaveFailed
    }
    listens {
      SAVE { data : AgentMemory }
      AgentMemoryBrowse.MEMORIZE -> MEMORIZE
    }
  }
  trait AgentMemoryAgent -> AgentMemory [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "brain", title: "Memory", description: "Memory is ready" })
      DO_MEMORIZE -> active
        (agent/memorize @payload.data.content @payload.data.category)
        (persist create AgentMemory @payload.data { emit: { success: "AgentMemorySaved", failure: "AgentMemorySaveFailed" } })
        (emit MEMORIZED { id: "@payload.data.id" })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED { id: "" })
      MEMORIZED -> active
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
    }
    state active {
      RECALL -> active
        (agent/recall @payload.query)
      PIN -> active when (not (agent/is-pinned @payload.id))
        (agent/pin @payload.id)
        (emit PINNED { id: "@payload.id" })
      FORGET -> idle
        (agent/forget @payload.id)
        (emit FORGOT { id: "@payload.id" })
      REINFORCE -> active
        (agent/reinforce @payload.id)
        (emit REINFORCED { id: "@payload.id" })
      DECAY -> active
        (agent/decay)
        (emit DECAYED { id: "" })
    }
    emits {
      FORGOT -> external { id : string! }
      REINFORCED -> external { id : string! }
      DECAYED -> external { id : string! }
      PINNED -> external { id : string! }
      MEMORIZED -> external { id : string! }
      AgentMemoryLoaded
      AgentMemoryLoadFailed
      AgentMemorySaved
      AgentMemorySaveFailed
    }
    listens {
      DO_MEMORIZE { data  : AgentMemory }
      RECALL      { query : string! }
      PIN         { id    : string! }
      FORGET      { id    : string! }
      REINFORCE   { id    : string! }
      MEMORIZED   { data  : AgentMemory }
      AgentMemoryBrowse.RECALL -> RECALL
      AgentMemoryBrowse.DECAY -> DECAY
      AgentMemoryBrowse.PIN -> PIN
      AgentMemoryBrowse.REINFORCE -> REINFORCE
      AgentMemoryBrowse.FORGET -> FORGET
    }
  }
  page "/agentmemorys" as AgentMemoryPage -> AgentMemoryBrowse, AgentMemoryCreate, AgentMemoryAgent
}
