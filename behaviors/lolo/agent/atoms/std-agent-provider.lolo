app std-agent-provider "1.0.0"
"std-agent-provider as a Function"

orbital AgentProviderOrbital {
  entity AgentProvider [persistent: agentproviders] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    currentProvider : string = "anthropic"
    currentModel : string = "claude-sonnet-4-20250514"
    fallbackProvider : string = "openai"
    requestCount : number = 0
    message : string = ""
    notificationType : "info" | "success" | "warning" | "error" = "info"
  }

  type AgentProviderLoaded     = Event AgentProvider                  "Fired when AgentProvider finishes loading"
  type AgentProviderLoadFailed = Event { message : string } "Fired when AgentProvider fails to load"
  type AgentProviderRowLoaded  = Event { row : AgentProvider } "Fired on modal open with the pre-fill row"
  type AgentProviderUpdated = Event { id : string }
  type AgentProviderUpdateFailed = Event { error : string, code : string }
  trait AgentProviderModal -> AgentProvider [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch AgentProvider { emit: { success: "AgentProviderLoaded", failure: "AgentProviderLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", action: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      SWITCH -> loading
        (fetch AgentProvider { emit: { success: "AgentProviderRowLoaded", failure: "AgentProviderLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
    }
    state loading {
      AgentProviderRowLoaded -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Switch Provider", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Current:" }, { type: "badge", label: "@entity.currentProvider" }, { type: "badge", label: "@entity.currentModel" }] }, { type: "form-section", entity: @payload.row, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["currentProvider", "currentModel"] }] })
      AgentProviderLoadFailed -> closed
        (render-ui modal null)
        (notify "Failed to load provider" error)
        (fetch AgentProvider { emit: { success: "AgentProviderLoaded", failure: "AgentProviderLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", action: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch AgentProvider { emit: { success: "AgentProviderLoaded", failure: "AgentProviderLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", action: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      SAVE -> closed
        (persist update AgentProvider @payload.data { emit: { success: "AgentProviderUpdated", failure: "AgentProviderUpdateFailed" } })
        (render-ui modal null)
        (emit SWITCHED)
        (fetch AgentProvider { emit: { success: "AgentProviderLoaded", failure: "AgentProviderLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", action: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
    }
    emits {
      SWITCHED -> external { id: string }
      AgentProviderLoaded
      AgentProviderLoadFailed
      AgentProviderRowLoaded
      AgentProviderUpdated
      AgentProviderUpdateFailed
    }
    listens {
      SAVE { data : object! }
          AgentProviderLoadFailed { message : string }

      AgentProviderUpdateFailed { error : string, code : string }
    }
  }
  trait AgentProviderNotification -> AgentProvider [interaction, instance] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch AgentProvider { emit: { success: "AgentProviderLoaded", failure: "AgentProviderLoadFailed" } })
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "server"}, { type: "typography", content: "Provider Status", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "server"}, { type: "typography", content: "Provider Status", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] })
      HIDE -> hidden
        (set @entity.message "")
    }
emits {
      AgentProviderLoaded
      AgentProviderLoadFailed
    }

        listens {
      SHOW { message : string!, notificationType : "info" | "success" | "warning" | "error" }
          AgentProviderLoadFailed { message : string }
    }
  }
  trait AgentProviderAgent -> AgentProvider [interaction, instance] {
    initial: idle
    state idle {
      INIT -> active
        (fetch AgentProvider { emit: { success: "AgentProviderLoaded", failure: "AgentProviderLoadFailed" } })
        (agent/provider)
        (agent/model)
        (render-ui main { type: "empty-state", icon: "repeat", title: "Provider", description: "Provider is ready" })
      DO_SWITCH -> switching
        (agent/switch-provider @payload.data.currentProvider @payload.data.currentModel)
        (set @entity.currentProvider @payload.data.currentProvider)
        (set @entity.currentModel @payload.data.currentModel)
    }
    state active {
      DO_SWITCH -> switching
        (agent/switch-provider @payload.data.currentProvider @payload.data.currentModel)
        (set @entity.currentProvider @payload.data.currentProvider)
        (set @entity.currentModel @payload.data.currentModel)
      SWITCHED -> switching
        (agent/switch-provider @entity.currentProvider @entity.currentModel)
      SWITCH_AUTO -> switching
        (agent/switch-provider @entity.fallbackProvider)
        (set @entity.currentProvider @entity.fallbackProvider)
    }
    state switching {
      INIT -> active
        (agent/provider)
        (agent/model)
        (set @entity.requestCount (+ @entity.requestCount 1))
        (emit SHOW { message: "Provider switched", notificationType: "info" })
    }
    emits {
      SHOW -> internal { message: string!, notificationType: "info" | "success" | "warning" | "error" }
      AgentProviderLoaded
      AgentProviderLoadFailed
    }
    listens {
      AgentProviderModal.SWITCHED -> SWITCHED
      DO_SWITCH { data : object! }
          AgentProviderLoadFailed { message : string }
    }
  }
  page "/agentproviders" as AgentProviderPage -> AgentProviderModal, AgentProviderNotification, AgentProviderAgent
}