app std-agent-conversation "1.0.0"
"std-agent-conversation as a Function"

orbital AgentConversationOrbital {
  entity AgentConversation [persistent: agentconversations] {
    id          : string!
    name        : string
    description : string
    status      : "active" | "inactive" | "pending" | "sent" = "active"
    createdAt   : string
    messages    : [string] = []
    turnCount   : number = 0
    lastMessage : string = ""
    tokenCount  : number = 0
    role        : "user" | "assistant" | "system" | "tool" = "user"
    content     : string = ""
    timestamp   : string = ""
    toolName    : string = ""
  }

  type AgentConversationLoaded       = Event { data : [AgentConversation] }      "Fired when conversation finishes loading; payload.data holds the turns"
  type AgentConversationLoadFailed   = Event { error : string, code : string }  "Fired when conversation fails to load"
  type AgentConversationSaved        = Event { id : string }                    "Fired when a new turn is persisted"
  type AgentConversationSaveFailed   = Event { error : string, code : string }  "Fired when persisting a turn fails"
  type AgentConversationDeleted      = Event { id : string }                    "Fired when the conversation is cleared"
  type AgentConversationDeleteFailed = Event { error : string, code : string }  "Fired when clearing the conversation fails"

  trait AgentConversationThread -> AgentConversation [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch AgentConversation { emit: { success: "AgentConversationLoaded", failure: "AgentConversationLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading conversation…" }] })
      AgentConversationLoaded -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "Conversation Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "secondary" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }] })
      AgentConversationLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state idle {
      COMPOSE -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "Conversation Thread", variant: "h2" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SEND", cancelEvent: "CANCEL_COMPOSE", fields: ["content"] }] })
      CLEAR -> deleting
        (persist delete AgentConversation { emit: { success: "AgentConversationDeleted", failure: "AgentConversationDeleteFailed" } })
        (render-ui main { type: "spinner" })
    }
    state composing {
      SEND -> persisting
        (persist create AgentConversation { role: "user", content: "@payload.content", timestamp: "@now", status: "sent" } { emit: { success: "AgentConversationSaved", failure: "AgentConversationSaveFailed" } })
        (render-ui main { type: "spinner" })
      CANCEL_COMPOSE -> loading
        (fetch AgentConversation { emit: { success: "AgentConversationLoaded", failure: "AgentConversationLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state persisting {
      AgentConversationSaved -> loading
        (fetch AgentConversation { emit: { success: "AgentConversationLoaded", failure: "AgentConversationLoadFailed" } })
        (render-ui main { type: "spinner" })
      AgentConversationSaveFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to send" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state deleting {
      AgentConversationDeleted -> loading
        (fetch AgentConversation { emit: { success: "AgentConversationLoaded", failure: "AgentConversationLoadFailed" } })
        (render-ui main { type: "spinner" })
      AgentConversationDeleteFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to clear" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state error {
      INIT -> loading
        (fetch AgentConversation { emit: { success: "AgentConversationLoaded", failure: "AgentConversationLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits: [AgentConversationLoaded, AgentConversationLoadFailed, AgentConversationSaved, AgentConversationSaveFailed, AgentConversationDeleted, AgentConversationDeleteFailed]
    listens {
      SEND { content : string! }
      AgentConversationLoadFailed { error : string, code : string }
      AgentConversationSaveFailed { error : string, code : string }
      AgentConversationDeleteFailed { error : string, code : string }
    }
  }

  trait AgentConversationAgent -> AgentConversation [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentConversation { emit: { success: "AgentConversationLoaded", failure: "AgentConversationLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "message-circle", title: "Conversation", description: "Conversation is ready" })
      SEND_MESSAGE -> active
        (agent/generate @payload.content)
        (emit TOKEN_UPDATE { tokenCount: 0 })
    }
    state active {
      SEND_MESSAGE -> active
        (agent/generate @payload.content)
        (emit TOKEN_UPDATE { tokenCount: 0 })
      PAUSE -> paused
      CLEAR -> idle
    }
    state paused {
      RESUME -> active
      CLEAR -> idle
    }
    emits {
      TOKEN_UPDATE internal { tokenCount : number! }
    }
    emits: [AgentConversationLoaded, AgentConversationLoadFailed]
    listens {
      SEND_MESSAGE { content : string! }
      TOKEN_UPDATE { tokenCount : number! }
      AgentConversationLoadFailed { error : string, code : string }
    }
  }

  page "/agentconversations" as AgentConversationPage -> AgentConversationThread, AgentConversationAgent
}
