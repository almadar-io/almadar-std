app std-agent-tutor "1.0.0"
"std-agent-tutor as a Function"

orbital TutorSessionOrbital {
  uses Browse from "std/behaviors/std-browse"
  uses Tabs from "std/behaviors/std-tabs"

  entity TutorSession [runtime] {
    id : string!
    topic : string = ""
    studentLevel : string = "unknown"
    explanation : string = ""
    questionsAsked : number = 0
    correctAnswers : number = 0
    sessionStatus : string = "idle"
    error : string = ""
  }

  type TutorSessionLoaded     = Event { data : [TutorSession] }                  "Fired when TutorSession finishes loading"
  type TutorSessionLoadFailed = Event { error : string, code : string } "Fired when TutorSession fails to load"
  type TutorChatDeleted = Event { id : string }
  type TutorChatDeleteFailed = Event { error : string, code : string }
  type ConceptSaved = Event { id : string }
  type ConceptSaveFailed = Event { error : string, code : string }
  type StudentAssessmentSaved = Event { id : string }
  type StudentAssessmentSaveFailed = Event { error : string, code : string }
  trait TeachingSession -> TutorSession [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch TutorSession { emit: { success: "TutorSessionLoaded", failure: "TutorSessionLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "graduation-cap"}, { type: "typography", content: "Tutor", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "What topic would you like to learn about? The tutor will assess your level and guide you through it.", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "START_SESSION", fields: ["topic"] }] }] }] }] })
      START_SESSION -> assessing
        (set @entity.topic @payload.topic)
        (set @entity.sessionStatus assessing)
        (agent/recall @payload.topic)
        (agent/generate @payload.topic)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search"}, { type: "typography", content: "Assessing your level...", variant: "h3" }, { type: "spinner"}, { type: "typography", content: "Recalling prior learning and classifying skill level", variant: "caption" }] }] })
    }
    state assessing {
      ASSESSMENT_COMPLETE -> teaching
        (set @entity.sessionStatus teaching)
        (agent/memorize @entity.topic student-level)
        (emit ASSESSMENT_DONE)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "book-open"}, { type: "typography", content: "Lesson: @entity.topic", variant: "h2" }] }, { type: "badge", label: "@entity.studentLevel" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@entity.explanation", variant: "body" }] }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Quiz Me", action: "START_QUIZ", variant: "primary", icon: "help-circle" }, { type: "button", label: "Explain More", action: "EXPLAIN_MORE", variant: "secondary", icon: "book-open" }, { type: "button", label: "New Topic", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "stack", direction: "horizontal", gap: "xs", children: [{ type: "badge", label: "@entity.questionsAsked" }, { type: "badge", label: "@entity.correctAnswers" }] }] }] })
    }
    state teaching {
      EXPLAIN_MORE -> teaching
        (agent/generate @entity.topic)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "book-open"}, { type: "typography", content: "Lesson: @entity.topic", variant: "h2" }] }, { type: "badge", label: "@entity.studentLevel" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@entity.explanation", variant: "body" }] }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Quiz Me", action: "START_QUIZ", variant: "primary", icon: "help-circle" }, { type: "button", label: "Explain More", action: "EXPLAIN_MORE", variant: "secondary", icon: "book-open" }, { type: "button", label: "New Topic", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "stack", direction: "horizontal", gap: "xs", children: [{ type: "badge", label: "@entity.questionsAsked" }, { type: "badge", label: "@entity.correctAnswers" }] }] }] })
      START_QUIZ -> teaching
        (emit ASSESSMENT_DONE)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "book-open"}, { type: "typography", content: "Lesson: @entity.topic", variant: "h2" }] }, { type: "badge", label: "@entity.studentLevel" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@entity.explanation", variant: "body" }] }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Quiz Me", action: "START_QUIZ", variant: "primary", icon: "help-circle" }, { type: "button", label: "Explain More", action: "EXPLAIN_MORE", variant: "secondary", icon: "book-open" }, { type: "button", label: "New Topic", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "stack", direction: "horizontal", gap: "xs", children: [{ type: "badge", label: "@entity.questionsAsked" }, { type: "badge", label: "@entity.correctAnswers" }] }] }] })
      RESET -> idle
        (set @entity.sessionStatus idle)
        (set @entity.topic "")
        (set @entity.explanation "")
        (set @entity.questionsAsked 0)
        (set @entity.correctAnswers 0)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "graduation-cap"}, { type: "typography", content: "Tutor", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "What topic would you like to learn about? The tutor will assess your level and guide you through it.", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "START_SESSION", fields: ["topic"] }] }] }] }] })
    }
    emits {
      ASSESSMENT_DONE internal { level: string }
      ASSESSMENT_DONE external { level: string }
    }
    listens {
      START_SESSION { topic : string! }
          TutorSessionLoadFailed { error : string, code : string }
    
      TutorChatDeleteFailed { error : string, code : string }
      ConceptSaveFailed { error : string, code : string }
      StudentAssessmentSaveFailed { error : string, code : string }
    }
    emits: [TutorSessionLoaded, TutorSessionLoadFailed, TutorChatDeleted, TutorChatDeleteFailed, ConceptSaved, ConceptSaveFailed, StudentAssessmentSaved, StudentAssessmentSaveFailed]
  }
  page "/teach" as TeachPage -> TeachingSession
}
orbital QuizQuestionOrbital {
  entity QuizQuestion [runtime] {
    id : string!
    question : string
    options : string
    correctAnswer : string
    studentAnswer : string
    isCorrect : boolean
    feedback : string
    quizStatus : string
  }

  type QuizQuestionLoaded     = Event { data : [QuizQuestion] }                  "Fired when QuizQuestion finishes loading"
  type QuizQuestionLoadFailed = Event { error : string, code : string } "Fired when QuizQuestion fails to load"
  trait QuizEngine -> QuizQuestion [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch QuizQuestion { emit: { success: "QuizQuestionLoaded", failure: "QuizQuestionLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle"}, { type: "typography", content: "Quiz", variant: "h2" }] }, { type: "divider" }, { type: "typography", content: "Waiting for a quiz to start...", variant: "body" }] }] })
      GENERATE_QUESTION -> quizzing
        (set @entity.quizStatus generating)
        (agent/generate @entity.question)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle"}, { type: "typography", content: "Quiz Question", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@entity.question", variant: "h3" }, { type: "typography", content: "@entity.options", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SUBMIT_ANSWER", fields: ["studentAnswer"] }] }] }] }] })
    }
    state quizzing {
      QUESTION_READY -> quizzing
        (set @entity.quizStatus waiting)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle"}, { type: "typography", content: "Quiz Question", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@entity.question", variant: "h3" }, { type: "typography", content: "@entity.options", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SUBMIT_ANSWER", fields: ["studentAnswer"] }] }] }] }] })
      SUBMIT_ANSWER -> reviewing
        (set @entity.studentAnswer @payload.studentAnswer)
        (set @entity.quizStatus grading)
        (agent/generate @payload.studentAnswer)
        (emit QUIZ_GRADED)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Answer Review", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.isCorrect" }] }, { type: "typography", content: "@entity.feedback", variant: "body" }, { type: "typography", content: "Correct answer", variant: "caption" }, { type: "typography", content: "@entity.correctAnswer", variant: "body" }] }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Next Question", action: "NEXT_QUESTION", variant: "primary", icon: "arrow-right" }, { type: "button", label: "Back to Lesson", action: "BACK_TO_LESSON", variant: "ghost", icon: "book-open" }] }] }] })
    }
    state reviewing {
      NEXT_QUESTION -> quizzing
        (set @entity.quizStatus generating)
        (set @entity.studentAnswer "")
        (set @entity.feedback "")
        (agent/generate @entity.question)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle"}, { type: "typography", content: "Quiz Question", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@entity.question", variant: "h3" }, { type: "typography", content: "@entity.options", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SUBMIT_ANSWER", fields: ["studentAnswer"] }] }] }] }] })
      BACK_TO_LESSON -> idle
        (set @entity.quizStatus idle)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "help-circle"}, { type: "typography", content: "Quiz", variant: "h2" }] }, { type: "divider" }, { type: "typography", content: "Waiting for a quiz to start...", variant: "body" }] }] })
    }
    emits {
      QUIZ_GRADED internal { correct: boolean }
      QUIZ_GRADED external { correct: boolean }
    }
    listens {
      * ASSESSMENT_DONE -> GENERATE_QUESTION
          QuizQuestionLoadFailed { error : string, code : string }
          SUBMIT_ANSWER { studentAnswer : string }
    }
    emits: [QuizQuestionLoaded, QuizQuestionLoadFailed]
  }
  page "/quiz" -> QuizEngine
}
orbital TutorChatOrbital {
  entity TutorChat [runtime] {
    id : string!
    messages : [string]
    turnCount : number
    lastMessage : string
    tokenCount : number
    role : string
    content : string
    timestamp : string
    toolName : string
    status : string
  }

  type TutorChatLoaded     = Event { data : [TutorChat] }                  "Fired when TutorChat finishes loading"
  type TutorChatLoadFailed = Event { error : string, code : string } "Fired when TutorChat fails to load"
  type TutorChatDeleteFailed = Event { error : string, code : string }
  type TutorChatDeleted = Event { id : string }
  trait TutorConversation -> TutorChat [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch TutorChat { emit: { success: "TutorChatLoaded", failure: "TutorChatLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      TutorChatLoaded -> idle
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle"}, { type: "typography", content: "TutorChat Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "outline" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }] }] })
      TutorChatLoadFailed -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load tutorchat" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
      COMPOSE -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "TutorChat Thread", variant: "h2" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SEND", cancelEvent: "CANCEL_COMPOSE", fields: ["content"] }] })
      CLEAR -> idle
        (persist delete TutorChat { emit: { success: "TutorChatDeleted", failure: "TutorChatDeleteFailed" } })
        (fetch TutorChat { emit: { success: "TutorChatLoaded", failure: "TutorChatLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state composing {
      SEND -> idle
        (persist create TutorChat { role: "user", content: "@payload.content", timestamp: "@now", status: "sent" } { emit: { success: "SEND_MESSAGE" } })
        (fetch TutorChat { emit: { success: "TutorChatLoaded", failure: "TutorChatLoadFailed" } })
        (render-ui main { type: "spinner" })
      CANCEL_COMPOSE -> idle
        (fetch TutorChat { emit: { success: "TutorChatLoaded", failure: "TutorChatLoadFailed" } })
        (render-ui main { type: "spinner" })
      CLEAR -> idle
        (persist delete TutorChat { emit: { success: "TutorChatDeleted", failure: "TutorChatDeleteFailed" } })
        (fetch TutorChat { emit: { success: "TutorChatLoaded", failure: "TutorChatLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      SEND_MESSAGE internal { content: string }
    }
    emits: [TutorChatDeleteFailed, TutorChatDeleted, TutorChatLoadFailed, TutorChatLoaded]
    listens {
      TutorChatLoadFailed { error : string, code : string }
      SEND { content : string }
    }
  }
  trait TutorChatAgent -> TutorChat [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch TutorChat { emit: { success: "TutorChatLoaded", failure: "TutorChatLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "empty-state", icon: "message-circle", title: "Conversation", description: "Conversation is ready" }] })
      SEND_MESSAGE -> active
        (set @entity.lastMessage @payload.content)
        (set @entity.turnCount (+ @entity.turnCount 1))
        (agent/generate @payload.content)
        (emit TOKEN_UPDATE)
    }
    state active {
      SEND_MESSAGE -> active
        (set @entity.lastMessage @payload.content)
        (set @entity.turnCount (+ @entity.turnCount 1))
        (agent/generate @payload.content)
        (emit TOKEN_UPDATE)
      PAUSE -> paused
      CLEAR -> idle
        (set @entity.messages [])
        (set @entity.turnCount 0)
        (set @entity.lastMessage "")
        (set @entity.tokenCount 0)
    }
    state paused {
      RESUME -> active
      CLEAR -> idle
        (set @entity.messages [])
        (set @entity.turnCount 0)
        (set @entity.lastMessage "")
        (set @entity.tokenCount 0)
    }
    emits {
      TOKEN_UPDATE internal { tokenCount: number }
    }
    emits: [TutorChatLoaded, TutorChatLoadFailed]
    listens {
      TutorChatLoadFailed { error : string, code : string }
      SEND_MESSAGE { content : string }
    }
  }
  page "/chat" -> TutorConversation
}
orbital ConceptOrbital {
  entity Concept [persistent: concepts] {
    id : string!
    content : string
    category : string
    strength : number
    pinned : boolean
    scope : string
    lastAccessedAt : string
    createdAt : string
  }

  type ConceptLoaded     = Event { data : [Concept] }                  "Fired when Concept finishes loading"
  type ConceptLoadFailed = Event { error : string, code : string } "Fired when Concept fails to load"
  type ConceptSaveFailed = Event { error : string, code : string }
  type ConceptSaved = Event { id : string }
  trait ConceptBrowse -> Concept [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Concept { emit: { success: "ConceptLoaded", failure: "ConceptLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      ConceptLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "Concept Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Memorize", action: "MEMORIZE", variant: "primary", icon: "plus" }, { type: "button", label: "Recall", action: "RECALL", variant: "secondary", icon: "search" }, { type: "button", label: "Decay All", action: "DECAY", variant: "ghost", icon: "clock" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Pin", event: "PIN", variant: "ghost"}, { label: "Reinforce", event: "REINFORCE", variant: "ghost"}, { label: "Forget", event: "FORGET", variant: "danger"}], fields: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "strength", label: "Strength", variant: "caption" }] }] }] })
      ConceptLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load concept" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    listens {
      ConceptCreate MEMORIZED -> INIT
      ConceptAgent PINNED -> INIT
      ConceptAgent FORGOT -> INIT
      ConceptAgent REINFORCED -> INIT
      ConceptAgent DECAYED -> INIT
          ConceptLoadFailed { error : string, code : string }
    }
    emits: [ConceptLoaded, ConceptLoadFailed]
  }
  trait ConceptCreate -> Concept [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Concept { emit: { success: "ConceptLoaded", failure: "ConceptLoadFailed" } })
      MEMORIZE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle"}, { type: "typography", content: "Memorize", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["content", "category", "scope"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Concept @payload.data { emit: { success: "ConceptSaved", failure: "ConceptSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit MEMORIZED)
    }
    emits {
      MEMORIZED
    }
    emits: [ConceptLoadFailed, ConceptLoaded, ConceptSaveFailed, ConceptSaved]
    listens {
      ConceptLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait ConceptAgent -> Concept [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Concept { emit: { success: "ConceptLoaded", failure: "ConceptLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "empty-state", icon: "brain", title: "Memory", description: "Memory is ready" }] })
      DO_MEMORIZE -> active
        (agent/memorize @payload.data.content @payload.data.category)
        (persist create Concept @payload.data { emit: { success: "ConceptSaved", failure: "ConceptSaveFailed" } })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED)
      MEMORIZED -> active
        (fetch Concept { emit: { success: "ConceptLoaded", failure: "ConceptLoadFailed" } })
    }
    state active {
      RECALL -> active
        (agent/recall @payload.query)
      PIN -> active when (not (agent/is-pinned @payload.id))
        (agent/pin @payload.id)
        (set @entity.pinned true)
        (emit PINNED)
      FORGET -> idle
        (agent/forget @payload.id)
        (emit FORGOT)
      REINFORCE -> active
        (agent/reinforce @payload.id)
        (emit REINFORCED)
      DECAY -> active
        (agent/decay)
        (emit DECAYED)
    }
    emits {
      FORGOT external { id: string }
      REINFORCED external { id: string }
      DECAYED external { id: string }
      PINNED external { id: string }
    }
    listens {
      * QUIZ_GRADED -> REINFORCE
          ConceptLoadFailed { error : string, code : string }
          DO_MEMORIZE { data : string }
          RECALL { query : string }
          PIN { id : string }
          FORGET { id : string }
          REINFORCE { id : string }
    }
    emits: [ConceptLoadFailed, ConceptLoaded, ConceptSaveFailed, ConceptSaved]
  }
  page "/concepts" -> ConceptBrowse, ConceptCreate, ConceptAgent
}
orbital StudentAssessmentOrbital {
  entity StudentAssessment [runtime] {
    id : string!
    input : string
    category : string
    confidence : number
    model : string
    message : string
    notificationType : string
  }

  type StudentAssessmentLoaded     = Event { data : [StudentAssessment] }                  "Fired when StudentAssessment finishes loading"
  type StudentAssessmentLoadFailed = Event { error : string, code : string } "Fired when StudentAssessment fails to load"
  type StudentAssessmentSaveFailed = Event { error : string, code : string }
  type StudentAssessmentSaved = Event { id : string }
  trait LevelClassifier -> StudentAssessment [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch StudentAssessment { emit: { success: "StudentAssessmentLoaded", failure: "StudentAssessmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "StudentAssessment", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      CLASSIFY -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "StudentAssessment", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "typography", variant: "caption", content: "Categories:" }, { type: "badge", label: "beginner", variant: "secondary" }, { type: "badge", label: "intermediate", variant: "secondary" }, { type: "badge", label: "advanced", variant: "secondary" }, { type: "badge", label: "expert", variant: "secondary" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["input"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch StudentAssessment { emit: { success: "StudentAssessmentLoaded", failure: "StudentAssessmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "StudentAssessment", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create StudentAssessment @payload.data { emit: { success: "StudentAssessmentSaved", failure: "StudentAssessmentSaveFailed" } })
        (render-ui modal null)
        (emit CLASSIFIED)
        (fetch StudentAssessment { emit: { success: "StudentAssessmentLoaded", failure: "StudentAssessmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "StudentAssessment", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      CLASSIFIED
    }
    emits: [StudentAssessmentLoadFailed, StudentAssessmentLoaded, StudentAssessmentSaveFailed, StudentAssessmentSaved]
    listens {
      StudentAssessmentLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait StudentAssessmentNotification -> StudentAssessment [interaction, collection] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch StudentAssessment { emit: { success: "StudentAssessmentLoaded", failure: "StudentAssessmentLoadFailed" } })
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "StudentAssessment Result", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "StudentAssessment Result", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] }] })
      HIDE -> hidden
        (set @entity.message "")
    }
    emits: [StudentAssessmentLoaded, StudentAssessmentLoadFailed]
    listens {
      StudentAssessmentLoadFailed { error : string, code : string }
      SHOW { message : string, notificationType : string }
    }
  }
  trait StudentAssessmentAgent -> StudentAssessment [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch StudentAssessment { emit: { success: "StudentAssessmentLoaded", failure: "StudentAssessmentLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "AI Tutor", navItems: [{ label: "Teach", href: "/teach", icon: "book-open" }, { label: "Quiz", href: "/quiz", icon: "help-circle" }, { label: "Concepts", href: "/concepts", icon: "brain" }], children: [{ type: "empty-state", icon: "tag", title: "Classifier", description: "Classifier is ready" }] })
      DO_CLASSIFY -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "beginner, intermediate, advanced, expert" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
      CLASSIFIED -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "beginner, intermediate, advanced, expert" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
    }
    state classifying {
      DO_CLASSIFY -> classified
        (set @entity.category @payload.data.input)
        (emit SHOW)
    }
    state classified {
      RESET -> idle
        (set @entity.input "")
        (set @entity.category "")
        (set @entity.confidence 0)
    }
    emits {
      SHOW internal { category: string, confidence: number }
    }
    listens {
      LevelClassifier CLASSIFIED -> CLASSIFIED
          StudentAssessmentLoadFailed { error : string, code : string }
          DO_CLASSIFY { data : string }
    }
    emits: [StudentAssessmentLoaded, StudentAssessmentLoadFailed]
  }
  page "/assessment" -> LevelClassifier
}
orbital TutorNavOrbital {
  uses Tabs from "std/behaviors/std-tabs"

  entity TutorNav [runtime] {
    id : string!
    topic : string = ""
    studentLevel : string = "unknown"
    explanation : string = ""
    questionsAsked : number = 0
    correctAnswers : number = 0
    sessionStatus : string = "idle"
    error : string = ""
  }
  trait TutorTabs = Tabs.traits.TabContentTabs -> TutorSession {
  }
  page "/tutor/nav" -> TutorTabs
}
orbital ConceptViewOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity ConceptView [persistent: conceptviews] {
    id : string!
    content : string
    category : string
    strength : number
  }
  trait ConceptsBrowse = Browse.traits.BrowseItemBrowse -> Concept {
  }
  page "/tutor/concepts" -> ConceptsBrowse
}
