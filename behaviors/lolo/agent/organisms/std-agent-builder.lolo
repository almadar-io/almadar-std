        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      COMPACT -> normal
        (agent/compact)
        (set @entity.lastCompactedAt @now)
        (agent/token-count)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      RESET -> normal
        (set @entity.current 0)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    emits {
      RESET
      BuildLoopLoaded
      BuildLoopLoadFailed
    }
    listens {
      BuildLoopLoadFailed { error : string, code : string }
      UPDATE { current : number }
      SchemaBuilder.RESET -> RESET
      ToolLoopStepProgress.RESET -> RESET
    }
  }
  page "/build" -> SchemaBuilder
}
orbital BuildFixOrbital {
  entity BuildFix [runtime] {
    id : string!
    target : string @description "The intended destination or recipient of an action." @synonyms "destination, recipient, target, endpoint"
    validationErrors : string @description "A textual description of validation issues." @synonyms "errors, issues, problems, faults"
    fixAttempts : number @description "The number of times a fix has been attempted." @synonyms "attempts, retries, fixCount"
    maxAttempts : number @description "The maximum number of attempts allowed." @synonyms "limit, retries, count"
    status : string @description "Indicates the current state or condition of the item." @synonyms "state, condition, progress" = "idle"
    currentFix : string @description "The current attempt to resolve an issue." @synonyms "fix, correction, remediation"
    errorCount : number @description "The number of errors encountered." @synonyms "error number, errors, count"
    error : string @description "A textual description of an error or failure." @synonyms "failure, problem, issue, message" = ""
    currentStep : number @description "The index of the step currently being processed." @synonyms "step number, step index, current iteration"
    totalSteps : number @description "The total number of steps involved in the plan." @synonyms "count, number, size, length"
    steps : string @description "Ordered sequence of actions to achieve a goal." @synonyms "sequence, order, steps, procedure" = ""
    toolName : string @description "The name of the tool used to perform a task." @synonyms "tool, application, program"
    args : string @description "Arguments passed to a function or process." @synonyms "parameters, inputs, arguments, values"
    result : string @description "The outcome or output of a process or operation." @synonyms "output, outcome, value, return"
    prompt : string @description "The text used to initiate or guide a process." @synonyms "query, instruction, request, input" = ""
    response : string @description "The text output generated by a language model." @synonyms "output, text, answer, result" = ""
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, supplier" = "anthropic"
    model : string @description "The underlying data model used for this plan." @synonyms "schema, definition, structure" = "claude-sonnet-4-20250514"
  }

  type BuildFixLoaded     = Event { data : [BuildFix] }                  "Fired when BuildFix finishes loading"
  type BuildFixLoadFailed = Event { error : string, code : string } "Fired when BuildFix fails to load"
  type BuildFixSaveFailed = Event { error : string, code : string }
  type BuildFixSaved = Event { id : string }
  trait FixLoop -> BuildFix [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.maxAttempts 0)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wrench"}, { type: "typography", content: "Validation-Fix Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter the target to validate and auto-fix", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "FIX", fields: ["target"] }] }] }] }] })
      FIX -> validating
        (set @entity.status validating)
        (set @entity.fixAttempts 0)
        (set @entity.validationErrors "")
        (set @entity.errorCount 0)
        (agent/invoke validate-schema { target: "@entity.target" })
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield-check"}, { type: "typography", content: "Validating...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "@entity.target" }, { type: "badge", label: "@entity.maxAttempts" }] }] }] })
    }
    state validating {
      VALIDATION_PASSED -> succeeded
        (set @entity.status succeeded)
        (emit FIX_SUCCEEDED)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Validation Passed", variant: "h2" }] }, { type: "button", label: "New Target", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Fix Attempts", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Status", value: "Passed", icon: "check" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Target", variant: "caption" }, { type: "typography", content: "@entity.target", variant: "body" }] }] }] }] })
      VALIDATION_ERRORS -> fixing
        (set @entity.validationErrors @payload.errors)
        (set @entity.errorCount @payload.count)
        (set @entity.fixAttempts (+ @entity.fixAttempts 1))
        (set @entity.status fixing)
        (agent/generate (str/concat "Target: " @entity.target "\n\nValidation errors:\n" @payload.errors "\n\nGenerate a fix that resolves these errors. Return only the fix content."))
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Generating fix...", variant: "h2" }] }, { type: "badge", label: "@entity.fixAttempts" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Validation Errors", variant: "caption" }, { type: "alert", variant: "error", message: "@entity.validationErrors" }] }] }, { type: "spinner"}] }] })
      EXCEEDED_ATTEMPTS -> failed
        (set @entity.status failed)
        (set @entity.error @payload.error)
        (emit FIX_FAILED)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Fix Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Attempts Used", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Remaining Errors", value: "@entity.errorCount", icon: "alert-triangle" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Validation Errors", variant: "caption" }, { type: "typography", content: "@entity.validationErrors", variant: "body" }] }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state fixing {
      FIX_GENERATED -> applying
        (set @entity.currentFix @payload.fix)
        (set @entity.status applying)
        (agent/invoke apply-fix { target: "@entity.target", fix: "@payload.fix" })
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "tool"}, { type: "typography", content: "Applying fix...", variant: "h3" }, { type: "spinner"}, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Proposed Fix", variant: "caption" }, { type: "typography", content: "@entity.currentFix", variant: "body" }] }] }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (emit FIX_FAILED)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Fix Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Attempts Used", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Remaining Errors", value: "@entity.errorCount", icon: "alert-triangle" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Validation Errors", variant: "caption" }, { type: "typography", content: "@entity.validationErrors", variant: "body" }] }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state applying {
      FIX_APPLIED -> validating
        (set @entity.status validating)
        (agent/invoke validate-schema { target: "@entity.target" })
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield-check"}, { type: "typography", content: "Validating...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "@entity.target" }, { type: "badge", label: "@entity.maxAttempts" }] }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (emit FIX_FAILED)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Fix Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Attempts Used", value: "@entity.fixAttempts", icon: "wrench" }, { type: "stat-display", label: "Remaining Errors", value: "@entity.errorCount", icon: "alert-triangle" }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Validation Errors", variant: "caption" }, { type: "typography", content: "@entity.validationErrors", variant: "body" }] }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state succeeded {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.target "")
        (set @entity.validationErrors "")
        (set @entity.currentFix "")
        (set @entity.fixAttempts 0)
        (set @entity.errorCount 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wrench"}, { type: "typography", content: "Validation-Fix Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter the target to validate and auto-fix", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "FIX", fields: ["target"] }] }] }] }] })
    }
    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.target "")
        (set @entity.validationErrors "")
        (set @entity.currentFix "")
        (set @entity.fixAttempts 0)
        (set @entity.errorCount 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wrench"}, { type: "typography", content: "Validation-Fix Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter the target to validate and auto-fix", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "FIX", fields: ["target"] }] }] }] }] })
    }
    emits {
      FIX_SUCCEEDED -> external { target: string }
      FIX_FAILED -> external { target: string, error: string }
      RESET
    }
    listens {
      FixLoop.FIX_SUCCEEDED -> INIT
      FixLoop.FIX_FAILED -> INIT
      BuildLoopOrbital.SchemaBuilder.TOOL_LOOP_DONE -> FIX
          VALIDATION_ERRORS { errors : string, count : number }
          EXCEEDED_ATTEMPTS { error : string }
          FIX_GENERATED { fix : string }
          FAILED { error : string }
      FixLoopStepProgress.RESET -> RESET
    }
  }
  trait FixLoopStepProgress -> BuildFix [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.totalSteps 0)
        (fetch BuildFix { emit: { success: "BuildFixLoaded", failure: "BuildFixLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "BuildFix", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Validate" }, { id: "1", title: "Analyze" }, { id: "2", title: "Fix" }, { id: "3", title: "Re-validate" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] }] })
      START -> in_progress
        (set @entity.status in_progress)
        (set @entity.currentStep 0)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "loader"}, { type: "typography", content: "BuildFix", variant: "h2" }, { type: "badge", label: "In Progress", variant: "warning" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Validate" }, { id: "1", title: "Analyze" }, { id: "2", title: "Fix" }, { id: "3", title: "Re-validate" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "stat-display", label: "Current Step", value: "@entity.currentStep" }, { type: "stat-display", label: "Total Steps", value: "@entity.totalSteps" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Advance", action: "ADVANCE", variant: "primary", icon: "chevron-right" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "BuildFix", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Validate" }, { id: "1", title: "Analyze" }, { id: "2", title: "Fix" }, { id: "3", title: "Re-validate" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] }] })
    }
    state in_progress {
      ADVANCE -> in_progress when (< @entity.currentStep @entity.totalSteps)
        (set @entity.currentStep (+ @entity.currentStep 1))
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "loader"}, { type: "typography", content: "BuildFix", variant: "h2" }, { type: "badge", label: "In Progress", variant: "warning" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Validate" }, { id: "1", title: "Analyze" }, { id: "2", title: "Fix" }, { id: "3", title: "Re-validate" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "stat-display", label: "Current Step", value: "@entity.currentStep" }, { type: "stat-display", label: "Total Steps", value: "@entity.totalSteps" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Advance", action: "ADVANCE", variant: "primary", icon: "chevron-right" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      COMPLETE -> completed
        (set @entity.status completed)
        (set @entity.currentStep @entity.totalSteps)
        (render-ui main { type: "dashboard-layout", appName: "Schema Builder", navItems: [{ label: "Plan", href: "/plan", icon: "clipboard-list" }, { label: "Build", href: "/build", icon: "hammer" }, { label: "Fix", href: "/fix", icon: "wrench" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "BuildFix", variant: "h2" }, { type: "badge", label: "Completed", variant: "success" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.totalSteps", steps: [{ id: "0", title: "Validate" }, { id: "1", title: "Analyze" }, { id: "2", title: "Fix" }, { id: "3", title: "Re-validate" }] }, { type: "alert", variant: "success", message: "All steps completed successfully." }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
