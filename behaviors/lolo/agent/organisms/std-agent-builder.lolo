orbital BuildSessionOrbital {
    type BuildSessionLoaded = Event { data : [BuildSession] } "Fired when BuildSession finishes loading"

    type BuildSessionLoadFailed = Event { error : string, code : string } "Fired when BuildSession fails to load"

    type BuildSessionUpdateFailed = Event { error : string, code : string }

    type BuildSessionUpdated = Event { id : string }

  entity BuildSession [runtime] {
    id : string!
    sessionId : string @description "Unique identifier for a user's session." @synonyms "session ID, session, identifier"
    parentId : string @description "Reference to the parent build plan." @synonyms "parent, reference, ancestor"
    label : string @description "A human-readable identifier for the element." @synonyms "title, name, heading"
    status : string @description "Indicates the current state or condition of the item." @synonyms "state, condition, progress" = idle
    createdAt : string
  }

  trait BuildSessionManager -> BuildSession [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch BuildSession {
          emit: { failure: BuildSessionLoadFailed, success: BuildSessionLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      BuildSessionLoaded -> browsing
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: terminal, type: icon }, {
                  content: "BuildSession Manager"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                children: [{
                  action: FORK
                  icon: git-branch
                  label: Fork
                  type: button
                  variant: secondary
                }, {
                  action: LABEL
                  icon: tag
                  label: Label
                  type: button
                  variant: secondary
                }, {
                  action: END
                  icon: square
                  label: End
                  type: button
                  variant: ghost
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: terminal
                label: "Session ID"
                name: sessionId
                variant: h4
              }, {
                label: Status
                name: status
                variant: badge
              }, {
                label: Label
                name: label
                variant: caption
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      BuildSessionLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load buildsession"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      FORK
      LABEL
      END
      BuildSessionLoaded
      BuildSessionLoadFailed
    }

    listens {
      BuildSessionAgent.FORKED -> INIT
      BuildSessionLabel.LABELED -> INIT
      BuildSessionAgent.ENDED -> INIT
      BuildSessionLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait BuildSessionLabel -> BuildSession [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.sessionId "")
        (fetch BuildSession {
          emit: { failure: BuildSessionLoadFailed, success: BuildSessionLoaded }
        })
      LABEL -> open
        (fetch BuildSession {
          emit: { failure: BuildSessionLoadFailed, success: BuildSessionLoaded }
        })
        (render-ui modal {
          children: [{
            children: [{ name: tag, type: icon }, {
              content: "Label Session"
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              content: "Session:"
              type: typography
              variant: caption
            }, { label: @entity.sessionId, type: badge }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            cancelEvent: CLOSE
            entity: @entity
            fields: (label)
            mode: edit
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
        (notify Cancelled info)
      SAVE -> closed
        (persist update BuildSession ?data {
          emit: { failure: BuildSessionUpdateFailed, success: BuildSessionUpdated }
        })
        (render-ui modal null)
        (render-ui main { type: box })
        (emit LABELED)
    }

    emits {
      LABELED
      BuildSessionLoadFailed
      BuildSessionLoaded
      BuildSessionUpdateFailed
      BuildSessionUpdated
    }

    listens {
      BuildSessionLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
      BuildSessionManager.LABEL -> LABEL
    }
  }

  trait BuildSessionAgent -> BuildSession [interaction, collection] {
    initial: active

    state active {
      INIT -> active
        (set @entity.sessionId "")
        (fetch BuildSession {
          emit: { failure: BuildSessionLoadFailed, success: BuildSessionLoaded }
        })
        (agent/session-id)
        (set @entity.createdAt @now)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            description: "Session is ready"
            icon: git-branch
            title: Session
            type: empty-state
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FORK -> forked
        (set @entity.parentId @entity.sessionId)
        (agent/fork)
        (agent/session-id)
        (persist create BuildSession {
          createdAt: @now
          parentId: @entity.parentId
          sessionId: @entity.sessionId
          status: forked
        } {
          emit: { success: FORKED }
        })
      DO_LABEL -> active
        (agent/label ?data.label)
        (set @entity.label ?data.label)
      LABELED -> active
        (agent/label @entity.label)
        (fetch BuildSession {
          emit: { failure: BuildSessionLoadFailed, success: BuildSessionLoaded }
        })
      END -> ended
        (set @entity.status ended)
        (emit ENDED)
    }

    state forked {
      FORK -> forked
        (set @entity.parentId @entity.sessionId)
        (agent/fork)
        (agent/session-id)
        (persist create BuildSession {
          createdAt: @now
          parentId: @entity.parentId
          sessionId: @entity.sessionId
          status: forked
        } {
          emit: { success: FORKED }
        })
      DO_LABEL -> forked
        (agent/label ?data.label)
        (set @entity.label ?data.label)
      LABELED -> forked
        (agent/label @entity.label)
        (fetch BuildSession {
          emit: { failure: BuildSessionLoadFailed, success: BuildSessionLoaded }
        })
      END -> ended
        (set @entity.status ended)
        (emit ENDED)
    }

    state ended {
      INIT -> active
        (fetch BuildSession {
          emit: { failure: BuildSessionLoadFailed, success: BuildSessionLoaded }
        })
        (agent/session-id)
        (set @entity.createdAt @now)
        (set @entity.status active)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            description: "Session is ready"
            icon: git-branch
            title: Session
            type: empty-state
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    emits {
      ENDED -> external {
        sessionId : string
      }
      FORKED -> external {
        sessionId : string
      }
      BuildSessionLoaded
      BuildSessionLoadFailed
    }

    listens {
      BuildSessionAgent.ENDED -> INIT
      BuildSessionAgent.FORKED -> INIT
      BuildSessionLoadFailed {
        error : string
        code : string
      }
      DO_LABEL {
        data : string
      }
      BuildSessionManager.FORK -> FORK
      BuildSessionManager.END -> END
    }
  }

  page "/session" -> BuildSessionManager
}

orbital BuildTaskOrbital {
  uses Tabs from "std/behaviors/std-tabs"

    type BuildTaskLoaded = Event { data : [BuildTask] } "Fired when BuildTask finishes loading"

    type BuildTaskLoadFailed = Event { error : string, code : string } "Fired when BuildTask fails to load"

  entity BuildTask [runtime] {
    id : string!
    prompt : string @description "The text used to initiate or guide a process." @synonyms "instruction, query, request, input" = ""
    plan : string @description "The high-level outline or strategy for achieving a goal." @synonyms "strategy, outline, approach, design"
    schema : string @description "Defines the data structure used for the build plan." @synonyms "structure, format, definition"
    validationStatus : string @description "Indicates the outcome of a validation process." @synonyms "validation result, check status, verification state"
    buildPhase : string @description "The stage or phase of the build process." @synonyms "phase, stage, step"
    attempts : number @description "The number of times an operation has been tried." @synonyms "count, tries, retries"
    sessionId : string @description "Unique identifier for a user's session." @synonyms "session ID, session, identifier"
    error : string @description "A textual description of an encountered problem." @synonyms "issue, problem, fault, message" = ""
    activeTab : string @description "The currently selected tab or view within the interface." @synonyms "selection, current tab, view" = ""
    items : [ItemSpec] @description "A list of individual specifications or elements." @synonyms "elements, entries, list, details" = []
  }

  trait BuilderTabs = Tabs.traits.TabsItemTabs -> BuildTask {
  }

  page "/builder/nav" -> BuilderTabs
}

orbital BuildProgressOrbital {
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"

    type BuildProgressLoaded = Event { data : [BuildProgress] } "Fired when BuildProgress finishes loading"

    type BuildProgressLoadFailed = Event { error : string, code : string } "Fired when BuildProgress fails to load"

  entity BuildProgress [runtime] {
    id : string!
    steps : string @description "Ordered sequence of actions to achieve a goal." @synonyms "sequence, order, steps, phases" = ""
    currentStep : number @description "The index of the currently executing step." @synonyms "step number, step index, current task"
    totalSteps : number @description "The total number of steps involved in the plan." @synonyms "count, number, size, length"
    status : string @description "The current state or condition of the build plan." @synonyms "state, condition, progress" = idle
  }

  trait BuildStepProgress = AgentStepProgress.traits.AgentStepProgressProgress -> BuildProgress {
  }

  page "/builder/progress" -> BuildStepProgress
}