  trait ToolLoopCompletionFlow -> BuildLoop [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.model claude-sonnet-4-20250514)
        (set @entity.provider anthropic)
        (fetch BuildLoop {
          emit: { failure: BuildLoopLoadFailed, success: BuildLoopLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: BuildLoop
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      GENERATE -> open
        (render-ui modal {
          children: [{
            children: [{ name: sparkles, type: icon }, {
              content: BuildLoop
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{ label: @entity.provider, type: badge }, { label: @entity.model, type: badge }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (prompt)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch BuildLoop {
          emit: { failure: BuildLoopLoadFailed, success: BuildLoopLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: BuildLoop
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create BuildLoop ?data {
          emit: { failure: BuildLoopSaveFailed, success: BuildLoopSaved }
        })
        (render-ui modal null)
        (emit GENERATED)
        (fetch BuildLoop {
          emit: { failure: BuildLoopLoadFailed, success: BuildLoopLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: BuildLoop
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    emits {
      SAVE -> internal
      GENERATED -> internal
      BuildLoopLoadFailed
      BuildLoopLoaded
      BuildLoopSaveFailed
      BuildLoopSaved
    }

    listens {
      BuildLoopLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
    }
  }

