app std-agent-builder "1.0.0"
"Agent app builder: prompt-driven plan/build/fix loop. Pick for NL app generators."
type ItemSpec = { id : string, label : string!, value : string, icon : string }
orbital BuildPlanOrbital {
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"

  uses Tabs from "std/behaviors/std-tabs"

    type BuildPlanLoaded = Event { data : [BuildPlan] } "Fired when BuildPlan finishes loading"

    type BuildPlanLoadFailed = Event { error : string, code : string } "Fired when BuildPlan fails to load"

    type BuildTaskLoadFailed = Event { error : string, code : string } "Emitted event BuildTaskLoadFailed"

    type BuildTaskLoaded = Event { error : string, code : string } "Emitted event BuildTaskLoaded"

    type BuildProgressLoaded = Event { error : string, code : string } "Emitted event BuildProgressLoaded"

    type BuildProgressLoadFailed = Event { error : string, code : string } "Emitted event BuildProgressLoadFailed"

    type BuildPlanSaved = Event { id : string }

    type BuildPlanSaveFailed = Event { error : string, code : string }

    type BuildLoopSaved = Event { id : string }

    type BuildLoopSaveFailed = Event { error : string, code : string }

    type BuildFixSaved = Event { id : string }

    type BuildFixSaveFailed = Event { error : string, code : string }

    type BuildSessionUpdated = Event { id : string }

    type BuildSessionUpdateFailed = Event { error : string, code : string }

  entity BuildPlan [runtime] {
    id : string!
    task : string @description "A description of the task being performed." @synonyms "activity, job, operation" = ""
    category : string @description "A classification or grouping for the build plan." @synonyms "type, group, classification" = ""
    steps : string @description "Ordered sequence of actions to achieve a goal." @synonyms "sequence, order, steps, progression" = ""
    confidence : number @description "A numerical value representing the certainty of a result." @synonyms "probability, certainty, likelihood, score" = 0
    status : string @description "The current state or condition of the build plan." @synonyms "state, condition, progress" = idle
    relevantMemories : string @description "A reference to related memory entries." @synonyms "memory reference, memory link, memory ID" = ""
    memoryCount : number @description "The number of associated memories." @synonyms "count, number, quantity" = 0
    error : string @description "Textual description of an error or failure." @synonyms "failure, problem, issue, message" = ""
    input : string @description "Data provided as an initial value or query." @synonyms "query, value, initialData" = ""
    prompt : string @description "The text used to initiate or guide a process." @synonyms "query, instruction, request, input" = ""
    response : string @description "The text output generated by a language model." @synonyms "output, text, answer, result" = ""
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, supplier" = anthropic
    model : string @description "The underlying data model used for the plan." @synonyms "schema, definition, structure" = claude-sonnet-4-20250514
    content : string @description "The textual data associated with a specific item." @synonyms "text, data, body, value" = ""
    scope : string @description "The area or domain this plan applies to." @synonyms "domain, area, subject, focus" = ""
    strength : number @description "Numerical measure of reliability or effectiveness." @synonyms "score, rating, value, level" = 1
    pinned : boolean @description "Indicates whether the item is marked for prioritized access." @synonyms "flagged, marked, favorited" = false
    action : string @description "The specific action to be performed." @synonyms "operation, command, activity" = ""
    detail : string @description "A more in-depth explanation or specification." @synonyms "description, notes, specifics, details" = ""
    timestamp : string @description "Date and time of the event or record creation." @synonyms "date, time, created, recorded" = ""
    duration : number @description "The length of time an operation took." @synonyms "time, length, elapsed" = 0
    icon : string @description "A visual representation, often a graphic, for identification." @synonyms "image, symbol, graphic, representation" = circle
  }

  trait BuildPlanner -> BuildPlan [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: map, type: icon }, {
                content: "Task Planner"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to plan"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: PLAN
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      PLAN -> classifying
        (set @entity.status classifying)
        (agent/generate (str/concat "Classify this task into exactly one category.\n" "Categories: " "schema, component, trait, page, behavior" "\n" "Task: " @entity.task "\n" "Return only the category name."))
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: tag, type: icon }, {
              content: "Classifying task..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              content: @entity.task
              type: typography
              variant: caption
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state classifying {
      CLASSIFIED -> recalling
        (set @entity.category ?category)
        (set @entity.status recalling)
        (agent/recall (str/concat @entity.category " " @entity.task) 5)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: brain, type: icon }, {
              content: "Recalling relevant experience..."
              type: typography
              variant: h3
            }, { type: spinner }, { label: @entity.category, type: badge }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "Planning Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state recalling {
      MEMORIES_LOADED -> planning
        (set @entity.relevantMemories ?memories)
        (set @entity.memoryCount ?count)
        (set @entity.status planning)
        (agent/generate (str/concat "Task: " @entity.task "\n" "Category: " @entity.category "\n" "Relevant experience:\n" @entity.relevantMemories "\n\n" "Generate a numbered step-by-step execution plan. " "Include a confidence score (0-100) for how likely this plan will succeed."))
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: cpu, type: icon }, {
              content: "Generating plan..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              children: [{ label: @entity.category, type: badge }, { label: @entity.memoryCount, type: badge }]
              direction: horizontal
              gap: md
              justify: center
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "Planning Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state planning {
      PLAN_GENERATED -> ready
        (set @entity.steps ?steps)
        (set @entity.confidence ?confidence)
        (set @entity.status ready)
        (agent/memorize (str/concat "Plan for " @entity.category " task: " @entity.task) pattern-affinity)
        (emit PLAN_READY)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: check-circle, type: icon }, {
                  content: "Plan Ready"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                action: RESET
                icon: rotate-ccw
                label: "New Plan"
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                icon: tag
                label: Category
                type: stat-display
                value: @entity.category
              }, {
                icon: target
                label: Confidence
                type: stat-display
                value: @entity.confidence
              }, {
                icon: brain
                label: "Memories Used"
                type: stat-display
                value: @entity.memoryCount
              }]
              cols: 3
              type: simple-grid
            }, { type: divider }, {
              children: [{
                children: [{
                  content: Task
                  type: typography
                  variant: caption
                }, {
                  content: @entity.task
                  type: typography
                  variant: body
                }, { type: divider }, {
                  content: "Execution Plan"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.steps
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }, {
              children: [{
                children: [{
                  content: "Relevant Memories"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.relevantMemories
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "Planning Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state ready {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.category "")
        (set @entity.steps "")
        (set @entity.confidence 0)
        (set @entity.relevantMemories "")
        (set @entity.memoryCount 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: map, type: icon }, {
                content: "Task Planner"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to plan"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: PLAN
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    emits {
      PLAN_READY -> external {
        id : string
      }
      BuildPlanSaved
      BuildPlanSaveFailed
      BuildLoopSaved
      BuildLoopSaveFailed
      BuildFixSaved
      BuildFixSaveFailed
      BuildSessionUpdated
      BuildSessionUpdateFailed
    }

    listens {
      BuildPlanner.PLAN_READY -> INIT
      CLASSIFIED {
        category : string!
      }
      MEMORIES_LOADED {
        memories : string!
        count : number!
      }
      PLAN_GENERATED {
        steps : string!
        confidence : number!
        plan : string
        toolName : string
        toolArgs : string
      }
      FAILED {
        error : string!
      }
      BuildPlanSaveFailed {
        error : string
        code : string
      }
      BuildLoopSaveFailed {
        error : string
        code : string
      }
      BuildFixSaveFailed {
        error : string
        code : string
      }
      BuildSessionUpdateFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerTaskInput -> BuildPlan [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
      NEW_TASK -> open
        (render-ui modal {
          children: [{ name: map, type: icon }, {
            content: "Describe the task to plan"
            type: typography
            variant: h3
          }, { type: divider }, {
            cancelEvent: CLOSE
            entity: @entity
            fields: (task)
            mode: edit
            submitEvent: PLAN
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
        (notify Cancelled info)
      PLAN -> closed
        (render-ui modal null)
        (render-ui main { type: box })
    }

    emits {
      BuildPlanLoaded
      BuildPlanLoadFailed
    }

    listens {
      PLAN {
        data : object!
      }
      BuildPlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerClassifierFlow -> BuildPlan [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: BuildPlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      CLASSIFY -> open
        (render-ui modal {
          children: [{
            children: [{ name: tag, type: icon }, {
              content: BuildPlan
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              content: "Categories:"
              type: typography
              variant: caption
            }, {
              label: schema
              type: badge
              variant: secondary
            }, {
              label: component
              type: badge
              variant: secondary
            }, {
              label: trait
              type: badge
              variant: secondary
            }, {
              label: page
              type: badge
              variant: secondary
            }, {
              label: behavior
              type: badge
              variant: secondary
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (input)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: BuildPlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create BuildPlan ?data {
          emit: { failure: BuildPlanSaveFailed, success: BuildPlanSaved }
        })
        (render-ui modal null)
        (emit CLASSIFIED)
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: BuildPlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    emits {
      SAVE -> internal
      CLASSIFIED -> internal
      BuildPlanLoadFailed
      BuildPlanLoaded
      BuildPlanSaveFailed
      BuildPlanSaved
    }

    listens {
      SAVE {
        data : object!
      }
      BuildPlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerCompletionFlow -> BuildPlan [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.model claude-sonnet-4-20250514)
        (set @entity.provider anthropic)
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: BuildPlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      GENERATE -> open
        (render-ui modal {
          children: [{
            children: [{ name: sparkles, type: icon }, {
              content: BuildPlan
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{ label: @entity.provider, type: badge }, { label: @entity.model, type: badge }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (prompt)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: BuildPlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create BuildPlan ?data {
          emit: { failure: BuildPlanSaveFailed, success: BuildPlanSaved }
        })
        (render-ui modal null)
        (emit GENERATED)
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: BuildPlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    emits {
      SAVE -> internal
      GENERATED -> internal
      BuildPlanLoadFailed
      BuildPlanLoaded
      BuildPlanSaveFailed
      BuildPlanSaved
    }

    listens {
      SAVE {
        data : object!
      }
      BuildPlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerMemoryLifecycle -> BuildPlan [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch BuildPlan {
          emit: { failure: BuildPlanLoadFailed, success: BuildPlanLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      BuildPlanLoaded -> browsing
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: brain, type: icon }, {
                  content: "BuildPlan Manager"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: brain
                label: Content
                name: content
                variant: h4
              }, {
                label: Category
                name: category
                variant: badge
              }, {
                label: Strength
                name: strength
                variant: caption
              }]
              itemActions: [{
                event: PIN
                label: Pin
                variant: ghost
              }, {
                event: REINFORCE
                label: Reinforce
                variant: ghost
              }, {
                event: FORGET
                label: Forget
                variant: danger
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      BuildPlanLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load buildplan"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      BuildPlanLoaded
      BuildPlanLoadFailed
    }

    listens {
      PIN {
        id : string!
        row : BuildPlan
      }
      REINFORCE {
        id : string!
        row : BuildPlan
      }
      FORGET {
        id : string!
        row : BuildPlan
      }
      BuildPlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  page "/plan" as PlanPage -> BuildPlanner
}

orbital BuildLoopOrbital {
    type BuildLoopLoaded = Event { data : [BuildLoop] } "Fired when BuildLoop finishes loading"

    type BuildLoopLoadFailed = Event { error : string, code : string } "Fired when BuildLoop fails to load"

    type BuildLoopSaveFailed = Event { error : string, code : string }

    type BuildLoopSaved = Event { id : string }

  entity BuildLoop [runtime] {
    id : string!
    task : string @description "A brief description of the work to be performed." @synonyms "activity, job, operation" = ""
    plan : string @description "The overall strategy or outline for achieving a goal." @synonyms "strategy, outline, approach, scheme"
    iterations : number @description "The number of times a process repeats." @synonyms "count, repeats, loops"
    maxIterations : number @description "The maximum number of iterations allowed." @synonyms "limit, maximum, count"
    status : string @description "Current state of the process or item." @synonyms "state, condition, progress" = idle
    result : string @description "The outcome or output of a process or operation." @synonyms "output, outcome, value, product"
    currentTool : string @description "The name of the tool currently being used." @synonyms "tool, agent, function"
    lastToolResult : string @description "The output or data returned by the last tool execution." @synonyms "output, result, data, return"
    error : string @description "Textual description of an error or issue encountered." @synonyms "issue, problem, fault, message" = ""
    currentStep : number @description "The index of the currently executing step." @synonyms "step number, step index, current task"
    totalSteps : number @description "The total number of steps involved in the process." @synonyms "count, number, size, quantity"
    steps : string @description "Ordered sequence of actions to achieve a goal." @synonyms "sequence, order, steps, phases" = ""
    toolName : string @description "The name of the tool used in this step." @synonyms "tool, utility, application"
    args : string @description "Arguments passed to a function or process." @synonyms "parameters, inputs, arguments, values"
    prompt : string @description "The text used to initiate or guide a process." @synonyms "query, instruction, request, input" = ""
    response : string @description "The text output generated by a language model." @synonyms "output, text, answer, result" = ""
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, supplier" = anthropic
    model : string @description "The underlying language model used for processing." @synonyms "engine, LLM, language model" = claude-sonnet-4-20250514
    tokenCount : number @description "The number of tokens used." @synonyms "count, tokens, usage"
    maxTokens : number @description "The maximum number of tokens allowed for a given operation." @synonyms "token limit, max length, token count"
    usage : number @description "Indicates the number of times this resource has been utilized." @synonyms "count, uses, frequency, occurrences"
    current : number @description "The present value of a numerical measurement or count." @synonyms "value, amount, quantity"
    max : number @description "The maximum allowable value for a numerical property." @synonyms "limit, maximum, upper bound"
    threshold : number @description "A numerical value representing a limit or boundary." @synonyms "limit, boundary, cutoff, minimum, maximum"
    lastCompactedAt : string @description "Timestamp of the last compaction event." @synonyms "compacted, last compacted, compaction time"
    action : string @description "The operation to be performed." @synonyms "command, operation, verb" = ""
    detail : string @description "A more detailed explanation or description of the item." @synonyms "description, notes, specifics, particulars" = ""
    timestamp : string @description "Date and time of the event or record creation." @synonyms "date, time, created, recorded" = ""
    duration : number @description "The length of time an operation took." @synonyms "time, length, elapsed" = 0
  }

  trait SchemaBuilder -> BuildLoop [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.maxIterations 0)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: repeat, type: icon }, {
                content: "Tool Execution Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to execute with tools"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: EXECUTE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      EXECUTE -> planning
        (set @entity.status planning)
        (set @entity.iterations 0)
        (agent/generate (str/concat "Task: " @entity.task "\n\nAvailable tools: " (str/join (agent/tools) ", ") "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."))
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: brain, type: icon }, {
              content: "Planning execution..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              content: @entity.task
              type: typography
              variant: caption
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state planning {
      PLAN_GENERATED -> executing
        (set @entity.plan ?plan)
        (set @entity.currentTool ?toolName)
        (set @entity.iterations ["+", @entity.iterations, 1])
        (agent/invoke ?toolName ?toolArgs)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: tool, type: icon }, {
                  content: "Executing Tool"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, { label: @entity.maxIterations, type: badge }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Current Tool"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.currentTool
                  type: typography
                  variant: h4
                }, { type: spinner }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, {
              children: [{
                children: [{
                  content: Plan
                  type: typography
                  variant: caption
                }, {
                  content: @entity.plan
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: repeat
                label: "Iterations Used"
                type: stat-display
                value: @entity.iterations
              }, {
                icon: shield
                label: "Max Allowed"
                type: stat-display
                value: @entity.maxIterations
              }]
              cols: 2
              type: simple-grid
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state executing {
      TOOL_RESULT -> checking
        (set @entity.lastToolResult ?output)
        (agent/generate (str/concat "Task: " @entity.task "\nPlan: " @entity.plan "\nTool output: " ?output "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."))
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: eye, type: icon }, {
              content: "Checking result..."
              type: typography
              variant: h3
            }, { type: spinner }, { label: @entity.iterations, type: badge }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: repeat
                label: "Iterations Used"
                type: stat-display
                value: @entity.iterations
              }, {
                icon: shield
                label: "Max Allowed"
                type: stat-display
                value: @entity.maxIterations
              }]
              cols: 2
              type: simple-grid
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state checking {
      CHECK_PASSED -> completed
        (set @entity.result ?result)
        (set @entity.status completed)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: check-circle, type: icon }, {
                  content: "Loop Complete"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                action: RESET
                icon: rotate-ccw
                label: "New Task"
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                icon: repeat
                label: Iterations
                type: stat-display
                value: @entity.iterations
              }, {
                icon: check
                label: Status
                type: stat-display
                value: @entity.status
              }]
              cols: 2
              type: simple-grid
            }, { type: divider }, {
              children: [{
                children: [{
                  content: Task
                  type: typography
                  variant: caption
                }, {
                  content: @entity.task
                  type: typography
                  variant: body
                }, { type: divider }, {
                  content: Result
                  type: typography
                  variant: caption
                }, {
                  content: @entity.result
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      CHECK_NEEDS_MORE -> executing
        (set @entity.currentTool ?toolName)
        (set @entity.iterations ["+", @entity.iterations, 1])
        (if [">=", (agent/context-usage), 0.8] (agent/compact hybrid) (log "Context below compact threshold"))
        (agent/invoke ?toolName ?toolArgs)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: tool, type: icon }, {
                  content: "Executing Tool"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, { label: @entity.maxIterations, type: badge }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Current Tool"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.currentTool
                  type: typography
                  variant: h4
                }, { type: spinner }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, {
              children: [{
                children: [{
                  content: Plan
                  type: typography
                  variant: caption
                }, {
                  content: @entity.plan
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      MAX_ITERATIONS -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: repeat
                label: "Iterations Used"
                type: stat-display
                value: @entity.iterations
              }, {
                icon: shield
                label: "Max Allowed"
                type: stat-display
                value: @entity.maxIterations
              }]
              cols: 2
              type: simple-grid
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: repeat, type: icon }, {
                content: "Tool Execution Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to execute with tools"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: EXECUTE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: repeat, type: icon }, {
                content: "Tool Execution Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to execute with tools"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: EXECUTE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    emits {
      TOOL_LOOP_DONE -> external {
        schema : string
      }
      RESET
    }

    listens {
      BuildPlanOrbital.BuildPlanner.PLAN_READY -> EXECUTE
      TOOL_RESULT {
        output : string
      }
      CHECK_PASSED {
        result : string
      }
      CHECK_NEEDS_MORE {
        toolName : string
        toolArgs : string
      }
      MAX_ITERATIONS {
        error : string
      }
      PLAN_GENERATED {
        plan : string
        toolName : string
        toolArgs : string
      }
      FAILED {
        error : string
      }
      ToolLoopStepProgress.RESET -> RESET
      ToolLoopContextMonitor.RESET -> RESET
    }
  }

  trait ToolLoopStepProgress -> BuildLoop [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.totalSteps 0)
        (fetch BuildLoop {
          emit: { failure: BuildLoopLoadFailed, success: BuildLoopLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: list-ordered, type: icon }, {
                content: BuildLoop
                type: typography
                variant: h2
              }, {
                label: Idle
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Plan
              }, {
                id: "1"
                title: Execute
              }, {
                id: "2"
                title: Check
              }, {
                id: "3"
                title: Complete
              }]
              type: wizard-progress
            }, {
              action: START
              icon: play
              label: Start
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      START -> in_progress
        (set @entity.status in_progress)
        (set @entity.currentStep 0)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: loader, type: icon }, {
                content: BuildLoop
                type: typography
                variant: h2
              }, {
                label: "In Progress"
                type: badge
                variant: warning
