}

orbital BuildFixOrbital {
    type BuildFixLoaded = Event { data : [BuildFix] } "Fired when BuildFix finishes loading"

    type BuildFixLoadFailed = Event { error : string, code : string } "Fired when BuildFix fails to load"

    type BuildFixSaveFailed = Event { error : string, code : string }

    type BuildFixSaved = Event { id : string }

  entity BuildFix [runtime] {
    id : string!
    target : string @description "The intended destination or recipient of an action." @synonyms "destination, recipient, target, endpoint"
    validationErrors : string @description "A textual description of validation issues." @synonyms "errors, issues, problems, faults"
    fixAttempts : number @description "The number of times a fix has been attempted." @synonyms "attempts, retries, fixCount"
    maxAttempts : number @description "The maximum number of attempts allowed." @synonyms "limit, retries, count"
    status : string @description "Indicates the current state or condition of the item." @synonyms "state, condition, progress" = idle
    currentFix : string @description "The current attempt to resolve an issue." @synonyms "fix, correction, remediation"
    errorCount : number @description "The number of errors encountered." @synonyms "error number, errors, count"
    error : string @description "A textual description of an error or failure." @synonyms "failure, problem, issue, message" = ""
    currentStep : number @description "The index of the step currently being processed." @synonyms "step number, step index, current iteration"
    totalSteps : number @description "The total number of steps involved in the plan." @synonyms "count, number, size, length"
    steps : string @description "Ordered sequence of actions to achieve a goal." @synonyms "sequence, order, steps, procedure" = ""
    toolName : string @description "The name of the tool used to perform a task." @synonyms "tool, application, program"
    args : string @description "Arguments passed to a function or process." @synonyms "parameters, inputs, arguments, values"
    result : string @description "The outcome or output of a process or operation." @synonyms "output, outcome, value, return"
    prompt : string @description "The text used to initiate or guide a process." @synonyms "query, instruction, request, input" = ""
    response : string @description "The text output generated by a language model." @synonyms "output, text, answer, result" = ""
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, supplier" = anthropic
    model : string @description "The underlying data model used for this plan." @synonyms "schema, definition, structure" = claude-sonnet-4-20250514
  }

  trait FixLoop -> BuildFix [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.maxAttempts 0)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: wrench, type: icon }, {
                content: "Validation-Fix Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Enter the target to validate and auto-fix"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (target)
                  mode: edit
                  submitEvent: FIX
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FIX -> validating
        (set @entity.status validating)
        (set @entity.fixAttempts 0)
        (set @entity.validationErrors "")
        (set @entity.errorCount 0)
        (agent/invoke validate-schema { target: @entity.target })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: shield-check, type: icon }, {
              content: "Validating..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              children: [{ label: @entity.target, type: badge }, { label: @entity.maxAttempts, type: badge }]
              direction: horizontal
              gap: md
              justify: center
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state validating {
      VALIDATION_PASSED -> succeeded
        (set @entity.status succeeded)
        (emit FIX_SUCCEEDED)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: check-circle, type: icon }, {
                  content: "Validation Passed"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                action: RESET
                icon: rotate-ccw
                label: "New Target"
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                icon: wrench
                label: "Fix Attempts"
                type: stat-display
                value: @entity.fixAttempts
              }, {
                icon: check
                label: Status
                type: stat-display
                value: Passed
              }]
              cols: 2
              type: simple-grid
            }, {
              children: [{
                children: [{
                  content: Target
                  type: typography
                  variant: caption
                }, {
                  content: @entity.target
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      VALIDATION_ERRORS -> fixing
        (set @entity.validationErrors ?errors)
        (set @entity.errorCount ?count)
        (set @entity.fixAttempts ["+", @entity.fixAttempts, 1])
        (set @entity.status fixing)
        (agent/generate (str/concat "Target: " @entity.target "\n\nValidation errors:\n" ?errors "\n\nGenerate a fix that resolves these errors. Return only the fix content."))
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: cpu, type: icon }, {
                  content: "Generating fix..."
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, { label: @entity.fixAttempts, type: badge }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Validation Errors"
                  type: typography
                  variant: caption
                }, {
                  message: @entity.validationErrors
                  type: alert
                  variant: error
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, { type: spinner }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      EXCEEDED_ATTEMPTS -> failed
        (set @entity.status failed)
        (set @entity.error ?error)
        (emit FIX_FAILED)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Fix Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: wrench
                label: "Attempts Used"
                type: stat-display
                value: @entity.fixAttempts
              }, {
                icon: alert-triangle
                label: "Remaining Errors"
                type: stat-display
                value: @entity.errorCount
              }]
              cols: 2
              type: simple-grid
            }, {
              children: [{
                children: [{
                  content: "Last Validation Errors"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.validationErrors
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state fixing {
      FIX_GENERATED -> applying
        (set @entity.currentFix ?fix)
        (set @entity.status applying)
        (agent/invoke apply-fix { fix: ?fix, target: @entity.target })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: tool, type: icon }, {
              content: "Applying fix..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              children: [{
                children: [{
                  content: "Proposed Fix"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.currentFix
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (emit FIX_FAILED)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Fix Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: wrench
                label: "Attempts Used"
                type: stat-display
                value: @entity.fixAttempts
              }, {
                icon: alert-triangle
                label: "Remaining Errors"
                type: stat-display
                value: @entity.errorCount
              }]
              cols: 2
              type: simple-grid
            }, {
              children: [{
                children: [{
                  content: "Last Validation Errors"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.validationErrors
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state applying {
      FIX_APPLIED -> validating
        (set @entity.status validating)
        (agent/invoke validate-schema { target: @entity.target })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: shield-check, type: icon }, {
              content: "Validating..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              children: [{ label: @entity.target, type: badge }, { label: @entity.maxAttempts, type: badge }]
              direction: horizontal
              gap: md
              justify: center
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (emit FIX_FAILED)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Fix Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: wrench
                label: "Attempts Used"
                type: stat-display
                value: @entity.fixAttempts
              }, {
                icon: alert-triangle
                label: "Remaining Errors"
                type: stat-display
                value: @entity.errorCount
              }]
              cols: 2
              type: simple-grid
            }, {
              children: [{
                children: [{
                  content: "Last Validation Errors"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.validationErrors
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state succeeded {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.target "")
        (set @entity.validationErrors "")
        (set @entity.currentFix "")
        (set @entity.fixAttempts 0)
        (set @entity.errorCount 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: wrench, type: icon }, {
                content: "Validation-Fix Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Enter the target to validate and auto-fix"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (target)
                  mode: edit
                  submitEvent: FIX
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.target "")
        (set @entity.validationErrors "")
        (set @entity.currentFix "")
        (set @entity.fixAttempts 0)
        (set @entity.errorCount 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: wrench, type: icon }, {
                content: "Validation-Fix Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Enter the target to validate and auto-fix"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (target)
                  mode: edit
                  submitEvent: FIX
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    emits {
      FIX_SUCCEEDED -> external {
        target : string
      }
      FIX_FAILED -> external {
        target : string
        error : string
      }
      RESET
    }

    listens {
      FixLoop.FIX_SUCCEEDED -> INIT
      FixLoop.FIX_FAILED -> INIT
      BuildLoopOrbital.SchemaBuilder.TOOL_LOOP_DONE -> FIX
      VALIDATION_ERRORS {
        errors : string
        count : number
      }
      EXCEEDED_ATTEMPTS {
        error : string
      }
      FIX_GENERATED {
        fix : string
      }
      FAILED {
        error : string
      }
      FixLoopStepProgress.RESET -> RESET
    }
  }

  trait FixLoopStepProgress -> BuildFix [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.totalSteps 0)
        (fetch BuildFix {
          emit: { failure: BuildFixLoadFailed, success: BuildFixLoaded }
        })
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: list-ordered, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: Idle
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Validate
              }, {
                id: "1"
                title: Analyze
              }, {
                id: "2"
                title: Fix
              }, {
                id: "3"
                title: Re-validate
              }]
              type: wizard-progress
            }, {
              action: START
              icon: play
              label: Start
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      START -> in_progress
        (set @entity.status in_progress)
        (set @entity.currentStep 0)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: loader, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: "In Progress"
                type: badge
                variant: warning
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Validate
              }, {
                id: "1"
                title: Analyze
              }, {
                id: "2"
                title: Fix
              }, {
                id: "3"
                title: Re-validate
              }]
              type: wizard-progress
            }, {
              align: center
              children: [{
                label: "Current Step"
                type: stat-display
                value: @entity.currentStep
              }, {
                label: "Total Steps"
                type: stat-display
                value: @entity.totalSteps
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              children: [{
                action: ADVANCE
                icon: chevron-right
                label: Advance
                type: button
                variant: primary
              }, {
                action: RESET
                icon: rotate-ccw
                label: Reset
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: list-ordered, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: Idle
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Validate
              }, {
                id: "1"
                title: Analyze
              }, {
                id: "2"
                title: Fix
              }, {
                id: "3"
                title: Re-validate
              }]
              type: wizard-progress
            }, {
              action: START
              icon: play
              label: Start
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state in_progress {
      ADVANCE -> in_progress when ["<", @entity.currentStep, @entity.totalSteps]
        (set @entity.currentStep ["+", @entity.currentStep, 1])
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: loader, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: "In Progress"
                type: badge
                variant: warning
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Validate
              }, {
                id: "1"
                title: Analyze
              }, {
                id: "2"
                title: Fix
              }, {
                id: "3"
                title: Re-validate
              }]
              type: wizard-progress
            }, {
              align: center
              children: [{
                label: "Current Step"
                type: stat-display
                value: @entity.currentStep
              }, {
                label: "Total Steps"
                type: stat-display
                value: @entity.totalSteps
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              children: [{
                action: ADVANCE
                icon: chevron-right
                label: Advance
                type: button
                variant: primary
              }, {
                action: RESET
                icon: rotate-ccw
                label: Reset
                type: button
                variant: ghost
