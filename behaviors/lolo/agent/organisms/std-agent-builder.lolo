          }]
          type: dashboard-layout
        })
      COMPLETE -> completed
        (set @entity.status completed)
        (set @entity.currentStep @entity.totalSteps)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: check-circle, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: Completed
                type: badge
                variant: success
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.totalSteps
              steps: [{
                id: "0"
                title: Validate
              }, {
                id: "1"
                title: Analyze
              }, {
                id: "2"
                title: Fix
              }, {
                id: "3"
                title: Re-validate
              }]
              type: wizard-progress
            }, {
              message: "All steps completed successfully."
              type: alert
              variant: success
            }, {
              action: RESET
              icon: rotate-ccw
              label: Reset
              type: button
              variant: ghost
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      FAIL -> failed
        (set @entity.status failed)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: x-circle, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: Failed
                type: badge
                variant: danger
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Validate
              }, {
                id: "1"
                title: Analyze
              }, {
                id: "2"
                title: Fix
              }, {
                id: "3"
                title: Re-validate
              }]
              type: wizard-progress
            }, {
              message: "Pipeline failed at the current step."
              type: alert
              variant: error
            }, {
              children: [{
                label: "Failed At Step"
                type: stat-display
                value: @entity.currentStep
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: RESET
              icon: rotate-ccw
              label: Reset
              type: button
              variant: ghost
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: list-ordered, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: Idle
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Validate
              }, {
                id: "1"
                title: Analyze
              }, {
                id: "2"
                title: Fix
              }, {
                id: "3"
                title: Re-validate
              }]
              type: wizard-progress
            }, {
              action: START
              icon: play
              label: Start
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/plan"
            icon: clipboard-list
            label: Plan
          }, {
            href: "/build"
            icon: hammer
            label: Build
          }, {
            href: "/fix"
            icon: wrench
            label: Fix
          }]
          type: dashboard-layout
        })
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main {
          appName: "Schema Builder"
          children: [{
            children: [{
              align: center
              children: [{ name: list-ordered, type: icon }, {
                content: BuildFix
                type: typography
                variant: h2
              }, {
                label: Idle
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
