app std-agent-builder "1.0.0"
"Agent builder organism — plan, build, validate, fix a single orbital end-to-end."

type OrbitalSpec = { orbitalName: string!, organism: string!, method: string!, deltaPrompt: string! }

orbital AgentBuilderOrbital {

  entity BuilderProcess [runtime] {
    request : string = ""
    plan : string = ""
    orbitalName : string = ""
    spec : OrbitalSpec = {}
    validationResult : string = ""
    fixPrompt : string = ""
    status : "idle" | "done" = idle
  }

  trait BuilderPipeline -> BuilderProcess [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.request "")
        (set @entity.plan "")
        (set @entity.orbitalName "")
        (set @entity.validationResult "")
        (set @entity.fixPrompt "")
        (set @entity.status idle)
      START -> planning
        (set @entity.request ?request)
        (set @entity.orbitalName ?orbitalName)
        (llm/generate @entity.request { emit: { success: PLANNED, failure: PLAN_FAILED } })
    }

    state planning {
      PLANNED -> done
        (set @entity.plan ?result)
        (behavior/instantiate @entity.orbitalName @entity.plan)
        (validate/validate @entity.orbitalName)
        (set @entity.status done)
        (emit BUILD_COMPLETE { orbitalName: @entity.orbitalName, plan: @entity.plan })
      PLAN_FAILED -> done
        (set @entity.plan "")
        (behavior/instantiate @entity.orbitalName @entity.plan)
        (validate/validate @entity.orbitalName)
        (set @entity.status done)
        (emit BUILD_COMPLETE { orbitalName: @entity.orbitalName, plan: @entity.plan })
    }

    state done {
      INIT -> done
        (set @entity.status done)
      RESET -> idle
        (set @entity.request "")
        (set @entity.plan "")
        (set @entity.orbitalName "")
        (set @entity.validationResult "")
        (set @entity.fixPrompt "")
        (set @entity.status idle)
    }

    emits {
      BUILD_COMPLETE {
        orbitalName : string!
        plan : string!
      }
      PLANNED {
        result : string!
      }
    }

    listens {
      START {
        request : string!
        orbitalName : string!
      }
      RETRY
    }
  }

  trait BuilderListener -> BuilderProcess [lifecycle, instance] {
    initial: waiting

    state waiting {
      INIT -> waiting
        (set @entity.status idle)
      BUILD_COMPLETE -> resolved
        (set @entity.status done)
    }

    state resolved {
      INIT -> resolved
        (set @entity.status done)
      RESET -> waiting
        (set @entity.status idle)
    }

    listens {
      BuilderPipeline.BUILD_COMPLETE -> BUILD_COMPLETE
      RESET
    }
  }

  page "/agent-builder" as AgentBuilderPage -> BuilderPipeline, BuilderListener
}
