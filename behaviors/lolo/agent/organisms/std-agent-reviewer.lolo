app std-agent-reviewer "1.0.0"
"Agent reviewer: code/doc review with RAG analysis and issue tracking."

type ItemSpec = { id : string, label : string!, value : string, icon : string }

orbital ReviewOrbital {
  uses Browse from "std/behaviors/std-browse"
  uses Tabs from "std/behaviors/std-tabs"

  entity Review [runtime] {
    id : string!
    target : string = ""
    category : string = ""
    issues : string = "[]"
    suggestions : string = "[]"
    score : number = 0
    reviewStatus : string = "idle"
    error : string = ""
    activeTab : string = ""
    items : [ItemSpec] = []

  }

  type ReviewLoaded     = Event { data : [Review] }                  "Fired when Review finishes loading"
  type ReviewLoadFailed = Event { error : string, code : string } "Fired when Review fails to load"
  type ReviewRagSaved = Event { id : string }
  type ReviewRagSaveFailed = Event { error : string, code : string }
  type AnalysisSaved = Event { id : string }
  type AnalysisSaveFailed = Event { error : string, code : string }
  type ReviewCompletionSaved = Event { id : string }
  type ReviewCompletionSaveFailed = Event { error : string, code : string }
  trait ReviewGenerator -> Review [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.category "")
        (fetch Review { emit: { success: "ReviewLoaded", failure: "ReviewLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-search"}, { type: "typography", content: "Code Review", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review.", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SUBMIT_REVIEW", fields: ["target"] }] }] }] }] })
      SUBMIT_REVIEW -> analyzing
        (set @entity.target @payload.target)
        (set @entity.reviewStatus analyzing)
        (agent/recall @payload.target)
        (agent/search-code @payload.target)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search"}, { type: "typography", content: "Analyzing input...", variant: "h3" }, { type: "spinner"}, { type: "typography", content: "Classifying and searching for patterns", variant: "caption" }] }] })
    }
    state analyzing {
      PATTERNS_FOUND -> reviewing
        (set @entity.reviewStatus reviewing)
        (agent/generate @entity.target)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Generating review...", variant: "h3" }, { type: "spinner"}, { type: "typography", content: "Category: @entity.category", variant: "caption" }] }] })
    }
    state reviewing {
      REVIEW_GENERATED -> completed
        (set @entity.reviewStatus completed)
        (agent/memorize @entity.target review-pattern)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Review Complete", variant: "h2" }] }, { type: "badge", label: "@entity.score" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.category" }, { type: "badge", label: "@entity.reviewStatus" }] }, { type: "typography", content: "Issues", variant: "h4" }, { type: "typography", content: "@entity.issues", variant: "body" }, { type: "divider" }, { type: "typography", content: "Suggestions", variant: "h4" }, { type: "typography", content: "@entity.suggestions", variant: "body" }] }] }, { type: "button", label: "New Review", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    state completed {
      RESET -> idle
        (set @entity.reviewStatus idle)
        (set @entity.target "")
        (set @entity.issues "[]")
        (set @entity.suggestions "[]")
        (set @entity.score 0)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-search"}, { type: "typography", content: "Code Review", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review.", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SUBMIT_REVIEW", fields: ["target"] }] }] }] }] })
    }
emits {
      ReviewLoaded
      ReviewLoadFailed
      ReviewRagSaved
      ReviewRagSaveFailed
      AnalysisSaved
      AnalysisSaveFailed
      ReviewCompletionSaved
      ReviewCompletionSaveFailed
    }

        listens {
      AnalysisOrbital.InputClassifier.CLASSIFIED -> SUBMIT_REVIEW
          ReviewLoadFailed { error : string, code : string }
          SUBMIT_REVIEW { target : string }
    
      ReviewRagSaveFailed { error : string, code : string }
      AnalysisSaveFailed { error : string, code : string }
      ReviewCompletionSaveFailed { error : string, code : string }
    }
  }
  page "/review" as ReviewPage -> ReviewGenerator
}
orbital ReviewRagOrbital {
  entity ReviewRag [runtime] {
    id : string!
    query : string
    context : string
    response : string
    memoryHits : number
    searchHits : number
    status : string
    error : string = ""
    content : string
    category : string = ""
    scope : string
    strength : number
    pinned : boolean
    language : string
    resultCount : number
    results : string
    prompt : string
    provider : string
    model : string
  }

  type ReviewRagLoaded     = Event { data : [ReviewRag] }                  "Fired when ReviewRag finishes loading"
  type ReviewRagLoadFailed = Event { error : string, code : string } "Fired when ReviewRag fails to load"
  type ReviewRagSaveFailed = Event { error : string, code : string }
  type ReviewRagSaved = Event { id : string }
  trait ReviewRagRag -> ReviewRag [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.query "")
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "RAG Pipeline", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter a query to retrieve context and generate a response", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "GENERATE", fields: ["query"] }] }] }] }] })
      GENERATE -> retrieving
        (set @entity.status retrieving)
        (agent/recall @entity.query 5)
        (agent/search-code @entity.query)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search"}, { type: "typography", content: "Retrieving context...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "Recalling memories" }, { type: "badge", label: "Searching code" }] }] }] })
    }
    state retrieving {
      RETRIEVAL_DONE -> generating
        (set @entity.context @payload.context)
        (set @entity.memoryHits @payload.memoryHits)
        (set @entity.searchHits @payload.searchHits)
        (set @entity.status generating)
        (agent/generate (str/concat "Context:\n" @entity.context "\n\nQuery: " @entity.query "\n\nProvide a comprehensive answer based on the retrieved context."))
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Generating response...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "@entity.memoryHits" }, { type: "badge", label: "@entity.searchHits" }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "RAG Pipeline Error", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state generating {
      GENERATION_DONE -> completed
        (set @entity.response @payload.response)
        (set @entity.status completed)
        (agent/memorize (str/concat "RAG query: " @entity.query) pattern-affinity)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "RAG Complete", variant: "h2" }] }, { type: "button", label: "New Query", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Memory Hits", value: "@entity.memoryHits", icon: "brain" }, { type: "stat-display", label: "Code Hits", value: "@entity.searchHits", icon: "code" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Query", variant: "caption" }, { type: "typography", content: "@entity.query", variant: "body" }, { type: "divider" }, { type: "typography", content: "Response", variant: "caption" }, { type: "typography", content: "@entity.response", variant: "body" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Retrieved Context", variant: "caption" }, { type: "typography", content: "@entity.context", variant: "body" }] }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "RAG Pipeline Error", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.context "")
        (set @entity.memoryHits 0)
        (set @entity.searchHits 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "RAG Pipeline", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Enter a query to retrieve context and generate a response", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "GENERATE", fields: ["query"] }] }] }] }] })
    }
    listens {
      RETRIEVAL_DONE { context : string, memoryHits : number, searchHits : number }
          FAILED { error : string }
          GENERATION_DONE { response : string }
      RagCompletionFlow.GENERATE -> GENERATE
    }
  }
  trait RagTabs -> ReviewRag [interaction, collection] {
    state idle {
      INIT -> idle
        (fetch ReviewRag { emit: { success: "ReviewRagLoaded", failure: "ReviewRagLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading RAG pipeline…" }] })
      ReviewRagLoaded -> idle
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain" }, { type: "typography", content: "RAG Pipeline", variant: "h2" }] }, { type: "divider" }, { type: "tabs", tabs: [{ label: "Query", value: "query" }, { label: "Sources", value: "sources" }, { label: "Response", value: "response" }], defaultActiveTab: "query", tabChangeEvent: "SELECT_TAB" }, { type: "divider" }, { type: "data-grid", entity: @payload.data, fields: [], className: "transition-shadow hover:shadow-md cursor-pointer", renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", variant: "h4", content: "@item.query" }, { type: "typography", variant: "caption", color: "muted", content: "@item.query" }] }] }] }] })
      ReviewRagLoadFailed -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load RAG pipeline" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
      SELECT_TAB -> idle
        (fetch ReviewRag { emit: { success: "ReviewRagLoaded", failure: "ReviewRagLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
emits {
      SELECT_TAB { tabId : string }
      ReviewRagLoaded
      ReviewRagLoadFailed
    }

        listens {
      ReviewRagLoadFailed { error : string, code : string }
      SELECT_TAB { tabId : string }
    }
  }
  trait RagMemoryLifecycle -> ReviewRag [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch ReviewRag { emit: { success: "ReviewRagLoaded", failure: "ReviewRagLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      ReviewRagLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "ReviewRag Manager", variant: "h2" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, fields: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "strength", label: "Strength", variant: "caption" }] }] }] })
      ReviewRagLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load reviewrag" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
emits {
      ReviewRagLoaded
      ReviewRagLoadFailed
    }

        listens {
      ReviewRagLoadFailed { error : string, code : string }
    }
  }
  trait RagSearchLifecycle -> ReviewRag [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch ReviewRag { emit: { success: "ReviewRagLoaded", failure: "ReviewRagLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      ReviewRagLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "search"}, { type: "typography", content: "ReviewRag", variant: "h2" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, fields: [{ name: "query", label: "Query", variant: "h4", icon: "search" }, { name: "language", label: "Language", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "resultCount", label: "Result Count", variant: "caption" }] }] }] })
      ReviewRagLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load reviewrag" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
emits {
      ReviewRagLoaded
      ReviewRagLoadFailed
    }

        listens {
      ReviewRagLoadFailed { error : string, code : string }
    }
  }
  trait RagCompletionFlow -> ReviewRag [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.model "")
        (set @entity.provider "")
        (fetch ReviewRag { emit: { success: "ReviewRagLoaded", failure: "ReviewRagLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewRag", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      GENERATE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewRag", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.provider" }, { type: "badge", label: "@entity.model" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["prompt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch ReviewRag { emit: { success: "ReviewRagLoaded", failure: "ReviewRagLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewRag", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create ReviewRag @payload.data { emit: { success: "ReviewRagSaved", failure: "ReviewRagSaveFailed" } })
        (render-ui modal null)
        (emit GENERATED)
        (fetch ReviewRag { emit: { success: "ReviewRagLoaded", failure: "ReviewRagLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewRag", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      SAVE -> internal
      GENERATED -> internal
      GENERATE
      ReviewRagLoadFailed
      ReviewRagLoaded
      ReviewRagSaveFailed
      ReviewRagSaved
    }
    listens {
      ReviewRagLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  page "/rag" -> ReviewRagRag
}
orbital AnalysisOrbital {
  entity Analysis [runtime] {
    id : string!
    input : string
    category : string = ""
    confidence : number
    model : string
    message : string
    notificationType : "info" | "success" | "warning" | "error" = "info"
  }

  type AnalysisLoaded     = Event { data : [Analysis] }                  "Fired when Analysis finishes loading"
  type AnalysisLoadFailed = Event { error : string, code : string } "Fired when Analysis fails to load"
  type AnalysisSaveFailed = Event { error : string, code : string }
  type AnalysisSaved = Event { id : string }
  trait InputClassifier -> Analysis [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch Analysis { emit: { success: "AnalysisLoaded", failure: "AnalysisLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Analysis", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      CLASSIFY -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Analysis", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "typography", variant: "caption", content: "Categories:" }, { type: "badge", label: "schema", variant: "secondary" }, { type: "badge", label: "component", variant: "secondary" }, { type: "badge", label: "trait", variant: "secondary" }, { type: "badge", label: "page", variant: "secondary" }, { type: "badge", label: "behavior", variant: "secondary" }, { type: "badge", label: "style", variant: "secondary" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["input"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch Analysis { emit: { success: "AnalysisLoaded", failure: "AnalysisLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Analysis", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create Analysis @payload.data { emit: { success: "AnalysisSaved", failure: "AnalysisSaveFailed" } })
        (render-ui modal null)
        (emit CLASSIFIED)
        (fetch Analysis { emit: { success: "AnalysisLoaded", failure: "AnalysisLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Analysis", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      CLASSIFIED -> internal { category: string }
      CLASSIFIED -> external { category: string }
      AnalysisLoadFailed
      AnalysisLoaded
      AnalysisSaveFailed
      AnalysisSaved
    }
    listens {
      AnalysisLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait AnalysisNotification -> Analysis [interaction, collection] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch Analysis { emit: { success: "AnalysisLoaded", failure: "AnalysisLoadFailed" } })
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Analysis Result", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Analysis Result", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] }] })
      HIDE -> hidden
        (set @entity.message "")
    }
emits {
      AnalysisLoaded
      AnalysisLoadFailed
    }

        listens {
      AnalysisLoadFailed { error : string, code : string }
      SHOW { message : string, notificationType : string }
    }
  }
  trait AnalysisAgent -> Analysis [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Analysis { emit: { success: "AnalysisLoaded", failure: "AnalysisLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "empty-state", icon: "tag", title: "Classifier", description: "Classifier is ready" }] })
      DO_CLASSIFY -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "schema, component, trait, page, behavior, style" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
      CLASSIFIED -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "schema, component, trait, page, behavior, style" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
    }
    state classifying {
      DO_CLASSIFY -> classified
        (set @entity.category @payload.data.input)
        (emit SHOW { message: "Input classified", notificationType: "success" })
    }
    state classified {
      RESET -> idle
        (set @entity.input "")
        (set @entity.category "")
        (set @entity.confidence 0)
    }
    emits {
      SHOW -> internal { message: string!, notificationType: "info" | "success" | "warning" | "error" }
      AnalysisLoaded
      AnalysisLoadFailed
    }
    listens {
      InputClassifier.CLASSIFIED -> CLASSIFIED
          AnalysisLoadFailed { error : string, code : string }
          DO_CLASSIFY { data : string }
    }
  }
  page "/analysis" -> InputClassifier
}
orbital ReviewCompletionOrbital {
  entity ReviewCompletion [runtime] {
    id : string!
    prompt : string
    response : string
    provider : string
    model : string
    status : string
    error : string = ""
    message : string
    notificationType : "info" | "success" | "warning" | "error" = "info"
  }

  type ReviewCompletionLoaded     = Event { data : [ReviewCompletion] }                  "Fired when ReviewCompletion finishes loading"
  type ReviewCompletionLoadFailed = Event { error : string, code : string } "Fired when ReviewCompletion fails to load"
  type ReviewCompletionSaveFailed = Event { error : string, code : string }
  type ReviewCompletionSaved = Event { id : string }
  trait ReviewCompletionFlow -> ReviewCompletion [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (set @entity.model "")
        (set @entity.provider "")
        (fetch ReviewCompletion { emit: { success: "ReviewCompletionLoaded", failure: "ReviewCompletionLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewCompletion", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      GENERATE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewCompletion", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.provider" }, { type: "badge", label: "@entity.model" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["prompt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch ReviewCompletion { emit: { success: "ReviewCompletionLoaded", failure: "ReviewCompletionLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewCompletion", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create ReviewCompletion @payload.data { emit: { success: "ReviewCompletionSaved", failure: "ReviewCompletionSaveFailed" } })
        (render-ui modal null)
        (emit GENERATED)
        (fetch ReviewCompletion { emit: { success: "ReviewCompletionLoaded", failure: "ReviewCompletionLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewCompletion", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      GENERATED
      ReviewCompletionLoadFailed
      ReviewCompletionLoaded
      ReviewCompletionSaveFailed
      ReviewCompletionSaved
    }
    listens {
      ReviewCompletionLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait ReviewCompletionNotification -> ReviewCompletion [interaction, collection] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch ReviewCompletion { emit: { success: "ReviewCompletionLoaded", failure: "ReviewCompletionLoadFailed" } })
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewCompletion Status", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "ReviewCompletion Status", variant: "h2" }] }, { type: "button", label: "Dismiss", action: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: "@entity.notificationType", message: "@entity.message" }, { type: "toast-slot" }, { type: "alert", variant: "warning", message: "@entity.message" }] }] })
      HIDE -> hidden
        (set @entity.message "")
    }
emits {
      ReviewCompletionLoaded
      ReviewCompletionLoadFailed
    }

        listens {
      ReviewCompletionLoadFailed { error : string, code : string }
      SHOW { message : string, notificationType : string }
    }
  }
  trait ReviewCompletionAgent -> ReviewCompletion [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ReviewCompletion { emit: { success: "ReviewCompletionLoaded", failure: "ReviewCompletionLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Code Reviewer", navItems: [{ label: "Review", href: "/review", icon: "file-search" }, { label: "Analysis", href: "/analysis", icon: "tag" }, { label: "Issues", href: "/issues", icon: "alert-triangle" }], children: [{ type: "empty-state", icon: "sparkles", title: "Completion", description: "Completion is ready" }] })
      DO_GENERATE -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
      GENERATED -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
    }
    state generating {
      DO_GENERATE -> completed
        (set @entity.response @payload.data.prompt)
        (set @entity.status completed)
        (emit SHOW { message: "Review complete", notificationType: "success" })
      RESET -> error when (= @entity.status generating)
        (set @entity.status error)
        (set @entity.error "Generation was cancelled")
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.prompt "")
    }
    state error {
      RETRY -> generating when (= @entity.status error)
        (set @entity.status generating)
        (set @entity.error "")
        (agent/generate @entity.prompt)
      RESET -> idle
        (set @entity.status idle)
        (set @entity.error "")
    }
    emits {
      SHOW -> internal { message: string!, notificationType: "info" | "success" | "warning" | "error" }
      ReviewCompletionLoaded
      ReviewCompletionLoadFailed
    }
    listens {
      ReviewCompletionFlow.GENERATED -> GENERATED
          ReviewCompletionLoadFailed { error : string, code : string }
          DO_GENERATE { data : string }
    }
  }
  page "/completion" -> ReviewCompletionFlow
}
orbital ReviewNavOrbital {
  uses Tabs from "std/behaviors/std-tabs"

  entity ReviewNav [runtime] {
    id : string!
    target : string = ""
    category : string = ""
    issues : string = "[]"
    suggestions : string = "[]"
    score : number = 0
    reviewStatus : string = "idle"
    error : string = ""
  }
  trait ReviewerTabs = Tabs.traits.TabsItemTabs -> Review {
  }
  page "/reviewer/nav" -> ReviewerTabs
}
orbital ReviewIssueOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity ReviewIssue [runtime] {
    id : string!
    description : string
    severity : string
    line : number
  }
  trait IssuesBrowse = Browse.traits.BrowseItemBrowse -> ReviewIssue {
  }
  page "/issues" -> IssuesBrowse
}
