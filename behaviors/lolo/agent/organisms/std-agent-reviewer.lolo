app std-agent-reviewer "1.0.0"
"Agent reviewer: code/doc review with RAG analysis and issue tracking."
type ItemSpec = { id : string, label : string!, value : string, icon : string }
orbital ReviewOrbital {
  uses Browse from "std/behaviors/std-browse"

  uses Tabs from "std/behaviors/std-tabs"

    type ReviewLoaded = Event { data : [Review] } "Fired when Review finishes loading"

    type ReviewLoadFailed = Event { error : string, code : string } "Fired when Review fails to load"

    type ReviewRagSaved = Event { id : string }

    type ReviewRagSaveFailed = Event { error : string, code : string }

    type AnalysisSaved = Event { id : string }

    type AnalysisSaveFailed = Event { error : string, code : string }

    type ReviewCompletionSaved = Event { id : string }

    type ReviewCompletionSaveFailed = Event { error : string, code : string }

  entity Review [runtime] {
    id : string!
    target : string @description "The item being reviewed." @synonyms "subject, item, targetObject" = ""
    category : string @description "Classification or type of the review." @synonyms "type, classification, kind" = ""
    issues : string @description "A textual description of identified problems or concerns." @synonyms "problems, concerns, defects, findings" = "[]"
    suggestions : string @description "Proposed improvements or recommendations for the reviewed item." @synonyms "recommendations, feedback, notes, advice" = "[]"
    score : number @description "A numerical value representing a rating or assessment." @synonyms "rating, value, measurement, grade" = 0
    reviewStatus : string @description "The current state of the review process." @synonyms "status, state, condition" = idle
    error : string @description "A textual description of an encountered error." @synonyms "problem, fault, issue, mistake" = ""
    activeTab : string @description "The currently selected tab within the interface." @synonyms "selection, current tab, tab" = ""
    items : [ItemSpec] @description "A list of items or elements being reviewed." @synonyms "elements, entries, details, components" = []
  }

  trait ReviewGenerator -> Review [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.category "")
        (fetch Review {
          emit: { failure: ReviewLoadFailed, success: ReviewLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{ name: file-search, type: icon }, {
                content: "Code Review"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review."
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (target)
                  mode: edit
                  submitEvent: SUBMIT_REVIEW
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      SUBMIT_REVIEW -> analyzing
        (set @entity.target ?target)
        (set @entity.reviewStatus analyzing)
        (agent/recall ?target)
        (agent/search-code ?target)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            align: center
            children: [{ name: search, type: icon }, {
              content: "Analyzing input..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              content: "Classifying and searching for patterns"
              type: typography
              variant: caption
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state analyzing {
      PATTERNS_FOUND -> reviewing
        (set @entity.reviewStatus reviewing)
        (agent/generate @entity.target)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            align: center
            children: [{ name: cpu, type: icon }, {
              content: "Generating review..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              content: "Category: @entity.category"
              type: typography
              variant: caption
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state reviewing {
      REVIEW_GENERATED -> completed
        (set @entity.reviewStatus completed)
        (agent/memorize @entity.target review-pattern)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: check-circle, type: icon }, {
                  content: "Review Complete"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, { label: @entity.score, type: badge }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  children: [{ label: @entity.category, type: badge }, { label: @entity.reviewStatus, type: badge }]
                  direction: horizontal
                  gap: sm
                  type: stack
                }, {
                  content: Issues
                  type: typography
                  variant: h4
                }, {
                  content: @entity.issues
                  type: typography
                  variant: body
                }, { type: divider }, {
                  content: Suggestions
                  type: typography
                  variant: h4
                }, {
                  content: @entity.suggestions
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }, {
              action: RESET
              icon: rotate-ccw
              label: "New Review"
              type: button
              variant: ghost
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state completed {
      RESET -> idle
        (set @entity.reviewStatus idle)
        (set @entity.target "")
        (set @entity.issues "[]")
        (set @entity.suggestions "[]")
        (set @entity.score 0)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{ name: file-search, type: icon }, {
                content: "Code Review"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Paste schema or code to review. The agent will classify, search for patterns, and generate a structured review."
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (target)
                  mode: edit
                  submitEvent: SUBMIT_REVIEW
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    emits {
      ReviewLoaded
      ReviewLoadFailed
      ReviewRagSaved
      ReviewRagSaveFailed
      AnalysisSaved
      AnalysisSaveFailed
      ReviewCompletionSaved
      ReviewCompletionSaveFailed
    }

    listens {
      AnalysisOrbital.InputClassifier.CLASSIFIED -> SUBMIT_REVIEW
      ReviewLoadFailed {
        error : string
        code : string
      }
      SUBMIT_REVIEW {
        target : string
      }
      ReviewRagSaveFailed {
        error : string
        code : string
      }
      AnalysisSaveFailed {
        error : string
        code : string
      }
      ReviewCompletionSaveFailed {
        error : string
        code : string
      }
    }
  }

  page "/review" as ReviewPage -> ReviewGenerator
}

orbital ReviewRagOrbital {
    type ReviewRagLoaded = Event { data : [ReviewRag] } "Fired when ReviewRag finishes loading"

    type ReviewRagLoadFailed = Event { error : string, code : string } "Fired when ReviewRag fails to load"

    type ReviewRagSaveFailed = Event { error : string, code : string }

    type ReviewRagSaved = Event { id : string }

  entity ReviewRag [runtime] {
    id : string!
    query : string @description "The text used to initiate the review process." @synonyms "search term, request, question, input"
    context : string @description "Background information or surrounding details." @synonyms "details, background, information, surrounding"
    response : string @description "The text-based output generated by the agent." @synonyms "output, text, answer, result"
    memoryHits : number @description "The number of memory-related search results." @synonyms "count, hits, number, quantity"
    searchHits : number @description "The number of results found during a search." @synonyms "count, hits, result count"
    status : string @description "The current state or condition of the review process." @synonyms "state, condition, progress"
    error : string @description "A textual description of an error encountered." @synonyms "problem, fault, issue, mistake" = ""
    content : string @description "The main text or data of the review." @synonyms "text, body, data, details"
    category : string @description "Classification or type of the review." @synonyms "type, kind, classification" = ""
    scope : string @description "The area or boundaries of the review's focus." @synonyms "area, range, boundaries, focus"
    strength : number @description "A numerical value representing the level of confidence or intensity." @synonyms "intensity, magnitude, value, level"
    pinned : boolean @description "Indicates whether the review is marked as important." @synonyms "flagged, highlighted, starred"
    language : string @description "The language used for the content being reviewed." @synonyms "locale, languageCode, languageTag"
    resultCount : number @description "The total number of results retrieved." @synonyms "count, total, size, quantity"
    results : string @description "The outcome or findings of the review process." @synonyms "outcome, findings, output, report"
    prompt : string @description "The text used as input for the review process." @synonyms "query, input, question, request"
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, vendor"
    model : string @description "The identifier of the language model used." @synonyms "modelName, llm, aiModel"
  }

  trait ReviewRagRag -> ReviewRag [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.query "")
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{ name: brain, type: icon }, {
                content: "RAG Pipeline"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Enter a query to retrieve context and generate a response"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (query)
                  mode: edit
                  submitEvent: GENERATE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      GENERATE -> retrieving
        (set @entity.status retrieving)
        (agent/recall @entity.query 5)
        (agent/search-code @entity.query)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            align: center
            children: [{ name: search, type: icon }, {
              content: "Retrieving context..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              children: [{
                label: "Recalling memories"
                type: badge
              }, {
                label: "Searching code"
                type: badge
              }]
              direction: horizontal
              gap: md
              justify: center
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state retrieving {
      RETRIEVAL_DONE -> generating
        (set @entity.context ?context)
        (set @entity.memoryHits ?memoryHits)
        (set @entity.searchHits ?searchHits)
        (set @entity.status generating)
        (agent/generate (str/concat "Context:\n" @entity.context "\n\nQuery: " @entity.query "\n\nProvide a comprehensive answer based on the retrieved context."))
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            align: center
            children: [{ name: cpu, type: icon }, {
              content: "Generating response..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              children: [{ label: @entity.memoryHits, type: badge }, { label: @entity.searchHits, type: badge }]
              direction: horizontal
              gap: md
              justify: center
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "RAG Pipeline Error"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state generating {
      GENERATION_DONE -> completed
        (set @entity.response ?response)
        (set @entity.status completed)
        (agent/memorize (str/concat "RAG query: " @entity.query) pattern-affinity)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: check-circle, type: icon }, {
                  content: "RAG Complete"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                action: RESET
                icon: rotate-ccw
                label: "New Query"
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                icon: brain
                label: "Memory Hits"
                type: stat-display
                value: @entity.memoryHits
              }, {
                icon: code
                label: "Code Hits"
                type: stat-display
                value: @entity.searchHits
              }]
              cols: 2
              type: simple-grid
            }, { type: divider }, {
              children: [{
                children: [{
                  content: Query
                  type: typography
                  variant: caption
                }, {
                  content: @entity.query
                  type: typography
                  variant: body
                }, { type: divider }, {
                  content: Response
                  type: typography
                  variant: caption
                }, {
                  content: @entity.response
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }, {
              children: [{
                children: [{
                  content: "Retrieved Context"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.context
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "RAG Pipeline Error"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.context "")
        (set @entity.memoryHits 0)
        (set @entity.searchHits 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{ name: brain, type: icon }, {
                content: "RAG Pipeline"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Enter a query to retrieve context and generate a response"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (query)
                  mode: edit
                  submitEvent: GENERATE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    listens {
      RETRIEVAL_DONE {
        context : string
        memoryHits : number
        searchHits : number
      }
      FAILED {
        error : string
      }
      GENERATION_DONE {
        response : string
      }
      RagCompletionFlow.GENERATE -> GENERATE
    }
  }

  trait RagTabs -> ReviewRag [interaction, collection] {
    state idle {
      INIT -> idle
        (fetch ReviewRag {
          emit: { failure: ReviewRagLoadFailed, success: ReviewRagLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading RAG pipeline…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      ReviewRagLoaded -> idle
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{ name: brain, type: icon }, {
                content: "RAG Pipeline"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              defaultActiveTab: query
              tabChangeEvent: SELECT_TAB
              tabs: [{ label: Query, value: query }, { label: Sources, value: sources }, { label: Response, value: response }]
              type: tabs
            }, { type: divider }, {
              className: "transition-shadow hover:shadow-md cursor-pointer"
              entity: ?data
              fields: []
              renderItem: (fn item {
                children: [{
                  content: @item.query
                  type: typography
                  variant: h4
                }, {
                  color: muted
                  content: @item.query
                  type: typography
                  variant: caption
                }]
                direction: vertical
                gap: sm
                type: stack
              })
              type: data-grid
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      ReviewRagLoadFailed -> idle
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load RAG pipeline"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      SELECT_TAB -> idle
        (fetch ReviewRag {
          emit: { failure: ReviewRagLoadFailed, success: ReviewRagLoaded }
        })
        (render-ui main { type: spinner })
    }

    emits {
      SELECT_TAB {
        tabId : string
      }
      ReviewRagLoaded
      ReviewRagLoadFailed
    }

    listens {
      ReviewRagLoadFailed {
        error : string
        code : string
      }
      SELECT_TAB {
        tabId : string
      }
    }
  }

  trait RagMemoryLifecycle -> ReviewRag [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch ReviewRag {
          emit: { failure: ReviewRagLoadFailed, success: ReviewRagLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      ReviewRagLoaded -> browsing
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: brain, type: icon }, {
                  content: "ReviewRag Manager"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: brain
                label: Content
                name: content
                variant: h4
              }, {
                colorMap: {
                  active: success
                  archived: neutral
                  cancelled: destructive
                  completed: success
                  disabled: neutral
                  done: success
                  draft: warning
                  error: destructive
                  failed: destructive
                  inactive: neutral
                  pending: warning
                  scheduled: warning
                }
                label: Category
                name: category
                variant: badge
              }, {
                label: Strength
                name: strength
                variant: caption
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      ReviewRagLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load reviewrag"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      ReviewRagLoaded
      ReviewRagLoadFailed
    }

    listens {
      ReviewRagLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait RagSearchLifecycle -> ReviewRag [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch ReviewRag {
          emit: { failure: ReviewRagLoadFailed, success: ReviewRagLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      ReviewRagLoaded -> browsing
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: search, type: icon }, {
                  content: ReviewRag
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: search
                label: Query
                name: query
                variant: h4
              }, {
                colorMap: {
                  active: success
                  archived: neutral
                  cancelled: destructive
                  completed: success
                  disabled: neutral
                  done: success
                  draft: warning
                  error: destructive
                  failed: destructive
                  inactive: neutral
                  pending: warning
                  scheduled: warning
                }
                label: Language
                name: language
                variant: badge
              }, {
                label: "Result Count"
                name: resultCount
                variant: caption
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      ReviewRagLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load reviewrag"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      ReviewRagLoaded
      ReviewRagLoadFailed
    }

    listens {
      ReviewRagLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait RagCompletionFlow -> ReviewRag [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.model "")
        (set @entity.provider "")
        (fetch ReviewRag {
          emit: { failure: ReviewRagLoadFailed, success: ReviewRagLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: ReviewRag
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      GENERATE -> open
        (render-ui modal {
          children: [{
            children: [{ name: sparkles, type: icon }, {
              content: ReviewRag
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{ label: @entity.provider, type: badge }, { label: @entity.model, type: badge }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (prompt)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch ReviewRag {
          emit: { failure: ReviewRagLoadFailed, success: ReviewRagLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: ReviewRag
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create ReviewRag ?data {
          emit: { failure: ReviewRagSaveFailed, success: ReviewRagSaved }
        })
        (render-ui modal null)
        (emit GENERATED)
        (fetch ReviewRag {
          emit: { failure: ReviewRagLoadFailed, success: ReviewRagLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: ReviewRag
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    emits {
      SAVE -> internal
      GENERATED -> internal
      GENERATE
      ReviewRagLoadFailed
      ReviewRagLoaded
      ReviewRagSaveFailed
      ReviewRagSaved
    }

    listens {
      ReviewRagLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
    }
  }

  page "/rag" -> ReviewRagRag
}

orbital AnalysisOrbital {
    type AnalysisLoaded = Event { data : [Analysis] } "Fired when Analysis finishes loading"

    type AnalysisLoadFailed = Event { error : string, code : string } "Fired when Analysis fails to load"

    type AnalysisSaveFailed = Event { error : string, code : string }

    type AnalysisSaved = Event { id : string }

  entity Analysis [runtime] {
    id : string!
    input : string @description "The text or data provided as initial input." @synonyms "data, source, text, content"
    category : string @description "Classification or type of the review." @synonyms "type, classification, kind" = ""
    confidence : number @description "A numerical value representing the certainty of a result." @synonyms "probability, certainty, likelihood, trust"
    model : string @description "The identifier of the language model used." @synonyms "modelName, llm, aiModel"
    message : string @description "Textual feedback or a comment related to the review." @synonyms "comment, note, remark, feedback"
    notificationType : "info" | "success" | "warning" | "error" @description "Type of notification generated by the review process." @synonyms "alert type, notification level, message type" = info
  }

  trait InputClassifier -> Analysis [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch Analysis {
          emit: { failure: AnalysisLoadFailed, success: AnalysisLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: Analysis
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      CLASSIFY -> open
        (render-ui modal {
          children: [{
            children: [{ name: tag, type: icon }, {
              content: Analysis
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              content: "Categories:"
              type: typography
              variant: caption
            }, {
              label: schema
              type: badge
              variant: secondary
            }, {
              label: component
              type: badge
              variant: secondary
            }, {
              label: trait
              type: badge
              variant: secondary
            }, {
              label: page
              type: badge
              variant: secondary
            }, {
              label: behavior
              type: badge
              variant: secondary
            }, {
              label: style
              type: badge
              variant: secondary
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (input)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch Analysis {
          emit: { failure: AnalysisLoadFailed, success: AnalysisLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: Analysis
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create Analysis ?data {
          emit: { failure: AnalysisSaveFailed, success: AnalysisSaved }
        })
        (render-ui modal null)
        (emit CLASSIFIED)
        (fetch Analysis {
          emit: { failure: AnalysisLoadFailed, success: AnalysisLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: Analysis
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    emits {
      CLASSIFIED -> internal {
        category : string
      }
      CLASSIFIED -> external {
        category : string
      }
      AnalysisLoadFailed
      AnalysisLoaded
      AnalysisSaveFailed
      AnalysisSaved
    }

    listens {
      AnalysisLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
    }
  }

  trait AnalysisNotification -> Analysis [interaction, collection] {
    initial: hidden

    state hidden {
      INIT -> hidden
        (fetch Analysis {
          emit: { failure: AnalysisLoadFailed, success: AnalysisLoaded }
        })
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: tag, type: icon }, {
                  content: "Analysis Result"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: HIDE
                icon: x
                label: Dismiss
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              message: @entity.message
              type: alert
              variant: @entity.notificationType
            }, { type: toast-slot }, {
              message: @entity.message
              type: alert
              variant: warning
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state visible {
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: tag, type: icon }, {
                  content: "Analysis Result"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: HIDE
                icon: x
                label: Dismiss
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              message: @entity.message
              type: alert
              variant: @entity.notificationType
            }, { type: toast-slot }, {
              message: @entity.message
              type: alert
              variant: warning
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      HIDE -> hidden
        (set @entity.message "")
    }

    emits {
      AnalysisLoaded
      AnalysisLoadFailed
    }

    listens {
      AnalysisLoadFailed {
        error : string
        code : string
      }
      SHOW {
        message : string
        notificationType : string
      }
    }
  }

  trait AnalysisAgent -> Analysis [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch Analysis {
          emit: { failure: AnalysisLoadFailed, success: AnalysisLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            description: "Classifier is ready"
            icon: tag
            title: Classifier
            type: empty-state
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      DO_CLASSIFY -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "schema, component, trait, page, behavior, style" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
      CLASSIFIED -> classifying
        (agent/generate (str/concat "Classify the following text into one of these categories: " "schema, component, trait, page, behavior, style" ". Text: " @entity.input ". Respond with JSON: {\"category\": \"...\", \"confidence\": 0.0-1.0}"))
    }

    state classifying {
      DO_CLASSIFY -> classified
        (set @entity.category ?data.input)
        (emit SHOW {
          message: "Input classified"
          notificationType: success
        })
    }

    state classified {
      RESET -> idle
        (set @entity.input "")
        (set @entity.category "")
        (set @entity.confidence 0)
    }

    emits {
      SHOW -> internal {
        message : string!
        notificationType : "info" | "success" | "warning" | "error"
      }
      AnalysisLoaded
      AnalysisLoadFailed
    }

    listens {
      InputClassifier.CLASSIFIED -> CLASSIFIED
      AnalysisLoadFailed {
        error : string
        code : string
      }
      DO_CLASSIFY {
        data : string
      }
    }
  }

  page "/analysis" -> InputClassifier
}

orbital ReviewCompletionOrbital {
    type ReviewCompletionLoaded = Event { data : [ReviewCompletion] } "Fired when ReviewCompletion finishes loading"

    type ReviewCompletionLoadFailed = Event { error : string, code : string } "Fired when ReviewCompletion fails to load"

    type ReviewCompletionSaveFailed = Event { error : string, code : string }

    type ReviewCompletionSaved = Event { id : string }

  entity ReviewCompletion [runtime] {
    id : string!
    prompt : string @description "The text used to initiate the review process." @synonyms "query, request, instruction"
    response : string @description "The text-based output generated by the agent." @synonyms "output, answer, text, result"
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, vendor"
    model : string @description "The identifier of the language model used." @synonyms "modelName, llm, aiModel"
    status : string @description "The current state or condition of the review process." @synonyms "state, condition, progress"
    error : string @description "A textual description of an error or problem encountered." @synonyms "problem, fault, issue, mistake" = ""
    message : string @description "The text of a notification or feedback message." @synonyms "text, content, note, comment"
    notificationType : "info" | "success" | "warning" | "error" @description "Type of notification generated by the review process." @synonyms "alert type, notification level, message type" = info
  }

