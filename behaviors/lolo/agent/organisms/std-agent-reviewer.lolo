            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    emits {
      GENERATED
      ReviewCompletionLoadFailed
      ReviewCompletionLoaded
      ReviewCompletionSaveFailed
      ReviewCompletionSaved
    }

    listens {
      ReviewCompletionLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
    }
  }

  trait ReviewCompletionNotification -> ReviewCompletion [interaction, collection] {
    initial: hidden

    state hidden {
      INIT -> hidden
        (fetch ReviewCompletion {
          emit: { failure: ReviewCompletionLoadFailed, success: ReviewCompletionLoaded }
        })
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: sparkles, type: icon }, {
                  content: "ReviewCompletion Status"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: HIDE
                icon: x
                label: Dismiss
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              message: @entity.message
              type: alert
              variant: @entity.notificationType
            }, { type: toast-slot }, {
              message: @entity.message
              type: alert
              variant: warning
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
    }

    state visible {
      SHOW -> visible
        (set @entity.message ?message)
        (set @entity.notificationType ?notificationType)
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: sparkles, type: icon }, {
                  content: "ReviewCompletion Status"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: HIDE
                icon: x
                label: Dismiss
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              message: @entity.message
              type: alert
              variant: @entity.notificationType
            }, { type: toast-slot }, {
              message: @entity.message
              type: alert
              variant: warning
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      HIDE -> hidden
        (set @entity.message "")
    }

    emits {
      ReviewCompletionLoaded
      ReviewCompletionLoadFailed
    }

    listens {
      ReviewCompletionLoadFailed {
        error : string
        code : string
      }
      SHOW {
        message : string
        notificationType : string
      }
    }
  }

  trait ReviewCompletionAgent -> ReviewCompletion [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ReviewCompletion {
          emit: { failure: ReviewCompletionLoadFailed, success: ReviewCompletionLoaded }
        })
        (render-ui main {
          appName: "Code Reviewer"
          children: [{
            description: "Completion is ready"
            icon: sparkles
            title: Completion
            type: empty-state
          }]
          navItems: [{
            href: "/review"
            icon: file-search
            label: Review
          }, {
            href: "/analysis"
            icon: tag
            label: Analysis
          }, {
            href: "/issues"
            icon: alert-triangle
            label: Issues
          }]
          type: dashboard-layout
        })
      DO_GENERATE -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
      GENERATED -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
    }

    state generating {
      DO_GENERATE -> completed
        (set @entity.response ?data.prompt)
        (set @entity.status completed)
        (emit SHOW {
          message: "Review complete"
          notificationType: success
        })
      RESET -> error when ["=", @entity.status, generating]
        (set @entity.status error)
        (set @entity.error "Generation was cancelled")
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.prompt "")
    }

    state error {
      RETRY -> generating when ["=", @entity.status, error]
        (set @entity.status generating)
        (set @entity.error "")
        (agent/generate @entity.prompt)
      RESET -> idle
        (set @entity.status idle)
        (set @entity.error "")
    }

    emits {
      SHOW -> internal {
        message : string!
        notificationType : "info" | "success" | "warning" | "error"
      }
      ReviewCompletionLoaded
      ReviewCompletionLoadFailed
    }

    listens {
      ReviewCompletionFlow.GENERATED -> GENERATED
      ReviewCompletionLoadFailed {
        error : string
        code : string
      }
      DO_GENERATE {
        data : string
      }
    }
  }

  page "/completion" -> ReviewCompletionFlow
}

orbital ReviewNavOrbital {
  uses Tabs from "std/behaviors/std-tabs"

  entity ReviewNav [runtime] {
    id : string!
    target : string @description "The item being reviewed." @synonyms "subject, item, focus" = ""
    category : string @description "Classification or type of the review." @synonyms "type, classification, kind" = ""
    issues : string @description "A textual representation of identified problems or concerns." @synonyms "problems, concerns, defects, findings" = "[]"
    suggestions : string @description "Recommendations or proposed improvements." @synonyms "recommendations, proposals, hints, advice" = "[]"
    score : number @description "A numerical value representing a rating or assessment." @synonyms "rating, value, grade, assessment" = 0
    reviewStatus : string @description "The current state of the review process." @synonyms "status, state, condition" = idle
    error : string @description "A textual description of an encountered error." @synonyms "problem, fault, issue, mistake" = ""
  }

  trait ReviewerTabs = Tabs.traits.TabsItemTabs -> Review {
  }

  page "/reviewer/nav" -> ReviewerTabs
}

orbital ReviewIssueOrbital {
  uses Browse from "std/behaviors/std-browse"

  entity ReviewIssue [runtime] {
    id : string!
    description : string @description "A textual explanation or summary of the review." @synonyms "summary, details, notes, explanation"
    severity : string @description "Indicates the seriousness or impact of a finding." @synonyms "priority, impact, level"
    line : number @description "The position of the element within a larger structure." @synonyms "position, index, number, sequence"
  }

  trait IssuesBrowse = Browse.traits.BrowseItemBrowse -> ReviewIssue {
  }

  page "/issues" -> IssuesBrowse
}