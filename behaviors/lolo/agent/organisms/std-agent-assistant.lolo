app std-agent-assistant "1.0.0"
"Agent chat assistant: conversation, persistent memory, provider config (ChatGPT-style)."
orbital AssistantOrbital {
    type AssistantLoaded = Event { data : [Assistant] } "Fired when Assistant finishes loading"

    type AssistantLoadFailed = Event { error : string, code : string } "Fired when Assistant fails to load"

    type AssistantDeleted = Event { id : string }

    type AssistantDeleteFailed = Event { error : string, code : string }

    type MemorySaved = Event { id : string }

    type MemorySaveFailed = Event { error : string, code : string }

    type ProviderConfigUpdated = Event { id : string }

    type ProviderConfigUpdateFailed = Event { error : string, code : string }

  entity Assistant [runtime] {
    id : string!
    messages : string @description "A sequence of text representing a conversation." @synonyms "conversation, transcript, dialogue, chat" = ""
    currentMessage : string @description "The text of the most recent message in the conversation." @synonyms "text, body, content" = ""
    response : string @description "The text generated as an output." @synonyms "reply, answer, output, result" = ""
    memoryCount : number @description "The number of memory entries." @synonyms "count, size, quantity" = 0
    contextUsage : number @description "Represents the amount of context utilized." @synonyms "usage, consumption, utilization" = 0
    provider : string @description "Specifies the external service or system used." @synonyms "service, source, backend" = default
    sessionId : string @description "Unique identifier for a user's session." @synonyms "session, sessionID" = ""
    status : string @description "Indicates the current operational state of the component." @synonyms "state, condition, mode" = idle
    error : string @description "Details about any errors encountered during operation." @synonyms "issue, problem, fault, exception" = ""
    turnCount : number @description "The number of interactions in the conversation." @synonyms "interaction count, round number, sequence number" = 0
    lastMessage : string @description "The text of the most recent message." @synonyms "last, recent, previous" = ""
    tokenCount : number @description "The number of tokens used." @synonyms "count, quantity, total" = 0
    role : string @description "Specifies the function or identity within the interaction." @synonyms "function, identity, persona, type" = user
    content : string @description "The text of the message or content being processed." @synonyms "text, body, data" = ""
    timestamp : string @description "Date and time when the event occurred." @synonyms "date, time, when" = ""
    toolName : string @description "Name of the tool utilized by the assistant." @synonyms "tool, function, action" = ""
  }

  trait AssistantConversation -> Assistant [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch Assistant {
          emit: { failure: AssistantLoadFailed, success: AssistantLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading assistant…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      AssistantLoaded -> idle
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: message-circle, type: icon }, {
                  content: "Assistant Thread"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                action: COMPOSE
                icon: plus
                label: "New Message"
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: []
              renderItem: (fn item {
                children: [{
                  align: center
                  children: [{ label: @item.role, type: badge }, {
                    label: @item.status
                    type: badge
                    variant: secondary
                  }, {
                    color: muted
                    content: @item.timestamp
                    type: typography
                    variant: caption
                  }]
                  direction: horizontal
                  gap: sm
                  type: stack
                }, {
                  content: @item.content
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: xs
                type: stack
              })
              type: data-list
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/chat"
            icon: message-circle
            label: Chat
          }, {
            href: "/memory"
            icon: brain
            label: Memory
          }, {
            href: "/settings"
            icon: settings
            label: Settings
          }]
          type: dashboard-layout
        })
      AssistantLoadFailed -> idle
        (render-ui main {
          align: center
          children: [{
            color: error
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load assistant"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      COMPOSE -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{ name: message-circle, type: icon }, {
              content: "Assistant Thread"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            cancelEvent: CANCEL_COMPOSE
            fields: (content)
            mode: create
            submitEvent: SEND
            type: form-section
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      CLEAR -> idle
        (persist delete Assistant {
          emit: { failure: AssistantDeleteFailed, success: AssistantDeleted }
        })
        (fetch Assistant {
          emit: { failure: AssistantLoadFailed, success: AssistantLoaded }
        })
        (render-ui main { type: spinner })
    }

    state composing {
      SEND -> idle
        (persist create Assistant {
          content: ?content
          role: user
          status: sent
          timestamp: @now
        } {
          emit: { success: SEND_MESSAGE }
        })
        (fetch Assistant {
          emit: { failure: AssistantLoadFailed, success: AssistantLoaded }
        })
        (render-ui main { type: spinner })
      CANCEL_COMPOSE -> idle
        (fetch Assistant {
          emit: { failure: AssistantLoadFailed, success: AssistantLoaded }
        })
        (render-ui main { type: spinner })
      CLEAR -> idle
        (persist delete Assistant {
          emit: { failure: AssistantDeleteFailed, success: AssistantDeleted }
        })
        (fetch Assistant {
          emit: { failure: AssistantLoadFailed, success: AssistantLoaded }
        })
        (render-ui main { type: spinner })
    }

    emits {
      SEND_MESSAGE -> internal {
        content : string
      }
      MEMORIZE_RESPONSE -> internal {
        content : string
      }
      MEMORIZE_RESPONSE -> external {
        content : string
      }
      AssistantLoaded
      AssistantLoadFailed
      AssistantDeleted
      AssistantDeleteFailed
      MemorySaved
      MemorySaveFailed
      ProviderConfigUpdated
      ProviderConfigUpdateFailed
    }

    listens {
      ProviderConfigOrbital.ProviderManager.PROVIDER_CHANGED -> INIT
      SEND {
        content : string!
      }
      AssistantLoadFailed {
        error : string
        code : string
      }
      AssistantDeleteFailed {
        error : string
        code : string
      }
      MemorySaveFailed {
        error : string
        code : string
      }
      ProviderConfigUpdateFailed {
        error : string
        code : string
      }
    }
  }

  trait AssistantAgent -> Assistant [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch Assistant {
          emit: { failure: AssistantLoadFailed, success: AssistantLoaded }
        })
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            description: "Conversation is ready"
            icon: message-circle
            title: Conversation
            type: empty-state
          }]
          navItems: [{
            href: "/chat"
            icon: message-circle
            label: Chat
          }, {
            href: "/memory"
            icon: brain
            label: Memory
          }, {
            href: "/settings"
            icon: settings
            label: Settings
          }]
          type: dashboard-layout
        })
      SEND_MESSAGE -> active
        (set @entity.lastMessage ?content)
        (set @entity.turnCount ["+", @entity.turnCount, 1])
        (agent/generate ?content)
        (emit TOKEN_UPDATE)
    }

    state active {
      SEND_MESSAGE -> active
        (set @entity.lastMessage ?content)
        (set @entity.turnCount ["+", @entity.turnCount, 1])
        (agent/generate ?content)
        (emit TOKEN_UPDATE)
      PAUSE -> paused
      CLEAR -> idle
        (set @entity.messages "")
        (set @entity.turnCount 0)
        (set @entity.lastMessage "")
        (set @entity.tokenCount 0)
    }

    state paused {
      RESUME -> active
      CLEAR -> idle
        (set @entity.messages "")
        (set @entity.turnCount 0)
        (set @entity.lastMessage "")
        (set @entity.tokenCount 0)
    }

    emits {
      TOKEN_UPDATE -> internal {
        tokenCount : number
      }
      AssistantLoaded
      AssistantLoadFailed
    }

    listens {
      SEND_MESSAGE {
        content : string!
      }
      AssistantLoadFailed {
        error : string
        code : string
      }
    }
  }

  page "/chat" as ChatPage -> AssistantConversation
}

orbital MemoryOrbital {
    type MemoryLoaded = Event { data : [Memory] } "Fired when Memory finishes loading"

    type MemoryLoadFailed = Event { error : string, code : string } "Fired when Memory fails to load"

    type MemorySaveFailed = Event { error : string, code : string }

    type MemorySaved = Event { id : string }

  entity Memory [persistent: memorys] {
    id : string!
    content : string @description "The text content of a message or data item." @synonyms "text, body, data, value" = ""
    category : string @description "Classification or type of the item." @synonyms "type, class, kind"
    strength : number @description "Numerical value representing a level or intensity." @synonyms "level, intensity, power, score"
    pinned : boolean @description "Indicates whether the item is marked as important." @synonyms "flagged, marked, important"
    scope : string @description "Defines the area or subject of the conversation." @synonyms "topic, subject, area, domain"
    lastAccessedAt : string @description "Timestamp of the last access or usage." @synonyms "accessed, last used, accessed time"
    createdAt : string
  }

  trait MemoryBrowse -> Memory [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Memory {
          emit: { failure: MemoryLoadFailed, success: MemoryLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      MemoryLoaded -> browsing
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: brain, type: icon }, {
                  content: "Memory Manager"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                children: [{
                  action: MEMORIZE
                  icon: plus
                  label: Memorize
                  type: button
                  variant: primary
                }, {
                  action: RECALL
                  icon: search
                  label: Recall
                  type: button
                  variant: secondary
                }, {
                  action: DECAY
                  icon: clock
                  label: "Decay All"
                  type: button
                  variant: ghost
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: brain
                label: Content
                name: content
                variant: h4
              }, {
                colorMap: {
                  active: success
                  archived: neutral
                  cancelled: error
                  completed: success
                  disabled: neutral
                  done: success
                  draft: warning
                  error: error
                  failed: error
                  inactive: neutral
                  pending: warning
                  scheduled: warning
                }
                label: Category
                name: category
                variant: badge
              }, {
                label: Strength
                name: strength
                variant: caption
              }]
              itemActions: [{
                event: PIN
                label: Pin
                variant: ghost
              }, {
                event: REINFORCE
                label: Reinforce
                variant: ghost
              }, {
                event: FORGET
                label: Forget
                variant: danger
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/chat"
            icon: message-circle
            label: Chat
          }, {
            href: "/memory"
            icon: brain
            label: Memory
          }, {
            href: "/settings"
            icon: settings
            label: Settings
          }]
          type: dashboard-layout
        })
      MemoryLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: error
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load memory"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      MEMORIZE
      RECALL
      DECAY
      PIN {
        id : string!
        row : Memory
      }
      REINFORCE {
        id : string!
        row : Memory
      }
      FORGET {
        id : string!
        row : Memory
      }
      MemoryLoaded
      MemoryLoadFailed
    }

    listens {
      MemoryCreate.MEMORIZED -> INIT
      MemoryAgent.PINNED -> INIT
      MemoryAgent.FORGOT -> INIT
      MemoryAgent.REINFORCED -> INIT
      MemoryAgent.DECAYED -> INIT
      MemoryLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait MemoryCreate -> Memory [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch Memory {
          emit: { failure: MemoryLoadFailed, success: MemoryLoaded }
        })
      MEMORIZE -> open
        (render-ui modal {
          children: [{
            children: [{ name: plus-circle, type: icon }, {
              content: Memorize
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            cancelEvent: CLOSE
            fields: (content category scope)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Memory ?data {
          emit: { failure: MemorySaveFailed, success: MemorySaved }
        })
        (render-ui modal null)
        (render-ui main { type: box })
        (emit MEMORIZED)
    }

    emits {
      MEMORIZED
      MemoryLoadFailed
      MemoryLoaded
      MemorySaveFailed
      MemorySaved
    }

    listens {
      MemoryLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
      MemoryBrowse.MEMORIZE -> MEMORIZE
    }
  }

  trait MemoryAgent -> Memory [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch Memory {
          emit: { failure: MemoryLoadFailed, success: MemoryLoaded }
        })
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            description: "Memory is ready"
            icon: brain
            title: Memory
            type: empty-state
          }]
          navItems: [{
            href: "/chat"
            icon: message-circle
            label: Chat
          }, {
            href: "/memory"
            icon: brain
            label: Memory
          }, {
            href: "/settings"
            icon: settings
            label: Settings
          }]
          type: dashboard-layout
        })
      DO_MEMORIZE -> active
        (agent/memorize ?data.content ?data.category)
        (persist create Memory ?data {
          emit: { failure: MemorySaveFailed, success: MemorySaved }
        })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED)
      MEMORIZED -> active
        (fetch Memory {
          emit: { failure: MemoryLoadFailed, success: MemoryLoaded }
        })
    }

    state active {
      RECALL -> active
        (agent/recall ?query)
      PIN -> active when (not (agent/is-pinned ?id))
        (agent/pin ?id)
        (set @entity.pinned true)
        (emit PINNED)
      FORGET -> idle
        (agent/forget ?id)
        (emit FORGOT)
      REINFORCE -> active
        (agent/reinforce ?id)
        (emit REINFORCED)
      DECAY -> active
        (agent/decay)
        (emit DECAYED)
    }

    emits {
      FORGOT -> external {
        id : string
      }
      REINFORCED -> external {
        id : string
      }
      DECAYED -> external {
        id : string
      }
      PINNED -> external {
        id : string
      }
      MemoryLoadFailed
      MemoryLoaded
      MemorySaveFailed
      MemorySaved
    }

    listens {
      AssistantOrbital.AssistantConversation.MEMORIZE_RESPONSE -> DO_MEMORIZE
      MemoryLoadFailed {
        error : string
        code : string
      }
      DO_MEMORIZE {
        data : string
      }
      RECALL {
        query : string
      }
      PIN {
        id : string
      }
      FORGET {
        id : string
      }
      REINFORCE {
        id : string
      }
      MemoryBrowse.RECALL -> RECALL
      MemoryBrowse.DECAY -> DECAY
      MemoryBrowse.PIN -> PIN
      MemoryBrowse.REINFORCE -> REINFORCE
      MemoryBrowse.FORGET -> FORGET
    }
  }

  page "/memory" -> MemoryBrowse, MemoryCreate, MemoryAgent
}

orbital AssistantContextOrbital {
    type AssistantContextLoaded = Event { data : [AssistantContext] } "Fired when AssistantContext finishes loading"

    type AssistantContextLoadFailed = Event { error : string, code : string } "Fired when AssistantContext fails to load"

  entity AssistantContext [runtime] {
    id : string!
    tokenCount : number @description "The number of tokens used." @synonyms "tokens, count" = 0
    maxTokens : number @description "The maximum number of tokens allowed for a request." @synonyms "limit, maximum, cap"
    usage : number @description "Represents the amount of resource consumed." @synonyms "consumption, utilization, amount"
    lastCompactedAt : string @description "Timestamp of the last compaction event." @synonyms "compacted, last compacted, compaction time"
    current : number @description "The present value of a numerical measurement." @synonyms "value, amount, quantity"
    max : number @description "The maximum value allowed for a related quantity." @synonyms "limit, maximum, upper bound"
    threshold : number @description "The minimum value required to trigger an action." @synonyms "limit, cutoff, boundary"
    message : string @description "The text content of a message." @synonyms "text, body, value"
    notificationType : "info" | "success" | "warning" | "error" @description "Indicates the type of notification (info, success, warning, error)." @synonyms "type, alert, status" = info
  }

  trait AssistantContextMonitor -> AssistantContext [interaction, collection] {
    initial: normal

    state normal {
      INIT -> normal
        (set @entity.max 0)
        (fetch AssistantContext {
          emit: { failure: AssistantContextLoadFailed, success: AssistantContextLoaded }
        })
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            children: [{
              align: center
              children: [{ name: gauge, type: icon }, {
                content: "Token Usage"
                type: typography
                variant: h2
              }, {
                label: Normal
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              max: @entity.max
              type: progress-bar
              value: @entity.current
            }, {
              children: [{
                label: "Tokens Used"
                type: stat-display
                value: @entity.current
              }, {
                label: "Max Tokens"
                type: stat-display
                value: @entity.max
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: RESET
              icon: rotate-ccw
              label: Reset
              type: button
              variant: ghost
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/chat"
            icon: message-circle
            label: Chat
          }, {
            href: "/memory"
            icon: brain
            label: Memory
          }, {
            href: "/settings"
            icon: settings
            label: Settings
          }]
          type: dashboard-layout
        })
      UPDATE -> normal when ["<", ["/", ?current, @entity.max], 0.85]
        (set @entity.current ?current)
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            children: [{
              align: center
              children: [{ name: gauge, type: icon }, {
                content: "Token Usage"
                type: typography
                variant: h2
              }, {
                label: Normal
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              max: @entity.max
              type: progress-bar
              value: @entity.current
            }, {
              children: [{
                label: "Tokens Used"
                type: stat-display
                value: @entity.current
              }, {
                label: "Max Tokens"
                type: stat-display
                value: @entity.max
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: RESET
              icon: rotate-ccw
              label: Reset
              type: button
              variant: ghost
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/chat"
            icon: message-circle
            label: Chat
          }, {
            href: "/memory"
            icon: brain
            label: Memory
          }, {
            href: "/settings"
            icon: settings
            label: Settings
          }]
          type: dashboard-layout
        })
      UPDATE -> warning when (and [">=", ["/", ?current, @entity.max], 0.85] ["<", ["/", ?current, @entity.max], 0.95])
        (set @entity.current ?current)
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            children: [{
              align: center
              children: [{ name: alert-triangle, type: icon }, {
                content: "Token Usage"
                type: typography
                variant: h2
              }, {
                label: Warning
                type: badge
                variant: warning
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              message: "Token usage approaching limit. Consider compacting."
              type: alert
              variant: warning
            }, {
              max: @entity.max
              type: progress-bar
              value: @entity.current
            }, {
              children: [{
                label: "Tokens Used"
                type: stat-display
                value: @entity.current
              }, {
                label: "Max Tokens"
                type: stat-display
                value: @entity.max
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              children: [{
                action: COMPACT
                icon: minimize-2
                label: Compact
                type: button
                variant: primary
              }, {
                action: RESET
                icon: rotate-ccw
                label: Reset
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/chat"
            icon: message-circle
            label: Chat
          }, {
            href: "/memory"
            icon: brain
            label: Memory
          }, {
            href: "/settings"
            icon: settings
            label: Settings
          }]
          type: dashboard-layout
        })
      UPDATE -> critical when [">=", ["/", ?current, @entity.max], 0.95]
        (set @entity.current ?current)
        (render-ui main {
          appName: "Agent Assistant"
          children: [{
            children: [{
              align: center
              children: [{ name: alert-octagon, type: icon }, {
                content: "Token Usage"
                type: typography
                variant: h2
              }, {
                label: Critical
                type: badge
                variant: danger
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              message: "Token usage critical. Compact immediately to avoid truncation."
              type: alert
              variant: error
            }, {
              max: @entity.max
              type: progress-bar
              value: @entity.current
            }, {
              children: [{
                label: "Tokens Used"
                type: stat-display
                value: @entity.current
              }, {
                label: "Max Tokens"
                type: stat-display
                value: @entity.max
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              children: [{
                action: COMPACT
                icon: minimize-2
                label: "Compact Now"
                type: button
                variant: primary
              }, {
                action: RESET
                icon: rotate-ccw
                label: Reset
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
