app std-agent-assistant "1.0.0"
"std-agent-assistant as a Function"

orbital AssistantOrbital {
  entity Assistant [runtime] {
    id : string!
    messages : string = "[]"
    currentMessage : string = ""
    response : string = ""
    memoryCount : number = 0
    contextUsage : number = 0
    provider : string = "default"
    sessionId : string = ""
    status : string = "idle"
    error : string = ""
    turnCount : number = 0
    lastMessage : string = ""
    tokenCount : number = 0
    role : string = "user"
    content : string = ""
    timestamp : string = ""
    toolName : string = ""
  }

  type AssistantLoaded     = Event { data : [Assistant] }                  "Fired when Assistant finishes loading"
  type AssistantLoadFailed = Event { error : string, code : string } "Fired when Assistant fails to load"
  type AssistantDeleted = Event { id : string }
  type AssistantDeleteFailed = Event { error : string, code : string }
  type MemorySaved = Event { id : string }
  type MemorySaveFailed = Event { error : string, code : string }
  type ProviderConfigUpdated = Event { id : string }
  type ProviderConfigUpdateFailed = Event { error : string, code : string }
  trait AssistantConversation -> Assistant [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Assistant { emit: { success: "AssistantLoaded", failure: "AssistantLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading assistant…" }] })
      AssistantLoaded -> idle
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "Assistant Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-list", entity: @payload.data, fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "secondary" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }] }] })
      AssistantLoadFailed -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load assistant" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
      COMPOSE -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "Assistant Thread", variant: "h2" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SEND", cancelEvent: "CANCEL_COMPOSE", fields: ["content"] }] })
      CLEAR -> idle
        (persist delete Assistant { emit: { success: "AssistantDeleted", failure: "AssistantDeleteFailed" } })
        (fetch Assistant { emit: { success: "AssistantLoaded", failure: "AssistantLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state composing {
      SEND -> idle
        (persist create Assistant { role: "user", content: "@payload.content", timestamp: "@now", status: "sent" })
        (emit SEND_MESSAGE)
        (fetch Assistant { emit: { success: "AssistantLoaded", failure: "AssistantLoadFailed" } })
        (render-ui main { type: "spinner" })
      CANCEL_COMPOSE -> idle
        (fetch Assistant { emit: { success: "AssistantLoaded", failure: "AssistantLoadFailed" } })
        (render-ui main { type: "spinner" })
      CLEAR -> idle
        (persist delete Assistant { emit: { success: "AssistantDeleted", failure: "AssistantDeleteFailed" } })
        (fetch Assistant { emit: { success: "AssistantLoaded", failure: "AssistantLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      SEND_MESSAGE internal { content: string }
      MEMORIZE_RESPONSE internal { content: string }
      MEMORIZE_RESPONSE external { content: string }
    }
    listens {
      * PROVIDER_CHANGED -> INIT
      SEND { content : string! }
          AssistantLoadFailed { error : string, code : string }
    
      AssistantDeleteFailed { error : string, code : string }
      MemorySaveFailed { error : string, code : string }
      ProviderConfigUpdateFailed { error : string, code : string }
    }
    emits: [AssistantLoaded, AssistantLoadFailed, AssistantDeleted, AssistantDeleteFailed, MemorySaved, MemorySaveFailed, ProviderConfigUpdated, ProviderConfigUpdateFailed]
  }
  trait AssistantAgent -> Assistant [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Assistant { emit: { success: "AssistantLoaded", failure: "AssistantLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "empty-state", icon: "message-circle", title: "Conversation", description: "Conversation is ready" }] })
      SEND_MESSAGE -> active
        (set @entity.lastMessage @payload.content)
        (set @entity.turnCount (+ @entity.turnCount 1))
        (agent/generate @payload.content)
        (emit TOKEN_UPDATE)
    }
    state active {
      SEND_MESSAGE -> active
        (set @entity.lastMessage @payload.content)
        (set @entity.turnCount (+ @entity.turnCount 1))
        (agent/generate @payload.content)
        (emit TOKEN_UPDATE)
      PAUSE -> paused
      CLEAR -> idle
        (set @entity.messages [])
        (set @entity.turnCount 0)
        (set @entity.lastMessage "")
        (set @entity.tokenCount 0)
    }
    state paused {
      RESUME -> active
      CLEAR -> idle
        (set @entity.messages [])
        (set @entity.turnCount 0)
        (set @entity.lastMessage "")
        (set @entity.tokenCount 0)
    }
    emits {
      TOKEN_UPDATE internal { tokenCount: number }
    }
    listens {
      SEND_MESSAGE { content : string! }
          AssistantLoadFailed { error : string, code : string }
    }
    emits: [AssistantLoaded, AssistantLoadFailed]
  }
  page "/chat" as ChatPage -> AssistantConversation
}
orbital MemoryOrbital {
  entity Memory [persistent: memorys] {
    id : string!
    content : string = ""
    category : string
    strength : number
    pinned : boolean
    scope : string
    lastAccessedAt : string
    createdAt : string
  }

  type MemoryLoaded     = Event { data : [Memory] }                  "Fired when Memory finishes loading"
  type MemoryLoadFailed = Event { error : string, code : string } "Fired when Memory fails to load"
  type MemorySaveFailed = Event { error : string, code : string }
  type MemorySaved = Event { id : string }
  trait MemoryBrowse -> Memory [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch Memory { emit: { success: "MemoryLoaded", failure: "MemoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      MemoryLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "Memory Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Memorize", action: "MEMORIZE", variant: "primary", icon: "plus" }, { type: "button", label: "Recall", action: "RECALL", variant: "secondary", icon: "search" }, { type: "button", label: "Decay All", action: "DECAY", variant: "ghost", icon: "clock" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Pin", event: "PIN", variant: "ghost"}, { label: "Reinforce", event: "REINFORCE", variant: "ghost"}, { label: "Forget", event: "FORGET", variant: "danger"}], fields: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "strength", label: "Strength", variant: "caption" }] }] }] })
      MemoryLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load memory" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    listens {
      MemoryCreate MEMORIZED -> INIT
      MemoryAgent PINNED -> INIT
      MemoryAgent FORGOT -> INIT
      MemoryAgent REINFORCED -> INIT
      MemoryAgent DECAYED -> INIT
          MemoryLoadFailed { error : string, code : string }
    }
    emits: [MemoryLoaded, MemoryLoadFailed]
  }
  trait MemoryCreate -> Memory [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (ref Memory)
      MEMORIZE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle"}, { type: "typography", content: "Memorize", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["content", "category", "scope"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create Memory @payload.data { emit: { success: "MemorySaved", failure: "MemorySaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit MEMORIZED)
    }
    emits {
      MEMORIZED
    }
    emits: [MemoryLoadFailed, MemoryLoaded, MemorySaveFailed, MemorySaved]
    listens {
      MemoryLoadFailed { error : string, code : string }
      SAVE { data : string }
    }
  }
  trait MemoryAgent -> Memory [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Memory { emit: { success: "MemoryLoaded", failure: "MemoryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "empty-state", icon: "brain", title: "Memory", description: "Memory is ready" }] })
      DO_MEMORIZE -> active
        (agent/memorize @payload.data.content @payload.data.category)
        (persist create Memory @payload.data { emit: { success: "MemorySaved", failure: "MemorySaveFailed" } })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED)
      MEMORIZED -> active
        (fetch Memory { emit: { success: "MemoryLoaded", failure: "MemoryLoadFailed" } })
    }
    state active {
      RECALL -> active
        (agent/recall @payload.query)
      PIN -> active when (not (agent/is-pinned @payload.id))
        (agent/pin @payload.id)
        (set @entity.pinned true)
        (emit PINNED)
      FORGET -> idle
        (agent/forget @payload.id)
        (emit FORGOT)
      REINFORCE -> active
        (agent/reinforce @payload.id)
        (emit REINFORCED)
      DECAY -> active
        (agent/decay)
        (emit DECAYED)
    }
    emits {
      FORGOT external { id: string }
      REINFORCED external { id: string }
      DECAYED external { id: string }
      PINNED external { id: string }
    }
    listens {
      * MEMORIZE_RESPONSE -> MEMORIZE
          MemoryLoadFailed { error : string, code : string }
          DO_MEMORIZE { data : string }
          RECALL { query : string }
          PIN { id : string }
          FORGET { id : string }
          REINFORCE { id : string }
    }
    emits: [MemoryLoadFailed, MemoryLoaded, MemorySaveFailed, MemorySaved]
  }
  page "/memory" -> MemoryBrowse, MemoryCreate, MemoryAgent
}
orbital AssistantContextOrbital {
  entity AssistantContext [runtime] {
    id : string!
    tokenCount : number = 0
    maxTokens : number
    usage : number
    lastCompactedAt : string
    current : number
    max : number
    threshold : number
    message : string
    notificationType : string
  }

  type AssistantContextLoaded     = Event { data : [AssistantContext] }                  "Fired when AssistantContext finishes loading"
  type AssistantContextLoadFailed = Event { error : string, code : string } "Fired when AssistantContext fails to load"
  trait AssistantContextMonitor -> AssistantContext [interaction, collection] {
    initial: normal
    state normal {
      INIT -> normal
        (fetch AssistantContext { emit: { success: "AssistantContextLoaded", failure: "AssistantContextLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      UPDATE -> normal when (< (/ @payload.current @entity.max) 0.85)
        (set @entity.current @payload.current)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      UPDATE -> warning when (and (>= (/ @payload.current @entity.max) 0.85) (< (/ @payload.current @entity.max) 0.95))
        (set @entity.current @payload.current)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Warning", variant: "warning" }] }, { type: "divider" }, { type: "alert", variant: "warning", message: "Token usage approaching limit. Consider compacting." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      UPDATE -> critical when (>= (/ @payload.current @entity.max) 0.95)
        (set @entity.current @payload.current)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-octagon"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Critical", variant: "danger" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Token usage critical. Compact immediately to avoid truncation." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact Now", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      COMPACT -> normal
        (agent/compact)
        (set @entity.lastCompactedAt @now)
        (agent/token-count)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      RESET -> normal
        (set @entity.current 0)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    state warning {
      UPDATE -> warning when (and (>= (/ @payload.current @entity.max) 0.85) (< (/ @payload.current @entity.max) 0.95))
        (set @entity.current @payload.current)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Warning", variant: "warning" }] }, { type: "divider" }, { type: "alert", variant: "warning", message: "Token usage approaching limit. Consider compacting." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      UPDATE -> critical when (>= (/ @payload.current @entity.max) 0.95)
        (set @entity.current @payload.current)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "alert-octagon"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Critical", variant: "danger" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "Token usage critical. Compact immediately to avoid truncation." }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Compact Now", action: "COMPACT", variant: "primary", icon: "minimize-2" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      UPDATE -> normal when (< (/ @payload.current @entity.max) 0.85)
        (set @entity.current @payload.current)
        (render-ui main { type: "dashboard-layout", appName: "Agent Assistant", navItems: [{ label: "Chat", href: "/chat", icon: "message-circle" }, { label: "Memory", href: "/memory", icon: "brain" }, { label: "Settings", href: "/settings", icon: "settings" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "gauge"}, { type: "typography", content: "Token Usage", variant: "h2" }, { type: "badge", label: "Normal", variant: "default" }] }, { type: "divider" }, { type: "progress-bar", value: "@entity.current", max: "@entity.max" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "stat-display", label: "Tokens Used", value: "@entity.current" }, { type: "stat-display", label: "Max Tokens", value: "@entity.max" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      COMPACT -> normal
        (agent/compact)
        (set @entity.lastCompactedAt @now)
        (agent/token-count)
