  trait ToolLoopCompletionFlow -> PipelineExec [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.model claude-sonnet-4-20250514)
        (set @entity.provider anthropic)
        (fetch PipelineExec {
          emit: { failure: PipelineExecLoadFailed, success: PipelineExecLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: PipelineExec
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      GENERATE -> open
        (render-ui modal {
          children: [{
            children: [{ name: sparkles, type: icon }, {
              content: PipelineExec
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{ label: @entity.provider, type: badge }, { label: @entity.model, type: badge }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (prompt)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch PipelineExec {
          emit: { failure: PipelineExecLoadFailed, success: PipelineExecLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: PipelineExec
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create PipelineExec ?data {
          emit: { failure: PipelineExecSaveFailed, success: PipelineExecSaved }
        })
        (render-ui modal null)
        (emit GENERATED)
        (fetch PipelineExec {
          emit: { failure: PipelineExecLoadFailed, success: PipelineExecLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: PipelineExec
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    emits {
      SAVE -> internal
      GENERATED -> internal
      PipelineExecLoadFailed
      PipelineExecLoaded
      PipelineExecSaveFailed
      PipelineExecSaved
    }

    listens {
      PipelineExecLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
    }
  }

