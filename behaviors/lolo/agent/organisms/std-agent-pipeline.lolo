app std-agent-pipeline "1.0.0"
"Agent pipeline: multi-step planned execution with session tree and progress logs."
orbital PipelinePlanOrbital {
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"

  uses Drawer from "std/behaviors/std-drawer"

    type PipelinePlanLoaded = Event { data : [PipelinePlan] } "Fired when PipelinePlan finishes loading"

    type PipelinePlanLoadFailed = Event { error : string, code : string } "Fired when PipelinePlan fails to load"

    type PipelineProgressLoaded = Event { error : string, code : string } "Emitted event PipelineProgressLoaded"

    type PipelineProgressLoadFailed = Event { error : string, code : string } "Emitted event PipelineProgressLoadFailed"

    type SessionTreeLoaded = Event { error : string, code : string } "Emitted event SessionTreeLoaded"

    type SessionTreeLoadFailed = Event { error : string, code : string } "Emitted event SessionTreeLoadFailed"

    type PipelinePlanSaved = Event { id : string }

    type PipelinePlanSaveFailed = Event { error : string, code : string }

    type PipelineExecSaved = Event { id : string }

    type PipelineExecSaveFailed = Event { error : string, code : string }

    type PipelineSessionUpdated = Event { id : string }

    type PipelineSessionUpdateFailed = Event { error : string, code : string }

    type ExecutionLogSaved = Event { id : string }

    type ExecutionLogSaveFailed = Event { error : string, code : string }

  entity PipelinePlan [runtime] {
    id : string!
    task : string @description "A brief description of the task being performed." @synonyms "activity, job, operation" = ""
    category : string @description "Classification or type of the pipeline plan." @synonyms "type, classification, kind" = ""
    steps : string @description "Ordered sequence of actions within a process." @synonyms "sequence, order, steps, stages" = ""
    confidence : number @description "A numerical value representing certainty or likelihood." @synonyms "probability, certainty, likelihood, score" = 0
    status : string @description "The current state of the process." @synonyms "state, condition, progress" = idle
    relevantMemories : string @description "Identifies memories pertinent to the current operation." @synonyms "memory identifiers, related memories, memory references" = ""
    memoryCount : number @description "The number of memory items associated with this plan." @synonyms "count, quantity, number" = 0
    error : string @description "Textual description of an error or failure condition." @synonyms "failure, problem, issue, fault" = ""
    input : string @description "The data provided as initial information for processing." @synonyms "initial data, source, starting point, query" = ""
    prompt : string @description "The text provided as input to the component." @synonyms "query, input text, instruction" = ""
    response : string @description "The text-based output generated by a process." @synonyms "output, result, answer, reply" = ""
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, vendor" = anthropic
    model : string @description "The identifier of the language model used." @synonyms "modelName, llm, languageModel" = claude-sonnet-4-20250514
    content : string @description "The textual data associated with a specific item." @synonyms "text, data, body, value" = ""
    scope : string @description "The area or domain this plan applies to." @synonyms "domain, area, context" = ""
    strength : number @description "Numerical value representing a degree of certainty or intensity." @synonyms "intensity, value, level, score" = 1
    pinned : boolean @description "Indicates whether the item is marked for persistent visibility." @synonyms "flagged, marked, favorited" = false
    action : string @description "The specific action to be performed." @synonyms "operation, command, activity" = ""
    detail : string @description "A more specific explanation or elaboration of a status." @synonyms "description, notes, specifics, explanation" = ""
    timestamp : string @description "Date and time of an event or record." @synonyms "date, time, when" = ""
    duration : number @description "The length of time the process took, in a numerical format." @synonyms "time, length, elapsed, runtime" = 0
    icon : string @description "Visual representation; typically a filename or URL." @synonyms "image, graphic, symbol" = circle
  }

  trait PipelinePlanner -> PipelinePlan [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{ name: map, type: icon }, {
                content: "Task Planner"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to plan"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: PLAN
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      PLAN -> classifying
        (set @entity.status classifying)
        (agent/generate (str/concat "Classify this task into exactly one category.\n" "Categories: " "data, transform, validate, deploy, test" "\n" "Task: " @entity.task "\n" "Return only the category name."))
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: tag, type: icon }, {
              content: "Classifying task..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              content: @entity.task
              type: typography
              variant: caption
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state classifying {
      CLASSIFIED -> recalling
        (set @entity.category ?category)
        (set @entity.status recalling)
        (agent/recall (str/concat @entity.category " " @entity.task) 5)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: brain, type: icon }, {
              content: "Recalling relevant experience..."
              type: typography
              variant: h3
            }, { type: spinner }, { label: @entity.category, type: badge }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "Planning Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state recalling {
      MEMORIES_LOADED -> planning
        (set @entity.relevantMemories ?memories)
        (set @entity.memoryCount ?count)
        (set @entity.status planning)
        (agent/generate (str/concat "Task: " @entity.task "\n" "Category: " @entity.category "\n" "Relevant experience:\n" @entity.relevantMemories "\n\n" "Generate a numbered step-by-step execution plan. " "Include a confidence score (0-100) for how likely this plan will succeed."))
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: cpu, type: icon }, {
              content: "Generating plan..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              children: [{ label: @entity.category, type: badge }, { label: @entity.memoryCount, type: badge }]
              direction: horizontal
              gap: md
              justify: center
              type: stack
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "Planning Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state planning {
      PLAN_GENERATED -> ready
        (set @entity.steps ?steps)
        (set @entity.confidence ?confidence)
        (set @entity.status ready)
        (agent/memorize (str/concat "Plan for " @entity.category " task: " @entity.task) pattern-affinity)
        (emit PLAN_READY)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: check-circle, type: icon }, {
                  content: "Plan Ready"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                action: RESET
                icon: rotate-ccw
                label: "New Plan"
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                icon: tag
                label: Category
                type: stat-display
                value: @entity.category
              }, {
                icon: target
                label: Confidence
                type: stat-display
                value: @entity.confidence
              }, {
                icon: brain
                label: "Memories Used"
                type: stat-display
                value: @entity.memoryCount
              }]
              cols: 3
              type: simple-grid
            }, { type: divider }, {
              children: [{
                children: [{
                  content: Task
                  type: typography
                  variant: caption
                }, {
                  content: @entity.task
                  type: typography
                  variant: body
                }, { type: divider }, {
                  content: "Execution Plan"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.steps
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }, {
              children: [{
                children: [{
                  content: "Relevant Memories"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.relevantMemories
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: alert-triangle, type: icon }, {
              content: "Planning Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              action: RESET
              icon: rotate-ccw
              label: "Try Again"
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state ready {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.category "")
        (set @entity.steps "")
        (set @entity.confidence 0)
        (set @entity.relevantMemories "")
        (set @entity.memoryCount 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{ name: map, type: icon }, {
                content: "Task Planner"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to plan"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: PLAN
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    emits {
      PLAN_READY -> external {
        plan : string
        category : string
      }
      PIPELINE_PLANNED -> external {
        steps : string
      }
      PipelinePlanSaved
      PipelinePlanSaveFailed
      PipelineExecSaved
      PipelineExecSaveFailed
      PipelineSessionUpdated
      PipelineSessionUpdateFailed
      ExecutionLogSaved
      ExecutionLogSaveFailed
    }

    listens {
      PipelinePlanner.PLAN_READY -> INIT
      CLASSIFIED {
        category : string!
      }
      MEMORIES_LOADED {
        memories : string!
        count : number!
      }
      PLAN_GENERATED {
        steps : string!
        confidence : number!
        plan : string
        toolName : string
        toolArgs : string
      }
      FAILED {
        error : string!
      }
      PipelinePlanSaveFailed {
        error : string
        code : string
      }
      PipelineExecSaveFailed {
        error : string
        code : string
      }
      PipelineSessionUpdateFailed {
        error : string
        code : string
      }
      ExecutionLogSaveFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerTaskInput -> PipelinePlan [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
      NEW_TASK -> open
        (render-ui modal {
          children: [{ name: map, type: icon }, {
            content: "Describe the task to plan"
            type: typography
            variant: h3
          }, { type: divider }, {
            cancelEvent: CLOSE
            entity: @entity
            fields: (task)
            mode: edit
            submitEvent: PLAN
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
        (notify Cancelled info)
      PLAN -> closed
        (render-ui modal null)
        (render-ui main { type: box })
    }

    emits {
      PipelinePlanLoaded
      PipelinePlanLoadFailed
    }

    listens {
      PLAN {
        data : object!
      }
      PipelinePlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerClassifierFlow -> PipelinePlan [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: PipelinePlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      CLASSIFY -> open
        (render-ui modal {
          children: [{
            children: [{ name: tag, type: icon }, {
              content: PipelinePlan
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              content: "Categories:"
              type: typography
              variant: caption
            }, {
              label: data
              type: badge
              variant: secondary
            }, {
              label: transform
              type: badge
              variant: secondary
            }, {
              label: validate
              type: badge
              variant: secondary
            }, {
              label: deploy
              type: badge
              variant: secondary
            }, {
              label: test
              type: badge
              variant: secondary
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (input)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: PipelinePlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create PipelinePlan ?data {
          emit: { failure: PipelinePlanSaveFailed, success: PipelinePlanSaved }
        })
        (render-ui modal null)
        (emit CLASSIFIED)
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: tag, type: icon }, {
                  content: PipelinePlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: CLASSIFY
                icon: tag
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: tag
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    emits {
      SAVE -> internal
      CLASSIFIED -> internal
      PipelinePlanLoadFailed
      PipelinePlanLoaded
      PipelinePlanSaveFailed
      PipelinePlanSaved
    }

    listens {
      SAVE {
        data : object!
      }
      PipelinePlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerCompletionFlow -> PipelinePlan [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.model claude-sonnet-4-20250514)
        (set @entity.provider anthropic)
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: PipelinePlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      GENERATE -> open
        (render-ui modal {
          children: [{
            children: [{ name: sparkles, type: icon }, {
              content: PipelinePlan
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{ label: @entity.provider, type: badge }, { label: @entity.model, type: badge }]
            direction: horizontal
            gap: sm
            type: stack
          }, {
            cancelEvent: CLOSE
            fields: (prompt)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: PipelinePlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      SAVE -> closed
        (persist create PipelinePlan ?data {
          emit: { failure: PipelinePlanSaveFailed, success: PipelinePlanSaved }
        })
        (render-ui modal null)
        (emit GENERATED)
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              children: [{
                children: [{ name: sparkles, type: icon }, {
                  content: PipelinePlan
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: md
                type: stack
              }, {
                action: GENERATE
                icon: sparkles
                label: Open
                type: button
                variant: primary
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              description: "Click Open to view details in a modal overlay."
              icon: sparkles
              title: "Nothing open"
              type: empty-state
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    emits {
      SAVE -> internal
      GENERATED -> internal
      PipelinePlanLoadFailed
      PipelinePlanLoaded
      PipelinePlanSaveFailed
      PipelinePlanSaved
    }

    listens {
      SAVE {
        data : object!
      }
      PipelinePlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait PlannerMemoryLifecycle -> PipelinePlan [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch PipelinePlan {
          emit: { failure: PipelinePlanLoadFailed, success: PipelinePlanLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      PipelinePlanLoaded -> browsing
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: brain, type: icon }, {
                  content: "PipelinePlan Manager"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: brain
                label: Content
                name: content
                variant: h4
              }, {
                colorMap: {
                  active: success
                  archived: neutral
                  cancelled: destructive
                  completed: success
                  disabled: neutral
                  done: success
                  draft: warning
                  error: destructive
                  failed: destructive
                  inactive: neutral
                  pending: warning
                  scheduled: warning
                }
                label: Category
                name: category
                variant: badge
              }, {
                label: Strength
                name: strength
                variant: caption
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      PipelinePlanLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load pipelineplan"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      PipelinePlanLoaded
      PipelinePlanLoadFailed
    }

    listens {
      PIN {
        id : string!
        row : PipelinePlan
      }
      REINFORCE {
        id : string!
        row : PipelinePlan
      }
      FORGET {
        id : string!
        row : PipelinePlan
      }
      PipelinePlanLoadFailed {
        error : string
        code : string
      }
    }
  }

  page "/pipeline" as PipelinePage -> PipelinePlanner
}

orbital PipelineExecOrbital {
    type PipelineExecLoaded = Event { data : [PipelineExec] } "Fired when PipelineExec finishes loading"

    type PipelineExecLoadFailed = Event { error : string, code : string } "Fired when PipelineExec fails to load"

    type PipelineExecSaveFailed = Event { error : string, code : string }

    type PipelineExecSaved = Event { id : string }

  entity PipelineExec [runtime] {
    id : string!
    task : string @description "A brief description of the task being performed." @synonyms "activity, job, operation" = ""
    plan : string @description "The overall strategy or blueprint for the execution." @synonyms "strategy, outline, scheme, design"
    iterations : number @description "The number of times a process repeats." @synonyms "count, repeats, loops"
    maxIterations : number @description "The maximum number of times the process can repeat." @synonyms "limit, maximum, count"
    status : string @description "The current state of the process." @synonyms "state, condition, progress" = idle
    result : string @description "The outcome or output of a process or operation." @synonyms "output, outcome, value, effect"
    currentTool : string @description "The name of the tool currently being utilized." @synonyms "tool, activeTool, currentAgent"
    lastToolResult : string @description "The output or result from the last tool execution." @synonyms "output, result, outcome, return"
    error : string @description "Details about any errors encountered during execution." @synonyms "failure, problem, issue, fault" = ""
    currentStep : number @description "The index of the currently executing step." @synonyms "step number, step index, current iteration"
    totalSteps : number @description "The total number of steps defined in the plan." @synonyms "count, number, size"
    steps : string @description "Ordered sequence of actions within a process." @synonyms "sequence, order, steps, stages" = ""
    toolName : string @description "The name of the tool used in this step." @synonyms "tool, utility, application"
    args : string @description "Arguments passed to the pipeline execution." @synonyms "parameters, inputs, data"
    prompt : string @description "The text used as input for a task or process." @synonyms "query, instruction, request, text" = ""
    response : string @description "The text output generated by a processing step." @synonyms "output, result, answer, text" = ""
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, vendor" = anthropic
    model : string @description "The identifier of the language model used." @synonyms "modelName, llm, languageModel" = claude-sonnet-4-20250514
    tokenCount : number @description "The number of tokens used." @synonyms "count, quantity, total"
    maxTokens : number @description "The maximum number of tokens allowed for processing." @synonyms "token limit, max length, token count"
    usage : number @description "Represents the number of times the component has been utilized." @synonyms "count, uses, frequency, occurrences"
    current : number @description "The current position or value within a sequence or range." @synonyms "index, position, value, stage"
    max : number @description "The maximum value or limit for a numerical property." @synonyms "limit, maximum, upper bound, cap"
    threshold : number @description "Minimum value required for a condition to be met." @synonyms "limit, cutoff, minimum"
    lastCompactedAt : string @description "Timestamp of the last compaction event." @synonyms "last compacted, compaction time"
    action : string @description "The specific operation to be performed." @synonyms "command, operation, task" = ""
    detail : string @description "A more specific explanation or elaboration of the main content." @synonyms "description, notes, specifics, details" = ""
    timestamp : string @description "Date and time of an event or record creation." @synonyms "date, time, created, recorded" = ""
    duration : number @description "The length of time the process took, in a numerical format." @synonyms "time, length, elapsed, runtime" = 0
  }

  trait PipelineExecutor -> PipelineExec [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.maxIterations 0)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{ name: repeat, type: icon }, {
                content: "Tool Execution Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to execute with tools"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: EXECUTE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      EXECUTE -> planning
        (set @entity.status planning)
        (set @entity.iterations 0)
        (agent/generate (str/concat "Task: " @entity.task "\n\nAvailable tools: " (str/join (agent/tools) ", ") "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."))
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: brain, type: icon }, {
              content: "Planning execution..."
              type: typography
              variant: h3
            }, { type: spinner }, {
              content: @entity.task
              type: typography
              variant: caption
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state planning {
      PLAN_GENERATED -> executing
        (set @entity.plan ?plan)
        (set @entity.currentTool ?toolName)
        (set @entity.iterations ["+", @entity.iterations, 1])
        (agent/invoke ?toolName ?toolArgs)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: tool, type: icon }, {
                  content: "Executing Tool"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, { label: @entity.maxIterations, type: badge }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Current Tool"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.currentTool
                  type: typography
                  variant: h4
                }, { type: spinner }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, {
              children: [{
                children: [{
                  content: Plan
                  type: typography
                  variant: caption
                }, {
                  content: @entity.plan
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: repeat
                label: "Iterations Used"
                type: stat-display
                value: @entity.iterations
              }, {
                icon: shield
                label: "Max Allowed"
                type: stat-display
                value: @entity.maxIterations
              }]
              cols: 2
              type: simple-grid
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state executing {
      TOOL_RESULT -> checking
        (set @entity.lastToolResult ?output)
        (agent/generate (str/concat "Task: " @entity.task "\nPlan: " @entity.plan "\nTool output: " ?output "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."))
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: eye, type: icon }, {
              content: "Checking result..."
              type: typography
              variant: h3
            }, { type: spinner }, { label: @entity.iterations, type: badge }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: repeat
                label: "Iterations Used"
                type: stat-display
                value: @entity.iterations
              }, {
                icon: shield
                label: "Max Allowed"
                type: stat-display
                value: @entity.maxIterations
              }]
              cols: 2
              type: simple-grid
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state checking {
      CHECK_PASSED -> completed
        (set @entity.result ?result)
        (set @entity.status completed)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: check-circle, type: icon }, {
                  content: "Loop Complete"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                action: RESET
                icon: rotate-ccw
                label: "New Task"
                type: button
                variant: ghost
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                icon: repeat
                label: Iterations
                type: stat-display
                value: @entity.iterations
              }, {
                icon: check
                label: Status
                type: stat-display
                value: @entity.status
              }]
              cols: 2
              type: simple-grid
            }, { type: divider }, {
              children: [{
                children: [{
                  content: Task
                  type: typography
                  variant: caption
                }, {
                  content: @entity.task
                  type: typography
                  variant: body
                }, { type: divider }, {
                  content: Result
                  type: typography
                  variant: caption
                }, {
                  content: @entity.result
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      CHECK_NEEDS_MORE -> executing
        (set @entity.currentTool ?toolName)
        (set @entity.iterations ["+", @entity.iterations, 1])
        (if [">=", (agent/context-usage), 0.8] (agent/compact hybrid) (log "Context below compact threshold"))
        (agent/invoke ?toolName ?toolArgs)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: tool, type: icon }, {
                  content: "Executing Tool"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, { label: @entity.maxIterations, type: badge }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Current Tool"
                  type: typography
                  variant: caption
                }, {
                  content: @entity.currentTool
                  type: typography
                  variant: h4
                }, { type: spinner }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }, {
              children: [{
                children: [{
                  content: Plan
                  type: typography
                  variant: caption
                }, {
                  content: @entity.plan
                  type: typography
                  variant: body
                }]
                direction: vertical
                gap: sm
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      MAX_ITERATIONS -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            align: center
            children: [{ name: x-circle, type: icon }, {
              content: "Loop Failed"
              type: typography
              variant: h2
            }, {
              message: @entity.error
              type: alert
              variant: error
            }, {
              children: [{
                icon: repeat
                label: "Iterations Used"
                type: stat-display
                value: @entity.iterations
              }, {
                icon: shield
                label: "Max Allowed"
                type: stat-display
                value: @entity.maxIterations
              }]
              cols: 2
              type: simple-grid
            }, {
              action: RESET
              icon: rotate-ccw
              label: Retry
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{ name: repeat, type: icon }, {
                content: "Tool Execution Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to execute with tools"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: EXECUTE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{ name: repeat, type: icon }, {
                content: "Tool Execution Loop"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              children: [{
                children: [{
                  content: "Describe the task to execute with tools"
                  type: typography
                  variant: body
                }, {
                  entity: @entity
                  fields: (task)
                  mode: edit
                  submitEvent: EXECUTE
                  type: form-section
                }]
                direction: vertical
                gap: md
                type: stack
              }]
              type: card
            }]
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    emits {
      STEP_COMPLETE -> internal {
        step : number
      }
      STEP_COMPLETE -> external {
        step : number
      }
      PIPELINE_FINISHED -> external {
        result : string
      }
      RESET
    }

    listens {
      PipelinePlanOrbital.PipelinePlanner.PIPELINE_PLANNED -> EXECUTE
      TOOL_RESULT {
        output : string
      }
      CHECK_PASSED {
        result : string
      }
      CHECK_NEEDS_MORE {
        toolName : string
        toolArgs : string
      }
      MAX_ITERATIONS {
        error : string
      }
      PLAN_GENERATED {
        plan : string
        toolName : string
        toolArgs : string
      }
      FAILED {
        error : string
      }
      ToolLoopStepProgress.RESET -> RESET
      ToolLoopContextMonitor.RESET -> RESET
    }
  }

  trait ToolLoopStepProgress -> PipelineExec [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.totalSteps 0)
        (fetch PipelineExec {
          emit: { failure: PipelineExecLoadFailed, success: PipelineExecLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{ name: list-ordered, type: icon }, {
                content: PipelineExec
                type: typography
                variant: h2
              }, {
                label: Idle
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { type: divider }, {
              currentStep: @entity.currentStep
              steps: [{
                id: "0"
                title: Plan
              }, {
                id: "1"
                title: Execute
              }, {
                id: "2"
                title: Check
              }, {
                id: "3"
                title: Complete
              }]
              type: wizard-progress
            }, {
              action: START
              icon: play
              label: Start
              type: button
              variant: primary
            }]
            direction: vertical
            gap: lg
            type: stack
