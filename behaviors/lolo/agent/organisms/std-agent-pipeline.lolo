app std-agent-pipeline "1.0.0"
"std-agent-pipeline as a Function"

orbital PipelinePlanOrbital {
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"
  uses Drawer from "std/behaviors/std-drawer"

  entity PipelinePlan [runtime] {
    id : string!
    task : string = ""
    category : string = ""
    steps : string = ""
    confidence : number = 0
    status : string = "idle"
    relevantMemories : string = ""
    memoryCount : number = 0
    error : string = ""
    input : string = ""
    prompt : string = ""
    response : string = ""
    provider : string = "anthropic"
    model : string = "claude-sonnet-4-20250514"
    content : string = ""
    scope : string = ""
    strength : number = 1
    pinned : boolean = false
    action : string = ""
    detail : string = ""
    timestamp : string = ""
    duration : number = 0
    icon : string = "circle"
  }

  type PipelinePlanLoaded     = Event { data : [PipelinePlan] }                  "Fired when PipelinePlan finishes loading"
  type PipelinePlanLoadFailed = Event { error : string, code : string } "Fired when PipelinePlan fails to load"

  type PipelineProgressLoaded = Event { error : string, code : string } "Emitted event PipelineProgressLoaded"

  type PipelineProgressLoadFailed = Event { error : string, code : string } "Emitted event PipelineProgressLoadFailed"

  type SessionTreeLoaded = Event { error : string, code : string } "Emitted event SessionTreeLoaded"

  type SessionTreeLoadFailed = Event { error : string, code : string } "Emitted event SessionTreeLoadFailed"
  type PipelinePlanSaved = Event { id : string }
  type PipelinePlanSaveFailed = Event { error : string, code : string }
  type PipelineExecSaved = Event { id : string }
  type PipelineExecSaveFailed = Event { error : string, code : string }
  type PipelineSessionUpdated = Event { id : string }
  type PipelineSessionUpdateFailed = Event { error : string, code : string }
  type ExecutionLogSaved = Event { id : string }
  type ExecutionLogSaveFailed = Event { error : string, code : string }
  trait PipelinePlanner -> PipelinePlan [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map"}, { type: "typography", content: "Task Planner", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to plan", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "PLAN", fields: ["task"] }] }] }] }] })
      PLAN -> classifying
        (set @entity.status classifying)
        (agent/generate (str/concat "Classify this task into exactly one category.\n" "Categories: " "data, transform, validate, deploy, test" "\n" "Task: " @entity.task "\n" "Return only the category name."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Classifying task...", variant: "h3" }, { type: "spinner"}, { type: "typography", content: "@entity.task", variant: "caption" }] }] })
    }
    state classifying {
      CLASSIFIED -> recalling
        (set @entity.category @payload.category)
        (set @entity.status recalling)
        (agent/recall (str/concat @entity.category " " @entity.task) 5)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "Recalling relevant experience...", variant: "h3" }, { type: "spinner"}, { type: "badge", label: "@entity.category" }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state recalling {
      MEMORIES_LOADED -> planning
        (set @entity.relevantMemories @payload.memories)
        (set @entity.memoryCount @payload.count)
        (set @entity.status planning)
        (agent/generate (str/concat "Task: " @entity.task "\n" "Category: " @entity.category "\n" "Relevant experience:\n" @entity.relevantMemories "\n\n" "Generate a numbered step-by-step execution plan. " "Include a confidence score (0-100) for how likely this plan will succeed."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Generating plan...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "@entity.category" }, { type: "badge", label: "@entity.memoryCount" }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state planning {
      PLAN_GENERATED -> ready
        (set @entity.steps @payload.steps)
        (set @entity.confidence @payload.confidence)
        (set @entity.status ready)
        (agent/memorize (str/concat "Plan for " @entity.category " task: " @entity.task) pattern-affinity)
        (emit PLAN_READY)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Plan Ready", variant: "h2" }] }, { type: "button", label: "New Plan", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Category", value: "@entity.category", icon: "tag" }, { type: "stat-display", label: "Confidence", value: "@entity.confidence", icon: "target" }, { type: "stat-display", label: "Memories Used", value: "@entity.memoryCount", icon: "brain" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Task", variant: "caption" }, { type: "typography", content: "@entity.task", variant: "body" }, { type: "divider" }, { type: "typography", content: "Execution Plan", variant: "caption" }, { type: "typography", content: "@entity.steps", variant: "body" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Relevant Memories", variant: "caption" }, { type: "typography", content: "@entity.relevantMemories", variant: "body" }] }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status error)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle"}, { type: "typography", content: "Planning Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state ready {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.category "")
        (set @entity.steps "")
        (set @entity.confidence 0)
        (set @entity.relevantMemories "")
        (set @entity.memoryCount 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "map"}, { type: "typography", content: "Task Planner", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to plan", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "PLAN", fields: ["task"] }] }] }] }] })
    }
    emits {
      PLAN_READY -> external { plan: string, category: string }
      PIPELINE_PLANNED -> external { steps: string }
      SessionTreeLoaded
      SessionTreeLoadFailed
      PipelinePlanSaved
      PipelinePlanSaveFailed
      PipelineExecSaved
      PipelineExecSaveFailed
      PipelineSessionUpdated
      PipelineSessionUpdateFailed
      ExecutionLogSaved
      ExecutionLogSaveFailed
    }
    listens {
      PipelinePlanner.PLAN_READY -> INIT
      CLASSIFIED { category : string! }
      MEMORIES_LOADED { memories : string!, count : number! }
      PLAN_GENERATED { steps : string!, confidence : number!, plan : string, toolName : string, toolArgs : string }
      FAILED { error : string! }
    
      PipelinePlanSaveFailed { error : string, code : string }
      PipelineExecSaveFailed { error : string, code : string }
      PipelineSessionUpdateFailed { error : string, code : string }
      ExecutionLogSaveFailed { error : string, code : string }
    }
  }
  trait PlannerTaskInput -> PipelinePlan [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
      NEW_TASK -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "icon", name: "map"}, { type: "typography", content: "Describe the task to plan", variant: "h3" }, { type: "divider" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "PLAN", cancelEvent: "CLOSE", fields: ["task"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      PLAN -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
emits {
      PipelinePlanLoaded
      PipelinePlanLoadFailed
    }

        listens {
      PLAN { data : object! }
          PipelinePlanLoadFailed { error : string, code : string }
    }
  }
  trait PlannerClassifierFlow -> PipelinePlan [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      CLASSIFY -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "PipelinePlan", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "typography", variant: "caption", content: "Categories:" }, { type: "badge", label: "data", variant: "secondary" }, { type: "badge", label: "transform", variant: "secondary" }, { type: "badge", label: "validate", variant: "secondary" }, { type: "badge", label: "deploy", variant: "secondary" }, { type: "badge", label: "test", variant: "secondary" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["input"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create PipelinePlan @payload.data { emit: { success: "PipelinePlanSaved", failure: "PipelinePlanSaveFailed" } })
        (render-ui modal null)
        (emit CLASSIFIED)
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", action: "CLASSIFY", variant: "primary", icon: "tag" }] }, { type: "divider" }, { type: "empty-state", icon: "tag", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      SAVE -> internal
      CLASSIFIED -> internal
      PipelinePlanLoadFailed
      PipelinePlanLoaded
      PipelinePlanSaveFailed
      PipelinePlanSaved
    }
    listens {
      SAVE { data : object! }
          PipelinePlanLoadFailed { error : string, code : string }
    }
  }
  trait PlannerCompletionFlow -> PipelinePlan [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      GENERATE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "PipelinePlan", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.provider" }, { type: "badge", label: "@entity.model" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["prompt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      SAVE -> closed
        (persist create PipelinePlan @payload.data { emit: { success: "PipelinePlanSaved", failure: "PipelinePlanSaveFailed" } })
        (render-ui modal null)
        (emit GENERATED)
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "PipelinePlan", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
    }
    emits {
      SAVE -> internal
      GENERATED -> internal
      PipelinePlanLoadFailed
      PipelinePlanLoaded
      PipelinePlanSaveFailed
      PipelinePlanSaved
    }
    listens {
      SAVE { data : object! }
          PipelinePlanLoadFailed { error : string, code : string }
    }
  }
  trait PlannerMemoryLifecycle -> PipelinePlan [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch PipelinePlan { emit: { success: "PipelinePlanLoaded", failure: "PipelinePlanLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      PipelinePlanLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "PipelinePlan Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Memorize", action: "MEMORIZE", variant: "primary", icon: "plus" }, { type: "button", label: "Recall", action: "RECALL", variant: "secondary", icon: "search" }, { type: "button", label: "Decay All", action: "DECAY", variant: "ghost", icon: "clock" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Pin", event: "PIN", variant: "ghost"}, { label: "Reinforce", event: "REINFORCE", variant: "ghost"}, { label: "Forget", event: "FORGET", variant: "danger"}], fields: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "strength", label: "Strength", variant: "caption" }] }] }] })
      PipelinePlanLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load pipelineplan" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
emits {
      PipelinePlanLoaded
      PipelinePlanLoadFailed
    }

        listens {
      PIN { id : string!, row : PipelinePlan }
      REINFORCE { id : string!, row : PipelinePlan }
      FORGET { id : string!, row : PipelinePlan }
          PipelinePlanLoadFailed { error : string, code : string }
    }
  }
  page "/pipeline" as PipelinePage -> PipelinePlanner
}
orbital PipelineExecOrbital {
  entity PipelineExec [runtime] {
    id : string!
    task : string = ""
    plan : string
    iterations : number
    maxIterations : number
    status : string = "idle"
    result : string
    currentTool : string
    lastToolResult : string
    error : string = ""
    currentStep : number
    totalSteps : number
    steps : string = ""
    toolName : string
    args : string
    prompt : string = ""
    response : string = ""
    provider : string = "anthropic"
    model : string = "claude-sonnet-4-20250514"
    tokenCount : number
    maxTokens : number
    usage : number
    current : number
    max : number
    threshold : number
    lastCompactedAt : string
    action : string = ""
    detail : string = ""
    timestamp : string = ""
    duration : number = 0
  }

  type PipelineExecLoaded     = Event { data : [PipelineExec] }                  "Fired when PipelineExec finishes loading"
  type PipelineExecLoadFailed = Event { error : string, code : string } "Fired when PipelineExec fails to load"
  type PipelineExecSaveFailed = Event { error : string, code : string }
  type PipelineExecSaved = Event { id : string }
  trait PipelineExecutor -> PipelineExec [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] }] })
      EXECUTE -> planning
        (set @entity.status planning)
        (set @entity.iterations 0)
        (agent/generate (str/concat "Task: " @entity.task "\n\nAvailable tools: " (str/join (agent/tools) ", ") "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "Planning execution...", variant: "h3" }, { type: "spinner"}, { type: "typography", content: "@entity.task", variant: "caption" }] }] })
    }
    state planning {
      PLAN_GENERATED -> executing
        (set @entity.plan @payload.plan)
        (set @entity.currentTool @payload.toolName)
        (set @entity.iterations (+ @entity.iterations 1))
        (agent/invoke @payload.toolName @payload.toolArgs)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "tool"}, { type: "typography", content: "Executing Tool", variant: "h2" }] }, { type: "badge", label: "@entity.maxIterations" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Current Tool", variant: "caption" }, { type: "typography", content: "@entity.currentTool", variant: "h4" }, { type: "spinner"}] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Plan", variant: "caption" }, { type: "typography", content: "@entity.plan", variant: "body" }] }] }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state executing {
      TOOL_RESULT -> checking
        (set @entity.lastToolResult @payload.output)
        (agent/generate (str/concat "Task: " @entity.task "\nPlan: " @entity.plan "\nTool output: " @payload.output "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "eye"}, { type: "typography", content: "Checking result...", variant: "h3" }, { type: "spinner"}, { type: "badge", label: "@entity.iterations" }] }] })
      FAILED -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state checking {
      CHECK_PASSED -> completed
        (set @entity.result @payload.result)
        (set @entity.status completed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "Loop Complete", variant: "h2" }] }, { type: "button", label: "New Task", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Status", value: "@entity.status", icon: "check" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Task", variant: "caption" }, { type: "typography", content: "@entity.task", variant: "body" }, { type: "divider" }, { type: "typography", content: "Result", variant: "caption" }, { type: "typography", content: "@entity.result", variant: "body" }] }] }] }] })
      CHECK_NEEDS_MORE -> executing
        (set @entity.currentTool @payload.toolName)
        (set @entity.iterations (+ @entity.iterations 1))
        (if (>= (agent/context-usage) 0.8) (agent/compact hybrid) (log "Context below compact threshold"))
        (agent/invoke @payload.toolName @payload.toolArgs)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "tool"}, { type: "typography", content: "Executing Tool", variant: "h2" }] }, { type: "badge", label: "@entity.maxIterations" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Current Tool", variant: "caption" }, { type: "typography", content: "@entity.currentTool", variant: "h4" }, { type: "spinner"}] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Plan", variant: "caption" }, { type: "typography", content: "@entity.plan", variant: "body" }] }] }] }] })
      MAX_ITERATIONS -> failed
        (set @entity.error @payload.error)
        (set @entity.status failed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "Loop Failed", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "simple-grid", cols: 2, children: [{ type: "stat-display", label: "Iterations Used", value: "@entity.iterations", icon: "repeat" }, { type: "stat-display", label: "Max Allowed", value: "@entity.maxIterations", icon: "shield" }] }, { type: "button", label: "Retry", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] }] })
    }
    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "repeat"}, { type: "typography", content: "Tool Execution Loop", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Describe the task to execute with tools", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "EXECUTE", fields: ["task"] }] }] }] }] })
    }
    emits {
      STEP_COMPLETE -> internal { step: number }
      STEP_COMPLETE -> external { step: number }
      PIPELINE_FINISHED -> external { result: string }
      RESET
    }
    listens {
      PipelinePlanOrbital.PipelinePlanner.PIPELINE_PLANNED -> EXECUTE
          TOOL_RESULT { output : string }
          CHECK_PASSED { result : string }
          CHECK_NEEDS_MORE { toolName : string, toolArgs : string }
          MAX_ITERATIONS { error : string }
          PLAN_GENERATED { plan : string, toolName : string, toolArgs : string }
          FAILED { error : string }
      ToolLoopStepProgress.RESET -> RESET
      ToolLoopContextMonitor.RESET -> RESET
    }
  }
  trait ToolLoopStepProgress -> PipelineExec [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch PipelineExec { emit: { success: "PipelineExecLoaded", failure: "PipelineExecLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] }] })
      START -> in_progress
        (set @entity.status in_progress)
        (set @entity.currentStep 0)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "loader"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "In Progress", variant: "warning" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "stat-display", label: "Current Step", value: "@entity.currentStep" }, { type: "stat-display", label: "Total Steps", value: "@entity.totalSteps" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Advance", action: "ADVANCE", variant: "primary", icon: "chevron-right" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] }] })
    }
    state in_progress {
      ADVANCE -> in_progress when (< @entity.currentStep @entity.totalSteps)
        (set @entity.currentStep (+ @entity.currentStep 1))
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "loader"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "In Progress", variant: "warning" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "stat-display", label: "Current Step", value: "@entity.currentStep" }, { type: "stat-display", label: "Total Steps", value: "@entity.totalSteps" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Advance", action: "ADVANCE", variant: "primary", icon: "chevron-right" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] }] })
      COMPLETE -> completed
        (set @entity.status completed)
        (set @entity.currentStep @entity.totalSteps)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "Completed", variant: "success" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.totalSteps", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "alert", variant: "success", message: "All steps completed successfully." }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      FAIL -> failed
        (set @entity.status failed)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "x-circle"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "Failed", variant: "danger" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "alert", variant: "error", message: "Pipeline failed at the current step." }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "stat-display", label: "Failed At Step", value: "@entity.currentStep" }] }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] }] })
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] }] })
    }
    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.currentStep 0)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-ordered"}, { type: "typography", content: "PipelineExec", variant: "h2" }, { type: "badge", label: "Idle", variant: "default" }] }, { type: "divider" }, { type: "wizard-progress", currentStep: "@entity.currentStep", steps: [{ id: "0", title: "Plan" }, { id: "1", title: "Execute" }, { id: "2", title: "Check" }, { id: "3", title: "Complete" }] }, { type: "button", label: "Start", action: "START", variant: "primary", icon: "play" }] }] })
    }
    emits {
      RESET
      PipelineExecLoaded
      PipelineExecLoadFailed
    }
    listens {
      PipelineExecLoadFailed { error : string, code : string }
      PipelineExecutor.RESET -> RESET
      ToolLoopContextMonitor.RESET -> RESET
    }
  }
  trait ToolLoopCompletionFlow -> PipelineExec [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch PipelineExec { emit: { success: "PipelineExecLoaded", failure: "PipelineExecLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "PipelineExec", variant: "h2" }] }, { type: "button", label: "Open", action: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] }] })
      GENERATE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "sparkles"}, { type: "typography", content: "PipelineExec", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.provider" }, { type: "badge", label: "@entity.model" }] }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["prompt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (fetch PipelineExec { emit: { success: "PipelineExecLoaded", failure: "PipelineExecLoadFailed" } })
