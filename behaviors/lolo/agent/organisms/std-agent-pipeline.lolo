  entity PipelineSession [runtime] {
    id : string!
    sessionId : string
    parentId : string
    label : string
    status : string = "idle"
    createdAt : string
  }

  type PipelineSessionLoaded     = Event { data : [PipelineSession] }                  "Fired when PipelineSession finishes loading"
  type PipelineSessionLoadFailed = Event { error : string, code : string } "Fired when PipelineSession fails to load"
  type PipelineSessionUpdateFailed = Event { error : string, code : string }
  type PipelineSessionUpdated = Event { id : string }
  trait PipelineSessionManager -> PipelineSession [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch PipelineSession { emit: { success: "PipelineSessionLoaded", failure: "PipelineSessionLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      PipelineSessionLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "terminal"}, { type: "typography", content: "PipelineSession Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Fork", action: "FORK", variant: "secondary", icon: "git-branch" }, { type: "button", label: "Label", action: "LABEL", variant: "secondary", icon: "tag" }, { type: "button", label: "End", action: "END", variant: "ghost", icon: "square" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "View", event: "VIEW", variant: "ghost"}], fields: [{ name: "sessionId", label: "Session ID", variant: "h4", icon: "terminal" }, { name: "status", label: "Status", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "label", label: "Label", variant: "caption" }] }] }] })
      PipelineSessionLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load pipelinesession" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      FORK
      LABEL
      END
      PipelineSessionLoaded
      PipelineSessionLoadFailed
    }
    listens {
      PipelineSessionAgent.FORKED -> INIT
      PipelineSessionLabel.LABELED -> INIT
      PipelineSessionAgent.ENDED -> INIT
      PipelineExecOrbital.PipelineExecutor.STEP_COMPLETE -> INIT
          PipelineSessionLoadFailed { error : string, code : string }
    }
  }
  trait PipelineSessionLabel -> PipelineSession [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch PipelineSession { emit: { success: "PipelineSessionLoaded", failure: "PipelineSessionLoadFailed" } })
      LABEL -> open
        (fetch PipelineSession { emit: { success: "PipelineSessionLoaded", failure: "PipelineSessionLoadFailed" } })
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "tag"}, { type: "typography", content: "Label Session", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Session:" }, { type: "badge", label: "@entity.sessionId" }] }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["label"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist update PipelineSession @payload.data { emit: { success: "PipelineSessionUpdated", failure: "PipelineSessionUpdateFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit LABELED)
    }
    emits {
      LABELED
      PipelineSessionLoadFailed
      PipelineSessionLoaded
      PipelineSessionUpdateFailed
      PipelineSessionUpdated
    }
    listens {
      PipelineSessionLoadFailed { error : string, code : string }
      SAVE { data : string }
      PipelineSessionManager.LABEL -> LABEL
    }
  }
  trait PipelineSessionAgent -> PipelineSession [interaction, collection] {
    initial: active
    state active {
      INIT -> active
        (fetch PipelineSession { emit: { success: "PipelineSessionLoaded", failure: "PipelineSessionLoadFailed" } })
        (agent/session-id)
        (set @entity.createdAt @now)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "empty-state", icon: "git-branch", title: "Session", description: "Session is ready" }] })
      FORK -> forked
        (set @entity.parentId @entity.sessionId)
        (agent/fork)
        (agent/session-id)
        (persist create PipelineSession { sessionId: "@entity.sessionId", parentId: "@entity.parentId", status: "forked", createdAt: "@now" } { emit: { success: "FORKED" } })
      DO_LABEL -> active
        (agent/label @payload.data.label)
        (set @entity.label @payload.data.label)
      LABELED -> active
        (agent/label @entity.label)
        (fetch PipelineSession { emit: { success: "PipelineSessionLoaded", failure: "PipelineSessionLoadFailed" } })
      END -> ended
        (set @entity.status ended)
        (emit ENDED)
    }
    state forked {
      FORK -> forked
        (set @entity.parentId @entity.sessionId)
        (agent/fork)
        (agent/session-id)
        (persist create PipelineSession { sessionId: "@entity.sessionId", parentId: "@entity.parentId", status: "forked", createdAt: "@now" } { emit: { success: "FORKED" } })
      DO_LABEL -> forked
        (agent/label @payload.data.label)
        (set @entity.label @payload.data.label)
      LABELED -> forked
        (agent/label @entity.label)
        (fetch PipelineSession { emit: { success: "PipelineSessionLoaded", failure: "PipelineSessionLoadFailed" } })
      END -> ended
        (set @entity.status ended)
        (emit ENDED)
    }
    state ended {
      INIT -> active
        (fetch PipelineSession { emit: { success: "PipelineSessionLoaded", failure: "PipelineSessionLoadFailed" } })
        (agent/session-id)
        (set @entity.createdAt @now)
        (set @entity.status active)
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "empty-state", icon: "git-branch", title: "Session", description: "Session is ready" }] })
    }
    emits {
      ENDED -> external { sessionId: string }
      FORKED -> external { sessionId: string }
      PipelineSessionLoaded
      PipelineSessionLoadFailed
    }
    listens {
      PipelineSessionAgent.ENDED -> INIT
      PipelineSessionAgent.FORKED -> INIT
          PipelineSessionLoadFailed { error : string, code : string }
          DO_LABEL { data : string }
      PipelineSessionManager.FORK -> FORK
      PipelineSessionManager.END -> END
    }
  }
  page "/session" -> PipelineSessionManager
}
orbital ExecutionLogOrbital {
  entity ExecutionLog [persistent: executionlogs] {
    id : string!
    content : string = ""
    category : string = ""
    strength : number = 1
    pinned : boolean = false
    scope : string = ""
    lastAccessedAt : string
    createdAt : string
  }

  type ExecutionLogLoaded     = Event { data : [ExecutionLog] }                  "Fired when ExecutionLog finishes loading"
  type ExecutionLogLoadFailed = Event { error : string, code : string } "Fired when ExecutionLog fails to load"
  type ExecutionLogSaveFailed = Event { error : string, code : string }
  type ExecutionLogSaved = Event { id : string }
  trait ExecutionLogBrowse -> ExecutionLog [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch ExecutionLog { emit: { success: "ExecutionLogLoaded", failure: "ExecutionLogLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      ExecutionLogLoaded -> browsing
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain"}, { type: "typography", content: "ExecutionLog Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Memorize", action: "MEMORIZE", variant: "primary", icon: "plus" }, { type: "button", label: "Recall", action: "RECALL", variant: "secondary", icon: "search" }, { type: "button", label: "Decay All", action: "DECAY", variant: "ghost", icon: "clock" }] }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Pin", event: "PIN", variant: "ghost"}, { label: "Reinforce", event: "REINFORCE", variant: "ghost"}, { label: "Forget", event: "FORGET", variant: "danger"}], fields: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "strength", label: "Strength", variant: "caption" }] }] }] })
      ExecutionLogLoadFailed -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load executionlog" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    emits {
      MEMORIZE
      RECALL
      DECAY
      PIN { id : string!, row : ExecutionLog }
      REINFORCE { id : string!, row : ExecutionLog }
      FORGET { id : string!, row : ExecutionLog }
      ExecutionLogLoaded
      ExecutionLogLoadFailed
    }
    listens {
      ExecutionLogCreate.MEMORIZED -> INIT
      ExecutionLogAgent.PINNED -> INIT
      ExecutionLogAgent.FORGOT -> INIT
      ExecutionLogAgent.REINFORCED -> INIT
      ExecutionLogAgent.DECAYED -> INIT
          ExecutionLogLoadFailed { error : string, code : string }
    }
  }
  trait ExecutionLogCreate -> ExecutionLog [interaction, collection] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch ExecutionLog { emit: { success: "ExecutionLogLoaded", failure: "ExecutionLogLoadFailed" } })
      MEMORIZE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle"}, { type: "typography", content: "Memorize", variant: "h3" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["content", "category", "scope"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create ExecutionLog @payload.data { emit: { success: "ExecutionLogSaved", failure: "ExecutionLogSaveFailed" } })
        (render-ui modal null)
        (render-ui main { type: "box" })
        (emit MEMORIZED)
    }
    emits {
      MEMORIZED
      ExecutionLogLoadFailed
      ExecutionLogLoaded
      ExecutionLogSaveFailed
      ExecutionLogSaved
    }
    listens {
      ExecutionLogLoadFailed { error : string, code : string }
      SAVE { data : string }
      ExecutionLogBrowse.MEMORIZE -> MEMORIZE
    }
  }
  trait ExecutionLogAgent -> ExecutionLog [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ExecutionLog { emit: { success: "ExecutionLogLoaded", failure: "ExecutionLogLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "Agent Pipeline", navItems: [{ label: "Pipeline", href: "/pipeline", icon: "git-branch" }, { label: "Execution", href: "/execution", icon: "play" }, { label: "Logs", href: "/logs", icon: "terminal" }], children: [{ type: "empty-state", icon: "brain", title: "Memory", description: "Memory is ready" }] })
      DO_MEMORIZE -> active
        (agent/memorize @payload.data.content @payload.data.category)
        (persist create ExecutionLog @payload.data { emit: { success: "ExecutionLogSaved", failure: "ExecutionLogSaveFailed" } })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED)
      MEMORIZED -> active
        (fetch ExecutionLog { emit: { success: "ExecutionLogLoaded", failure: "ExecutionLogLoadFailed" } })
    }
    state active {
      RECALL -> active
        (agent/recall @payload.query)
      PIN -> active when (not (agent/is-pinned @payload.id))
        (agent/pin @payload.id)
        (set @entity.pinned true)
        (emit PINNED)
      FORGET -> idle
        (agent/forget @payload.id)
        (emit FORGOT)
      REINFORCE -> active
        (agent/reinforce @payload.id)
        (emit REINFORCED)
      DECAY -> active
        (agent/decay)
        (emit DECAYED)
    }
    emits {
      FORGOT -> external { id: string }
      REINFORCED -> external { id: string }
      DECAYED -> external { id: string }
      PINNED -> external { id: string }
      ExecutionLogLoadFailed
      ExecutionLogLoaded
      ExecutionLogSaveFailed
      ExecutionLogSaved
    }
    listens {
      PipelineExecOrbital.PipelineExecutor.PIPELINE_FINISHED -> MEMORIZE
          ExecutionLogLoadFailed { error : string, code : string }
          DO_MEMORIZE { data : string }
          RECALL { query : string }
          PIN { id : string }
          FORGET { id : string }
          REINFORCE { id : string }
      ExecutionLogBrowse.RECALL -> RECALL
      ExecutionLogBrowse.DECAY -> DECAY
      ExecutionLogBrowse.PIN -> PIN
      ExecutionLogBrowse.REINFORCE -> REINFORCE
      ExecutionLogBrowse.FORGET -> FORGET
    }
  }
  page "/logs" -> ExecutionLogBrowse, ExecutionLogCreate, ExecutionLogAgent
}
orbital PipelineProgressOrbital {
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"

  entity PipelineProgress [runtime] {
    id : string!
    steps : string = ""
    currentStep : number
    totalSteps : number
    status : string = "idle"
  }

  type PipelineProgressLoaded     = Event { data : [PipelineProgress] }                  "Fired when PipelineProgress finishes loading"
  type PipelineProgressLoadFailed = Event { error : string, code : string } "Fired when PipelineProgress fails to load"
  trait PipelineStepProgress = AgentStepProgress.traits.AgentStepProgressProgress -> PipelineProgress {
  }
  page "/pipeline/progress" -> PipelineStepProgress
}
orbital SessionTreeOrbital {
  uses Drawer from "std/behaviors/std-drawer"

  entity SessionTree [runtime] {
    id : string!
    branchId : string
    label : string
    status : string = "idle"
  }

  type SessionTreeLoaded     = Event { data : [SessionTree] }                  "Fired when SessionTree finishes loading"
  type SessionTreeLoadFailed = Event { error : string, code : string } "Fired when SessionTree fails to load"
  trait SessionTreeDrawer = Drawer.traits.DrawerContentDrawer -> SessionTree {
  }
  page "/pipeline/tree" -> SessionTreeDrawer
}
