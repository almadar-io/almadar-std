}

orbital PipelineSessionOrbital {
    type PipelineSessionLoaded = Event { data : [PipelineSession] } "Fired when PipelineSession finishes loading"

    type PipelineSessionLoadFailed = Event { error : string, code : string } "Fired when PipelineSession fails to load"

    type PipelineSessionUpdateFailed = Event { error : string, code : string }

    type PipelineSessionUpdated = Event { id : string }

  entity PipelineSession [runtime] {
    id : string!
    sessionId : string @description "Unique identifier for the session associated with the plan." @synonyms "session id, session, identifier"
    parentId : string @description "Reference to the parent item in a hierarchical structure." @synonyms "parent, ancestor, reference, origin"
    label : string @description "A human-readable identifier for the pipeline plan." @synonyms "name, title, identifier"
    status : string @description "Current state of the process or operation." @synonyms "state, condition, progress" = idle
    createdAt : string
  }

  trait PipelineSessionManager -> PipelineSession [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch PipelineSession {
          emit: { failure: PipelineSessionLoadFailed, success: PipelineSessionLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      PipelineSessionLoaded -> browsing
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: terminal, type: icon }, {
                  content: "PipelineSession Manager"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                children: [{
                  action: FORK
                  icon: git-branch
                  label: Fork
                  type: button
                  variant: secondary
                }, {
                  action: LABEL
                  icon: tag
                  label: Label
                  type: button
                  variant: secondary
                }, {
                  action: END
                  icon: square
                  label: End
                  type: button
                  variant: ghost
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: terminal
                label: "Session ID"
                name: sessionId
                variant: h4
              }, {
                colorMap: {
                  active: success
                  archived: neutral
                  cancelled: destructive
                  completed: success
                  disabled: neutral
                  done: success
                  draft: warning
                  error: destructive
                  failed: destructive
                  inactive: neutral
                  pending: warning
                  scheduled: warning
                }
                label: Status
                name: status
                variant: badge
              }, {
                label: Label
                name: label
                variant: caption
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      PipelineSessionLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load pipelinesession"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      FORK
      LABEL
      END
      PipelineSessionLoaded
      PipelineSessionLoadFailed
    }

    listens {
      PipelineSessionAgent.FORKED -> INIT
      PipelineSessionLabel.LABELED -> INIT
      PipelineSessionAgent.ENDED -> INIT
      PipelineExecOrbital.PipelineExecutor.STEP_COMPLETE -> INIT
      PipelineSessionLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait PipelineSessionLabel -> PipelineSession [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (set @entity.sessionId "")
        (fetch PipelineSession {
          emit: { failure: PipelineSessionLoadFailed, success: PipelineSessionLoaded }
        })
      LABEL -> open
        (fetch PipelineSession {
          emit: { failure: PipelineSessionLoadFailed, success: PipelineSessionLoaded }
        })
        (render-ui modal {
          children: [{
            children: [{ name: tag, type: icon }, {
              content: "Label Session"
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              content: "Session:"
              type: typography
              variant: caption
            }, { label: @entity.sessionId, type: badge }]
            direction: horizontal
            gap: md
            type: stack
          }, {
            cancelEvent: CLOSE
            entity: @entity
            fields: (label)
            mode: edit
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
        (notify Cancelled info)
      SAVE -> closed
        (persist update PipelineSession ?data {
          emit: { failure: PipelineSessionUpdateFailed, success: PipelineSessionUpdated }
        })
        (render-ui modal null)
        (render-ui main { type: box })
        (emit LABELED)
    }

    emits {
      LABELED
      PipelineSessionLoadFailed
      PipelineSessionLoaded
      PipelineSessionUpdateFailed
      PipelineSessionUpdated
    }

    listens {
      PipelineSessionLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
      PipelineSessionManager.LABEL -> LABEL
    }
  }

  trait PipelineSessionAgent -> PipelineSession [interaction, collection] {
    initial: active

    state active {
      INIT -> active
        (set @entity.sessionId "")
        (fetch PipelineSession {
          emit: { failure: PipelineSessionLoadFailed, success: PipelineSessionLoaded }
        })
        (agent/session-id)
        (set @entity.createdAt @now)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            description: "Session is ready"
            icon: git-branch
            title: Session
            type: empty-state
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      FORK -> forked
        (set @entity.parentId @entity.sessionId)
        (agent/fork)
        (agent/session-id)
        (persist create PipelineSession {
          createdAt: @now
          parentId: @entity.parentId
          sessionId: @entity.sessionId
          status: forked
        } {
          emit: { success: FORKED }
        })
      DO_LABEL -> active
        (agent/label ?data.label)
        (set @entity.label ?data.label)
      LABELED -> active
        (agent/label @entity.label)
        (fetch PipelineSession {
          emit: { failure: PipelineSessionLoadFailed, success: PipelineSessionLoaded }
        })
      END -> ended
        (set @entity.status ended)
        (emit ENDED)
    }

    state forked {
      FORK -> forked
        (set @entity.parentId @entity.sessionId)
        (agent/fork)
        (agent/session-id)
        (persist create PipelineSession {
          createdAt: @now
          parentId: @entity.parentId
          sessionId: @entity.sessionId
          status: forked
        } {
          emit: { success: FORKED }
        })
      DO_LABEL -> forked
        (agent/label ?data.label)
        (set @entity.label ?data.label)
      LABELED -> forked
        (agent/label @entity.label)
        (fetch PipelineSession {
          emit: { failure: PipelineSessionLoadFailed, success: PipelineSessionLoaded }
        })
      END -> ended
        (set @entity.status ended)
        (emit ENDED)
    }

    state ended {
      INIT -> active
        (fetch PipelineSession {
          emit: { failure: PipelineSessionLoadFailed, success: PipelineSessionLoaded }
        })
        (agent/session-id)
        (set @entity.createdAt @now)
        (set @entity.status active)
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            description: "Session is ready"
            icon: git-branch
            title: Session
            type: empty-state
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
    }

    emits {
      ENDED -> external {
        sessionId : string
      }
      FORKED -> external {
        sessionId : string
      }
      PipelineSessionLoaded
      PipelineSessionLoadFailed
    }

    listens {
      PipelineSessionAgent.ENDED -> INIT
      PipelineSessionAgent.FORKED -> INIT
      PipelineSessionLoadFailed {
        error : string
        code : string
      }
      DO_LABEL {
        data : string
      }
      PipelineSessionManager.FORK -> FORK
      PipelineSessionManager.END -> END
    }
  }

  page "/session" -> PipelineSessionManager
}

orbital ExecutionLogOrbital {
    type ExecutionLogLoaded = Event { data : [ExecutionLog] } "Fired when ExecutionLog finishes loading"

    type ExecutionLogLoadFailed = Event { error : string, code : string } "Fired when ExecutionLog fails to load"

    type ExecutionLogSaveFailed = Event { error : string, code : string }

    type ExecutionLogSaved = Event { id : string }

  entity ExecutionLog [persistent: executionlogs] {
    id : string!
    content : string @description "The textual data associated with a specific item." @synonyms "text, data, body, value" = ""
    category : string @description "Classification or grouping of the pipeline plan." @synonyms "type, group, classification" = ""
    strength : number @description "A numerical value representing the intensity or force." @synonyms "magnitude, power, intensity" = 1
    pinned : boolean @description "Indicates whether the item is marked for persistent visibility." @synonyms "flagged, marked, saved, favorited" = false
    scope : string @description "Defines the area or context of the plan's operation." @synonyms "domain, area, context, range" = ""
    lastAccessedAt : string @description "Timestamp of the last access to the resource." @synonyms "accessed, last touch, last use"
    createdAt : string
  }

  trait ExecutionLogBrowse -> ExecutionLog [interaction, collection] {
    state browsing {
      INIT -> browsing
        (fetch ExecutionLog {
          emit: { failure: ExecutionLogLoadFailed, success: ExecutionLogLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      ExecutionLogLoaded -> browsing
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            children: [{
              align: center
              children: [{
                align: center
                children: [{ name: brain, type: icon }, {
                  content: "ExecutionLog Manager"
                  type: typography
                  variant: h2
                }]
                direction: horizontal
                gap: sm
                type: stack
              }, {
                children: [{
                  action: MEMORIZE
                  icon: plus
                  label: Memorize
                  type: button
                  variant: primary
                }, {
                  action: RECALL
                  icon: search
                  label: Recall
                  type: button
                  variant: secondary
                }, {
                  action: DECAY
                  icon: clock
                  label: "Decay All"
                  type: button
                  variant: ghost
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: horizontal
              gap: md
              justify: between
              type: stack
            }, { type: divider }, {
              entity: ?data
              fields: [{
                icon: brain
                label: Content
                name: content
                variant: h4
              }, {
                colorMap: {
                  active: success
                  archived: neutral
                  cancelled: destructive
                  completed: success
                  disabled: neutral
                  done: success
                  draft: warning
                  error: destructive
                  failed: destructive
                  inactive: neutral
                  pending: warning
                  scheduled: warning
                }
                label: Category
                name: category
                variant: badge
              }, {
                label: Strength
                name: strength
                variant: caption
              }]
              itemActions: [{
                event: PIN
                label: Pin
                variant: ghost
              }, {
                event: REINFORCE
                label: Reinforce
                variant: ghost
              }, {
                event: FORGET
                label: Forget
                variant: danger
              }]
              type: data-grid
            }]
            className: "max-w-5xl mx-auto w-full"
            direction: vertical
            gap: lg
            type: stack
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      ExecutionLogLoadFailed -> browsing
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load executionlog"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      MEMORIZE
      RECALL
      DECAY
      PIN {
        id : string!
        row : ExecutionLog
      }
      REINFORCE {
        id : string!
        row : ExecutionLog
      }
      FORGET {
        id : string!
        row : ExecutionLog
      }
      ExecutionLogLoaded
      ExecutionLogLoadFailed
    }

    listens {
      ExecutionLogCreate.MEMORIZED -> INIT
      ExecutionLogAgent.PINNED -> INIT
      ExecutionLogAgent.FORGOT -> INIT
      ExecutionLogAgent.REINFORCED -> INIT
      ExecutionLogAgent.DECAYED -> INIT
      ExecutionLogLoadFailed {
        error : string
        code : string
      }
    }
  }

  trait ExecutionLogCreate -> ExecutionLog [interaction, collection] {
    initial: closed

    state closed {
      INIT -> closed
        (fetch ExecutionLog {
          emit: { failure: ExecutionLogLoadFailed, success: ExecutionLogLoaded }
        })
      MEMORIZE -> open
        (render-ui modal {
          children: [{
            children: [{ name: plus-circle, type: icon }, {
              content: Memorize
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            cancelEvent: CLOSE
            fields: (content category scope)
            mode: create
            submitEvent: SAVE
            type: form-section
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: box })
        (notify Cancelled info)
      SAVE -> closed
        (persist create ExecutionLog ?data {
          emit: { failure: ExecutionLogSaveFailed, success: ExecutionLogSaved }
        })
        (render-ui modal null)
        (render-ui main { type: box })
        (emit MEMORIZED)
    }

    emits {
      MEMORIZED
      ExecutionLogLoadFailed
      ExecutionLogLoaded
      ExecutionLogSaveFailed
      ExecutionLogSaved
    }

    listens {
      ExecutionLogLoadFailed {
        error : string
        code : string
      }
      SAVE {
        data : string
      }
      ExecutionLogBrowse.MEMORIZE -> MEMORIZE
    }
  }

  trait ExecutionLogAgent -> ExecutionLog [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (fetch ExecutionLog {
          emit: { failure: ExecutionLogLoadFailed, success: ExecutionLogLoaded }
        })
        (render-ui main {
          appName: "Agent Pipeline"
          children: [{
            description: "Memory is ready"
            icon: brain
            title: Memory
            type: empty-state
          }]
          navItems: [{
            href: "/pipeline"
            icon: git-branch
            label: Pipeline
          }, {
            href: "/execution"
            icon: play
            label: Execution
          }, {
            href: "/logs"
            icon: terminal
            label: Logs
          }]
          type: dashboard-layout
        })
      DO_MEMORIZE -> active
        (agent/memorize ?data.content ?data.category)
        (persist create ExecutionLog ?data {
          emit: { failure: ExecutionLogSaveFailed, success: ExecutionLogSaved }
        })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED)
      MEMORIZED -> active
        (fetch ExecutionLog {
          emit: { failure: ExecutionLogLoadFailed, success: ExecutionLogLoaded }
        })
    }

    state active {
      RECALL -> active
        (agent/recall ?query)
      PIN -> active when (not (agent/is-pinned ?id))
        (agent/pin ?id)
        (set @entity.pinned true)
        (emit PINNED)
      FORGET -> idle
        (agent/forget ?id)
        (emit FORGOT)
      REINFORCE -> active
        (agent/reinforce ?id)
        (emit REINFORCED)
      DECAY -> active
        (agent/decay)
        (emit DECAYED)
    }

    emits {
      FORGOT -> external {
        id : string
      }
      REINFORCED -> external {
        id : string
      }
      DECAYED -> external {
        id : string
      }
      PINNED -> external {
        id : string
      }
      ExecutionLogLoadFailed
      ExecutionLogLoaded
      ExecutionLogSaveFailed
      ExecutionLogSaved
    }

    listens {
      PipelineExecOrbital.PipelineExecutor.PIPELINE_FINISHED -> DO_MEMORIZE
      ExecutionLogLoadFailed {
        error : string
        code : string
      }
      DO_MEMORIZE {
        data : string
      }
      RECALL {
        query : string
      }
      PIN {
        id : string
      }
      FORGET {
        id : string
      }
      REINFORCE {
        id : string
      }
      ExecutionLogBrowse.RECALL -> RECALL
      ExecutionLogBrowse.DECAY -> DECAY
      ExecutionLogBrowse.PIN -> PIN
      ExecutionLogBrowse.REINFORCE -> REINFORCE
      ExecutionLogBrowse.FORGET -> FORGET
    }
  }

  page "/logs" -> ExecutionLogBrowse, ExecutionLogCreate, ExecutionLogAgent
}

orbital PipelineProgressOrbital {
  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"

    type PipelineProgressLoaded = Event { data : [PipelineProgress] } "Fired when PipelineProgress finishes loading"

    type PipelineProgressLoadFailed = Event { error : string, code : string } "Fired when PipelineProgress fails to load"

  entity PipelineProgress [runtime] {
    id : string!
    steps : string @description "Ordered sequence of actions within a process." @synonyms "sequence, order, steps, stages" = ""
    currentStep : number @description "The index of the currently executing step." @synonyms "step number, step index, current iteration"
    totalSteps : number @description "The total number of steps defined in the plan." @synonyms "count, number, size, length"
    status : string @description "Current state of the process." @synonyms "state, condition, progress" = idle
  }

  trait PipelineStepProgress = AgentStepProgress.traits.AgentStepProgressProgress -> PipelineProgress {
  }

  page "/pipeline/progress" -> PipelineStepProgress
}

orbital SessionTreeOrbital {
  uses Drawer from "std/behaviors/std-drawer"

    type SessionTreeLoaded = Event { data : [SessionTree] } "Fired when SessionTree finishes loading"

    type SessionTreeLoadFailed = Event { error : string, code : string } "Fired when SessionTree fails to load"

  entity SessionTree [runtime] {
    id : string!
    branchId : string @description "Unique identifier for a branch within a hierarchical structure." @synonyms "branch, identifier, reference"
    label : string @description "A human-readable identifier for the pipeline plan." @synonyms "name, title, identifier"
    status : string @description "Current state of the process." @synonyms "state, condition, progress" = idle
  }

  trait SessionTreeDrawer = Drawer.traits.DrawerContentDrawer -> SessionTree {
  }

  page "/pipeline/tree" -> SessionTreeDrawer
}