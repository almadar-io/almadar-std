app std-agent-fix-loop "1.0.0"
"Agent fix-loop molecule — validate an orbital, generate a repair prompt if errors, apply fix."

type ValidationError = { orbitalName: string, message: string!, code: string!, severity: string }

orbital AgentFixLoopOrbital {

  entity FixLoop [runtime] {
    orbitalName : string = ""
    errors : [ValidationError] = []
    fixPrompt : string = ""
    status : "idle" | "validating" | "fixing" | "fixed" | "valid" = idle
  }

  trait FixLoopExecution -> FixLoop [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.orbitalName "")
        (set @entity.errors [])
        (set @entity.fixPrompt "")
        (set @entity.status idle)
      VALIDATE_ORBITAL -> generating_prompt
        (set @entity.orbitalName ?orbitalName)
        (validate/validate @entity.orbitalName)
        (llm/generate @entity.orbitalName { emit: { success: PROMPT_GENERATED, failure: PROMPT_GENERATION_FAILED } })
    }

    state generating_prompt {
      PROMPT_GENERATED -> fixed
        (set @entity.fixPrompt ?result)
        (set @entity.status fixed)
        (emit FIX_APPLIED { orbitalName: @entity.orbitalName, fixPrompt: @entity.fixPrompt })
      PROMPT_GENERATION_FAILED -> fixed
        (set @entity.fixPrompt "")
        (set @entity.status fixed)
    }

    state fixed {
      INIT -> fixed
        (set @entity.status fixed)
      RESET -> idle

    emits {
      FIX_APPLIED {
        orbitalName : string!
        fixPrompt : string!
      }
      PROMPT_GENERATED {
        result : string!
      }
    }

    listens {
      VALIDATE_ORBITAL {
        orbitalName : string!
      }
    }
  }

  trait FixLoopListener -> FixLoop [lifecycle, instance] {
    initial: waiting

    state waiting {
      INIT -> waiting
        (set @entity.status idle)
      FIX_APPLIED -> resolved
        (set @entity.status fixed)
    }

    state resolved {
      INIT -> resolved
        (set @entity.status fixed)
      RESET -> waiting
        (set @entity.status idle)
    }

    listens {
      FixLoopExecution.FIX_APPLIED -> FIX_APPLIED
      RESET
    }
  }

  page "/agent-fix-loop" as AgentFixLoopPage -> FixLoopExecution, FixLoopListener
}
