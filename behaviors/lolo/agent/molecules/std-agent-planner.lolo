app std-agent-planner "1.0.0"
"std-agent-planner as a Function"
orbital AgentPlannerOrbital {
  uses AgentClassifier from "std/behaviors/std-agent-classifier"

  uses AgentCompletion from "std/behaviors/std-agent-completion"

  uses AgentMemory from "std/behaviors/std-agent-memory"

  uses Modal from "std/behaviors/std-modal"

    type AgentPlannerLoaded = Event AgentPlanner "Fired when AgentPlanner finishes loading"

    type AgentPlannerLoadFailed = Event { message : string } "Fired when AgentPlanner fails to load"

  entity AgentPlanner [runtime] {
    id : string
    name : string @description "A human-readable identifier for the agent planner." @synonyms "title, label, identifier"
    description : string @description "A textual explanation of the component's functionality." @synonyms "explanation, details, notes, summary"
    status : "active" | "inactive" | "pending" @description "Indicates the current operational state of the component." @synonyms "state, condition, operationalStatus" = active
    createdAt : string
    task : string @description "The objective or goal to be achieved." @synonyms "objective, goal, purpose, aim" = ""
    category : string @description "Classification or grouping of the agent planner." @synonyms "type, group, classification" = ""
    steps : string @description "Ordered sequence of actions to achieve a goal." @synonyms "sequence, process, instructions, procedure" = ""
    confidence : number @description "Represents the certainty level of a prediction or result." @synonyms "probability, certainty, likelihood, score" = 0
    relevantMemories : string @description "References to memories deemed important for the task." @synonyms "memory references, related memories, memory IDs" = ""
    memoryCount : number @description "The number of memories associated with this planner." @synonyms "count, size, quantity" = 0
    error : string @description "Details about any errors encountered during processing." @synonyms "failure, problem, issue, fault" = ""
    input : string @description "Data provided as an initial value or parameter." @synonyms "parameter, argument, value, initialData" = ""
    prompt : string @description "The text used as input for generating a response." @synonyms "query, instruction, request, text" = ""
    response : string @description "The output generated by the agent." @synonyms "result, output, answer" = ""
    provider : string @description "Identifies the source or origin of the data." @synonyms "source, origin, supplier" = anthropic
    model : string @description "The identifier of the language model used." @synonyms "model_id, language_model, llm" = claude-sonnet-4-20250514
    content : string @description "The textual data associated with the planner's output." @synonyms "text, data, body, payload" = ""
    scope : string @description "The area or domain this planner applies to." @synonyms "domain, area, range, boundaries" = ""
    strength : number @description "A numerical value representing the intensity or magnitude." @synonyms "magnitude, intensity, power, value" = 1
    pinned : boolean @description "Indicates whether the item is marked as important." @synonyms "flagged, marked, favorited" = false
    action : string @description "The specific action to be performed." @synonyms "command, operation, task" = ""
    detail : string @description "A more in-depth explanation or elaboration." @synonyms "notes, specifics, particulars, elaboration" = ""
    timestamp : string @description "The date and time when the event occurred." @synonyms "date, time, when" = ""
    duration : number @description "The length of time an operation took, typically in seconds." @synonyms "time, length, elapsed" = 0
    icon : string @description "A visual representation, often a symbol or image." @synonyms "image, symbol, graphic, visual" = circle
  }

  trait AgentPlannerPlanner -> AgentPlanner [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main {
          children: [{
            align: center
            children: [{ name: map, type: icon }, {
              content: "Task Planner"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Describe the task to plan"
                type: typography
                variant: body
              }, {
                entity: @entity
                fields: (task)
                mode: edit
                submitEvent: PLAN
                type: form-section
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      PLAN -> classifying
        (set @entity.status classifying)
        (agent/generate (str/concat "Classify this task into exactly one category.\n" "Categories: " "code, schema, design, debug, deploy" "\n" "Task: " @entity.task "\n" "Return only the category name."))
        (render-ui main {
          align: center
          children: [{ name: tag, type: icon }, {
            content: "Classifying task..."
            type: typography
            variant: h3
          }, { type: spinner }, {
            content: @entity.task
            type: typography
            variant: caption
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state classifying {
      CLASSIFIED -> recalling
        (set @entity.category ?category)
        (set @entity.status recalling)
        (agent/recall (str/concat @entity.category " " @entity.task) 5)
        (render-ui main {
          align: center
          children: [{ name: brain, type: icon }, {
            content: "Recalling relevant experience..."
            type: typography
            variant: h3
          }, { type: spinner }, { label: @entity.category, type: badge }]
          direction: vertical
          gap: lg
          type: stack
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          align: center
          children: [{ name: alert-triangle, type: icon }, {
            content: "Planning Failed"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            action: RESET
            icon: rotate-ccw
            label: "Try Again"
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state recalling {
      MEMORIES_LOADED -> planning
        (set @entity.relevantMemories ?memories)
        (set @entity.memoryCount ?count)
        (set @entity.status planning)
        (agent/generate (str/concat "Task: " @entity.task "\n" "Category: " @entity.category "\n" "Relevant experience:\n" @entity.relevantMemories "\n\n" "Generate a numbered step-by-step execution plan. " "Include a confidence score (0-100) for how likely this plan will succeed."))
        (render-ui main {
          align: center
          children: [{ name: cpu, type: icon }, {
            content: "Generating plan..."
            type: typography
            variant: h3
          }, { type: spinner }, {
            children: [{ label: @entity.category, type: badge }, { label: @entity.memoryCount, type: badge }]
            direction: horizontal
            gap: md
            justify: center
            type: stack
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          align: center
          children: [{ name: alert-triangle, type: icon }, {
            content: "Planning Failed"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            action: RESET
            icon: rotate-ccw
            label: "Try Again"
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state planning {
      PLAN_GENERATED -> ready
        (set @entity.steps ?steps)
        (set @entity.confidence ?confidence)
        (set @entity.status ready)
        (agent/memorize (str/concat "Plan for " @entity.category " task: " @entity.task) pattern-affinity)
        (emit PLAN_READY)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: check-circle, type: icon }, {
                content: "Plan Ready"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: RESET
              icon: rotate-ccw
              label: "New Plan"
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: sm
            justify: between
            type: stack
          }, { type: divider }, {
            children: [{
              icon: tag
              label: Category
              type: stat-display
              value: @entity.category
            }, {
              icon: target
              label: Confidence
              type: stat-display
              value: @entity.confidence
            }, {
              icon: brain
              label: "Memories Used"
              type: stat-display
              value: @entity.memoryCount
            }]
            cols: 3
            type: simple-grid
          }, { type: divider }, {
            children: [{
              children: [{
                content: Task
                type: typography
                variant: caption
              }, {
                content: @entity.task
                type: typography
                variant: body
              }, { type: divider }, {
                content: "Execution Plan"
                type: typography
                variant: caption
              }, {
                content: @entity.steps
                type: typography
                variant: body
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }, {
            children: [{
              children: [{
                content: "Relevant Memories"
                type: typography
                variant: caption
              }, {
                content: @entity.relevantMemories
                type: typography
                variant: body
              }]
              direction: vertical
              gap: sm
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          align: center
          children: [{ name: alert-triangle, type: icon }, {
            content: "Planning Failed"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            action: RESET
            icon: rotate-ccw
            label: "Try Again"
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state ready {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.category "")
        (set @entity.steps "")
        (set @entity.confidence 0)
        (set @entity.relevantMemories "")
        (set @entity.memoryCount 0)
        (set @entity.error "")
        (render-ui main {
          children: [{
            align: center
            children: [{ name: map, type: icon }, {
              content: "Task Planner"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Describe the task to plan"
                type: typography
                variant: body
              }, {
                entity: @entity
                fields: (task)
                mode: edit
                submitEvent: PLAN
                type: form-section
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    emits {
      PLAN_READY -> external {
        plan : string
        category : string
      }
    }

    listens {
      AgentPlannerPlanner.PLAN_READY -> INIT
      PlannerTaskInput.PLAN -> PLAN
      CLASSIFIED {
        category : string!
      }
      MEMORIES_LOADED {
        memories : string!
        count : number!
      }
      PLAN_GENERATED {
        steps : string!
        confidence : number!
      }
      FAILED {
        error : string!
      }
    }
  }

  trait PlannerTaskInput = Modal.traits.ModalRecordModal -> AgentPlanner {
    events {
      OPEN: NEW_TASK
      SAVE: PLAN
    }

    config {
      icon: plus-circle
      title: "New Task"
      fields: (task)
      mode: create
    }
  }

  trait PlannerClassifierFlow = AgentClassifier.traits.AgentClassifierModal -> AgentPlanner {
    emitsScope internal
  }

  trait PlannerCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentPlanner {
    emitsScope internal
  }

  trait PlannerMemoryLifecycle = AgentMemory.traits.AgentMemoryBrowse -> AgentPlanner {
    emitsScope internal
  }

  page "/agentplanners" as AgentPlannerPage -> AgentPlannerPlanner, PlannerTaskInput, PlannerClassifierFlow, PlannerCompletionFlow, PlannerMemoryLifecycle
}