app std-agent-learner "1.0.0"
"std-agent-learner as a Function"

orbital AgentLearnerOrbital {
  uses AgentCompletion from "std/behaviors/std-agent-completion"
  uses AgentMemory from "std/behaviors/std-agent-memory"
  uses AgentProvider from "std/behaviors/std-agent-provider"
  uses Browse from "std/behaviors/std-browse"

  entity AgentLearner [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    outcome : string = ""
    category : string = ""
    impact : string = ""
    memoryId : string = ""
    isSuccess : boolean = false
    provider : string = ""
    consecutiveFailures : number = 0
    totalSuccesses : number = 0
    totalFailures : number = 0
    error : string = ""
    content : string = ""
    scope : string = ""
    strength : number = 1
    pinned : boolean = false
    prompt : string = ""
    response : string = ""
    model : string = "claude-sonnet-4-20250514"
    currentProvider : string = "anthropic"
    currentModel : string = "claude-sonnet-4-20250514"
    fallbackProvider : string = "anthropic"
    requestCount : number = 0
    action : string = ""
    detail : string = ""
    timestamp : string = ""
    duration : number = 0
    icon : string = "circle"
  }

  type AgentLearnerLoaded     = Event AgentLearner                  "Fired when AgentLearner finishes loading"
  type AgentLearnerLoadFailed = Event { message : string } "Fired when AgentLearner fails to load"
  trait AgentLearnerLearner -> AgentLearner [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.provider (agent/provider))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "graduation-cap"}, { type: "typography", content: "Outcome Learner", variant: "h2" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Successes", value: "@entity.totalSuccesses", icon: "check-circle" }, { type: "stat-display", label: "Failures", value: "@entity.totalFailures", icon: "x-circle" }, { type: "stat-display", label: "Current Provider", value: "@entity.provider", icon: "cpu" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Listening for task outcomes...", variant: "body" }, { type: "typography", content: "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.", variant: "caption" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Outcome", variant: "caption" }, { type: "typography", content: "@entity.outcome", variant: "body" }, { type: "typography", content: "Impact Analysis", variant: "caption" }, { type: "typography", content: "@entity.impact", variant: "body" }] }] }] })
      TASK_SUCCEEDED -> recording
        (set @entity.outcome @payload.outcome)
        (set @entity.category @payload.category)
        (set @entity.isSuccess true)
        (set @entity.consecutiveFailures 0)
        (set @entity.totalSuccesses (+ @entity.totalSuccesses 1))
        (set @entity.status recording)
        (agent/memorize (str/concat "Success: " @payload.outcome) @payload.category)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "save"}, { type: "typography", content: "Recording outcome...", variant: "h3" }, { type: "spinner"}, { type: "badge", label: "@entity.outcome" }] })
      TASK_FAILED -> recording
        (set @entity.outcome @payload.outcome)
        (set @entity.category @payload.category)
        (set @entity.isSuccess false)
        (set @entity.consecutiveFailures (+ @entity.consecutiveFailures 1))
        (set @entity.totalFailures (+ @entity.totalFailures 1))
        (set @entity.status recording)
        (agent/memorize (str/concat "Failure: " @payload.outcome) @payload.category)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "save"}, { type: "typography", content: "Recording outcome...", variant: "h3" }, { type: "spinner"}, { type: "badge", label: "@entity.outcome" }] })
      RESET -> idle
        (set @entity.provider (agent/provider))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "graduation-cap"}, { type: "typography", content: "Outcome Learner", variant: "h2" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Successes", value: "@entity.totalSuccesses", icon: "check-circle" }, { type: "stat-display", label: "Failures", value: "@entity.totalFailures", icon: "x-circle" }, { type: "stat-display", label: "Current Provider", value: "@entity.provider", icon: "cpu" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Listening for task outcomes...", variant: "body" }, { type: "typography", content: "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.", variant: "caption" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Outcome", variant: "caption" }, { type: "typography", content: "@entity.outcome", variant: "body" }, { type: "typography", content: "Impact Analysis", variant: "caption" }, { type: "typography", content: "@entity.impact", variant: "body" }] }] }] })
    }
    state recording {
      RECORDED -> analyzing
        (set @entity.memoryId @payload.memoryId)
        (if @entity.isSuccess (agent/reinforce @payload.memoryId) (agent/decay))
        (if (>= @entity.consecutiveFailures 3) (agent/switch-provider anthropic) (log "No provider switch needed"))
        (set @entity.status analyzing)
        (agent/generate (str/concat "Outcome: " @entity.outcome "\n" "Category: " @entity.category "\n" "Result: " (if @entity.isSuccess success failure) "\n" "Consecutive failures: " (str/concat @entity.consecutiveFailures) "\n\n" "Analyze the impact of this outcome. What should be learned? Keep it to 1-2 sentences."))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu"}, { type: "typography", content: "Analyzing impact...", variant: "h3" }, { type: "spinner"}, { type: "stack", direction: "horizontal", gap: "md", justify: "center", children: [{ type: "badge", label: "@entity.category" }, { type: "badge", label: "@entity.isSuccess" }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "graduation-cap"}, { type: "typography", content: "Outcome Learner", variant: "h2" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Successes", value: "@entity.totalSuccesses", icon: "check-circle" }, { type: "stat-display", label: "Failures", value: "@entity.totalFailures", icon: "x-circle" }, { type: "stat-display", label: "Current Provider", value: "@entity.provider", icon: "cpu" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Listening for task outcomes...", variant: "body" }, { type: "typography", content: "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.", variant: "caption" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Outcome", variant: "caption" }, { type: "typography", content: "@entity.outcome", variant: "body" }, { type: "typography", content: "Impact Analysis", variant: "caption" }, { type: "typography", content: "@entity.impact", variant: "body" }] }] }] })
    }
    state analyzing {
      ANALYSIS_DONE -> idle
        (set @entity.impact @payload.impact)
        (set @entity.status idle)
        (set @entity.provider (agent/provider))
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "graduation-cap"}, { type: "typography", content: "Outcome Learner", variant: "h2" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Successes", value: "@entity.totalSuccesses", icon: "check-circle" }, { type: "stat-display", label: "Failures", value: "@entity.totalFailures", icon: "x-circle" }, { type: "stat-display", label: "Current Provider", value: "@entity.provider", icon: "cpu" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Listening for task outcomes...", variant: "body" }, { type: "typography", content: "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.", variant: "caption" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Outcome", variant: "caption" }, { type: "typography", content: "@entity.outcome", variant: "body" }, { type: "typography", content: "Impact Analysis", variant: "caption" }, { type: "typography", content: "@entity.impact", variant: "body" }] }] }] })
      FAILED -> idle
        (set @entity.error @payload.error)
        (set @entity.status idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "graduation-cap"}, { type: "typography", content: "Outcome Learner", variant: "h2" }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Successes", value: "@entity.totalSuccesses", icon: "check-circle" }, { type: "stat-display", label: "Failures", value: "@entity.totalFailures", icon: "x-circle" }, { type: "stat-display", label: "Current Provider", value: "@entity.provider", icon: "cpu" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Listening for task outcomes...", variant: "body" }, { type: "typography", content: "This module records TASK_SUCCEEDED and TASK_FAILED events automatically.", variant: "caption" }] }] }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", content: "Last Outcome", variant: "caption" }, { type: "typography", content: "@entity.outcome", variant: "body" }, { type: "typography", content: "Impact Analysis", variant: "caption" }, { type: "typography", content: "@entity.impact", variant: "body" }] }] }] })
    }
    emits {
      TASK_SUCCEEDED -> external { outcome: string, category: string }
    }
    listens {
      AgentLearnerLearner.TASK_SUCCEEDED -> TASK_SUCCEEDED
      RECORDED { memoryId : string! }
      ANALYSIS_DONE { impact : string! }
      FAILED { error : string! }
          TASK_SUCCEEDED { outcome : string, category : string }
          TASK_FAILED { outcome : string, category : string }
    }
  }
  trait LearnerRecordsBrowse = Browse.traits.BrowseItemBrowse -> AgentLearner {
  }
  trait LearnerMemoryLifecycle = AgentMemory.traits.AgentMemoryBrowse -> AgentLearner {
    emitsScope internal
  }
  trait LearnerCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentLearner {
    emitsScope internal
  }
  trait LearnerProviderManager = AgentProvider.traits.AgentProviderModal -> AgentLearner {
    emitsScope internal
  }
  page "/agentlearners" as AgentLearnerPage -> AgentLearnerLearner, LearnerRecordsBrowse, LearnerMemoryLifecycle, LearnerCompletionFlow, LearnerProviderManager
}