app std-agent-tool-loop "1.0.0"
"std-agent-tool-loop as a Function"
orbital AgentToolLoopOrbital {
  uses AgentCompletion from "std/behaviors/std-agent-completion"

  uses AgentContextWindow from "std/behaviors/std-agent-context-window"

  uses AgentStepProgress from "std/behaviors/std-agent-step-progress"

  uses AgentToolCall from "std/behaviors/std-agent-tool-call"

    type AgentToolLoopLoaded = Event AgentToolLoop "Fired when AgentToolLoop finishes loading"

    type AgentToolLoopLoadFailed = Event { message : string } "Fired when AgentToolLoop fails to load"

  entity AgentToolLoop [runtime] {
    id : string
    name : string @description "A human-readable identifier for the loop." @synonyms "label, identifier, title"
    description : string @description "A textual explanation of the field's content." @synonyms "explanation, details, notes, summary"
    status : "idle" | "in_progress" | "planning" | "completed" | "failed" @description "Indicates the current operational state of the loop." @synonyms "state, condition, operational_status" = idle
    createdAt : string
    task : string @description "The identifier or name of the assigned task." @synonyms "taskName, identifier, job" = ""
    plan : string @description "A textual representation of the operational plan." @synonyms "strategy, outline, sequence, steps" = ""
    iterations : number @description "The number of times a process repeats." @synonyms "count, repeats, loops" = 0
    maxIterations : number @description "The maximum number of iterations allowed." @synonyms "limit, count, maximum" = 10
    result : string @description "The output or outcome of a process or operation." @synonyms "output, outcome, value, data" = ""
    currentTool : string @description "The name of the tool currently being executed." @synonyms "tool, toolName, activeTool" = ""
    lastToolResult : string @description "The outcome of the last tool execution." @synonyms "output, result, value" = ""
    error : string @description "Details about any errors encountered during processing." @synonyms "failure, problem, issue, fault" = ""
    currentStep : number @description "The index of the current step in a sequence." @synonyms "step, index, position" = 0
    totalSteps : number @description "The total number of steps in the process." @synonyms "count, quantity, number, size" = 4
    steps : string @description "A sequence of actions or operations to be performed." @synonyms "sequence, order, process, stages" = "Plan,Execute,Check,Complete"
    toolName : string @description "The name of the tool being used." @synonyms "tool, identifier, reference" = ""
    args : string @description "Arguments passed to the function." @synonyms "parameters, inputs, arguments" = ""
    prompt : string @description "The text input provided to the tool." @synonyms "query, input, request" = ""
    response : string @description "The text-based output generated by a tool." @synonyms "output, answer, content, text" = ""
    provider : string @description "Specifies the source or origin of the data." @synonyms "source, origin, vendor" = anthropic
    model : string @description "The identifier of the language model used." @synonyms "model_id, language_model, llm" = claude-sonnet-4-20250514
    tokenCount : number @description "The number of tokens used." @synonyms "count, quantity, total" = 0
    maxTokens : number @description "The maximum number of tokens allowed for processing." @synonyms "limit, token limit, max length" = 200000
    usage : number @description "Represents the number of times the component has been utilized." @synonyms "count, uses, invocations, frequency" = 0
    current : number @description "The current value of a numerical measurement or counter." @synonyms "value, count, level, index" = 0
    max : number @description "The maximum value allowed or supported." @synonyms "limit, maximum, upper bound" = 200000
    threshold : number @description "A numerical value representing a limit or boundary." @synonyms "limit, boundary, cutoff, level" = 0.85
    lastCompactedAt : string @description "Timestamp of the last compaction event." @synonyms "compacted, last compacted, compaction time" = ""
    action : string @description "The operation or command to be executed." @synonyms "command, operation, task, verb" = ""
    detail : string @description "A detailed explanation or note about a specific event." @synonyms "note, comment, explanation, remark" = ""
    timestamp : string @description "The date and time when an event occurred." @synonyms "date, time, when" = ""
    duration : number @description "The time taken to complete a process, measured in numerical units." @synonyms "time, length, elapsed, period" = 0
  }

  trait AgentToolLoopLoop -> AgentToolLoop [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.maxIterations 10)
        (render-ui main {
          children: [{
            align: center
            children: [{ name: repeat, type: icon }, {
              content: "Tool Execution Loop"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Describe the task to execute with tools"
                type: typography
                variant: body
              }, {
                entity: @entity
                fields: (task)
                mode: edit
                submitEvent: EXECUTE
                type: form-section
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      EXECUTE -> planning
        (set @entity.status planning)
        (set @entity.iterations 0)
        (agent/generate (str/concat "Task: " @entity.task "\n\nAvailable tools: " (str/join (agent/tools) ", ") "\n\nGenerate a step-by-step plan. Return the first tool to call and its arguments."))
        (render-ui main {
          align: center
          children: [{ name: brain, type: icon }, {
            content: "Planning execution..."
            type: typography
            variant: h3
          }, { type: spinner }, {
            content: @entity.task
            type: typography
            variant: caption
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state planning {
      PLAN_GENERATED -> executing
        (set @entity.plan ?plan)
        (set @entity.currentTool ?toolName)
        (set @entity.iterations ["+", @entity.iterations, 1])
        (agent/invoke ?toolName ?toolArgs)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: tool, type: icon }, {
                content: "Executing Tool"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { label: @entity.maxIterations, type: badge }]
            direction: horizontal
            gap: sm
            justify: between
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Current Tool"
                type: typography
                variant: caption
              }, {
                content: @entity.currentTool
                type: typography
                variant: h4
              }, { type: spinner }]
              direction: vertical
              gap: sm
              type: stack
            }]
            type: card
          }, {
            children: [{
              children: [{
                content: Plan
                type: typography
                variant: caption
              }, {
                content: @entity.plan
                type: typography
                variant: body
              }]
              direction: vertical
              gap: sm
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          align: center
          children: [{ name: x-circle, type: icon }, {
            content: "Loop Failed"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            children: [{
              icon: repeat
              label: "Iterations Used"
              type: stat-display
              value: @entity.iterations
            }, {
              icon: shield
              label: "Max Allowed"
              type: stat-display
              value: @entity.maxIterations
            }]
            cols: 2
            type: simple-grid
          }, {
            action: RESET
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state executing {
      TOOL_RESULT -> checking
        (set @entity.lastToolResult ?output)
        (agent/generate (str/concat "Task: " @entity.task "\nPlan: " @entity.plan "\nTool output: " ?output "\n\nIs the task complete? If yes, provide the final result. If no, specify the next tool and arguments."))
        (render-ui main {
          align: center
          children: [{ name: eye, type: icon }, {
            content: "Checking result..."
            type: typography
            variant: h3
          }, { type: spinner }, { label: @entity.iterations, type: badge }]
          direction: vertical
          gap: lg
          type: stack
        })
      FAILED -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          align: center
          children: [{ name: x-circle, type: icon }, {
            content: "Loop Failed"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            children: [{
              icon: repeat
              label: "Iterations Used"
              type: stat-display
              value: @entity.iterations
            }, {
              icon: shield
              label: "Max Allowed"
              type: stat-display
              value: @entity.maxIterations
            }]
            cols: 2
            type: simple-grid
          }, {
            action: RESET
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state checking {
      CHECK_PASSED -> completed
        (set @entity.result ?result)
        (set @entity.status completed)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: check-circle, type: icon }, {
                content: "Loop Complete"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: RESET
              icon: rotate-ccw
              label: "New Task"
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: sm
            justify: between
            type: stack
          }, { type: divider }, {
            children: [{
              icon: repeat
              label: Iterations
              type: stat-display
              value: @entity.iterations
            }, {
              icon: check
              label: Status
              type: stat-display
              value: @entity.status
            }]
            cols: 2
            type: simple-grid
          }, { type: divider }, {
            children: [{
              children: [{
                content: Task
                type: typography
                variant: caption
              }, {
                content: @entity.task
                type: typography
                variant: body
              }, { type: divider }, {
                content: Result
                type: typography
                variant: caption
              }, {
                content: @entity.result
                type: typography
                variant: body
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      CHECK_NEEDS_MORE -> executing
        (set @entity.currentTool ?toolName)
        (set @entity.iterations ["+", @entity.iterations, 1])
        (if [">=", (agent/context-usage), 0.8] (agent/compact hybrid) (log "Context below compact threshold"))
        (agent/invoke ?toolName ?toolArgs)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: tool, type: icon }, {
                content: "Executing Tool"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, { label: @entity.maxIterations, type: badge }]
            direction: horizontal
            gap: sm
            justify: between
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Current Tool"
                type: typography
                variant: caption
              }, {
                content: @entity.currentTool
                type: typography
                variant: h4
              }, { type: spinner }]
              direction: vertical
              gap: sm
              type: stack
            }]
            type: card
          }, {
            children: [{
              children: [{
                content: Plan
                type: typography
                variant: caption
              }, {
                content: @entity.plan
                type: typography
                variant: body
              }]
              direction: vertical
              gap: sm
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      MAX_ITERATIONS -> failed
        (set @entity.error ?error)
        (set @entity.status failed)
        (render-ui main {
          align: center
          children: [{ name: x-circle, type: icon }, {
            content: "Loop Failed"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            children: [{
              icon: repeat
              label: "Iterations Used"
              type: stat-display
              value: @entity.iterations
            }, {
              icon: shield
              label: "Max Allowed"
              type: stat-display
              value: @entity.maxIterations
            }]
            cols: 2
            type: simple-grid
          }, {
            action: RESET
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main {
          children: [{
            align: center
            children: [{ name: repeat, type: icon }, {
              content: "Tool Execution Loop"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Describe the task to execute with tools"
                type: typography
                variant: body
              }, {
                entity: @entity
                fields: (task)
                mode: edit
                submitEvent: EXECUTE
                type: form-section
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state failed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.task "")
        (set @entity.plan "")
        (set @entity.result "")
        (set @entity.currentTool "")
        (set @entity.lastToolResult "")
        (set @entity.iterations 0)
        (set @entity.error "")
        (render-ui main {
          children: [{
            align: center
            children: [{ name: repeat, type: icon }, {
              content: "Tool Execution Loop"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Describe the task to execute with tools"
                type: typography
                variant: body
              }, {
                entity: @entity
                fields: (task)
                mode: edit
                submitEvent: EXECUTE
                type: form-section
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    listens {
      PLAN_GENERATED {
        plan : string!
        toolName : string!
        toolArgs : object!
      }
      TOOL_RESULT {
        output : string!
      }
      CHECK_PASSED {
        result : string!
      }
      CHECK_NEEDS_MORE {
        toolName : string!
        toolArgs : object!
      }
      MAX_ITERATIONS {
        error : string!
      }
      FAILED {
        error : string!
      }
    }
  }

  trait ToolLoopStepProgress = AgentStepProgress.traits.AgentStepProgressProgress -> AgentToolLoop {
    emitsScope internal
  }

  trait ToolLoopCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentToolLoop {
    emitsScope internal
  }

  trait ToolLoopToolCallFlow = AgentToolCall.traits.AgentToolCallModal -> AgentToolLoop {
    emitsScope internal
  }

  trait ToolLoopContextMonitor = AgentContextWindow.traits.AgentContextWindowGauge -> AgentToolLoop {
    emitsScope internal
  }

  page "/agenttoolloops" as AgentToolLoopPage -> AgentToolLoopLoop, ToolLoopStepProgress, ToolLoopCompletionFlow, ToolLoopToolCallFlow, ToolLoopContextMonitor
}