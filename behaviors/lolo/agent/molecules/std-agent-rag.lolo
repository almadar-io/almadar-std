app std-agent-rag "1.0.0"
"std-agent-rag as a Function"
type ItemSpec = { id : string, label : string!, value : string, icon : string }
orbital AgentRagOrbital {
  uses AgentCompletion from "std/behaviors/std-agent-completion"

  uses AgentMemory from "std/behaviors/std-agent-memory"

  uses AgentSearch from "std/behaviors/std-agent-search"

  uses Tabs from "std/behaviors/std-tabs"

    type AgentRagLoaded = Event AgentRag "Fired when AgentRag finishes loading"

    type AgentRagLoadFailed = Event { message : string } "Fired when AgentRag fails to load"

  entity AgentRag [runtime] {
    id : string
    name : string @description "A human-readable identifier for the agent." @synonyms "title, label, identifier"
    description : string @description "A brief explanation of the component's function." @synonyms "explanation, details, summary, notes"
    status : "idle" | "retrieving" | "generating" | "completed" | "error" @description "Indicates the current operational state of the component." @synonyms "state, condition, operational_status" = idle
    createdAt : string
    query : string @description "The text used to initiate a search or request." @synonyms "search term, request, input, question" = ""
    context : string @description "The surrounding information used for processing." @synonyms "background, details, surrounding text" = ""
    response : string @description "The text output generated by the agent." @synonyms "output, answer, text, result" = ""
    memoryHits : number @description "The number of memory hits retrieved." @synonyms "count, hits, number" = 0
    searchHits : number @description "The number of search results retrieved." @synonyms "count, total, size, number" = 0
    error : string @description "Details about any errors encountered during processing." @synonyms "failure, problem, issue, exception" = ""
    content : string @description "The textual data associated with an item." @synonyms "text, data, body, value" = ""
    category : string @description "Classification or type of the agent rag." @synonyms "type, classification, kind" = ""
    scope : string @description "Defines the boundaries or area of focus." @synonyms "domain, area, range, limits" = ""
    strength : number @description "A numerical value representing confidence or relevance." @synonyms "score, confidence, relevance, rating" = 1
    pinned : boolean @description "Indicates whether the item is marked as important." @synonyms "flagged, marked, important" = false
    language : string @description "The language used for processing and generation." @synonyms "locale, languageCode, languageTag" = ""
    resultCount : number @description "The number of results returned." @synonyms "count, size, total, quantity" = 0
    results : string @description "The output or outcome of a process or operation." @synonyms "output, outcome, result, data" = "[]"
    prompt : string @description "The text used as input for generating a response." @synonyms "instruction, query, input" = ""
    provider : string @description "Identifies the source or service providing data." @synonyms "source, origin, vendor" = anthropic
    model : string @description "Specifies the language model used for processing." @synonyms "engine, classifier, algorithm" = claude-sonnet-4-20250514
    activeTab : string @description "The currently selected tab within the interface." @synonyms "selection, current tab, tab" = ""
    items : [ItemSpec] @description "A list of items retrieved or processed." @synonyms "entries, records, data" = []
  }

  trait AgentRagRag -> AgentRag [interaction, collection] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.query "")
        (render-ui main {
          children: [{
            align: center
            children: [{ name: brain, type: icon }, {
              content: "RAG Pipeline"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Enter a query to retrieve context and generate a response"
                type: typography
                variant: body
              }, {
                entity: @entity
                fields: (query)
                mode: edit
                submitEvent: GENERATE
                type: form-section
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      GENERATE -> retrieving
        (set @entity.status retrieving)
        (agent/recall @entity.query 5)
        (agent/search-code @entity.query)
        (render-ui main {
          align: center
          children: [{ name: search, type: icon }, {
            content: "Retrieving context..."
            type: typography
            variant: h3
          }, { type: spinner }, {
            children: [{
              label: "Recalling memories"
              type: badge
            }, {
              label: "Searching code"
              type: badge
            }]
            direction: horizontal
            gap: md
            justify: center
            type: stack
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state retrieving {
      RETRIEVAL_DONE -> generating
        (set @entity.context ?context)
        (set @entity.memoryHits ?memoryHits)
        (set @entity.searchHits ?searchHits)
        (set @entity.status generating)
        (agent/generate (str/concat "Context:\n" @entity.context "\n\nQuery: " @entity.query "\n\nProvide a comprehensive answer based on the retrieved context."))
        (render-ui main {
          align: center
          children: [{ name: cpu, type: icon }, {
            content: "Generating response..."
            type: typography
            variant: h3
          }, { type: spinner }, {
            children: [{ label: @entity.memoryHits, type: badge }, { label: @entity.searchHits, type: badge }]
            direction: horizontal
            gap: md
            justify: center
            type: stack
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          align: center
          children: [{ name: alert-triangle, type: icon }, {
            content: "RAG Pipeline Error"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            action: RESET
            icon: rotate-ccw
            label: "Try Again"
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state generating {
      GENERATION_DONE -> completed
        (set @entity.response ?response)
        (set @entity.status completed)
        (agent/memorize (str/concat "RAG query: " @entity.query) pattern-affinity)
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: check-circle, type: icon }, {
                content: "RAG Complete"
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: RESET
              icon: rotate-ccw
              label: "New Query"
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: sm
            justify: between
            type: stack
          }, { type: divider }, {
            children: [{
              icon: brain
              label: "Memory Hits"
              type: stat-display
              value: @entity.memoryHits
            }, {
              icon: code
              label: "Code Hits"
              type: stat-display
              value: @entity.searchHits
            }]
            cols: 2
            type: simple-grid
          }, { type: divider }, {
            children: [{
              children: [{
                content: Query
                type: typography
                variant: caption
              }, {
                content: @entity.query
                type: typography
                variant: body
              }, { type: divider }, {
                content: Response
                type: typography
                variant: caption
              }, {
                content: @entity.response
                type: typography
                variant: body
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }, {
            children: [{
              children: [{
                content: "Retrieved Context"
                type: typography
                variant: caption
              }, {
                content: @entity.context
                type: typography
                variant: body
              }]
              direction: vertical
              gap: sm
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
      FAILED -> idle
        (set @entity.error ?error)
        (set @entity.status error)
        (render-ui main {
          align: center
          children: [{ name: alert-triangle, type: icon }, {
            content: "RAG Pipeline Error"
            type: typography
            variant: h2
          }, {
            message: @entity.error
            type: alert
            variant: error
          }, {
            action: RESET
            icon: rotate-ccw
            label: "Try Again"
            type: button
            variant: primary
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.context "")
        (set @entity.memoryHits 0)
        (set @entity.searchHits 0)
        (set @entity.error "")
        (render-ui main {
          children: [{
            align: center
            children: [{ name: brain, type: icon }, {
              content: "RAG Pipeline"
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                content: "Enter a query to retrieve context and generate a response"
                type: typography
                variant: body
              }, {
                entity: @entity
                fields: (query)
                mode: edit
                submitEvent: GENERATE
                type: form-section
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            type: card
          }]
          direction: vertical
          gap: lg
          type: stack
        })
    }

    listens {
      RETRIEVAL_DONE {
        context : string!
        memoryHits : number!
        searchHits : number!
      }
      GENERATION_DONE {
        response : string!
      }
      FAILED {
        error : string!
      }
    }
  }

  trait RagTabs = Tabs.traits.TabsItemTabs -> AgentRag {
  }

  trait RagMemoryLifecycle = AgentMemory.traits.AgentMemoryBrowse -> AgentRag {
    emitsScope internal
  }

  trait RagSearchLifecycle = AgentSearch.traits.AgentSearchBrowse -> AgentRag {
    emitsScope internal
  }

  trait RagCompletionFlow = AgentCompletion.traits.AgentCompletionModal -> AgentRag {
    emitsScope internal
  }

  page "/agentrags" as AgentRagPage -> AgentRagRag, RagTabs, RagMemoryLifecycle, RagSearchLifecycle, RagCompletionFlow
}