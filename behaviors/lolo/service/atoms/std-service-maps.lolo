app std-service-maps "1.0.0"
"std-service-maps — Maps service for geocoding, reverse-geocoding, and distance via Mapbox/Google. Bind via `uses Maps from \"std/behaviors/std-service-maps\"` and configure `apiKey` / `provider` at the call site. Pass `uiTrait: \"@trait.YourMapsForm\"` to inject your own form; leave unset to render the atom's default geocode form (standalone surface)."

orbital ServiceMapsOrbital {
  entity ServiceMaps [runtime] {
    id : string!
    address : string = ""
    lat : number = 0
    lng : number = 0
    formattedAddress : string = ""
    distanceKm : number = 0
    error : string = ""
    status : "idle" | "geocoding" | "succeeded" | "error" = "idle"
  }

  type ServiceMapsLoaded     = Event ServiceMaps                  "Fired when ServiceMaps finishes loading"
  type ServiceMapsLoadFailed = Event { message : string } "Fired when ServiceMaps fails to load"

  trait ServiceMapsDefaultForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "map-pin" }, { type: "typography", content: "Maps", variant: "h2" }] }, { type: "divider" }, { type: "input", inputType: "text", placeholder: "Enter an address..." }, { type: "button", label: "Geocode", action: "GEOCODE", variant: "primary", icon: "search" }] })
    }
    emits {
      GEOCODE -> external { address : string }
    }
  }

  trait ServiceMapsMaps -> ServiceMaps [interaction, instance] {
    initial: idle
    config {
      uiTrait  : trait  = "@trait.ServiceMapsDefaultForm"
        @label "Geocode form"
        @description "Trait that renders the address lookup UI"
        @tier "internal"
      apiKey   : string = ""
        @label "Maps API key"
        @description "API key for the chosen maps provider (Mapbox or Google)"
        @tier "internal"
      provider : string = "mapbox"
        @label "Maps provider"
        @description "Which mapping vendor handles geocoding requests"
        @tier "customization"
    }
    state idle {
      INIT -> idle
        (fetch ServiceMaps { emit: { success: "ServiceMapsLoaded", failure: "ServiceMapsLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      GEOCODE -> geocoding
        (set @entity.address @payload.address)
        (set @entity.status "geocoding")
        (render-ui main { type: "loading-state", title: "Geocoding...", message: "Resolving address to coordinates." })
        (call-service maps "geocode" { address: "@payload.address", apiKey: "@config.apiKey", provider: "@config.provider" } { emit: { success: "GEOCODED", failure: "FAILED" } })
      REVERSE_GEOCODE -> geocoding
        (set @entity.lat @payload.lat)
        (set @entity.lng @payload.lng)
        (set @entity.status "geocoding")
        (render-ui main { type: "loading-state", title: "Reverse geocoding...", message: "Resolving coordinates to address." })
        (call-service maps "reverseGeocode" { lat: "@payload.lat", lng: "@payload.lng", apiKey: "@config.apiKey", provider: "@config.provider" } { emit: { success: "REVERSE_GEOCODED", failure: "FAILED" } })
      DISTANCE -> geocoding
        (set @entity.status "geocoding")
        (render-ui main { type: "loading-state", title: "Computing distance...", message: "Calculating distance between points." })
        (call-service maps "distance" { fromLat: "@payload.fromLat", fromLng: "@payload.fromLng", toLat: "@payload.toLat", toLng: "@payload.toLng", apiKey: "@config.apiKey", provider: "@config.provider" } { emit: { success: "DISTANCE_COMPUTED", failure: "FAILED" } })
      ServiceMapsLoaded -> idle
      ServiceMapsLoadFailed -> idle
    }
    state geocoding {
      GEOCODED -> succeeded
        (set @entity.lat @payload.lat)
        (set @entity.lng @payload.lng)
        (set @entity.formattedAddress @payload.formattedAddress)
        (set @entity.status "succeeded")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Address geocoded successfully" }, { type: "typography", variant: "body", color: "muted", content: "@entity.formattedAddress" }, { type: "button", label: "New Lookup", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      REVERSE_GEOCODED -> succeeded
        (set @entity.address @payload.address)
        (set @entity.formattedAddress @payload.address)
        (set @entity.status "succeeded")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Coordinates reverse-geocoded successfully" }, { type: "typography", variant: "body", color: "muted", content: "@entity.address" }, { type: "button", label: "New Lookup", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      DISTANCE_COMPUTED -> succeeded
        (set @entity.distanceKm @payload.distanceKm)
        (set @entity.status "succeeded")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Distance computed successfully" }, { type: "typography", variant: "body", color: "muted", content: "@entity.distanceKm" }, { type: "button", label: "New Lookup", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (set @entity.status "error")
        (render-ui main { type: "error-state", title: "Maps Request Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state succeeded {
      RESET -> idle
        (set @entity.status "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
    }
    state error {
      RETRY -> idle
        (set @entity.status "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      RESET -> idle
        (set @entity.status "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
    }
    emits {
      ServiceMapsLoaded       -> external { id : string }
      ServiceMapsLoadFailed   -> external { message : string }
      GEOCODED                -> external { lat : number!, lng : number!, formattedAddress : string! }
      REVERSE_GEOCODED        -> external { address : string! }
      DISTANCE_COMPUTED       -> external { distanceKm : number! }
      FAILED                  { error : string! }
    }

    listens {
      ServiceMapsDefaultForm.GEOCODE -> GEOCODE
      GEOCODE { address : string! }
      REVERSE_GEOCODE { lat : number!, lng : number! }
      DISTANCE { fromLat : number!, fromLng : number!, toLat : number!, toLng : number! }
      GEOCODED { lat : number!, lng : number!, formattedAddress : string! }
      REVERSE_GEOCODED { address : string! }
      DISTANCE_COMPUTED { distanceKm : number! }
      FAILED { error : string! }
      ServiceMapsLoaded { id : string }
      ServiceMapsLoadFailed { message : string }
    }
  }
  page "/servicemaps" as ServiceMapsPage -> ServiceMapsMaps
}
