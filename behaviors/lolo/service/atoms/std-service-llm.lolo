app std-service-llm "2.0.0"
"std-service-llm — LLM completion service. Bind via `uses Llm from \"std/behaviors/std-service-llm\"` and configure `provider` / `model` / `prompt` / `temperature` / `maxTokens` at the call site. Pass `uiTrait: \"@trait.YourLlmForm\"` to inject your own prompt form; leave unset to render the atom's default form (standalone surface)."

orbital ServiceLlmOrbital {
  entity ServiceLlm [runtime] {
    id : string!
    provider : string = "openai"
    model : string = "gpt-4"
    prompt : string = ""
    temperature : number = 0.7
    maxTokens : number = 2048
    result : string = ""
    llmStatus : string = "idle"
    error : string = ""
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type ServiceLlmLoaded     = Event ServiceLlm                  "Fired when ServiceLlm finishes loading"
  type ServiceLlmLoadFailed = Event { message : string } "Fired when ServiceLlm fails to load"
  type LlmCompleted = Event { id : string, content : string }
  type ServiceLlmLlmFailed = Event { error : string, code : string }

  ;; Default UI: a sibling trait pointing back at the standalone form.
  ;; Consumers override `uiTrait` to inject their own prompt form;
  ;; the default value below keeps standalone usage working.
  trait ServiceLlmDefaultForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "brain" }, { type: "typography", content: "LLM Completion", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "select", options: [{ label: "OpenAI", value: "openai" }, { label: "Anthropic", value: "anthropic" }, { label: "Google", value: "google" }] }, { type: "select", options: [{ label: "GPT-4", value: "gpt-4" }, { label: "GPT-4 Turbo", value: "gpt-4-turbo" }, { label: "Claude 3.5 Sonnet", value: "claude-3-5-sonnet" }, { label: "Gemini Pro", value: "gemini-pro" }] }, { type: "textarea", placeholder: "Enter your prompt..." }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "input", inputType: "number", placeholder: "Temperature (0.0 - 2.0)" }, { type: "input", inputType: "number", placeholder: "Max tokens" }] }] }, { type: "button", label: "Complete", action: "COMPLETE", variant: "primary", icon: "sparkles" }] })
    }
    emits {
      COMPLETE -> external { source : string }
    }
  }

  trait ServiceLlmLlm -> ServiceLlm [interaction, instance] {
    initial: idle
    config {
      uiTrait     : trait  = "@trait.ServiceLlmDefaultForm"
        @label "Prompt form"
        @description "Trait that renders the LLM prompt UI"
        @tier "internal"
      provider    : string = "openai"
        @label "Provider"
        @description "LLM vendor to call (openai, anthropic, google, etc.)"
        @tier "customization"
      model       : string = "gpt-4"
        @label "Model"
        @description "Specific model identifier from the chosen provider"
        @tier "customization"
      prompt      : string = ""
        @label "Prompt text"
        @description "Prompt sent to the model for completion"
        @tier "customization"
      temperature : number = 0.7
        @label "Temperature"
        @description "Sampling randomness, 0.0 deterministic to 2.0 highly creative"
        @tier "advanced"
      maxTokens   : number = 2048
        @label "Max tokens"
        @description "Upper bound on tokens in the model's response"
        @tier "advanced"
    }
    state idle {
      INIT -> idle
        (set @entity.provider @config.provider)
        (set @entity.model @config.model)
        (set @entity.prompt @config.prompt)
        (set @entity.temperature @config.temperature)
        (set @entity.maxTokens @config.maxTokens)
        (fetch ServiceLlm { emit: { success: "ServiceLlmLoaded", failure: "ServiceLlmLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      COMPLETE -> processing
        (render-ui main { type: "loading-state", title: "Generating...", message: "Calling LLM provider." })
        (call-service llm "generate" { userPrompt: "@config.prompt", model: "@config.model", temperature: "@config.temperature", maxTokens: "@config.maxTokens" } { emit: { success: "LlmCompleted", failure: "FAILED" } })
      ServiceLlmLoaded -> idle
      ServiceLlmLoadFailed -> idle
    }
    state processing {
      LlmCompleted -> complete
        (set @entity.result @payload.content)
        (set @entity.llmStatus "complete")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "LLM completion ready" }, { type: "typography", variant: "body", content: "@entity.result" }, { type: "button", label: "Start Over", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (set @entity.llmStatus "error")
        (emit ServiceLlmLlmFailed { error: @entity.error, code: "llm_complete_failed" })
        (render-ui main { type: "error-state", title: "LLM Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state complete {
      RESET -> idle
        (set @entity.llmStatus "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      ;; Self-loop on the external emit so ORB_X_UNUSED_EMISSION sees an
      ;; in-atom listener for the externally-consumed LlmCompleted emit.
      LlmCompleted -> complete
    }
    state error {
      ;; Mirrors the complete self-loop above: ServiceLlmLlmFailed is emitted
      ;; from the FAILED transition body in processing for downstream consumers,
      ;; and listened to here so the validator doesn't flag the emission as unused.
      ServiceLlmLlmFailed -> error
      RETRY -> idle
        (set @entity.llmStatus "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      RESET -> idle
        (set @entity.llmStatus "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
    }
    emits {
      ServiceLlmLoaded         -> external { id : string }
      ServiceLlmLoadFailed     -> external { message : string }
      LlmCompleted             -> external { id : string, content : string }
      ServiceLlmLlmFailed      -> external { error : string, code : string }
      ;; Internal chain trigger fired as call-service emit.failure.
      FAILED                   { error : string! }
    }

    listens {
      ServiceLlmDefaultForm.COMPLETE -> COMPLETE
      FAILED { error : string! }
      ServiceLlmLoaded { id : string }
      ServiceLlmLoadFailed { message : string }
      LlmCompleted { id : string, content : string }
      ServiceLlmLlmFailed { error : string, code : string }
    }
  }
  page "/servicellms" as ServiceLlmPage -> ServiceLlmLlm
}
