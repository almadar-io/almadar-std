app std-service-llm "1.0.0"
"std-service-llm as a Function"

orbital ServiceLlmOrbital {
  entity ServiceLlm [runtime] {
    id : string!
    inputText : string = ""
    action : string = "generate"
    result : string = ""
    llmStatus : string = "idle"
    error : string = ""
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type ServiceLlmLoaded     = Event ServiceLlm                  "Fired when ServiceLlm finishes loading"
  type ServiceLlmLoadFailed = Event { message : string } "Fired when ServiceLlm fails to load"
  type ServiceLlmLlmCompleted = Event { result : object }
  type ServiceLlmLlmFailed = Event { error : string, code : string }
  trait ServiceLlmLlm -> ServiceLlm [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ServiceLlm { emit: { success: "ServiceLlmLoaded", failure: "ServiceLlmLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "brain" }, { type: "typography", content: "ServiceLlm LLM", variant: "h2" }] }, { type: "divider" }, { type: "textarea", placeholder: "Enter text for LLM processing..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Generate", action: "GENERATE", variant: "primary", icon: "sparkles" }, { type: "button", label: "Classify", action: "CLASSIFY", variant: "secondary", icon: "tag" }, { type: "button", label: "Summarize", action: "SUMMARIZE", variant: "secondary", icon: "align-left" }] }] })
      GENERATE -> processing
        (set @entity.action generate)
        (render-ui main { type: "loading-state", title: "Processing...", message: "Running servicellm LLM task..." })
        (call-service llm generate { userPrompt: "@entity.inputText" } { emit: { success: "ServiceLlmLlmCompleted", failure: "ServiceLlmLlmFailed" } })
      CLASSIFY -> processing
        (set @entity.action classify)
        (render-ui main { type: "loading-state", title: "Processing...", message: "Running servicellm LLM task..." })
        (call-service llm classify { text: "@entity.inputText", categories: ["positive", "negative", "neutral"] } { emit: { success: "ServiceLlmLlmCompleted", failure: "ServiceLlmLlmFailed" } })
      SUMMARIZE -> processing
        (set @entity.action summarize)
        (render-ui main { type: "loading-state", title: "Processing...", message: "Running servicellm LLM task..." })
        (call-service llm summarize { text: "@entity.inputText" } { emit: { success: "ServiceLlmLlmCompleted", failure: "ServiceLlmLlmFailed" } })
    }
    state processing {
      COMPLETE -> complete
        (set @entity.result @payload.content)
        (set @entity.llmStatus complete)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "LLM task complete" }, { type: "typography", variant: "body", content: "@entity.result" }, { type: "button", label: "Start Over", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (set @entity.llmStatus error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "error-state", title: "LLM Failed", message: "@entity.error", onRetry: "RETRY" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Retry", action: "RETRY", variant: "primary", icon: "refresh-cw" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    state complete {
      RESET -> idle
        (set @entity.llmStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "brain" }, { type: "typography", content: "ServiceLlm LLM", variant: "h2" }] }, { type: "divider" }, { type: "textarea", placeholder: "Enter text for LLM processing..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Generate", action: "GENERATE", variant: "primary", icon: "sparkles" }, { type: "button", label: "Classify", action: "CLASSIFY", variant: "secondary", icon: "tag" }, { type: "button", label: "Summarize", action: "SUMMARIZE", variant: "secondary", icon: "align-left" }] }] })
    }
    state error {
      RETRY -> idle
        (set @entity.llmStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "brain" }, { type: "typography", content: "ServiceLlm LLM", variant: "h2" }] }, { type: "divider" }, { type: "textarea", placeholder: "Enter text for LLM processing..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Generate", action: "GENERATE", variant: "primary", icon: "sparkles" }, { type: "button", label: "Classify", action: "CLASSIFY", variant: "secondary", icon: "tag" }, { type: "button", label: "Summarize", action: "SUMMARIZE", variant: "secondary", icon: "align-left" }] }] })
      RESET -> idle
        (set @entity.llmStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "brain" }, { type: "typography", content: "ServiceLlm LLM", variant: "h2" }] }, { type: "divider" }, { type: "textarea", placeholder: "Enter text for LLM processing..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Generate", action: "GENERATE", variant: "primary", icon: "sparkles" }, { type: "button", label: "Classify", action: "CLASSIFY", variant: "secondary", icon: "tag" }, { type: "button", label: "Summarize", action: "SUMMARIZE", variant: "secondary", icon: "align-left" }] }] })
    }
emits {
      ServiceLlmLoaded
      ServiceLlmLoadFailed
      ServiceLlmLlmCompleted
      ServiceLlmLlmFailed
    }

        listens {
      COMPLETE { content : string! }
      FAILED { error : string! }
          ServiceLlmLoadFailed { message : string }
    
      ServiceLlmLlmFailed { error : string, code : string }
    }
  }
  page "/servicellms" as ServiceLlmPage -> ServiceLlmLlm
}