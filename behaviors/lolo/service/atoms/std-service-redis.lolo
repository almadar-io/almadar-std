app std-service-redis "1.0.0"
"std-service-redis as a Function"

orbital ServiceRedisOrbital {
  entity ServiceRedis [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    key : string
    value : string
    ttl : number = 3600
    result : string
    redisStatus : string = "idle"
    error : string
  }

  type ServiceRedisLoaded     = Event ServiceRedis                  "Fired when ServiceRedis finishes loading"
  type ServiceRedisLoadFailed = Event { message : string } "Fired when ServiceRedis fails to load"
  type ServiceRedisRedisCompleted = Event { result : object }
  type ServiceRedisRedisFailed = Event { error : string, code : string }
  trait ServiceRedisRedis -> ServiceRedis [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.key "")
        (set @entity.ttl 3600)
        (set @entity.value "")
        (fetch ServiceRedis { emit: { success: "ServiceRedisLoaded", failure: "ServiceRedisLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "input", inputType: "number", placeholder: "3600" }] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] })
      GET_KEY -> executing
        (render-ui main { type: "loading-state", title: "Executing...", message: "Running redis operation..." })
        (call-service redis get { key: "@entity.key" } { emit: { success: "ServiceRedisRedisCompleted", failure: "ServiceRedisRedisFailed" } })
      SET_KEY -> executing
        (render-ui main { type: "loading-state", title: "Executing...", message: "Running redis operation..." })
        (call-service redis set { key: "@entity.key", value: "@entity.value", ttl: "@entity.ttl" } { emit: { success: "ServiceRedisRedisCompleted", failure: "ServiceRedisRedisFailed" } })
      DELETE_KEY -> executing
        (render-ui main { type: "loading-state", title: "Executing...", message: "Running redis operation..." })
        (call-service redis delete { key: "@entity.key" } { emit: { success: "ServiceRedisRedisCompleted", failure: "ServiceRedisRedisFailed" } })
    }
    state executing {
      EXECUTED -> complete
        (set @entity.result @payload.data)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Operation complete" }, { type: "typography", variant: "body", color: "muted", content: "@entity.result" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "error-state", title: "Redis Error", message: "@entity.error", onRetry: "RESET" })
    }
    state complete {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "input", inputType: "number", placeholder: "3600" }] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] })
    }
    state error {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "input", inputType: "number", placeholder: "3600" }] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] })
    }
emits {
      ServiceRedisLoaded            -> external { id : string }
      ServiceRedisLoadFailed        -> external { message : string }
      ServiceRedisRedisCompleted           -> external { result : object }
      ServiceRedisRedisFailed              -> external { error : string, code : string }
    }

        listens {
      EXECUTED { data : string! }
      FAILED { error : string! }
          ServiceRedisLoadFailed { message : string }
    
      ServiceRedisRedisFailed { error : string, code : string }
    }
  }
  page "/servicerediss" as ServiceRedisPage -> ServiceRedisRedis
}