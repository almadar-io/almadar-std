app std-service-redis "2.0.0"
"std-service-redis — Redis cache service. Bind via `uses Redis from \"std/behaviors/std-service-redis\"` and configure `op` / `key` / `value` / `ttl` at the call site. Pass `uiTrait: \"@trait.YourRedisForm\"` to inject your own form; leave unset to render the atom's default form (standalone surface)."

orbital ServiceRedisOrbital {
  entity ServiceRedis [runtime] {
    id : string!
    key : string = ""
    value : string = ""
    ttl : number = 0
    op : "get" | "set" | "del" = "get"
    result : object = {}
    redisStatus : string = "idle"
    error : string = ""
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type ServiceRedisLoaded     = Event ServiceRedis                  "Fired when ServiceRedis finishes loading"
  type ServiceRedisLoadFailed = Event { message : string } "Fired when ServiceRedis fails to load"
  type RedisDone = Event { result : object }
  type ServiceRedisRedisFailed = Event { error : string, code : string }

  ;; Default UI: a sibling trait pointing back at the standalone form.
  ;; Consumers override `uiTrait` to inject their own form;
  ;; the default value below keeps standalone usage working.
  trait ServiceRedisDefaultForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "select", options: [{ label: "Get", value: "get" }, { label: "Set", value: "set" }, { label: "Delete", value: "del" }] }, { type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "input", inputType: "number", placeholder: "ttl seconds" }] }, { type: "button", label: "Execute", action: "EXEC", variant: "primary", icon: "play" }] })
    }
    emits {
      EXEC -> external { source : string }
    }
  }

  trait ServiceRedisRedis -> ServiceRedis [interaction, instance] {
    initial: idle
    config {
      uiTrait : trait                    = "@trait.ServiceRedisDefaultForm"
        @label "Operation form"
        @description "Trait that renders the Redis operation UI"
      key     : string                   = ""
        @label "Cache key"
        @description "Redis key the operation reads, writes, or deletes"
      value   : string                   = ""
        @label "Cache value"
        @description "Value to store when running a set operation"
      ttl     : number                   = 0
        @label "TTL seconds"
        @description "Time-to-live for the key in seconds (0 = no expiry)"
      op      : "get" | "set" | "del"    = "get"
        @label "Operation"
        @description "Which Redis command to run: get, set, or delete"
    }
    state idle {
      INIT -> idle
        (set @entity.key @config.key)
        (set @entity.value @config.value)
        (set @entity.ttl @config.ttl)
        (set @entity.op @config.op)
        (fetch ServiceRedis { emit: { success: "ServiceRedisLoaded", failure: "ServiceRedisLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      EXEC -> executing
        (render-ui main { type: "loading-state", title: "Executing...", message: "Running redis operation..." })
        (call-service redis "@config.op" { key: "@config.key", value: "@config.value", ttl: "@config.ttl" } { emit: { success: "RedisDone", failure: "FAILED" } })
      ServiceRedisLoaded -> idle
      ServiceRedisLoadFailed -> idle
    }
    state executing {
      RedisDone -> complete
        (set @entity.result @payload.result)
        (set @entity.redisStatus "succeeded")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Operation complete" }, { type: "typography", variant: "body", color: "muted", content: "@entity.result" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (emit ServiceRedisRedisFailed { error: @entity.error, code: "redis_op_failed" })
        (render-ui main { type: "error-state", title: "Redis Error", message: "@entity.error", onRetry: "RESET" })
    }
    state complete {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      ;; Self-loop on the external emit so ORB_X_UNUSED_EMISSION sees an
      ;; in-atom listener for RedisDone.
      RedisDone -> complete
    }
    state error {
      ;; Self-loop so the validator sees an in-atom listener for the
      ;; externally-consumed ServiceRedisRedisFailed emit.
      ServiceRedisRedisFailed -> error
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
    }
emits {
      ServiceRedisLoaded            -> external { id : string }
      ServiceRedisLoadFailed        -> external { message : string }
      RedisDone                     -> external { result : object }
      ServiceRedisRedisFailed       -> external { error : string, code : string }
      FAILED                        { error : string! }
    }

        listens {
      ServiceRedisDefaultForm.EXEC -> EXEC
      RedisDone { result : object }
      FAILED { error : string! }
      ServiceRedisLoaded { id : string }
      ServiceRedisLoadFailed { message : string }
      ServiceRedisRedisFailed { error : string, code : string }
    }
  }
  page "/servicerediss" as ServiceRedisPage -> ServiceRedisRedis
}
