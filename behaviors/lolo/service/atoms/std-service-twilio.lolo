app std-service-twilio "1.0.0"
"std-service-twilio as a Function"

orbital ServiceTwilioOrbital {
  entity ServiceTwilio [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    to : string
    messageBody : string
    channel : string = "sms"
    messageSid : string
    sendStatus : string = "idle"
    error : string
  }

  type ServiceTwilioLoaded     = Event ServiceTwilio                  "Fired when ServiceTwilio finishes loading"
  type ServiceTwilioLoadFailed = Event { message : string } "Fired when ServiceTwilio fails to load"
  type ServiceTwilioTwilioCompleted = Event { result : object }
  type ServiceTwilioTwilioFailed = Event { error : string, code : string }
  trait ServiceTwilioTwilio -> ServiceTwilio [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (set @entity.messageBody "")
        (set @entity.to "")
        (fetch ServiceTwilio { emit: { success: "ServiceTwilioLoaded", failure: "ServiceTwilioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "ServiceTwilio Messaging", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "+1234567890" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Send SMS", action: "SEND_SMS", variant: "primary", icon: "message-circle" }, { type: "button", label: "Send WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
      SEND_SMS -> sending
        (render-ui main { type: "loading-state", title: "Sending message...", message: "Delivering servicetwilio message..." })
        (call-service twilio "sendSMS" { to: "@entity.to", body: "@entity.messageBody" } { emit: { success: "ServiceTwilioTwilioCompleted", failure: "ServiceTwilioTwilioFailed" } })
      SEND_WHATSAPP -> sending
        (render-ui main { type: "loading-state", title: "Sending message...", message: "Delivering servicetwilio message..." })
        (call-service twilio "sendWhatsApp" { to: "@entity.to", body: "@entity.messageBody" } { emit: { success: "ServiceTwilioTwilioCompleted", failure: "ServiceTwilioTwilioFailed" } })
    }
    state sending {
      SENT -> sent
        (set @entity.sendStatus sent)
        (set @entity.messageSid @payload.messageSid)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Message sent successfully" }, { type: "button", label: "Send Another", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.sendStatus error)
        (set @entity.error @payload.error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "error-state", title: "Send Failed", message: "Could not deliver the message.", onRetry: "RETRY" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Retry", action: "RETRY", variant: "primary", icon: "refresh-cw" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    state sent {
      RESET -> idle
        (set @entity.sendStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "ServiceTwilio Messaging", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "+1234567890" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Send SMS", action: "SEND_SMS", variant: "primary", icon: "message-circle" }, { type: "button", label: "Send WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "ServiceTwilio Messaging", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "+1234567890" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Send SMS", action: "SEND_SMS", variant: "primary", icon: "message-circle" }, { type: "button", label: "Send WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
      RESET -> idle
        (set @entity.sendStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "ServiceTwilio Messaging", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "+1234567890" }, { type: "textarea", placeholder: "Write your message..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Send SMS", action: "SEND_SMS", variant: "primary", icon: "message-circle" }, { type: "button", label: "Send WhatsApp", action: "SEND_WHATSAPP", variant: "secondary", icon: "phone" }] }] })
    }
emits {
      ServiceTwilioLoaded            -> external { id : string }
      ServiceTwilioLoadFailed        -> external { message : string }
      ServiceTwilioTwilioCompleted           -> external { result : object }
      ServiceTwilioTwilioFailed              -> external { error : string, code : string }
    }

        listens {
      SENT { messageSid : string }
      FAILED { error : string! }
          ServiceTwilioLoadFailed { message : string }
    
      ServiceTwilioTwilioFailed { error : string, code : string }
    }
  }
  page "/servicetwilios" as ServiceTwilioPage -> ServiceTwilioTwilio
}