app std-service-twilio "2.0.0"
"std-service-twilio — Twilio messaging service. Bind via `uses Twilio from \"std/behaviors/std-service-twilio\"` and configure `recipient` / `body` / `sender` / `mode` at the call site (mapped to Twilio `to`/`body`/`from`/`mode`). Pass `uiTrait: \"@trait.YourMessagingForm\"` to inject your own form; leave unset to render the atom's default test form (standalone surface)."

orbital ServiceTwilioOrbital {
  entity ServiceTwilio [runtime] {
    id : string!
    to : string = ""
    body : string = ""
    from : string = ""
    mode : "sms" | "voice" | "whatsapp" = "sms"
    messageSid : string = ""
    sendStatus : string = "idle"
    error : string = ""
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type ServiceTwilioLoaded     = Event ServiceTwilio                  "Fired when ServiceTwilio finishes loading"
  type ServiceTwilioLoadFailed = Event { message : string } "Fired when ServiceTwilio fails to load"
  type ServiceTwilioTwilioCompleted = Event { id : string }
  type ServiceTwilioTwilioFailed = Event { error : string, code : string }

  trait ServiceTwilioDefaultForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "message-circle" }, { type: "typography", content: "Twilio Messaging", variant: "h2" }] }, { type: "divider" }, { type: "input", inputType: "tel", placeholder: "+1234567890" }, { type: "textarea", placeholder: "Write your message..." }, { type: "select", options: [{ label: "SMS", value: "sms" }, { label: "Voice", value: "voice" }, { label: "WhatsApp", value: "whatsapp" }] }, { type: "button", label: "Send", action: "SEND", variant: "primary", icon: "send" }] })
    }
    emits {
      SEND -> external { source : string }
    }
  }

  trait ServiceTwilioTwilio -> ServiceTwilio [interaction, instance] {
    initial: idle
    config {
      uiTrait: trait = "@trait.ServiceTwilioDefaultForm"
        @label "Composer form"
        @description "Trait that renders the Twilio message composer UI"
        @tier "internal"
      recipient: string = ""
        @label "Recipient phone"
        @description "Destination phone number in E.164 format (e.g. +14155551234)"
        @tier "customization"
      body: string = ""
        @label "Message body"
        @description "Text content Twilio should deliver to the recipient"
        @tier "customization"
      sender: string = ""
        @label "From number"
        @description "Twilio number or sender ID the message is sent from"
        @tier "customization"
      mode: "sms" | "voice" | "whatsapp" = "sms"
        @label "Channel"
        @description "Twilio delivery channel: SMS, voice call, or WhatsApp"
        @tier "customization"
    }
    state idle {
      INIT -> idle
        (set @entity.to @config.recipient)
        (set @entity.body @config.body)
        (set @entity.mode @config.mode)
        (fetch ServiceTwilio { emit: { success: "ServiceTwilioLoaded", failure: "ServiceTwilioLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      SEND -> sending
        (render-ui main { type: "loading-state", title: "Sending message...", message: "Delivering your message." })
        (call-service twilio "sendSMS" { to: "@config.recipient", body: "@config.body" } { emit: { success: "TwilioSent", failure: "FAILED" } })
      ServiceTwilioLoaded -> idle
      ServiceTwilioLoadFailed -> idle
    }
    state sending {
      TwilioSent -> sent
        (set @entity.sendStatus "sent")
        (set @entity.messageSid @payload.id)
        (emit ServiceTwilioTwilioCompleted { id: @entity.messageSid })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Message sent successfully" }, { type: "typography", variant: "body", color: "muted", content: "@entity.messageSid" }, { type: "button", label: "Send Another", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.sendStatus "error")
        (set @entity.error @payload.error)
        (emit ServiceTwilioTwilioFailed { error: @entity.error, code: "send_failed" })
        (render-ui main { type: "error-state", title: "Send Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state sent {
      RESET -> idle
        (set @entity.sendStatus "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      ServiceTwilioTwilioCompleted -> sent
    }
    state error {
      ServiceTwilioTwilioFailed -> error
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      RESET -> idle
        (set @entity.sendStatus "idle")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
    }
    emits {
      ServiceTwilioLoaded            -> external { id : string }
      ServiceTwilioLoadFailed        -> external { message : string }
      TwilioSent                     -> external { id : string }
      ServiceTwilioTwilioCompleted   -> external { id : string }
      ServiceTwilioTwilioFailed      -> external { error : string, code : string }
      FAILED                         { error : string! }
    }

    listens {
      ServiceTwilioDefaultForm.SEND -> SEND
      TwilioSent { id : string }
      FAILED { error : string! }
      ServiceTwilioLoaded { id : string }
      ServiceTwilioLoadFailed { message : string }
      ServiceTwilioTwilioCompleted { id : string }
      ServiceTwilioTwilioFailed { error : string, code : string }
    }
  }
  page "/servicetwilios" as ServiceTwilioPage -> ServiceTwilioTwilio
}
