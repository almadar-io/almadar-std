app std-service-storage "2.0.0"
"std-service-storage — Object storage upload service. Bind via `uses Storage from \"std/behaviors/std-service-storage\"` and configure `bucket` / `acl` / `maxSize` / `allowedMimeTypes` at the call site. Pass `uiTrait: \"@trait.YourUploadForm\"` to inject your own picker; leave unset to render the atom's default file picker (standalone surface)."

orbital ServiceStorageOrbital {
  entity ServiceStorage [runtime] {
    id : string!
    bucket : string = ""
    fileKey : string = ""
    url : string = ""
    storageStatus : string = "idle"
    error : string = ""
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type ServiceStorageLoaded     = Event ServiceStorage                  "Fired when ServiceStorage finishes loading"
  type ServiceStorageLoadFailed = Event { message : string } "Fired when ServiceStorage fails to load"
  type StorageUploaded = Event { id : string, url : string }
  type ServiceStorageStorageFailed = Event { error : string, code : string }

  trait ServiceStorageDefaultForm [interaction, instance] {
    initial: ready
    state ready {
      INIT -> ready
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "hard-drive" }, { type: "typography", content: "Upload File", variant: "h2" }] }, { type: "divider" }, { type: "input", inputType: "text", placeholder: "Choose file..." }, { type: "button", label: "Upload", action: "UPLOAD", variant: "primary", icon: "upload" }] })
    }
    emits {
      UPLOAD -> external { source : string, file : string }
    }
  }

  trait ServiceStorageStorage -> ServiceStorage [interaction, instance] {
    initial: idle
    config {
      uiTrait          : trait    = "@trait.ServiceStorageDefaultForm"
        @label "Upload form"
        @description "Trait that renders the file picker UI"
      bucket           : string   = ""
        @label "Bucket name"
        @description "Object storage bucket files are uploaded into"
      acl              : "public" | "private" = "private"
        @label "Access level"
        @description "Whether uploaded files are publicly readable or private"
      maxSize          : number   = 10485760
        @label "Max file size"
        @description "Largest accepted upload size in bytes (default 10 MB)"
      allowedMimeTypes : [string] = []
        @label "Allowed types"
        @description "MIME types the upload accepts (empty list = allow all)"
    }
    state idle {
      INIT -> idle
        (set @entity.bucket @config.bucket)
        (fetch ServiceStorage { emit: { success: "ServiceStorageLoaded", failure: "ServiceStorageLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      UPLOAD -> uploading
        (render-ui main { type: "loading-state", title: "Uploading...", message: "Uploading file to storage." })
        (call-service storage "upload" { bucket: "@config.bucket", acl: "@config.acl", file: "@payload.file" } { emit: { success: "StorageUploaded", failure: "FAILED" } })
      ServiceStorageLoaded -> idle
      ServiceStorageLoadFailed -> idle
    }
    state uploading {
      StorageUploaded -> succeeded
        (set @entity.fileKey @payload.id)
        (set @entity.url @payload.url)
        (set @entity.storageStatus "succeeded")
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Upload successful!" }, { type: "typography", variant: "body", color: "muted", content: "@entity.url" }, { type: "button", label: "Upload Another", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (emit ServiceStorageStorageFailed { error: @entity.error, code: "upload_failed" })
        (render-ui main { type: "error-state", title: "Upload Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state succeeded {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      StorageUploaded -> succeeded
    }
    state error {
      ServiceStorageStorageFailed -> error
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: ["@config.uiTrait"] })
    }
    emits {
      ServiceStorageLoaded            -> external { id : string }
      ServiceStorageLoadFailed        -> external { message : string }
      StorageUploaded                 -> external { id : string, url : string }
      ServiceStorageStorageFailed     -> external { error : string, code : string }
      FAILED                          { error : string! }
    }

    listens {
      ServiceStorageDefaultForm.UPLOAD -> UPLOAD
      UPLOAD { source : string, file : string }
      FAILED { error : string! }
      ServiceStorageLoaded { id : string }
      ServiceStorageLoadFailed { message : string }
      StorageUploaded { id : string, url : string }
      ServiceStorageStorageFailed { error : string, code : string }
    }
  }
  page "/servicestorages" as ServiceStoragePage -> ServiceStorageStorage
}
