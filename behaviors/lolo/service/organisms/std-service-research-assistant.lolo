app std-service-research-assistant "1.0.0"
"std-service-research-assistant as a Function"

orbital ResearchOrbital {
  entity Research [runtime] {
    id : string!
    query : string = ""
    videoTitle : string = ""
    videoDescription : string = ""
    summary : string = ""
    pipelineStatus : string = "idle"
    error : string = ""
  }
  type ResearchYoutubeCompleted = Event { result : object }
  type ResearchYoutubeFailed = Event { error : string, code : string }
  type ResearchLlmCompleted = Event { result : object }
  type ResearchLlmFailed = Event { error : string, code : string }
  type ResearchRedisCompleted = Event { result : object }
  type ResearchRedisFailed = Event { error : string, code : string }
  type ResearchStorageCompleted = Event { result : object }
  type ResearchStorageFailed = Event { error : string, code : string }
  type ResearchCustomBearerApiCompleted = Event { result : object }
  type ResearchCustomBearerApiFailed = Event { error : string, code : string }
  trait ResearchPipeline -> Research [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Content Research", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Search YouTube for content to summarize", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SEARCH", fields: ["query"] }] }] }] }] })
      SEARCH -> searching
        (set @entity.pipelineStatus searching)
        (call-service youtube search { query: "@entity.query", maxResults: 5, type: "video" } { emit: { success: "ResearchYoutubeCompleted", failure: "ResearchYoutubeFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Searching YouTube...", variant: "h3" }, { type: "spinner" }, { type: "typography", content: "@entity.query", variant: "caption" }] }] })
    }
    state searching {
      SEARCH_COMPLETE -> results
        (set @entity.pipelineStatus results)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "video" }, { type: "typography", content: "Search Results", variant: "h2" }] }, { type: "button", label: "New Search", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.results, fields: [], itemActions: [{ label: "Summarize", event: "SELECT_AND_SUMMARIZE", variant: "primary" }], columns: [{ name: "videoTitle", label: "Title", variant: "h4", icon: "video" }, { name: "videoDescription", label: "Description", variant: "caption" }] }] }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (set @entity.pipelineStatus error)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Pipeline Error", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state results {
      SELECT_AND_SUMMARIZE -> summarizing
        (set @entity.pipelineStatus summarizing)
        (call-service youtube "getVideo" { videoId: "@payload.videoId" } { emit: { success: "ResearchYoutubeCompleted", failure: "ResearchYoutubeFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "cpu" }, { type: "typography", content: "Fetching & summarizing...", variant: "h3" }, { type: "spinner" }, { type: "typography", content: "@entity.videoTitle", variant: "caption" }] }] })
      RESET -> idle
        (set @entity.pipelineStatus idle)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Content Research", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Search YouTube for content to summarize", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SEARCH", fields: ["query"] }] }] }] }] })
    }
    state summarizing {
      VIDEO_FETCHED -> summarizing
        (set @entity.videoTitle @payload.title)
        (set @entity.videoDescription @payload.description)
        (call-service llm summarize { text: "@entity.videoDescription" } { emit: { success: "ResearchLlmCompleted", failure: "ResearchLlmFailed" } })
      SUMMARY_COMPLETE -> complete
        (set @entity.summary @payload.content)
        (set @entity.pipelineStatus complete)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Research Complete", variant: "h2" }] }, { type: "button", label: "New Search", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "video" }, { type: "typography", content: "@entity.videoTitle", variant: "h3" }] }, { type: "divider" }, { type: "typography", content: "Summary", variant: "caption" }, { type: "typography", content: "@entity.summary", variant: "body" }] }] }] }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (set @entity.pipelineStatus error)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "alert-triangle" }, { type: "typography", content: "Pipeline Error", variant: "h2" }, { type: "alert", variant: "error", message: "@entity.error" }, { type: "button", label: "Try Again", action: "RESET", variant: "primary", icon: "rotate-ccw" }] }] })
    }
    state complete {
      RESET -> idle
        (set @entity.pipelineStatus idle)
        (set @entity.error "")
        (set @entity.summary "")
        (set @entity.videoTitle "")
        (set @entity.videoDescription "")
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Content Research", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Search YouTube for content to summarize", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SEARCH", fields: ["query"] }] }] }] }] })
    }
    state error {
      RESET -> idle
        (set @entity.pipelineStatus idle)
        (set @entity.error "")
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Content Research", variant: "h2" }] }, { type: "divider" }, { type: "card", children: [{ type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "Search YouTube for content to summarize", variant: "body" }, { type: "form-section", entity: @entity, mode: "edit", submitEvent: "SEARCH", fields: ["query"] }] }] }] }] })
    }
    listens {
      SEARCH_COMPLETE { results : [Research] }
      SELECT_AND_SUMMARIZE { videoId : string! }
      VIDEO_FETCHED { title : string!, description : string! }
      SUMMARY_COMPLETE { content : string! }
      FAILED { error : string! }

      ResearchYoutubeFailed { error : string, code : string }
      ResearchLlmFailed { error : string, code : string }
      ResearchRedisFailed { error : string, code : string }
      ResearchStorageFailed { error : string, code : string }
      ResearchCustomBearerApiFailed { error : string, code : string }
    }
    emits: [ResearchYoutubeCompleted, ResearchYoutubeFailed, ResearchLlmCompleted, ResearchLlmFailed, ResearchRedisCompleted, ResearchRedisFailed, ResearchStorageCompleted, ResearchStorageFailed, ResearchCustomBearerApiCompleted, ResearchCustomBearerApiFailed]
  }
  page "/research" as ResearchPage -> ResearchPipeline
}
orbital CacheEntryOrbital {
  entity CacheEntry [runtime] {
    id : string!
    key : string
    value : string
    ttl : number
    result : string
    redisStatus : string
    error : string = ""
  }

  type CacheEntryLoaded     = Event { data : [CacheEntry] }                  "Fired when CacheEntry finishes loading"
  type CacheEntryLoadFailed = Event { error : string, code : string } "Fired when CacheEntry fails to load"
  type ResearchRedisCompleted = Event { data : object }
  type ResearchRedisFailed = Event { error : string, code : string }
  trait CacheEntryRedis -> CacheEntry [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch CacheEntry { emit: { success: "CacheEntryLoaded", failure: "CacheEntryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "input", inputType: "number", placeholder: "3600" }] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] }] })
      GET_KEY -> executing
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Executing...", message: "Running redis operation..." }] })
        (call-service redis get { key: "@entity.key" } { emit: { success: "ResearchRedisCompleted", failure: "ResearchRedisFailed" } })
      SET_KEY -> executing
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Executing...", message: "Running redis operation..." }] })
        (call-service redis set { key: "@entity.key", value: "@entity.value", ttl: "@entity.ttl" } { emit: { success: "ResearchRedisCompleted", failure: "ResearchRedisFailed" } })
      DELETE_KEY -> executing
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Executing...", message: "Running redis operation..." }] })
        (call-service redis delete { key: "@entity.key" } { emit: { success: "ResearchRedisCompleted", failure: "ResearchRedisFailed" } })
    }
    state executing {
      EXECUTED -> complete
        (set @entity.result @payload.data)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Operation complete" }, { type: "typography", variant: "body", color: "muted", content: "@entity.result" }, { type: "button", label: "Reset", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "error-state", title: "Redis Error", message: "@entity.error", onRetry: "RESET" }] })
    }
    state complete {
      RESET -> idle
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "input", inputType: "number", placeholder: "3600" }] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] }] })
    }
    state error {
      RESET -> idle
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "database" }, { type: "typography", content: "Redis Cache", variant: "h2" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "md", children: [{ type: "input", placeholder: "cache-key" }, { type: "input", placeholder: "cache-value" }, { type: "input", inputType: "number", placeholder: "3600" }] }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Get", action: "GET_KEY", variant: "primary", icon: "download" }, { type: "button", label: "Set", action: "SET_KEY", variant: "primary", icon: "upload" }, { type: "button", label: "Delete", action: "DELETE_KEY", variant: "danger", icon: "trash-2" }] }] }] })
    }
    emits: [CacheEntryLoadFailed, CacheEntryLoaded, ResearchRedisCompleted, ResearchRedisFailed]
    listens {
      CacheEntryLoadFailed { error : string, code : string }
      EXECUTED { data : string }
      FAILED { error : string }
    }
  }
  page "/cache" -> CacheEntryRedis
}
orbital ReportOrbital {
  entity Report [runtime] {
    id : string!
    bucket : string
    fileKey : string
    prefix : string
    content : string
    storageStatus : string
    result : string
    error : string = ""
  }

  type ReportLoaded     = Event { data : [Report] }                  "Fired when Report finishes loading"
  type ReportLoadFailed = Event { error : string, code : string } "Fired when Report fails to load"
  type ResearchStorageCompleted = Event { data : object }
  type ResearchStorageFailed = Event { error : string, code : string }
  trait ReportStorage -> Report [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Report { emit: { success: "ReportLoaded", failure: "ReportLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "hard-drive" }, { type: "typography", content: "Report Storage", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "bucket-name" }, { type: "input", placeholder: "path/to/file.txt" }, { type: "input", placeholder: "path/prefix/" }, { type: "textarea", placeholder: "File content..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Upload", action: "UPLOAD_FILE", variant: "primary", icon: "upload" }, { type: "button", label: "Download", action: "DOWNLOAD_FILE", variant: "secondary", icon: "download" }, { type: "button", label: "List", action: "LIST_FILES", variant: "secondary", icon: "list" }, { type: "button", label: "Delete", action: "DELETE_FILE", variant: "danger", icon: "trash-2" }] }] }] })
      UPLOAD_FILE -> executing
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Processing...", message: "Executing storage operation on report..." }] })
        (call-service storage upload { bucket: "@entity.bucket", key: "@entity.fileKey", content: "@entity.content" } { emit: { success: "ResearchStorageCompleted", failure: "ResearchStorageFailed" } })
      DOWNLOAD_FILE -> executing
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Processing...", message: "Executing storage operation on report..." }] })
        (call-service storage download { bucket: "@entity.bucket", key: "@entity.fileKey" } { emit: { success: "ResearchStorageCompleted", failure: "ResearchStorageFailed" } })
      LIST_FILES -> executing
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Processing...", message: "Executing storage operation on report..." }] })
        (call-service storage list { bucket: "@entity.bucket", prefix: "@entity.prefix" } { emit: { success: "ResearchStorageCompleted", failure: "ResearchStorageFailed" } })
      DELETE_FILE -> executing
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Processing...", message: "Executing storage operation on report..." }] })
        (call-service storage delete { bucket: "@entity.bucket", key: "@entity.fileKey" } { emit: { success: "ResearchStorageCompleted", failure: "ResearchStorageFailed" } })
    }
    state executing {
      EXECUTED -> complete
        (set @entity.result @payload.data)
        (set @entity.storageStatus complete)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "alert", variant: "success", message: "Operation completed successfully" }, { type: "typography", variant: "body", color: "muted", content: "@entity.result" }, { type: "button", label: "Back", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (set @entity.storageStatus error)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "error-state", title: "Operation Failed", message: "@entity.error" }, { type: "button", label: "Back", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    state complete {
      RESET -> idle
        (set @entity.storageStatus idle)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "hard-drive" }, { type: "typography", content: "Report Storage", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "bucket-name" }, { type: "input", placeholder: "path/to/file.txt" }, { type: "input", placeholder: "path/prefix/" }, { type: "textarea", placeholder: "File content..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Upload", action: "UPLOAD_FILE", variant: "primary", icon: "upload" }, { type: "button", label: "Download", action: "DOWNLOAD_FILE", variant: "secondary", icon: "download" }, { type: "button", label: "List", action: "LIST_FILES", variant: "secondary", icon: "list" }, { type: "button", label: "Delete", action: "DELETE_FILE", variant: "danger", icon: "trash-2" }] }] }] })
    }
    state error {
      RESET -> idle
        (set @entity.storageStatus idle)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "hard-drive" }, { type: "typography", content: "Report Storage", variant: "h2" }] }, { type: "divider" }, { type: "input", placeholder: "bucket-name" }, { type: "input", placeholder: "path/to/file.txt" }, { type: "input", placeholder: "path/prefix/" }, { type: "textarea", placeholder: "File content..." }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Upload", action: "UPLOAD_FILE", variant: "primary", icon: "upload" }, { type: "button", label: "Download", action: "DOWNLOAD_FILE", variant: "secondary", icon: "download" }, { type: "button", label: "List", action: "LIST_FILES", variant: "secondary", icon: "list" }, { type: "button", label: "Delete", action: "DELETE_FILE", variant: "danger", icon: "trash-2" }] }] }] })
    }
    emits: [ReportLoadFailed, ReportLoaded, ResearchStorageCompleted, ResearchStorageFailed]
    listens {
      ReportLoadFailed { error : string, code : string }
      EXECUTED { data : string }
      FAILED { error : string }
    }
  }
  page "/reports" -> ReportStorage
}
orbital KnowledgeQueryOrbital {
  entity KnowledgeQuery [runtime] {
    id : string!
    endpoint : string
    method : string
    requestBody : string
    responseData : string
    statusCode : number
    callStatus : string
    error : string = ""
  }

  type KnowledgeQueryLoaded     = Event { data : [KnowledgeQuery] }                  "Fired when KnowledgeQuery finishes loading"
  type KnowledgeQueryLoadFailed = Event { error : string, code : string } "Fired when KnowledgeQuery fails to load"
  type ResearchCustomBearerApiCompleted = Event { data : object }
  type ResearchCustomBearerApiFailed = Event { error : string, code : string }
  trait KnowledgeQueryCustomBearer -> KnowledgeQuery [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch KnowledgeQuery { emit: { success: "KnowledgeQueryLoaded", failure: "KnowledgeQueryLoadFailed" } })
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield" }, { type: "typography", content: "Bearer API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] }] })
      CALL_API -> calling
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "loading-state", title: "Calling API...", message: "Sending request to knowledgequery endpoint..." }] })
        (call-service custom-bearer-api execute { endpoint: "@entity.endpoint", method: "@entity.method", body: "@entity.requestBody" } { emit: { success: "ResearchCustomBearerApiCompleted", failure: "ResearchCustomBearerApiFailed" } })
    }
    state calling {
      API_RESPONSE -> complete
        (set @entity.responseData @payload.data)
        (set @entity.statusCode @payload.statusCode)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Response", variant: "h2" }, { type: "badge", label: "@entity.statusCode", variant: "info" }, { type: "code-block", code: "@entity.responseData", language: "json" }, { type: "button", label: "New Request", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "error-state", title: "Request Failed", message: "@entity.error", onRetry: "RETRY" }] })
    }
    state complete {
      RESET -> idle
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield" }, { type: "typography", content: "Bearer API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield" }, { type: "typography", content: "Bearer API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] }] })
      RESET -> idle
        (render-ui main { type: "dashboard-layout", appName: "ResearchAssistant", navItems: [{ label: "Research", href: "/research", icon: "search" }, { label: "Cache", href: "/cache", icon: "database" }, { label: "Reports", href: "/reports", icon: "file-text" }, { label: "Knowledge", href: "/knowledge", icon: "book-open" }], children: [{ type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "shield" }, { type: "typography", content: "Bearer API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] }] })
    }
    emits: [KnowledgeQueryLoadFailed, KnowledgeQueryLoaded, ResearchCustomBearerApiCompleted, ResearchCustomBearerApiFailed]
    listens {
      KnowledgeQueryLoadFailed { error : string, code : string }
      API_RESPONSE { data : string, statusCode : string }
      FAILED { error : string }
    }
  }
  page "/knowledge" -> KnowledgeQueryCustomBearer
}
