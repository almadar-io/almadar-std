app std-stats "2.0.0"
"std-stats — embeddable analytics-card atom. ITEMS_LOADED aggregates @payload.data per @config.metrics (count|sum|avg|min|max with optional filter, format, icon, max, target, trend) and renders one stat-display per entry. Drop into a dashboard alongside std-browse / std-search / std-filter."

orbital StatsItemOrbital {
  type StatCard = {
    label   : string!
    value   : number
    icon    : string
    format  : "number" | "currency" | "percent"
    variant : "default" | "primary" | "success" | "warning" | "error" | "info"
    prefix  : string
    suffix  : string
    max     : number
    target  : number
    trend   : number
  }

  entity StatsItem [runtime] {
    id    : string!
    cards : [StatCard] = []
  }

  trait StatsItemStats -> StatsItem [interaction, instance] {
    initial: idle
    config {
      metrics : [object] = [
        { label: "Total Items", aggregation: "count", icon: "list",         variant: "primary", format: "number" },
        { label: "Active",      aggregation: "count", icon: "check-circle", variant: "success", format: "number" },
        { label: "Avg Value",   aggregation: "avg",   icon: "trending-up",  variant: "info",    format: "number", field: "value" }
      ]
      title   : string = "Summary"
    }
    state idle {
      INIT -> idle
        ;; Pre-seed cards from @config.metrics so the atom renders a
        ;; visible skeleton on initial mount even before any upstream
        ;; ITEMS_LOADED fires. value=0 acts as a placeholder; real
        ;; aggregations replace these once data arrives.
        (set @entity.cards (array/map @config.metrics ["fn", "metric", {
          label:   (object/get @metric "label"),
          icon:    (object/get @metric "icon" ""),
          format:  (object/get @metric "format" "number"),
          variant: (object/get @metric "variant" "default"),
          prefix:  (object/get @metric "prefix" ""),
          suffix:  (object/get @metric "suffix" ""),
          max:     (object/get @metric "max" 0),
          target:  (object/get @metric "target" 0),
          trend:   (object/get @metric "trend" 0),
          value:   0
        }]))
        (render-ui main { type: "data-grid", entity: "@entity.cards", fields: [], renderItem: ["fn", "card", { type: "stat-display", label: "@card.label", value: "@card.value", icon: "@card.icon", format: "@card.format", variant: "@card.variant", max: "@card.max" }] })
      ITEMS_LOADED -> idle
        (set @entity.cards (array/map @config.metrics ["fn", "metric", {
          label:   (object/get @metric "label"),
          icon:    (object/get @metric "icon" ""),
          format:  (object/get @metric "format" "number"),
          variant: (object/get @metric "variant" "default"),
          prefix:  (object/get @metric "prefix" ""),
          suffix:  (object/get @metric "suffix" ""),
          max:     (object/get @metric "max" 0),
          target:  (object/get @metric "target" 0),
          trend:   (object/get @metric "trend" 0),
          value:   (if (= (object/get @metric "aggregation" "count") "sum")
                       (array/sum (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                       (if (= (object/get @metric "aggregation" "count") "avg")
                           (array/avg (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                           (if (= (object/get @metric "aggregation" "count") "min")
                               (array/min (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                               (if (= (object/get @metric "aggregation" "count") "max")
                                   (array/max (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                                   (array/len (array/filter @payload.data (object/get @metric "filter" true)))))))
        }]))
        (render-ui main { type: "data-list", entity: "@entity.cards", fields: [], renderItem: ["fn", "card", { type: "stat-display", label: "@card.label", value: "@card.value", icon: "@card.icon", format: "@card.format", variant: "@card.variant", prefix: "@card.prefix", suffix: "@card.suffix", max: "@card.max", target: "@card.target", trend: "@card.trend" }] })
    }
    listens {
      ITEMS_LOADED { data : [object], totalCount : number }
    }
  }
  page "/statsitems" as StatsItemStatsPage -> StatsItemStats
}
