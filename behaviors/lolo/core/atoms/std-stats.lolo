app std-stats "2.0.0"
"std-stats — embeddable analytics-card atom. Drop into a dashboard
molecule alongside std-browse / std-search / std-filter; wire its
ITEMS_LOADED listener to the upstream collection's success emit, then
configure `metrics` per call-site to declare WHICH aggregations to
show.

Aggregation runs in the lolo state machine (no custom React component
beyond stat-display): the ITEMS_LOADED transition uses array/map over
@config.metrics, applies the per-metric `filter` predicate to
@payload.data, then dispatches the chosen aggregation kind. Cards
drop into a data-list whose renderItem maps each card to a
stat-display pattern. The atom owns an auxiliary entity (StatsItem)
for UI state — explicit-binding rule applies: every @entity.X is set
explicitly via (set @entity.X ...) on each transition.

Each entry in `metrics` (all but `label` optional):
- label       string!                          card title
- aggregation count|sum|avg|min|max  default count   what to compute
- field       string                           numeric entity field for sum/avg/min/max
- filter      SExpression                      row predicate (e.g. fn-form testing @row.status). Drops non-matching
                                               rows BEFORE aggregation. Omitted = all rows. Compiler statically
                                               unrolls array/map over @config.metrics so the fn-form is fully
                                               specialized into pure TS at codegen time.
- format      number|currency|percent default number   value formatting
- variant     default|primary|success|warning|error|info   color
- icon        string                                       lucide icon name
- prefix      string                                       prepended to displayed value (e.g. \"≈ \")
- suffix      string                                       appended (e.g. \" /mo\", \" ms\")
- max         number                                       optional denominator. >0 renders \"value / max\".
- target      number                                       optional progress target. >0 renders a progress bar.
- trend       number                                       signed delta vs previous period. >0 ↑ green, <0 ↓ red.

For dynamic max/target/trend (computed against @payload.data),
schema authors today must precompute and pass literal numbers; an
SExpression-evaluating slot is a future extension."

orbital StatsItemOrbital {
  type StatCard = {
    label   : string!
    value   : number
    icon    : string
    format  : "number" | "currency" | "percent"
    variant : "default" | "primary" | "success" | "warning" | "error" | "info"
    prefix  : string
    suffix  : string
    max     : number
    target  : number
    trend   : number
  }

  entity StatsItem [runtime] {
    id    : string!
    cards : [StatCard] = []
  }

  trait StatsItemStats -> StatsItem [interaction, instance] {
    initial: idle
    config {
      metrics : [object] = []
      title   : string = ""
    }
    state idle {
      INIT -> idle
        (set @entity.cards [])
        (render-ui main { type: "data-grid", entity: "@entity.cards", fields: [], renderItem: ["fn", "card", { type: "stat-display", label: "@card.label", value: "@card.value", icon: "@card.icon", format: "@card.format", variant: "@card.variant", max: "@card.max" }] })
      ITEMS_LOADED -> idle
        (set @entity.cards (array/map @config.metrics ["fn", "metric", {
          label:   (object/get @metric "label"),
          icon:    (object/get @metric "icon" ""),
          format:  (object/get @metric "format" "number"),
          variant: (object/get @metric "variant" "default"),
          prefix:  (object/get @metric "prefix" ""),
          suffix:  (object/get @metric "suffix" ""),
          max:     (object/get @metric "max" 0),
          target:  (object/get @metric "target" 0),
          trend:   (object/get @metric "trend" 0),
          value:   (if (= (object/get @metric "aggregation" "count") "sum")
                       (array/sum (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                       (if (= (object/get @metric "aggregation" "count") "avg")
                           (array/avg (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                           (if (= (object/get @metric "aggregation" "count") "min")
                               (array/min (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                               (if (= (object/get @metric "aggregation" "count") "max")
                                   (array/max (array/filter @payload.data (object/get @metric "filter" true)) (object/get @metric "field" ""))
                                   (array/len (array/filter @payload.data (object/get @metric "filter" true)))))))
        }]))
        (render-ui main { type: "data-list", entity: "@entity.cards", fields: [], renderItem: ["fn", "card", { type: "stat-display", label: "@card.label", value: "@card.value", icon: "@card.icon", format: "@card.format", variant: "@card.variant", prefix: "@card.prefix", suffix: "@card.suffix", max: "@card.max", target: "@card.target", trend: "@card.trend" }] })
    }
    listens {
      ITEMS_LOADED { data : [object], totalCount : number }
    }
  }
  page "/statsitems" as StatsItemStatsPage -> StatsItemStats
}
