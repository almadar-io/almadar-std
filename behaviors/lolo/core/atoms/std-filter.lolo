app std-filter "1.0.0"
"std-filter as a Function — single primitive: filter-group"

orbital FilterTargetOrbital {
  entity FilterTarget [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  type FilterTargetLoaded     = Event { data : [FilterTarget] }        "Fired when FilterTarget finishes loading; payload.data holds the filtered list"
  type FilterTargetLoadFailed = Event { error : string, code : string } "Fired when FilterTarget fails to load"

  trait FilterTargetFilter -> FilterTarget [interaction, collection] {
    initial: loading
    config {
      filters : object = []
      event : string = "FILTER"
    }
    state loading {
      INIT -> loading
        (fetch FilterTarget { emit: { success: "FilterTargetLoaded", failure: "FilterTargetLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      FilterTargetLoaded -> browsing
        (render-ui main { type: "filter-group", entity: FilterTarget, filters: "@config.filters" })
      FilterTargetLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "filter-group", entity: FilterTarget, filters: "@config.filters" }, { type: "typography", variant: "caption", color: "error", content: "@payload.error" }] })
    }
    state browsing {
      FILTER -> loading
        (fetch FilterTarget { filter: (= (object/get @entity @payload.field) @payload.value), emit: { success: "FilterTargetLoaded", failure: "FilterTargetLoadFailed" } })
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "filter-group", entity: FilterTarget, filters: "@config.filters" }, { type: "spinner", size: "sm" }] })
      CLEAR_FILTERS -> loading
        (fetch FilterTarget { emit: { success: "FilterTargetLoaded", failure: "FilterTargetLoadFailed" } })
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "filter-group", entity: FilterTarget, filters: "@config.filters" }, { type: "spinner", size: "sm" }] })
    }
    state error {
      INIT -> loading
        (fetch FilterTarget { emit: { success: "FilterTargetLoaded", failure: "FilterTargetLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
emits {
      FilterTargetLoaded
      FilterTargetLoadFailed
    }

        listens {
      FILTER { field : string!, value : string! }
      FilterTargetLoadFailed { error : string, code : string }
    }
  }
  page "/filtertargets" as FilterTargetFilterPage -> FilterTargetFilter
}
