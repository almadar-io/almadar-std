app std-filter "1.0.0"
"std-filter — single primitive: filter-group. Owns a FilterTarget runtime entity; every FILTER transition persists field/value so cross-trait listeners can route the latest selection into data atoms."

orbital FilterTargetOrbital {
  entity FilterTarget [runtime] {
    id    : string!
    field : string
    value : string
  }

  trait FilterTargetFilter -> FilterTarget [interaction, instance] {
    initial: idle
    config {
      filters : [object] = []
      event   : string   = "FILTER"
    }
    state idle {
      INIT -> idle
        (fetch FilterTarget {})
        (render-ui main { type: "filter-group", entity: FilterTarget, filters: "@config.filters" })
      FILTER -> idle
        (set @entity.field @payload.field)
        (set @entity.value @payload.value)
        (render-ui main { type: "filter-group", entity: FilterTarget, filters: "@config.filters" })
      CLEAR_FILTERS -> idle
        (set @entity.field "")
        (set @entity.value "")
        (emit FILTER { field: "", value: "" })
        (render-ui main { type: "filter-group", entity: FilterTarget, filters: "@config.filters" })
    }
    emits {
      FILTER { field : string!, value : string! }
    }
    listens {
      FILTER         { field : string!, value : string! }
      CLEAR_FILTERS
    }
  }
  page "/filtertargets" as FilterTargetFilterPage -> FilterTargetFilter
}
