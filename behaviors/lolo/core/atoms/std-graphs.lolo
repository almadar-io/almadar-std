app std-graphs "2.0.0"
"std-graphs — embeddable chart atom. ITEMS_LOADED groups @payload.data by @config.categoryField (or @config.timeField when timeAxis=true) and aggregates per bucket. Multi-series rendering via @config.series (preformatted ChartSeries shape). Histograms via chartType=histogram pass pre-binned @payload.data through unchanged. Stacked / 100% stacked bars via @config.stack. Post-process sort + limit. Clicking a data point emits UI:@config.drillEvent with { label, value, seriesLabel? }. Drop into a dashboard alongside std-stats / std-browse."

orbital GraphItemOrbital {
  type ChartPoint = { label : string!, value : number }
  type SeriesSpec = { name : string!, data : [ChartPoint], color : string, dashed : boolean }

  entity GraphItem [runtime] {
    id        : string!
    chartData : [ChartPoint] = []
  }

  trait GraphItemGraph -> GraphItem [interaction, instance] {
    initial: idle
    config {
      chartType     : "bar" | "line" | "pie" | "area" | "donut" | "histogram" | "scatter" = "bar"
        @label "Chart type"
        @description "Visual format for the rendered chart"
      timeAxis      : boolean = false
        @label "Time axis"
        @description "Group by timeField bucketed by period instead of categoryField"
      categoryField : string  = "status"
        @label "Group-by field"
        @description "Entity field whose values become the chart's categories"
      timeField     : string  = "date"
        @label "Date field"
        @description "Entity field used as the time axis when timeAxis is on"
      period        : "day" | "week" | "month" | "quarter" | "year" = "month"
        @label "Bucket period"
        @description "Calendar bucket size when grouping by time"
      valueField    : string  = ""
        @label "Value field"
        @description "Numeric field aggregated per bucket (blank = row count)"
      aggregation   : "count" | "sum" | "avg" | "min" | "max" = "count"
        @label "Aggregation"
        @description "How values within a bucket combine into one number"
      series        : [SeriesSpec] = []
        @label "Series"
        @description "Pre-formatted multi-series spec for stacked or layered charts"
      stack         : "none" | "stack" | "normalize" = "none"
        @label "Stacking"
        @description "Stack bars, normalize to 100%, or render side-by-side"
      sortField     : "value" | "label" | "none" = "none"
        @label "Sort by"
        @description "Order points by value, label, or leave unsorted"
      sortDir       : "asc" | "desc" = "desc"
        @label "Sort direction"
        @description "Ascending or descending order for the sort field"
      limit         : number  = 0
        @label "Top N"
        @description "Keep only the first N points after sorting (0 = all)"
      drillEvent    : string  = ""
        @label "Drill event"
        @description "Event emitted when a user clicks a chart point"
      title         : string  = "Distribution"
        @label "Title"
        @description "Heading shown above the chart"
      subtitle      : string  = "Counts per category"
        @label "Subtitle"
        @description "Secondary line below the title"
      height        : number  = 280
        @label "Chart height"
        @description "Pixel height of the rendered chart"
      showLegend    : boolean = true
        @label "Show legend"
        @description "Display the series legend"
      showValues    : boolean = false
        @label "Show values"
        @description "Render the numeric value on top of each data point"
      viewPattern   : pattern = "chart"
        @label "Render pattern"
        @description "UI pattern used to draw the chart"
    }
    state idle {
      INIT -> idle
        (set @entity.chartData [
          { label: "Active",   value: 6 },
          { label: "Pending",  value: 3 },
          { label: "Inactive", value: 1 }
        ])
        (render-ui main { type: "@config.viewPattern", title: "@config.title", subtitle: "@config.subtitle", chartType: "@config.chartType", data: "@entity.chartData", series: "@config.series", height: "@config.height", showLegend: "@config.showLegend", showValues: "@config.showValues", stack: "@config.stack", timeAxis: "@config.timeAxis", drillEvent: "@config.drillEvent" })
      ITEMS_LOADED -> idle
        (set @entity.chartData
          (if (= @config.chartType "histogram")
              (array/map @payload.data ["fn", "p", { label: (object/get @p "label"), value: (object/get @p "value") }])
              (array/map (object/entries (array/groupBy @payload.data (if @config.timeAxis @config.timeField @config.categoryField))) ["fn", "entry", {
                label: (object/get @entry "0"),
                value: (if (= @config.aggregation "sum")
                           (array/sum (object/get @entry "1") @config.valueField)
                           (if (= @config.aggregation "avg")
                               (array/avg (object/get @entry "1") @config.valueField)
                               (if (= @config.aggregation "min")
                                   (array/min (object/get @entry "1") @config.valueField)
                                   (if (= @config.aggregation "max")
                                       (array/max (object/get @entry "1") @config.valueField)
                                       (array/len (object/get @entry "1"))))))
              }])))
        (set @entity.chartData
          (if (!= @config.sortField "none")
              (array/sort @entity.chartData @config.sortField @config.sortDir)
              @entity.chartData))
        (set @entity.chartData
          (if (> @config.limit 0)
              (array/take @entity.chartData @config.limit)
              @entity.chartData))
        (render-ui main { type: "@config.viewPattern", title: "@config.title", subtitle: "@config.subtitle", chartType: "@config.chartType", data: "@entity.chartData", series: "@config.series", height: "@config.height", showLegend: "@config.showLegend", showValues: "@config.showValues", stack: "@config.stack", timeAxis: "@config.timeAxis", drillEvent: "@config.drillEvent" })
    }
    listens {
      ITEMS_LOADED { data : [object], totalCount : number }
    }
  }
  page "/graphitems" as GraphItemGraphPage -> GraphItemGraph
}
