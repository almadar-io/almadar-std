app std-file-store "2.0.0"
"std-file-store — the generic file/page tree primitive. A file-tree + config-driven data table over a hierarchical collection; opens a row in `viewing_single` with config-driven detail actions. Rebindable: pass `fields`/`itemActions`/`detailActions`/`tree` to retarget it at any hierarchical entity (files, wiki pages, note trees). Folds in the former std-page-tree via `reorderable` + a page field/action set."

type FieldSpec  = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }
type TreeNode   = { name : string!, path : string!, type : string!, children : [object] }

orbital StoredFileOrbital {
  entity StoredFile [persistent: storedfiles] {
    id            : string!
    name          : string! @description "The file's display name or title." @synonyms "title, label, filename"
    path          : string @description "The location of the file within the storage system." @synonyms "location, filepath, address" = ""
    mimeType      : string @description "The file's content type, indicating its format." @synonyms "type, format, media type" = ""
    sizeBytes     : number @description "The file's size in bytes." @synonyms "length, filesize, byteCount" = 0
    uploaderId    : string @description "Identifier of the user who uploaded the file." @synonyms "user, owner, creator" = ""
    uploaderName  : string @description "The name of the user who uploaded the file." @synonyms "owner, user, author" = ""
    folder        : string @description "The path to the containing directory." @synonyms "parent, directory, location" = ""
    uploadedAt    : string @description "Timestamp indicating when the file was uploaded." @synonyms "upload date, date uploaded, upload time" = ""
    isArchived    : boolean @description "Indicates whether the file is archived." @synonyms "archived, status, state" = false
  }

  type StoredFileLoaded     = Event { data : [StoredFile] }                "Fired when the collection finishes loading"
  type StoredFileLoadFailed = Event { error : string, code : string }      "Fired when the collection fails to load"

  trait StoredFileStore -> @rebindable StoredFile [interaction, collection] {
    config {
      title : string = "Files"
        @label "Section title"
        @description "Heading shown above the browser"
        @tier "presentation"
      headerIcon : string = "folder"
        @label "Header icon"
        @description "Icon shown beside the section title and in the detail header"
        @tier "presentation"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = "dense"
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
      reorderable : boolean = false
        @label "Reorderable rows"
        @description "Allow drag-reordering of rows (emits REORDER). On for ordered trees (e.g. wiki page nav)."
        @tier "presentation"
      fields : [FieldSpec] = [
        { name: "name",       label: "Name",     variant: "caption" },
        { name: "folder",     label: "Folder",   variant: "caption" },
        { name: "mimeType",   label: "Type",     variant: "badge"   },
        { name: "sizeBytes",  label: "Size",     variant: "caption" },
        { name: "uploadedAt", label: "Uploaded", variant: "caption" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the linked entity"
        @tier "presentation"
      itemActions : [ItemAction] = [
        { label: "Open",    event: "OPEN_FILE",    variant: "primary", icon: "arrow-right" },
        { label: "Archive", event: "ARCHIVE_FILE", variant: "danger" }
      ]
        @label "Row actions"
        @description "Buttons on each row"
        @tier "presentation"
      detailActions : [ItemAction] = [
        { label: "Download", event: "DOWNLOAD_FILE", variant: "primary" },
        { label: "Archive",  event: "ARCHIVE_FILE",  variant: "danger" }
      ]
        @label "Detail actions"
        @description "Buttons shown on the opened row's detail"
        @tier "presentation"
      tree : [TreeNode] = [
        { name: "Contracts", path: "Contracts", type: "dir", children: [{ name: "Active.pdf", path: "Active.pdf", type: "file" }, { name: "Archived.pdf", path: "Archived.pdf", type: "file" }] },
        { name: "Policies",  path: "Policies",  type: "dir", children: [{ name: "HR.docx", path: "Policies/HR.docx", type: "file" }, { name: "Security.md", path: "Policies/Security.md", type: "file" }] },
        { name: "Templates", path: "Templates", type: "dir", children: [{ name: "Invoice.docx", path: "Templates/Invoice.docx", type: "file" }, { name: "NDA.pdf", path: "Templates/NDA.pdf", type: "file" }] }
      ]
        @label "Folder tree"
        @description "Hierarchical nav tree shown above the table"
        @tier "presentation"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      StoredFileLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "@config.headerIcon" }, { type: "typography", content: "@config.title", variant: "h3" }, { type: "badge", label: "@payload.data.length", variant: "neutral", size: "sm" }] }, { type: "divider" }, { type: "file-tree", tree: "@config.tree" }, { type: "divider" }, { type: "data-list", look: "@config.tableLook", entity: "@payload.data", fields: "@config.fields", gap: "sm", reorderable: "@config.reorderable", reorderEvent: "REORDER", itemActions: "@config.itemActions" }] })
      StoredFileLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_FILE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.path @payload.row.path)
        (set @entity.folder @payload.row.folder)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "@config.headerIcon" }, { type: "typography", content: "@entity.name", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Folder" }, { type: "typography", variant: "body", content: "@entity.folder" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Path" }, { type: "typography", variant: "body", content: "@entity.path" }] }] }, { type: "divider" }, { type: "data-list", entity: "@config.detailActions", gap: "sm", variant: "default", fields: [], renderItem: ["fn", "a", { type: "button", label: "@a.label", variant: "@a.variant", action: "@a.event", actionPayload: { id: "@entity.id" } }] }] })
      REORDER -> loading
        (set @entity.id @payload.row.id)
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Reordering…" }] })
      ARCHIVE_FILE -> loading
        (set @entity.id @payload.id)
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading…" }] })
      DOWNLOAD_FILE -> loading
        (set @entity.id @payload.id)
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Preparing…" }] })
      ARCHIVE_FILE -> loading
        (set @entity.id @payload.id)
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving…" }] })
    }
    state error {
      INIT -> loading
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_FILE     { id : string!, row : StoredFile }
      CLOSE_VIEW    { }
      DOWNLOAD_FILE { id : string! }
      ARCHIVE_FILE  { id : string! }
      REORDER       { id : string!, row : StoredFile }
      StoredFileLoaded     { data : [StoredFile] }
      StoredFileLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_FILE     { id : string!, row : StoredFile }
      CLOSE_VIEW    { }
      DOWNLOAD_FILE { id : string! }
      ARCHIVE_FILE  { id : string! }
      REORDER       { id : string!, row : StoredFile }
      StoredFileLoaded     { data : [StoredFile] }
      StoredFileLoadFailed { error : string, code : string }
    }
  }
  page "/files" as StoredFilePage -> StoredFileStore
}
