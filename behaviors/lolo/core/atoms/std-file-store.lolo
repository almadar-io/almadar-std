app std-file-store "1.0.0"
"std-file-store — generic file + folder + metadata primitive. Browses files via file-tree + data-grid; opens file detail in `viewing_single` with Download / Archive actions."

orbital StoredFileOrbital {
  entity StoredFile [persistent: storedfiles] {
    id            : string!
    name          : string!
    path          : string = ""
    mimeType      : string = ""
    sizeBytes     : number = 0
    uploaderId    : string = ""
    uploaderName  : string = ""
    folder        : string = ""
    uploadedAt    : string = ""
    isArchived    : boolean = false
  }

  type StoredFileLoaded     = Event { data : [StoredFile] }                "Fired when the StoredFile collection finishes loading"
  type StoredFileLoadFailed = Event { error : string, code : string }      "Fired when the StoredFile collection fails to load"

  trait StoredFileStore -> StoredFile [interaction, collection] {
    config {
      title : string = "Files"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading files…" }] })
      StoredFileLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "folder" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total files", value: "@payload.data.length", icon: "file" }, { type: "stat-display", label: "Folders", value: "12", icon: "folder" }, { type: "stat-display", label: "Uploaded this week", value: "18", icon: "upload" }, { type: "stat-display", label: "Archived", value: "4", icon: "archive" }] }, { type: "divider" }, { type: "file-tree", tree: [{ name: "Contracts", path: "Contracts", type: "dir", children: [{ name: "Active.pdf", path: "Active.pdf", type: "file" }, { name: "Archived.pdf", path: "Archived.pdf", type: "file" }] }, { name: "Policies", path: "Policies", type: "dir", children: [{ name: "HR.docx", path: "Policies/HR.docx", type: "file" }, { name: "Security.md", path: "Policies/Security.md", type: "file" }] }, { name: "Templates", path: "Templates", type: "dir", children: [{ name: "Invoice.docx", path: "Templates/Invoice.docx", type: "file" }, { name: "NDA.pdf", path: "Templates/NDA.pdf", type: "file" }] }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "name", label: "Name", variant: "caption" }, { name: "folder", label: "Folder", variant: "caption" }, { name: "mimeType", label: "Type", variant: "badge" }, { name: "sizeBytes", label: "Size", variant: "caption" }, { name: "uploadedAt", label: "Uploaded", variant: "caption" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_FILE", variant: "primary", icon: "arrow-right" }, { label: "Archive", event: "ARCHIVE_FILE", variant: "danger" }] }] })
      StoredFileLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_FILE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.name @payload.row.name)
        (set @entity.path @payload.row.path)
        (set @entity.mimeType @payload.row.mimeType)
        (set @entity.sizeBytes @payload.row.sizeBytes)
        (set @entity.uploaderId @payload.row.uploaderId)
        (set @entity.uploaderName @payload.row.uploaderName)
        (set @entity.folder @payload.row.folder)
        (set @entity.uploadedAt @payload.row.uploadedAt)
        (set @entity.isArchived @payload.row.isArchived)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "file" }, { type: "typography", content: "@entity.name", variant: "h3" }, { type: "badge", label: "@entity.mimeType", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Folder" }, { type: "typography", variant: "body", content: "@entity.folder" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Path" }, { type: "typography", variant: "body", content: "@entity.path" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Uploader" }, { type: "typography", variant: "body", content: "@entity.uploaderName" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Size", value: "@entity.sizeBytes", icon: "hard-drive" }, { type: "stat-display", label: "Type", value: "@entity.mimeType", icon: "file" }, { type: "stat-display", label: "Uploaded", value: "@entity.uploadedAt", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Download", variant: "primary", action: "DOWNLOAD_FILE", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Archive", variant: "danger", action: "ARCHIVE_FILE", actionPayload: { id: "@entity.id" } }] }] })
      ARCHIVE_FILE -> loading
        (set @entity.id @payload.id)
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving file…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading files…" }] })
      DOWNLOAD_FILE -> loading
        (set @entity.id @payload.id)
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Preparing download…" }] })
      ARCHIVE_FILE -> loading
        (set @entity.id @payload.id)
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Archiving file…" }] })
    }
    state error {
      INIT -> loading
        (fetch StoredFile { emit: { success: "StoredFileLoaded", failure: "StoredFileLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_FILE     { id : string!, row : StoredFile }
      CLOSE_VIEW    { }
      DOWNLOAD_FILE { id : string! }
      ARCHIVE_FILE  { id : string! }
      StoredFileLoaded     { data : [StoredFile] }
      StoredFileLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_FILE     { id : string!, row : StoredFile }
      CLOSE_VIEW    { }
      DOWNLOAD_FILE { id : string! }
      ARCHIVE_FILE  { id : string! }
      StoredFileLoaded     { data : [StoredFile] }
      StoredFileLoadFailed { error : string, code : string }
    }
  }
  page "/files" as StoredFilePage -> StoredFileStore
}
