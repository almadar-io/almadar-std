app std-cascade-on-delete "1.0.0"
"std-cascade-on-delete — relational `owns` cascade coordinator. Listens for a parent-deleted sentinel (`ParentDeleted` — rename via traitOverrides.events to the consumer's actual parent-deleted event), fetches dependent rows where `<foreignKeyField> === @payload.data.id` from the FIRST entry of `dependentEntities` (current operator surface has no loop primitive — multi-dependent support is a future extension), and emits `CascadeRowsLoaded` so a consumer trait can persist the deletes. Emits `CascadeCompleted` once the row list is published. Multi-dependent iteration and in-atom persist will land when the operator system supports collection iteration."

orbital CascadeOnDeleteOrbital {
  entity CascadeLog [runtime] {
    id           : string!
    parentId     : string  = ""
    parentEntity : string  = ""
    rowCount     : number  = 0
  }

  type ParentDeleted      = Event { data : object }                                "Rename via traitOverrides.events to the upstream parent-deleted event (e.g. ContactDeleted). `data.id` carries the parent's primary key."
  type CascadeRowsFetched = Event { data : [object] }                              "Internal: raw fetch result of dependent rows before re-broadcast."
  type CascadeRowsLoaded  = Event { parentId : string, data : [object] }           "Dependent row set for the deleted parent — consumer trait persists deletes."
  type CascadeCompleted   = Event { parentId : string, deletedCount : number }     "Fired once the dependent row set has been broadcast for cascade handling."
  type CascadeFailed      = Event { error : string, code : string }                "Fired when the dependent fetch fails."

  trait CascadeOnDeleteGate -> CascadeLog [lifecycle, instance] {
    config {
      parentEntity      : string   = ""
        @label "Parent entity"
        @description "Entity whose deletion triggers the cascade"
      dependentEntities : [string] = []
        @label "Dependent entities"
        @description "Entity names that hold rows pointing to the parent"
      foreignKeyField   : string   = ""
        @label "Foreign-key field"
        @description "Field on dependent rows that holds the parent's id"
    }
    initial: idle
    state idle {
      ParentDeleted -> idle
        (set @entity.parentId @payload.data.id)
        (set @entity.parentEntity @config.parentEntity)
        (fetch CascadeLog { filter: (= (object/get @entity @config.foreignKeyField) @entity.parentId), emit: { success: "CascadeRowsFetched", failure: "CascadeFailed" } })
      CascadeRowsFetched -> idle
        (set @entity.rowCount (array/len @payload.data))
        (emit CascadeRowsLoaded { parentId: "@entity.parentId", data: "@payload.data" })
        (emit CascadeCompleted { parentId: "@entity.parentId", deletedCount: "@entity.rowCount" })
    }
    emits {
      CascadeRowsFetched -> external { data : [object] }
      CascadeRowsLoaded  -> external { parentId : string, data : [object] }
      CascadeCompleted   -> external { parentId : string, deletedCount : number }
      CascadeFailed      -> external { error : string, code : string }
    }
    listens {
      ParentDeleted      { data : object }
      CascadeRowsFetched { data : [object] }
    }
  }
  page "/cascade-on-delete" as CascadeOnDeletePage -> CascadeOnDeleteGate
}
