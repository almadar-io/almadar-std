app std-related "1.0.0"
"std-related as a Function"
;;
;; Relation-rendering atom. Assumes the linked entity's relation field has
;; already been hydrated by an upstream fetch with include; this atom only
;; owns the rendering of the related children.
;;
;; Paired with std-browse via @trait.X this gives a one-line master-detail
;; layout: hstack [ @trait.ParentList, @trait.ParentRelated ]. The molecule
;; std-related-master-detail is the canonical showcase.

orbital RelatedItemOrbital {
  entity RelatedItem [persistent: relateditems] {
    id : string!
    name : string
  }

  type RelatedItemLoaded     = Event { data : [RelatedItem] }        "Fired when RelatedItem finishes loading; payload.data holds the list"
  type RelatedItemLoadFailed = Event { error : string, code : string } "Fired when RelatedItem fails to load"

  trait RelatedItemList -> RelatedItem [interaction, collection] {
    config {
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = "dense"
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch RelatedItem { emit: { success: "RelatedItemLoaded", failure: "RelatedItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "sm", align: "center", className: "py-8", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading related…" }] })
      RelatedItemLoaded -> loaded
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "link" }, { type: "typography", content: "Related", variant: "h3" }] }, { type: "divider" }, { type: "data-list", look: "@config.tableLook", entity: @payload.data, fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "body", content: "@item.name" }] }] }] })
      RelatedItemLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "sm", align: "center", className: "py-8", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "body", content: "Failed to load related" }, { type: "typography", variant: "caption", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "ghost", icon: "rotate-ccw" }] })
    }
    state loaded {
      INIT -> loading
        (fetch RelatedItem { emit: { success: "RelatedItemLoaded", failure: "RelatedItemLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch RelatedItem { emit: { success: "RelatedItemLoaded", failure: "RelatedItemLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    ;; consumer: parent molecule (e.g. std-related-master-detail) listens for SELECT_RELATED to drive a detail panel
emits {
      RelatedItemLoaded
      RelatedItemLoadFailed
    }

        listens {
      RelatedItemLoadFailed { error : string, code : string }
    }
  }

  page "/related" as Related -> RelatedItemList
}
