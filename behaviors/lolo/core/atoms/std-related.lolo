app std-related "1.0.0"
"std-related as a Function"
;;
;; Relation-rendering atom. Assumes the linked entity's relation field has
;; already been hydrated by an upstream fetch with include; this atom only
;; owns the rendering of the related children.
;;
;; Paired with std-browse via @trait.X this gives a one-line master-detail
;; layout: hstack [ @trait.ParentList, @trait.ParentRelated ]. The molecule
;; std-related-master-detail is the canonical showcase.
orbital RelatedItemOrbital {
    type RelatedItemLoaded = Event { data : [RelatedItem] } "Fired when RelatedItem finishes loading; payload.data holds the list"

    type RelatedItemLoadFailed = Event { error : string, code : string } "Fired when RelatedItem fails to load"

  entity RelatedItem [persistent: relateditems] {
    id : string!
    name : string @description "The identifier or designation for the related item." @synonyms "title, label, identifier"
  }

  trait RelatedItemList -> @rebindable RelatedItem [interaction, collection] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch RelatedItem {
          emit: { failure: RelatedItemLoadFailed, success: RelatedItemLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading related…"
            type: typography
            variant: caption
          }]
          className: py-8
          direction: vertical
          gap: sm
          type: stack
        })
      RelatedItemLoaded -> loaded
        (render-ui main {
          children: [{
            align: center
            children: [{ name: link, type: icon }, {
              content: Related
              type: typography
              variant: h3
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            entity: ?data
            fields: []
            look: @config.tableLook
            renderItem: (fn item {
              children: [{
                content: @item.name
                type: typography
                variant: body
              }]
              direction: vertical
              gap: xs
              type: stack
            })
            type: data-list
          }]
          direction: vertical
          gap: md
          type: stack
        })
      RelatedItemLoadFailed -> error
        (render-ui main {
          align: center
          children: [{
            color: destructive
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load related"
            type: typography
            variant: body
          }, {
            color: muted
            content: ?error
            type: typography
            variant: caption
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: sm
          type: stack
        })
    }

    state loaded {
      INIT -> loading
        (fetch RelatedItem {
          emit: { failure: RelatedItemLoadFailed, success: RelatedItemLoaded }
        })
        (render-ui main { type: spinner })
    }

    state error {
      INIT -> loading
        (fetch RelatedItem {
          emit: { failure: RelatedItemLoadFailed, success: RelatedItemLoaded }
        })
        (render-ui main { type: spinner })
    }

    emits {
      RelatedItemLoaded
        @description "Signals that related items have been successfully loaded."
        @synonyms "loaded, fetched, retrieved"
        @tier "essential"
      RelatedItemLoadFailed
        @description "Indicates failure to load related items."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }

    listens {
      RelatedItemLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load related items."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }

    config {
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = dense
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
    }
  }

  ;; consumer: parent molecule (e.g. std-related-master-detail) listens for SELECT_RELATED to drive a detail panel
  page "/related" as Related -> RelatedItemList
}