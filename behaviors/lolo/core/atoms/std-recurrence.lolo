app std-recurrence "1.0.0"
"std-recurrence — generic rule-based occurrence generator. Topology = defining_rule / generating_occurrences / viewing_calendar / awaiting_exception_decision / cancelled / error — adds SKIP_OCCURRENCE / RESCHEDULE_OCCURRENCE / END_AFTER_N / END_ON_DATE transitions a pure-CRUD atom can't express. Renders rule editor + calendar overview of generated occurrences + per-occurrence exception modal."

orbital RecurrenceOrbital {
  type OccurrenceItem = {
    id          : string!
    date        : string
    status      : "scheduled" | "skipped" | "completed" | "rescheduled"
    label       : string
    notes       : string
  }

  entity RecurrenceView [runtime] {
    id                   : string!
    occurrences          : [OccurrenceItem] = []
    frequency            : "daily" | "weekly" | "monthly" | "yearly" = "weekly"
    interval             : number = 1
    startDate            : string = ""
    endDate              : string = ""
    endAfterCount        : number = 0
    currentOccurrenceId  : string = ""
    currentOccurrenceDate: string = ""
    currentOccurrenceLabel: string = ""
    rescheduleDate       : string = ""
    skipReason           : string = ""
    errorMessage         : string = ""
  }

  type RecurrenceLoaded     = Event { data : [object] }                "Fired when occurrences finish loading"
  type RecurrenceLoadFailed = Event { error : string, code : string }  "Fired when fetch fails"
  type RecurrenceSaved      = Event { row : object }                   "Fired when a recurrence rule has been persisted"
  type RecurrenceSaveFailed = Event { error : string, code : string }  "Fired when persist fails"

  trait RecurrenceEditor -> RecurrenceView [interaction, instance] {
    config {
      title         : string = "Recurring Schedule"
      itemLabelField : string = "label"
      formFields    : [string] = ["frequency", "interval", "startDate", "endDate", "endAfterCount"]
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch RecurrenceView { emit: { success: "RecurrenceLoaded", failure: "RecurrenceLoadFailed" } })
        (render-ui main { type: "loading-state", title: "Loading schedule…" })
      RecurrenceLoaded -> viewing_calendar
        (set @entity.occurrences (array/map @payload.data ["fn", "row", {
          id:     (object/get @row "id" ""),
          date:   (object/get @row "date" ""),
          status: "scheduled",
          label:  (object/get @row "label" ""),
          notes:  (object/get @row "notes" "")
        }]))
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "calendar" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-list", entity: "@entity.occurrences", gap: "sm", fields: [], renderItem: ["fn", "occ", { type: "card", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clock" }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", content: "@occ.label", variant: "h4" }, { type: "typography", content: "@occ.date", variant: "caption", color: "muted" }] }, { type: "badge", label: "@occ.status", variant: "primary" }, { type: "button", label: "Edit", variant: "ghost", action: "OPEN_EXCEPTION", actionPayload: { id: "@occ.id", row: "@occ" }, icon: "edit" }] }] }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Edit Rule", variant: "secondary", action: "EDIT_RULE", icon: "settings" }, { type: "button", label: "End Schedule", variant: "danger", action: "CANCEL_SCHEDULE", icon: "x-circle" }] }] })
      RecurrenceLoadFailed -> error
        (set @entity.errorMessage @payload.error)
        (render-ui main { type: "error-state", title: "Failed to load", message: "@entity.errorMessage" })
      RecurrenceSaved -> viewing_calendar
        (render-ui main { type: "loading-state", title: "Refreshing…" })
      RecurrenceSaveFailed -> error
        (set @entity.errorMessage @payload.error)
        (render-ui main { type: "error-state", title: "Save failed", message: "@entity.errorMessage" })
    }
    state viewing_calendar {
      EDIT_RULE -> defining_rule
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CANCEL_RULE", icon: "arrow-left" }, { type: "icon", name: "settings" }, { type: "typography", content: "Recurrence Rule", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: "@entity", mode: "edit", submitEvent: "SAVE_RULE", cancelEvent: "CANCEL_RULE", fields: "@config.formFields" }] })
      OPEN_EXCEPTION -> awaiting_exception_decision
        (set @entity.currentOccurrenceId @payload.id)
        (set @entity.currentOccurrenceDate @payload.row.date)
        (set @entity.currentOccurrenceLabel @payload.row.label)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_EXCEPTION", icon: "arrow-left" }, { type: "icon", name: "calendar-x" }, { type: "typography", content: "@entity.currentOccurrenceLabel", variant: "h3" }, { type: "badge", label: "@entity.currentOccurrenceDate", variant: "primary" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Skip", variant: "secondary", action: "SKIP_OCCURRENCE", actionPayload: { id: "@entity.currentOccurrenceId" }, icon: "skip-forward" }, { type: "button", label: "Reschedule", variant: "primary", action: "RESCHEDULE_OCCURRENCE", actionPayload: { id: "@entity.currentOccurrenceId" }, icon: "calendar-clock" }] }] })
      CANCEL_SCHEDULE -> cancelled
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "x-circle" }, { type: "typography", content: "Schedule Ended", variant: "h3" }] }, { type: "divider" }, { type: "typography", variant: "body", content: "This recurring schedule has been cancelled." }, { type: "button", label: "Restart", variant: "secondary", action: "RESTART", icon: "rotate-ccw" }] })
    }
    state defining_rule {
      SAVE_RULE -> loading
        (render-ui main { type: "loading-state", title: "Saving rule…" })
      CANCEL_RULE -> viewing_calendar
        (render-ui main { type: "loading-state", title: "Cancelling edit…" })
    }
    state awaiting_exception_decision {
      SKIP_OCCURRENCE -> loading
        (render-ui main { type: "loading-state", title: "Skipping occurrence…" })
      RESCHEDULE_OCCURRENCE -> loading
        (set @entity.rescheduleDate @payload.newDate)
        (render-ui main { type: "loading-state", title: "Rescheduling…" })
      CLOSE_EXCEPTION -> viewing_calendar
        (render-ui main { type: "loading-state", title: "Closing…" })
    }
    state cancelled {
      RESTART -> loading
        (render-ui main { type: "loading-state", title: "Restarting…" })
    }
    state error {
      INIT -> loading
        (render-ui main { type: "loading-state", title: "Retrying…" })
    }
    emits {
      EDIT_RULE             { }
      SAVE_RULE             { data : object }
      CANCEL_RULE           { }
      OPEN_EXCEPTION        { id : string, row : object! }
      CLOSE_EXCEPTION       { }
      SKIP_OCCURRENCE       { id : string }
      RESCHEDULE_OCCURRENCE { id : string, newDate : string }
      CANCEL_SCHEDULE       { }
      RESTART               { }
      RecurrenceLoaded      { data : [object] }
      RecurrenceLoadFailed  { error : string, code : string }
    }
    listens {
      EDIT_RULE             { }
      SAVE_RULE             { data : object }
      CANCEL_RULE           { }
      OPEN_EXCEPTION        { id : string, row : object! }
      CLOSE_EXCEPTION       { }
      SKIP_OCCURRENCE       { id : string }
      RESCHEDULE_OCCURRENCE { id : string, newDate : string }
      CANCEL_SCHEDULE       { }
      RESTART               { }
      RecurrenceLoaded      { data : [object] }
      RecurrenceLoadFailed  { error : string, code : string }
      RecurrenceSaved       { row : object }
      RecurrenceSaveFailed  { error : string, code : string }
    }
  }
  page "/recurrence" as RecurrencePage -> RecurrenceEditor
}
