app std-scatter "1.0.0"
"std-scatter — embeddable scatter / bubble chart atom. ITEMS_LOADED maps @payload.data into {x,y,label,size,color} points using configured fields (no aggregation step — distinct from std-graphs). Drop into a dashboard alongside std-stats / std-graphs for two-numeric correlation views."
type ObjectSpec = { id : string, label : string, value : string }
orbital ScatterItemOrbital {
  uses Chart from "std/behaviors/ui-chart"

    type ScatterPoint = { x : number!, y : number!, label : string, size : number, color : string }

  entity ScatterItem [runtime] {
    id : string!
    points : [ScatterPoint] @description "An array of data points for the scatter chart." @synonyms "data, values, records" = []
  }

  trait ScatterItemPlotRender = Chart.traits.ChartRender -> ScatterItem {
    config {
      chartType: scatter
      drillEvent: @config.drillEvent
      height: @config.height
      scatterData: @entity.points
      subtitle: @config.subtitle
      title: @config.title
    }
  }

  trait ScatterItemPlotEvents -> ScatterItem [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (set @entity.points [{
        color: ""
        label: A
        size: 8
        x: 12
        y: 24
        }, {
        color: ""
        label: B
        size: 6
        x: 28
        y: 42
        }, {
        color: ""
        label: C
        size: 10
        x: 45
        y: 18
        }, {
        color: ""
        label: D
        size: 7
        x: 60
        y: 55
        }, {
        color: ""
        label: E
        size: 9
        x: 78
        y: 38
        }])
        ;; Pre-seed with a small sample so standalone previews render
        ;; something visible. ITEMS_LOADED replaces this with real data.
      ITEMS_LOADED -> idle
        (set @entity.points (array/map ?data (fn row {
        color: (object/get @row @config.colorField "")
        label: (object/get @row @config.labelField "")
        size: (object/get @row @config.sizeField 5)
        x: (object/get @row @config.xField 0)
        y: (object/get @row @config.yField 0)
        })))
    }

    listens {
      ITEMS_LOADED {
        data : [ObjectSpec]
        totalCount : number
      }
        @description "Data has been received and is ready for visualization."
        @synonyms "data-ready, data-available, loaded"
        @tier "domain"
    }

    config {
      xField : string = x
        @label "X-axis field"
        @description "Entity field mapped to the horizontal axis"
        @tier "presentation"
      yField : string = y
        @label "Y-axis field"
        @description "Entity field mapped to the vertical axis"
        @tier "presentation"
      labelField : string = ""
        @label "Label field"
        @description "Field used as the point label tooltip (blank = none)"
        @tier "presentation"
      sizeField : string = ""
        @label "Size field"
        @description "Numeric field that scales bubble size (blank = uniform)"
        @tier "presentation"
      colorField : string = ""
        @label "Color field"
        @description "Field used to color-code points (blank = single color)"
        @tier "presentation"
      title : string = Correlation
        @label "Title"
        @description "Heading shown above the chart"
        @tier "presentation"
      subtitle : string = "x vs y"
        @label "Subtitle"
        @description "Secondary line below the title"
        @tier "presentation"
      height : number = 280
        @label "Chart height"
        @description "Pixel height of the rendered scatter plot"
        @tier "presentation"
      drillEvent : string = ""
        @label "Drill event"
        @description "Event emitted when the user clicks a data point"
        @tier "internal"
    }
  }

  page "/scatteritems" as ScatterItemPlotPage -> ScatterItemPlotRender, ScatterItemPlotEvents
}
