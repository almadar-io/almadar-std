app std-thread "1.2.0"
"std-thread — forum-style nested replies with collapse + flat-mode toggle. Owns ThreadPost (persistent). flat:true covers 1:1 linear inquiry threads; flat:false renders forum-style nested. INIT fetches; REPLY persists a child post under @payload.parentId. Layer 3 variants override `bodyContent` to deliver chat-bubble, email-threaded, or linear-comments UX while inheriting the same trait, state machine, emits, and listens."

orbital ThreadPostOrbital {
  entity ThreadPost [persistent: threadposts] {
    id            : string!
    parentId      : string
    threadRootId  : string!
    authorId      : string!
    authorName    : string!
    content       : string!
    createdAt     : string
    voteCount     : number = 0
    replyCount    : number = 0
    ;; Forward relation: array of child ThreadPost IDs whose parentId === this.id.
    ;; Lowers to `type: "relation", cardinality: "many"` (orbital-lolo lower.rs).
    ;; @rebindable rewrites the target to the rebound entity in variant atoms.
    ;; `(fetch ThreadPost { include: ["replies"] })` triggers @almadar/runtime's
    ;; populateRelations to hydrate each ID into the full row inline so the
    ;; variant's bodyContent can render `@reply.authorName` etc. without
    ;; per-reply lookups.
    replies       : [ThreadPost]
    ;; Master-detail focus: SELECT sets this to the clicked row so split-pane
    ;; variants (email-threaded) can bind @entity.focusedRow.<field> in their
    ;; detail pane. Unused by list/bubble variants.
    focusedRow    : object = {}
  }

  type ThreadPostLoaded        = Event { data : [ThreadPost] }              "Fired when the thread-post collection finishes loading"
  type ThreadPostLoadFailed    = Event { error : string, code : string }    "Fired when the thread-post collection fails to load"
  type ThreadPostCreated       = Event { row : ThreadPost }                 "Fired after a new thread-post persists successfully"
  type ThreadPostCreateFailed  = Event { error : string, code : string }    "Fired when a new thread-post fails to persist"

  trait ThreadPostBrowse -> @rebindable ThreadPost [interaction, collection] {
    config {
      flat          : boolean = false
        @label "Flat thread"
        @description "Render replies as a linear list instead of nested tree"
        @tier "presentation"
      threadRootId  : string  = ""
        @label "Root post id"
        @description "Top-level post whose descendants are loaded (blank = all roots)"
        @tier "domain"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = "dense"
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
      bodyContent : render-ui = {
        type: "stack",
        direction: "vertical",
        gap: "md",
        children: [{
          type: "data-list",
          look: "@config.tableLook",
          entity: "@payload.data",
          variant: "card",
          gap: "sm",
          fields: [
            { name: "authorName", label: "Author", variant: "h4" },
            { name: "content", label: "", variant: "body" },
            { name: "voteCount", label: "Votes", variant: "caption" }
          ],
          itemActions: [{ label: "Reply", event: "REPLY", icon: "message-square" }]
        }]
      }
        @label "Body content tree"
        @description "Render-ui SExpr rendered after thread posts load. Default is the canonical forum-style data-list. Layer 3 variants override this with their own tree (chat bubbles, email-threaded cards, linear comment stacks, etc.) to deliver entirely different thread UX while inheriting the same trait, state machine, emits, and listens."
        @tier "internal"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch ThreadPost { include: ["replies"], emit: { success: "ThreadPostLoaded", failure: "ThreadPostLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      ThreadPostLoaded -> browsing
        (render-ui main @config.bodyContent)
      ThreadPostLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      INIT -> loading
        (fetch ThreadPost { include: ["replies"], emit: { success: "ThreadPostLoaded", failure: "ThreadPostLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      ThreadPostLoaded -> browsing
        (render-ui main @config.bodyContent)
      REPLY -> replying
        (set @entity.parentId (str/default @payload.parentNodeId @payload.parentId))
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "h4", content: "Write a reply" }, { type: "textarea", placeholder: "Your reply…", action: "EDIT_REPLY" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Submit", action: "SUBMIT_REPLY", variant: "primary", icon: "send" }, { type: "button", label: "Cancel", action: "CANCEL_REPLY", variant: "secondary" }] }] })
      SELECT -> loading
        (set @entity.focusedRow @payload.row)
        (fetch ThreadPost { include: ["replies"], emit: { success: "ThreadPostLoaded", failure: "ThreadPostLoadFailed" } })
    }
    state replying {
      EDIT_REPLY -> replying
        (set @entity.content @payload.value)
      SUBMIT_REPLY -> browsing
        (persist create ThreadPost @payload.data { emit: { success: "ThreadPostCreated", failure: "ThreadPostCreateFailed" } })
      CANCEL_REPLY -> browsing
        (set @entity.content "")
        (set @entity.parentId "")
      ThreadPostCreated -> browsing
        (set @entity.content "")
        (set @entity.parentId "")
        (fetch ThreadPost { include: ["replies"], emit: { success: "ThreadPostLoaded", failure: "ThreadPostLoadFailed" } })
      ThreadPostCreateFailed -> replying
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state error {
      INIT -> loading
        (fetch ThreadPost { include: ["replies"], emit: { success: "ThreadPostLoaded", failure: "ThreadPostLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      SELECT                 { id : string, row : object! }
      REPLY                  { parentId : string, parentNodeId : string, content : string }
      EDIT_REPLY             { value : string! }
      SUBMIT_REPLY           { data : object! }
      CANCEL_REPLY
      ThreadPostLoaded       { data : [ThreadPost] }
      ThreadPostLoadFailed   { error : string, code : string }
      ThreadPostCreated      { row : ThreadPost }
      ThreadPostCreateFailed { error : string, code : string }
    }
    listens {
      SELECT                 { id : string, row : object! }
      REPLY                  { parentId : string, parentNodeId : string, content : string }
      EDIT_REPLY             { value : string! }
      SUBMIT_REPLY           { data : object! }
      CANCEL_REPLY
      ThreadPostLoaded       { data : [ThreadPost] }
      ThreadPostLoadFailed   { error : string, code : string }
      ThreadPostCreated      { row : ThreadPost }
      ThreadPostCreateFailed { error : string, code : string }
    }
  }
  page "/threadposts" as ThreadPostBrowsePage -> ThreadPostBrowse
}
