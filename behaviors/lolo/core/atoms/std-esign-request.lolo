app std-esign-request "1.0.0"
"Generic e-signature request primitive: send a document for signing and track status."

orbital ESignRequestOrbital {
  entity ESignRequest [persistent: esignrequests] {
    id : string!
    documentId : string!
    documentName : string = ""
    recipientName : string!
    recipientEmail : string!
    status : "draft" | "sent" | "viewed" | "signed" | "declined" | "expired" = "draft"
    sentAt : string = ""
    signedAt : string = ""
    expiresAt : string = ""
    notes : string = ""
  }
  type ESignRequestLoaded = Event { data : [ESignRequest] }
  type ESignRequestLoadFailed = Event { error : string, code : string }

  trait ESignRequestSigning -> ESignRequest [interaction, collection] {
    config {
      title : string = "Signature Requests"
        @label "Section title"
        @description "Heading shown above the signature-request list"
        @tier "presentation"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = "dense"
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch ESignRequest { emit: { success: "ESignRequestLoaded", failure: "ESignRequestLoadFailed" } })
        (render-ui main { type: "spinner", size: "md" })
      ESignRequestLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", content: "@config.title", variant: "h3" }, { type: "signature-pad", label: "Recipient signature preview", helperText: "Read-only preview of the captured signature", height: 160, readOnly: true }, { type: "data-grid", look: "@config.tableLook", entity: @payload.data, fields: [{ name: "documentName", label: "Document", variant: "h4" }, { name: "recipientName", label: "Recipient", variant: "body" }, { name: "recipientEmail", label: "Email", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }, { name: "sentAt", label: "Sent", variant: "caption" }], itemActions: [{ label: "Send", event: "SEND_REQUEST", variant: "primary" }, { label: "Revoke", event: "REVOKE_REQUEST", variant: "danger" }] }] })
      ESignRequestLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", title: "Failed to load signature requests", message: "@payload.error" })
    }
    state browsing {
      SEND_REQUEST -> browsing
        (set @entity.id @payload.id)
        (notify "Signature request sent" success)
      REVOKE_REQUEST -> browsing
        (set @entity.id @payload.id)
        (notify "Signature request revoked" info)
    }
    state error {
      INIT -> loading
        (fetch ESignRequest { emit: { success: "ESignRequestLoaded", failure: "ESignRequestLoadFailed" } })
        (render-ui main { type: "spinner", size: "md" })
    }
    emits {
      SEND_REQUEST { id : string! }
      REVOKE_REQUEST { id : string! }
      ESignRequestLoaded { data : [ESignRequest] }
      ESignRequestLoadFailed { error : string, code : string }
    }
    listens {
      SEND_REQUEST { id : string! }
      REVOKE_REQUEST { id : string! }
      ESignRequestLoaded { data : [ESignRequest] }
      ESignRequestLoadFailed { error : string, code : string }
    }
  }
  page "/esign" as ESignRequestPage -> ESignRequestSigning
}
