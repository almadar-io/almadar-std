app std-tabs "2.0.0"
"std-tabs — embeddable tab-navigation atom. Renders a tabs strip from @config.tabs ([{id, label, icon?, badge?, content?}]); clicking a tab updates @entity.activeTab so only the matching @trait.X content shows. Events remap at the call site for routing, persistence, analytics."

orbital TabsItemOrbital {
  type TabSpec = {
    id      : string!
    label   : string!
    icon    : string
    badge   : string
    content : string
  }

  entity TabsItem [runtime] {
    id         : string!
    activeTab  : string = ""
    items      : [TabSpec] = []
  }

  trait TabsItemTabs -> TabsItem [interaction, instance] {
    initial: idle
    config {
      tabs        : [object] = [
        { id: "overview", label: "Overview", icon: "info" },
        { id: "details", label: "Details", icon: "list" },
        { id: "settings", label: "Settings", icon: "settings" }
      ]
      defaultTab  : string = "overview"
      variant     : "default" | "pills" | "underline" = "default"
      orientation : "horizontal" | "vertical" = "horizontal"
    }
    state idle {
      INIT -> idle
        (set @entity.items @config.tabs)
        (set @entity.activeTab @config.defaultTab)
        (render-ui main { type: "tabs", items: "@entity.items", activeTab: "@entity.activeTab", variant: "@config.variant", orientation: "@config.orientation", tabChangeEvent: "TAB_CHANGED" })
      TAB_CHANGED -> idle
        (set @entity.activeTab @payload.tabId)
        (render-ui main { type: "tabs", items: "@entity.items", activeTab: "@entity.activeTab", variant: "@config.variant", orientation: "@config.orientation", tabChangeEvent: "TAB_CHANGED" })
    }
    emits {
      TAB_CHANGED -> external { tabId : string! }
    }
    listens {
      TAB_CHANGED { tabId : string! }
    }
  }
  page "/tabsitems" as TabsItemTabsPage -> TabsItemTabs
}
