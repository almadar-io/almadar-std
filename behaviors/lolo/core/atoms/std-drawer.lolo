app std-drawer "2.2.0"
"std-drawer — drawer-slot atom. Renders ONLY to its `drawer` slot. The runtime's slot wrapper provides the backdrop + right-anchored panel + close-X chrome; the atom emits ONLY the panel body content. Host emits OPEN with payload {id, name, description} → renders body; CLOSE clears the slot. Stateless: state lives in the OPEN payload, not the entity, so the trait stays safe under consumer entity rebinds."
orbital DrawerContentOrbital {
  entity DrawerContent [runtime] {
    id : string!
  }

  uses Typography from "std/behaviors/ui-typography"
  uses Button from "std/behaviors/ui-button"

  trait Typography1 = Typography.traits.TypographyRender -> DrawerContent {
    config {
      content: ?name
      variant: h4
    }
  }

  trait Typography2 = Typography.traits.TypographyRender -> DrawerContent {
    config {
      color: muted
      content: ?description
      variant: body
    }
  }

  trait Button1 = Button.traits.ButtonRender -> DrawerContent {
    config {
      action: CLOSE
      label: Close
      variant: ghost
    }
  }

  trait DrawerContentDrawer -> @rebindable DrawerContent [interaction, instance] {
    initial: closed

    state closed {
      INIT -> closed
      OPEN -> open
        (render-ui drawer {
          children: [@trait.Typography1, @trait.Typography2, {
            children: [@trait.Button1]
            direction: horizontal
            gap: sm
            justify: end
            type: stack
          }]
          direction: vertical
          gap: md
          type: stack
        })
    }

    state open {
      CLOSE -> closed
        (render-ui drawer null)
    }

    listens {
      OPEN {
        id : string!
        name : string
        description : string
      }
        @description "Drawer content is requested and should be rendered."
        @synonyms "show, display, load, reveal"
        @tier "domain"
    }
  }

  page "/drawercontents/drawer" as DrawerContentDrawerPage -> DrawerContentDrawer
}