app std-branching-logic "1.0.0"
"std-branching-logic — survey skip-logic rules. Lists rules in `browsing`; opens rule detail in `viewing_single` with Edit / Delete actions."

orbital BranchingLogicOrbital {
  entity BranchingRule [persistent: branchingrules] {
    id               : string!
    surveyId         : string!
    sourceQuestionId : string!
    operator         : "equals" | "not-equals" | "contains" | "in" = "equals"
    value            : string
    targetQuestionId : string!
    priority         : number = 0
  }

  type BranchingRuleLoaded     = Event { data : [BranchingRule] }            "Fired when the branching-rule collection finishes loading"
  type BranchingRuleLoadFailed = Event { error : string, code : string }     "Fired when the branching-rule collection fails to load"

  trait BranchingRuleManage -> BranchingRule [interaction, collection] {
    config {
      title : string = "Branching Rules"
        @label "Section title"
        @description "Heading shown above the branching-rule list"
        @tier "customization"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch BranchingRule { emit: { success: "BranchingRuleLoaded", failure: "BranchingRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading branching rules…" }] })
      BranchingRuleLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "git-branch" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", label: "Total rules", value: "@payload.data.length", icon: "git-branch" }, { type: "stat-display", label: "Active surveys", value: "8", icon: "clipboard-list" }, { type: "stat-display", label: "Skip jumps", value: "42", icon: "skip-forward" }, { type: "stat-display", label: "Priority avg", value: "3", icon: "trending-up" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "sourceQuestionId", label: "If question", variant: "caption" }, { name: "operator", label: "Op", variant: "badge" }, { name: "value", label: "Value", variant: "caption" }, { name: "targetQuestionId", label: "Jump to", variant: "caption" }, { name: "priority", label: "Priority", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_RULE", variant: "primary", icon: "arrow-right" }, { label: "Delete", event: "DELETE_RULE", variant: "danger", icon: "trash-2" }] }] })
      BranchingRuleLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_RULE -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.surveyId @payload.row.surveyId)
        (set @entity.sourceQuestionId @payload.row.sourceQuestionId)
        (set @entity.operator @payload.row.operator)
        (set @entity.value @payload.row.value)
        (set @entity.targetQuestionId @payload.row.targetQuestionId)
        (set @entity.priority @payload.row.priority)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "git-branch" }, { type: "typography", content: "@entity.sourceQuestionId", variant: "h3" }, { type: "badge", label: "@entity.operator", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Survey" }, { type: "typography", variant: "body", content: "@entity.surveyId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Value" }, { type: "typography", variant: "body", content: "@entity.value" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", label: "Source", value: "@entity.sourceQuestionId", icon: "help-circle" }, { type: "stat-display", label: "Target", value: "@entity.targetQuestionId", icon: "arrow-right-circle" }, { type: "stat-display", label: "Priority", value: "@entity.priority", icon: "trending-up" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Delete", variant: "danger", action: "DELETE_RULE", actionPayload: { id: "@entity.id" } }] }] })
      DELETE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch BranchingRule { emit: { success: "BranchingRuleLoaded", failure: "BranchingRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting rule…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch BranchingRule { emit: { success: "BranchingRuleLoaded", failure: "BranchingRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading branching rules…" }] })
      DELETE_RULE -> loading
        (set @entity.id @payload.id)
        (fetch BranchingRule { emit: { success: "BranchingRuleLoaded", failure: "BranchingRuleLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Deleting rule…" }] })
    }
    state error {
      INIT -> loading
        (fetch BranchingRule { emit: { success: "BranchingRuleLoaded", failure: "BranchingRuleLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_RULE   { id : string!, row : BranchingRule }
      CLOSE_VIEW  { }
      DELETE_RULE { id : string! }
      BranchingRuleLoaded     { data : [BranchingRule] }
      BranchingRuleLoadFailed { error : string, code : string }
    }
    listens {
      OPEN_RULE   { id : string!, row : BranchingRule }
      CLOSE_VIEW  { }
      DELETE_RULE { id : string! }
      BranchingRuleLoaded     { data : [BranchingRule] }
      BranchingRuleLoadFailed { error : string, code : string }
    }
  }
  page "/branching-rules" as BranchingRuleManagePage -> BranchingRuleManage
}
