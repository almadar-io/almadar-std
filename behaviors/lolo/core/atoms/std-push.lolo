app std-push "1.0.0"
"std-push as a Function"
;;
;; External-event subscription atom. Wraps os/watch-http with a small
;; lifecycle state machine (idle -> subscribed ↔ reconnecting) using the
;; emit: config to turn incoming messages + failures into closed-circuit
;; events on the orbital's bus.
;;
;; Intra-frame: embed @trait.PushIndicator in a layout to show a live
;; connection status pill (see molecule std-push-activity-log).
;; Inter-frame: any trait can listens: PUSH_RECEIVED and react to payloads.
orbital PushSubscriberOrbital {
    type PushReceived = Event { message : string } "Fired on every incoming push frame"

    type PushDisconnected = Event { reason : string } "Fired when the push connection drops"

    type PushSubscriberLoaded = Event { data : [PushSubscriber] }

    type PushSubscriberLoadFailed = Event { error : string, code : string }

  entity PushSubscriber [runtime] {
    id : string!
    status : string @description "Current operational state of the subscriber." @synonyms "state, condition, mode"
  }

  trait PushSubscriberIndicator -> @rebindable PushSubscriber [interaction, instance] {
    initial: idle

    state idle {
      INIT -> connecting
        (fetch PushSubscriber {
          emit: { failure: PushSubscriberLoadFailed, success: PushSubscriberLoaded }
        })
        (os/watch-http "wss://push.example.com" {
          emit: { failure: PUSH_DISCONNECTED, on_message: PUSH_RECEIVED }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            content: "Connecting…"
            type: typography
            variant: caption
          }]
          direction: horizontal
          gap: sm
          type: stack
        })
    }

    state connecting {
      PUSH_RECEIVED -> subscribed
        (set @entity.status subscribed)
        (render-ui main {
          align: center
          children: [{
            color: success
            name: wifi
            type: icon
          }, {
            content: Connected
            type: typography
            variant: caption
          }]
          direction: horizontal
          gap: sm
          type: stack
        })
      PUSH_DISCONNECTED -> reconnecting
        (set @entity.status reconnecting)
        (render-ui main {
          align: center
          children: [{
            color: warning
            name: wifi-off
            type: icon
          }, {
            content: "Reconnecting…"
            type: typography
            variant: caption
          }]
          direction: horizontal
          gap: sm
          type: stack
        })
    }

    state subscribed {
      PUSH_RECEIVED -> subscribed
        (set @entity.status subscribed)
        (render-ui main {
          align: center
          children: [{
            color: success
            name: wifi
            type: icon
          }, {
            content: Connected
            type: typography
            variant: caption
          }]
          direction: horizontal
          gap: sm
          type: stack
        })
      PUSH_DISCONNECTED -> reconnecting
        (set @entity.status reconnecting)
        (render-ui main {
          align: center
          children: [{
            color: warning
            name: wifi-off
            type: icon
          }, {
            content: "Reconnecting…"
            type: typography
            variant: caption
          }]
          direction: horizontal
          gap: sm
          type: stack
        })
    }

    state reconnecting {
      PUSH_RECEIVED -> subscribed
        (set @entity.status subscribed)
        (render-ui main {
          align: center
          children: [{
            color: success
            name: wifi
            type: icon
          }, {
            content: Connected
            type: typography
            variant: caption
          }]
          direction: horizontal
          gap: sm
          type: stack
        })
      PUSH_DISCONNECTED -> reconnecting
        (render-ui main {
          align: center
          children: [{
            color: error
            name: wifi-off
            type: icon
          }, {
            content: Disconnected
            type: typography
            variant: caption
          }]
          direction: horizontal
          gap: sm
          type: stack
        })
    }

    emits {
      PUSH_RECEIVED -> external {
        message : string
      }
        @description "Data has been successfully received and processed."
        @synonyms "received, updated, ingested"
        @tier "essential"
      PUSH_DISCONNECTED -> external {
        reason : string
      }
        @description "Indicates the push connection has been lost."
        @synonyms "disconnected, lost, dropped, offline"
        @tier "internal"
      PushSubscriberLoadFailed
        @description "Indicates failure to load a subscriber."
        @synonyms "error, failure, failed, problem"
        @tier "internal"
      PushSubscriberLoaded
        @description "Signals successful initialization of a data subscription."
        @synonyms "initialized, ready, connected"
        @tier "essential"
    }

    listens {
      PUSH_RECEIVED {
        message : string
      }
        @description "Indicates a push notification has been successfully received."
        @synonyms "received, updated, new"
        @tier "essential"
      PUSH_DISCONNECTED {
        reason : string
      }
        @description "Indicates a disconnection from the push notification service."
        @synonyms "disconnected, offline, lost connection"
        @tier "internal"
      PushSubscriberLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a subscriber."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }
  }

  ;; consumers: any trait that needs live push feed (e.g. std-push-activity-log)
  page "/push" as Push -> PushSubscriberIndicator
}