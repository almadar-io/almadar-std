app std-app-layout "1.4.1"
"std-app-layout — dashboard-layout chrome (sidebar nav + top bar with search + topBarActions + notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data, and the consumer can add domain icons (cart / profile / help) via topBarActions. Bind once per orbital — the consumer rebinds linkedEntity via `XAppLayout = AppShell.traits.AppLayout -> XEntity` so multiple orbitals in one file each get their own chrome without colliding on a shared atom entity."

type NavItem = { label : string!, href : string!, icon : string, badge : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }
type NotificationSpec = { id : string, message : string, variant : string }

orbital AppLayoutOrbital {
  entity AppLayoutData [runtime] {
    id : string!
  }

  type AppLayoutStateLoaded     = Event { data : [AppLayoutData] }
  type AppLayoutStateLoadFailed = Event { error : string, code : string }

  trait AppLayout -> AppLayoutData [interaction, instance] {
    initial: composing
    config {
      contentTrait           : trait
        @label "Content trait"
        @description "Trait rendered inside the app layout content area"
        @tier "internal"
      appName                : string   = "App"
        @label "App name"
        @description "Product name shown in the chrome header"
        @tier "presentation"
      navItems               : [NavItem] = []
        @label "Sidebar links"
        @description "Top-level nav entries on the left rail"
        @tier "presentation"
      searchEvent            : string   = "SEARCH"
        @label "Search event"
        @description "Event emitted when the user runs a global search"
        @tier "internal"
      topBarActions          : [ItemAction] = []
        @label "Top-bar actions"
        @description "Icon buttons shown on the right side of the top bar"
        @tier "presentation"
      notifications          : [NotificationSpec] = []
        @label "Notifications"
        @description "Items shown in the notifications dropdown"
        @tier "presentation"
      notificationClickEvent : string   = "NOTIFY_CLICK"
        @label "Notification click event"
        @description "Event emitted when the user picks a notification"
        @tier "internal"
      layoutPattern          : pattern  = "dashboard-layout"
        @label "Layout pattern"
        @description "UI pattern used to render the application chrome"
        @tier "internal"
      layoutMode             : "sidebar" | "topnav" | "bottomnav" | "minimal" = "sidebar"
        @label "Layout mode"
        @description "Where the primary navigation lives in the chrome"
        @tier "presentation"
      detailSlot             : slot     = "modal"
        @label "Detail slot"
        @description "Slot where detail/edit views render"
        @tier "internal"
    }
    state composing {
      INIT -> composing
        (fetch AppLayoutData { emit: { success: "AppLayoutStateLoaded", failure: "AppLayoutStateLoadFailed" } })
        (render-ui main { type: "@config.layoutPattern", layoutMode: "@config.layoutMode", appName: "@config.appName", navItems: "@config.navItems", searchEvent: "@config.searchEvent", topBarActions: "@config.topBarActions", notifications: "@config.notifications", notificationClickEvent: "@config.notificationClickEvent", children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: ["@config.contentTrait"] }] })
      AppLayoutStateLoaded -> composing
      AppLayoutStateLoadFailed -> composing
      SEARCH -> composing
      NOTIFY_CLICK -> composing
    }
    emits {
      SEARCH                   -> external { value : string }
      NOTIFY_CLICK             -> external { id : string }
      AppLayoutStateLoaded
      AppLayoutStateLoadFailed
    }
    listens {
      AppLayoutStateLoadFailed { error : string, code : string }
    }
  }

  page "/app-layout" as AppLayoutPage -> AppLayout
}
