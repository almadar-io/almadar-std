app std-sidebar-meta "1.0.0"
"Right-rail meta panel — Linear/Jira/GitHub-style issue sidebar. Stacked label/value rows grouped with dividers. Standalone atom; fetches one SidebarRecord and renders inline."
orbital SidebarMetaOrbital {
    type SidebarRecordLoaded = Event { data : [object] } "Fired when the sidebar record finishes loading"

    type SidebarRecordLoadFailed = Event { error : string, code : string } "Fired when the sidebar record fetch fails"

  entity SidebarRecord [runtime] {
    id : string!
    title : string! @description "The descriptive name of the record." @synonyms "name, heading, subject" = Untitled
    status : "open" | "in_progress" | "closed" @description "Current state of the record." @synonyms "state, condition, phase" = open
    priority : "low" | "medium" | "high" @description "Indicates the level of importance or urgency." @synonyms "severity, importance, urgency" = medium
    assignee : string @description "The user currently responsible for the item." @synonyms "owner, responsible, assignedTo" = ""
    reporter : string @description "The user who initially reported the item." @synonyms "owner, submitter, creator" = ""
    milestone : string @description "The target date for completing related work." @synonyms "due date, target date, completion date" = ""
    labels : string @description "A collection of descriptive tags or categories." @synonyms "tags, categories, keywords, markers" = ""
    createdAt : string = ""
    updatedAt : string = ""
    errorMessage : string @description "Error message associated with the record." @synonyms "error, fault, issue" = ""
  }

  trait SidebarMeta -> SidebarRecord [interaction, instance] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch SidebarRecord {
          emit: { failure: SidebarRecordLoadFailed, success: SidebarRecordLoaded }
          limit: 1
        })
        (render-ui main {
          title: "Loading…"
          type: loading-state
        })
      SidebarRecordLoaded -> loading
        (set @entity.id (object/get (array/first ?data) id))
        (set @entity.title (object/get (array/first ?data) title))
        (set @entity.status (object/get (array/first ?data) status))
        (set @entity.priority (object/get (array/first ?data) priority))
        (set @entity.assignee (object/get (array/first ?data) assignee))
        (set @entity.reporter (object/get (array/first ?data) reporter))
        (set @entity.milestone (object/get (array/first ?data) milestone))
        (set @entity.labels (object/get (array/first ?data) labels))
        (set @entity.createdAt (object/get (array/first ?data) createdAt))
        (set @entity.updatedAt (object/get (array/first ?data) updatedAt))
        (render-ui main {
          children: [{
            children: [{
              children: [{
                color: muted
                content: @entity.id
                type: typography
                variant: caption
              }, {
                content: @entity.title
                type: typography
                variant: h4
                weight: semibold
              }]
              direction: vertical
              gap: xs
              type: stack
            }, { type: divider }, {
              align: center
              children: [{
                color: muted
                content: Status
                type: typography
                variant: overline
              }, {
                label: @entity.status
                size: sm
                type: badge
                variant: default
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, {
              align: center
              children: [{
                color: muted
                content: Priority
                type: typography
                variant: overline
              }, {
                label: @entity.priority
                size: sm
                type: badge
                variant: neutral
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, { type: divider }, {
              children: [{
                color: muted
                content: Assignee
                type: typography
                variant: overline
              }, {
                align: center
                children: [{
                  name: @entity.assignee
                  size: xs
                  type: avatar
                }, {
                  content: @entity.assignee
                  type: typography
                  variant: body
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: vertical
              gap: xs
              type: stack
            }, {
              children: [{
                color: muted
                content: Reporter
                type: typography
                variant: overline
              }, {
                align: center
                children: [{
                  name: @entity.reporter
                  size: xs
                  type: avatar
                }, {
                  content: @entity.reporter
                  type: typography
                  variant: body
                }]
                direction: horizontal
                gap: sm
                type: stack
              }]
              direction: vertical
              gap: xs
              type: stack
            }, { type: divider }, {
              align: center
              children: [{
                color: muted
                content: Milestone
                type: typography
                variant: overline
              }, {
                content: @entity.milestone
                type: typography
                variant: body
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, {
              children: [{
                color: muted
                content: Labels
                type: typography
                variant: overline
              }, {
                label: @entity.labels
                size: sm
                type: badge
                variant: neutral
              }]
              direction: vertical
              gap: xs
              type: stack
            }, { type: divider }, {
              align: center
              children: [{
                color: muted
                content: Created
                type: typography
                variant: overline
              }, {
                color: muted
                content: @entity.createdAt
                type: typography
                variant: caption
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }, {
              align: center
              children: [{
                color: muted
                content: Updated
                type: typography
                variant: overline
              }, {
                color: muted
                content: @entity.updatedAt
                type: typography
                variant: caption
              }]
              direction: horizontal
              gap: sm
              justify: between
              type: stack
            }]
            direction: vertical
            gap: md
            type: stack
          }]
          look: flat-bordered
          padding: md
          type: card
        })
      SidebarRecordLoadFailed -> error
        (set @entity.errorMessage ?error)
        (render-ui main {
          message: @entity.errorMessage
          title: "Failed to load sidebar"
          type: error-state
        })
    }

    state error {
      INIT -> loading
        (render-ui main {
          title: "Retrying…"
          type: loading-state
        })
    }

    emits {
      SidebarRecordLoaded {
        data : [object]
      }
        @description "Signals successful retrieval of data for the sidebar."
        @synonyms "loaded, fetched, received, updated"
        @tier "domain"
      SidebarRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load the sidebar record."
        @synonyms "error, failed, problem, unsuccessful"
        @tier "internal"
    }

    listens {
      SidebarRecordLoaded {
        data : [object]
      }
        @description "Indicates the sidebar data has been successfully retrieved."
        @synonyms "loaded, received, fetched, updated"
        @tier "domain"
      SidebarRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load the sidebar record data."
        @synonyms "error, failed, problem, load failure"
        @tier "internal"
    }
  }

  page "/sidebar-meta" as SidebarMetaPage -> SidebarMeta
}