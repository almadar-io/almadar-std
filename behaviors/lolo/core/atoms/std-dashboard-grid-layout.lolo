app std-dashboard-grid-layout "5.0.0"
"std-dashboard-grid-layout — dashboard-layout chrome mirroring Looker Studio / Power BI: top-right toolbar slots (export / share / settings — feed `headerActions`), horizontal filter row (date range, search, dropdown filters), divider, then 12 numbered tile slots in a responsive simple-grid below. Slots default to EmptyTile so callers only bind what they need via traitOverrides."

type NavItem = { label : string!, href : string!, icon : string, badge : string }

orbital DashboardGridLayoutOrbital {
  entity DashboardGridLayoutState [runtime] {
    id : string!
  }

  trait EmptyTile -> DashboardGridLayoutState [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (render-ui main { type: "box" })
    }
  }

  trait DashboardGridLayout -> DashboardGridLayoutState [interaction, instance] {
    initial: composing
    config {
      toolbar1Trait : trait = "@trait.EmptyTile"
        @label "Toolbar slot 1"
        @description "First top-right toolbar trait (typical use: export action)"
        @tier "customization"
      toolbar2Trait : trait = "@trait.EmptyTile"
        @label "Toolbar slot 2"
        @description "Second top-right toolbar trait (typical use: share action)"
        @tier "customization"
      toolbar3Trait : trait = "@trait.EmptyTile"
        @label "Toolbar slot 3"
        @description "Third top-right toolbar trait (typical use: settings action)"
        @tier "customization"
      filter1Trait : trait = "@trait.EmptyTile"
        @label "Filter slot 1"
        @description "First filter-row trait (typical use: date range picker)"
        @tier "customization"
      filter2Trait : trait = "@trait.EmptyTile"
        @label "Filter slot 2"
        @description "Second filter-row trait (typical use: search input)"
        @tier "customization"
      filter3Trait : trait = "@trait.EmptyTile"
        @label "Filter slot 3"
        @description "Third filter-row trait (typical use: dropdown filter)"
        @tier "customization"
      filter4Trait : trait = "@trait.EmptyTile"
        @label "Filter slot 4"
        @description "Fourth filter-row trait (typical use: secondary dropdown filter)"
        @tier "customization"
      tile1Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 1"
        @description "Trait rendered in the first dashboard grid tile"
        @tier "customization"
      tile2Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 2"
        @description "Trait rendered in the second dashboard grid tile"
        @tier "customization"
      tile3Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 3"
        @description "Trait rendered in the third dashboard grid tile"
        @tier "customization"
      tile4Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 4"
        @description "Trait rendered in the fourth dashboard grid tile"
        @tier "customization"
      tile5Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 5"
        @description "Trait rendered in the fifth dashboard grid tile"
        @tier "customization"
      tile6Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 6"
        @description "Trait rendered in the sixth dashboard grid tile"
        @tier "customization"
      tile7Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 7"
        @description "Trait rendered in the seventh dashboard grid tile"
        @tier "customization"
      tile8Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 8"
        @description "Trait rendered in the eighth dashboard grid tile"
        @tier "customization"
      tile9Trait  : trait = "@trait.EmptyTile"
        @label "Tile slot 9"
        @description "Trait rendered in the ninth dashboard grid tile"
        @tier "customization"
      tile10Trait : trait = "@trait.EmptyTile"
        @label "Tile slot 10"
        @description "Trait rendered in the tenth dashboard grid tile"
        @tier "customization"
      tile11Trait : trait = "@trait.EmptyTile"
        @label "Tile slot 11"
        @description "Trait rendered in the eleventh dashboard grid tile"
        @tier "customization"
      tile12Trait : trait = "@trait.EmptyTile"
        @label "Tile slot 12"
        @description "Trait rendered in the twelfth dashboard grid tile"
        @tier "customization"
      minTileWidth : number   = 320
        @label "Tile min width"
        @description "Minimum pixel width per tile before the grid re-flows"
        @tier "advanced"
      appName      : string   = "Dashboard"
        @label "App name"
        @description "Product name shown in the dashboard chrome"
        @tier "essential"
      navItems     : [NavItem] = [{ href: "/dashboard", label: "Dashboard", icon: "bar-chart-3" }]
        @label "Sidebar links"
        @description "Top-level nav entries on the left rail"
        @tier "essential"
    }
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "@config.appName", navItems: "@config.navItems", headerActions: { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [
          "@config.toolbar1Trait",
          "@config.toolbar2Trait",
          "@config.toolbar3Trait"
        ]}, children: [
          { type: "stack", direction: "vertical", gap: "md", children: [
            { type: "stack", direction: "horizontal", gap: "md", wrap: true, align: "center", children: [
              "@config.filter1Trait",
              "@config.filter2Trait",
              "@config.filter3Trait",
              "@config.filter4Trait"
            ]},
            { type: "divider" },
            { type: "simple-grid", minChildWidth: "@config.minTileWidth", children: [
              "@config.tile1Trait",
              "@config.tile2Trait",
              "@config.tile3Trait",
              "@config.tile4Trait",
              "@config.tile5Trait",
              "@config.tile6Trait",
              "@config.tile7Trait",
              "@config.tile8Trait",
              "@config.tile9Trait",
              "@config.tile10Trait",
              "@config.tile11Trait",
              "@config.tile12Trait"
            ]}
          ]}
        ]})
    }
  }

  page "/dashboard" as DashboardGridLayoutPage -> DashboardGridLayout
}
