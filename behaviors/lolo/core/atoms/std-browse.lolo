app std-browse "2.1.0"
"std-browse as a Function — single primitive: data-grid. Owns the fetch + REFETCH (query/filter/page) state machine. Consumers configure fields/imageField/itemActions/cols/gap/variant; the atom renders the grid. Each `fields[]` entry accepts `{ name, label, variant }` plus optional `referenceEntity` + `displayField` to render a foreign-key column as the joined entity's display value (data-grid resolves @list[referenceEntity] at render time when both keys are present)."

type FieldSpec = { name : string!, label : string, variant : string, icon : string, format : string, key : string, header : string }
type ItemAction = { label : string!, event : string!, variant : string, icon : string }
type ColumnSpec = { key : string!, field : string, header : string, width : string, align : string, className : string, weight : string, format : string, icon : string }

orbital BrowseItemOrbital {
  entity BrowseItem [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  type BrowseItemLoaded     = Event { data : [BrowseItem], totalCount : number } "Fired when the BrowseItem collection finishes loading; payload.data holds the (possibly paginated) slice and totalCount holds the unsliced filter total. totalCount is optional so compiled-path emitters that haven't been migrated yet still validate"
  type BrowseItemLoadFailed = Event { error : string, code : string } "Fired when the BrowseItem collection fails to load"

  trait BrowseItemBrowse -> @rebindable BrowseItem [interaction, collection] {
    initial: loading
    config {
      fields : [FieldSpec] = [
        { name: "name", label: "Name", variant: "h4" },
        { name: "description", label: "Description", variant: "caption" },
        { name: "status", label: "Status", variant: "badge" }
      ]
        @label "Columns to show"
        @description "Each column maps to one field on the BrowseItem entity"
        @tier "presentation"
      columns : [ColumnSpec] = [
        { key: "name", field: "name", header: "Name", align: "left", weight: "medium" },
        { key: "description", field: "description", header: "Detail", align: "left" },
        { key: "status", field: "status", header: "Status", align: "center", format: "badge" }
      ]
        @label "Table columns"
        @description "Column definitions for table-style variants (dense). Each maps an entity field to a column with optional width / align / weight / format."
        @tier "presentation"
      imageField : string = ""
        @label "Image field"
        @description "Entity field that holds the row thumbnail URL"
        @tier "presentation"
      titleBinding : string = "@item.name"
        @label "Title binding"
        @description "Per-row binding string for the card title slot. Layer 3 variants read this inside their renderItem; consumers override it to point at their entity's field (e.g. \"@item.dishName\")."
        @tier "presentation"
      descriptionBinding : string = "@item.description"
        @label "Description binding"
        @description "Per-row binding string for the card body/subtitle slot."
        @tier "presentation"
      badgeBinding : string = "@item.status"
        @label "Badge binding"
        @description "Per-row binding string for the status/badge slot."
        @tier "presentation"
      imageLabelBinding : string = "@item.thumbnailLabel"
        @label "Image label binding"
        @description "Per-row binding string for the image-area label slot (image-first variants)."
        @tier "presentation"
      priceBinding : string = "@item.price"
        @label "Price binding"
        @description "Per-row binding string for the price/amount overlay slot."
        @tier "presentation"
      metaBinding : string = "@item.createdAt"
        @label "Meta binding"
        @description "Per-row binding string for the secondary meta slot (timestamp / category)."
        @tier "presentation"
      categoryBinding : string = "@item.category"
        @label "Category binding"
        @description "Per-row binding string for the category/tag slot."
        @tier "presentation"
      priorityBinding : string = "@item.priority"
        @label "Priority binding"
        @description "Per-row binding string for the priority slot (triage / work-queue variants)."
        @tier "presentation"
      assigneeBinding : string = "@item.assignee"
        @label "Assignee binding"
        @description "Per-row binding string for the assignee/owner slot."
        @tier "presentation"
      itemActions : [ItemAction] = []
        @label "Row actions"
        @description "Buttons users can click on each row"
        @tier "presentation"
      cols : number = 1
        @label "Grid columns"
        @description "Number of columns in the responsive grid layout"
        @tier "presentation"
      gap : string = "md"
        @label "Cell spacing"
        @description "Gap size between rows (sm, md, lg)"
        @tier "presentation"
      pageSize : number = 10
        @label "Page size (fetch)"
        @description "Rows fetched from the server per page"
        @tier "presentation"
      displayPageSize : number = 10
        @label "Page size (display)"
        @description "Rows shown per visible page before pagination"
        @tier "presentation"
      viewPattern : pattern = "data-grid"
        @label "Render pattern"
        @description "UI pattern used to render the collection. Used by the default bodyContent tree; Layer 3 variants override bodyContent directly instead and may ignore this knob."
        @tier "internal"
      bodyContent : render-ui = {
        type: "stack",
        direction: "vertical",
        children: [{
          type: "data-grid",
          entity: "@payload.data",
          fields: "@config.fields",
          imageField: "@config.imageField",
          itemActions: "@config.itemActions",
          cols: "@config.cols",
          gap: "@config.gap",
          pageSize: "@config.displayPageSize"
        }]
      }
        @label "Body content tree"
        @description "Render-ui SExpr rendered after rows load. Default is the canonical data-grid call wrapped in a stack. Layer 3 variants override this with their own tree (composing data-list/data-grid/entity-table + custom renderItem lambdas + filter-group, kbd, card, etc.) to deliver entirely different browse UX while inheriting the same trait, state machine, emits, and listens."
        @tier "internal"
    }
    state loading {
      INIT -> loading
        (fetch BrowseItem { offset: 0, limit: @config.pageSize, emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      BrowseItemLoaded -> browsing
        (render-ui main @config.bodyContent)
      BrowseItemLoadFailed -> error
        (render-ui main { type: "typography", variant: "caption", color: "error", content: "@payload.error" })
    }
    state browsing {
      INIT -> loading
        (fetch BrowseItem { offset: 0, limit: @config.pageSize, emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      ;; REFETCH_* stays in `browsing` and DOES NOT replace the data-grid
      ;; with a spinner. Replacing during search-as-you-type unmounts the
      ;; grid every keystroke and causes a visible flicker. The fetch fires
      ;; in the background; when BrowseItemLoaded arrives we render the
      ;; grid with the new rows (handler below), so React reconciles the
      ;; data-grid in place instead of unmounting it.
      REFETCH_QUERY -> browsing
        (fetch BrowseItem { offset: 0, limit: @config.pageSize, filter: (or (= @payload.searchTerm "") (str/includes (object/get @entity "name") @payload.searchTerm)), emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
      REFETCH_FILTER -> browsing
        (fetch BrowseItem { offset: 0, limit: @config.pageSize, filter: (or (= @payload.value "") (= (object/get @entity @payload.field) @payload.value)), emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
      REFETCH_PAGE -> browsing
        (fetch BrowseItem { offset: (* (- @payload.page 1) @config.pageSize), limit: @config.pageSize, emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
      BrowseItemLoaded -> browsing
        (render-ui main @config.bodyContent)
    }
    state error {
      INIT -> loading
        (fetch BrowseItem { offset: 0, limit: @config.pageSize, emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
emits {
      BrowseItemLoaded
      BrowseItemLoadFailed
      ;; Generic CRUD item-action events fired when a consumer-supplied
      ;; `itemActions[]` button is clicked in the data-grid. Declared here
      ;; so any consumer that wires VIEW / EDIT / DELETE actions doesn't
      ;; need to re-declare on the bind site. Domain-specific actions
      ;; (ADD_TO_CART, FAVORITE, etc.) still need to be declared by the
      ;; consumer or wired via call-site emits override.
      VIEW   -> external { id : string!, row : BrowseItem }
      EDIT   -> external { id : string!, row : BrowseItem }
      DELETE -> external { id : string!, row : BrowseItem }
    }

        listens {
      REFETCH_QUERY { searchTerm : string! }
      REFETCH_FILTER { field : string!, value : string! }
      REFETCH_PAGE { page : number! }
      BrowseItemLoadFailed { error : string, code : string }
    }
  }
  page "/browseitems" as BrowseItemPage -> BrowseItemBrowse
}
