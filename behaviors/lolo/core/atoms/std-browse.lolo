app std-browse "1.0.0"
"std-browse as a Function — single primitive: data-grid"

orbital BrowseItemOrbital {
  entity BrowseItem [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  type BrowseItemLoaded     = Event { data : [BrowseItem] }        "Fired when the BrowseItem collection finishes loading; payload.data holds the list"
  type BrowseItemLoadFailed = Event { error : string, code : string } "Fired when the BrowseItem collection fails to load"

  trait BrowseItemBrowse -> BrowseItem [interaction, collection] {
    initial: loading
    config {
      fields : [object] = []
      pageSize : number = 0
    }
    state loading {
      INIT -> loading
        (fetch BrowseItem { emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      BrowseItemLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", children: [{ type: "data-grid", entity: @payload.data, fields: "@config.fields", pageSize: "@config.pageSize" }] })
      BrowseItemLoadFailed -> error
        (render-ui main { type: "typography", variant: "caption", color: "error", content: "@payload.error" })
    }
    state browsing {
      INIT -> loading
        (fetch BrowseItem { emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      REFETCH -> loading
        (fetch BrowseItem { emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    state error {
      INIT -> loading
        (fetch BrowseItem { emit: { success: "BrowseItemLoaded", failure: "BrowseItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
emits {
      BrowseItemLoaded
      BrowseItemLoadFailed
    }

        listens {
      REFETCH { query : string, field : string, value : string, page : number, pageSize : number }
      BrowseItemLoadFailed { error : string, code : string }
    }
  }
  page "/browseitems" as BrowseItemPage -> BrowseItemBrowse
}
