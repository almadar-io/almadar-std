app std-audit-capture "1.1.0"
"std-audit-capture — event-interceptor audit log. Listens for the generic `EntityMutated` sentinel (rename via traitOverrides.events to the real mutation event, e.g. ContactSaved) and persists an AuditEntry row capturing actor, action, entity type/id, before/after snapshots, and timestamp. `captureEventTypes` filters on @payload.data.kind (empty = capture all). Compose with `std-lifecycle` to apply retention. Composable via `extraTraits` to interpose audit logging behind any mutating trait."

orbital AuditCaptureOrbital {
  entity AuditEntry [persistent: audit_entries] {
    id         : string!
    actor      : string  = ""
    action     : string  = ""
    entityType : string  = ""
    entityId   : string  = ""
    before     : object  = {}
    after      : object  = {}
    recordedAt : number  = 0
  }

  type EntityMutated  = Event { data : object }                                                                                    "Rename via traitOverrides.events to the upstream mutation event (e.g. ContactSaved, ContactDeleted)."
  type AuditRecorded  = Event { actor : string, action : string, entityType : string, entityId : string, recordedAt : number }     "Re-emitted after the audit row persists; rename to wire downstream listeners (e.g. AuditDashboardAppended)."

  trait AuditCaptureListener -> @rebindable AuditEntry [lifecycle, instance, audit, compliance] {
    config {
      captureEntity     : string   = ""
        @label "Entity to audit"
        @description "Type name of the entity whose mutations get logged"
        @tier "domain"
      captureEventTypes : [string] = []
        @label "Event-kind filter"
        @description "When set, only @payload.data.kind values in this list are audited. Empty list = capture every event. Requires the upstream event to include a `kind` field on its payload."
        @tier "domain"
      excludeFields     : [string] = []
        @label "Skip fields"
        @description "Entity fields to omit from the audit payload (declarative; before/after still capture all fields in v1.1 — field exclusion lands when captureBeforeAfter wiring filters per-field)."
        @tier "domain"
      captureBeforeAfter : boolean = false
        @label "Capture before/after snapshots"
        @description "When true, persist `before` and `after` object snapshots from @payload.data on each audit row. Default off to keep audit rows small."
        @tier "domain"
      retentionDays      : number  = 2555
        @label "Retention (days)"
        @description "Days to keep audit rows. Default 2555 (7 years) for typical compliance regimes. WIRING DEFERRED: retention enforcement requires composing `std-lifecycle` against AuditEntry with a delete rule (gap — docs/Almadar_Std_Factories.md)."
        @tier "domain"
    }
    initial: idle
    state idle {
      EntityMutated -> idle
        (when (or (= (array/len @config.captureEventTypes) 0)
                  (array/includes @config.captureEventTypes (object/get @payload.data "kind" "")))
          (do
            (set @entity.actor "@user.id")
            (set @entity.action (object/get @payload.data "kind" "EntityMutated"))
            (set @entity.entityType @config.captureEntity)
            (set @entity.entityId (object/get @payload.data "id" ""))
            (set @entity.before (if @config.captureBeforeAfter (object/get @payload.data "before" {}) {}))
            (set @entity.after  (if @config.captureBeforeAfter (object/get @payload.data "after"  {}) {}))
            (set @entity.recordedAt 0)
            (persist create AuditEntry {
              actor:      "@user.id",
              action:     @entity.action,
              entityType: "@config.captureEntity",
              entityId:   @entity.entityId,
              before:     @entity.before,
              after:      @entity.after,
              recordedAt: 0
            })
            (emit AuditRecorded {
              actor:      "@user.id",
              action:     @entity.action,
              entityType: "@config.captureEntity",
              entityId:   @entity.entityId,
              recordedAt: 0
            })))
    }
    emits {
      AuditRecorded -> external { actor : string, action : string, entityType : string, entityId : string, recordedAt : number }
    }
    listens {
      EntityMutated { data : object }
    }
  }
  page "/audit-capture" as AuditCapturePage -> AuditCaptureListener
}
