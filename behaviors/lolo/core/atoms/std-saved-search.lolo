app std-saved-search "1.0.0"
"std-saved-search — persisted query + alert subscription. Owns a SavedSearch entity (one row per saved query) and a single manage trait that lists saved searches in a data-grid, lets users toggle their alert subscription / rename the search / delete it, and persists each change."

orbital SavedSearchOrbital {
  entity SavedSearch [persistent: savedsearches] {
    id             : string!
    name           : string!
    query          : string
    filters        : object
    alertEnabled   : boolean = false
    alertFrequency : "instant" | "daily" | "weekly" = "daily"
    userId         : string
    lastNotifiedAt : string
    createdAt      : string
  }

  type SavedSearchLoaded     = Event { data : [SavedSearch] }              "Fired when the saved-search collection finishes loading"
  type SavedSearchLoadFailed = Event { error : string, code : string }     "Fired when the saved-search collection fails to load"
  type SavedSearchUpdated    = Event { row : SavedSearch }                 "Fired after a saved-search row's update persists (toggle alert / rename / change frequency)"
  type SavedSearchDeleted    = Event { id : string }                       "Fired after a saved-search row is deleted"

  trait SavedSearchManage -> SavedSearch [interaction, collection] {
    config {
      title : string = "Saved Searches"
        @label "Section title"
        @description "Heading shown above the saved-search list"
        @tier "presentation"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch SavedSearch { emit: { success: "SavedSearchLoaded", failure: "SavedSearchLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading saved searches…" }] })
      SavedSearchLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "bookmark" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@payload.data", fields: [{ name: "name", label: "Name", variant: "h4" }, { name: "query", label: "Query", variant: "caption" }, { name: "alertFrequency", label: "Frequency", variant: "badge" }, { name: "alertEnabled", label: "Alerts", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Toggle alert", event: "TOGGLE_ALERT", variant: "secondary", icon: "bell" }, { label: "Edit", event: "EDIT", variant: "secondary", icon: "pencil" }, { label: "Delete", event: "DELETE", variant: "danger", icon: "trash-2" }] }] })
      SavedSearchLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      TOGGLE_ALERT -> browsing
        (set @entity.id @payload.id)
        (set @entity.alertEnabled @payload.enabled)
        (persist update SavedSearch @entity { emit: { success: "SavedSearchUpdated", failure: "SavedSearchLoadFailed" } })
      DELETE -> browsing
        (set @entity.id @payload.id)
        (persist delete SavedSearch @entity { emit: { success: "SavedSearchDeleted", failure: "SavedSearchLoadFailed" } })
      EDIT -> editing
        (set @entity.id @payload.id)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "pencil" }, { type: "typography", content: "Edit saved search", variant: "h3" }] }, { type: "divider" }, { type: "input", placeholder: "Name", value: @entity.name, action: "RENAME" }, { type: "select", options: [{ label: "Instant", value: "instant" }, { label: "Daily", value: "daily" }, { label: "Weekly", value: "weekly" }], placeholder: "Alert frequency", value: @entity.alertFrequency, action: "CHANGE_FREQUENCY" }, { type: "switch", checked: @entity.alertEnabled, label: "Alerts enabled" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Save", action: "SAVE", variant: "primary", icon: "check" }, { type: "button", label: "Cancel", action: "CANCEL", variant: "secondary", icon: "x" }] }] })
      SavedSearchUpdated -> loading
        (fetch SavedSearch { emit: { success: "SavedSearchLoaded", failure: "SavedSearchLoadFailed" } })
      SavedSearchDeleted -> loading
        (fetch SavedSearch { emit: { success: "SavedSearchLoaded", failure: "SavedSearchLoadFailed" } })
    }
    state editing {
      RENAME -> editing
        (set @entity.name @payload.value)
      CHANGE_FREQUENCY -> editing
        (set @entity.alertFrequency @payload.value)
      SAVE -> browsing
        (persist update SavedSearch @entity { emit: { success: "SavedSearchUpdated", failure: "SavedSearchLoadFailed" } })
      CANCEL -> loading
        (fetch SavedSearch { emit: { success: "SavedSearchLoaded", failure: "SavedSearchLoadFailed" } })
    }
    state error {
      INIT -> loading
        (fetch SavedSearch { emit: { success: "SavedSearchLoaded", failure: "SavedSearchLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      TOGGLE_ALERT     { id : string!, enabled : boolean! }
      DELETE           { id : string! }
      EDIT             { id : string! }
      RENAME           { value : string! }
      CHANGE_FREQUENCY { value : string! }
      SAVE
      CANCEL
      SavedSearchLoaded     { data : [SavedSearch] }
      SavedSearchLoadFailed { error : string, code : string }
      SavedSearchUpdated    { row : SavedSearch }
      SavedSearchDeleted    { id : string! }
    }
    listens {
      TOGGLE_ALERT     { id : string!, enabled : boolean! }
      DELETE           { id : string! }
      EDIT             { id : string! }
      RENAME           { value : string! }
      CHANGE_FREQUENCY { value : string! }
      SAVE
      CANCEL
      SavedSearchLoaded     { data : [SavedSearch] }
      SavedSearchLoadFailed { error : string, code : string }
      SavedSearchUpdated    { row : SavedSearch }
      SavedSearchDeleted    { id : string! }
    }
  }
  page "/savedsearches" as SavedSearchManagePage -> SavedSearchManage
}
