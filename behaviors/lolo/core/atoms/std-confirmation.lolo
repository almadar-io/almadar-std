app std-confirmation "1.0.0"
"std-confirmation as a Function"
;;
;; Modal-only confirmation trait: renders ONLY to the `modal` slot.
;; Consumers configure icon/title/alertMessage/confirmLabel at the
;; trait-ref call site via `config: { ... }`. Side effects (persist delete,
;; notify, etc.) belong in a sibling coordinator trait that
;; `listens { ConfirmTrait CONFIRM -> DO_DELETE }`.

orbital ConfirmActionOrbital {
  entity ConfirmAction [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    pendingId : string = ""
  }
  type ConfirmActionLoaded = Event { data : [ConfirmAction] }
  type ConfirmActionLoadFailed = Event { error : string, code : string }

  trait ConfirmActionConfirmation -> ConfirmAction [interaction, instance] {
    config {
      icon : string = "alert-triangle"
      title : string = "Confirm Action"
      alertMessage : string = "Are you sure?"
      confirmLabel : string = "Confirm"
    }
    initial: idle
    state idle {
      INIT -> idle
        (fetch ConfirmAction { emit: { success: "ConfirmActionLoaded", failure: "ConfirmActionLoadFailed" } })
      ;; Guard: REQUEST is rejected if no `row` payload was provided.
      ;; "Confirm an action against X" is meaningless without X — a
      ;; confirmation dialog with no entity to display is a precondition
      ;; violation, not a valid render. Without this guard, an empty
      ;; REQUEST payload would still open the modal with `@entity.name`
      ;; rendering empty (post-codegen-fix) which silently looks like a
      ;; UI bug. The guard surfaces the contract: callers MUST send the
      ;; targeted row in `payload.row`.
      REQUEST -> confirming when @payload.row
        (set @entity.pendingId @payload.id)
        (set @entity.name @payload.row.name)
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "@config.icon" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "alert", variant: "error", message: "@config.alertMessage" }, { type: "typography", content: "@entity.name", variant: "h4" }, { type: "typography", content: "@entity.pendingId", variant: "caption", color: "muted" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "end", children: [{ type: "button", label: "Cancel", action: "CANCEL", variant: "ghost" }, { type: "button", label: "@config.confirmLabel", action: "CONFIRM", actionPayload: { id: "@payload.id" }, variant: "danger", icon: "check" }] }] })
    }
    state confirming {
      CONFIRM -> idle
        (render-ui modal null)
      CANCEL -> idle
        (render-ui modal null)
      CLOSE -> idle
        (render-ui modal null)
    }

    emits {
      CONFIRM { id : string }
      CANCEL
      CLOSE
      ConfirmActionLoadFailed
      ConfirmActionLoaded
    }
    listens {
      REQUEST { id : string!, row : ConfirmAction }

      ConfirmActionLoadFailed { error : string, code : string }
    }
  }
  page "/confirmactions/confirm" as ConfirmActionConfirmPage -> ConfirmActionConfirmation
}
