app std-search "1.0.0"
"std-search as a Function"

orbital SearchResultOrbital {
  entity SearchResult [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }

  type SearchResultLoaded     = Event { data : [SearchResult] } "Fired when SearchResult collection finishes loading"
  type SearchResultLoadFailed = Event { error : string, code : string } "Fired when SearchResult collection fails to load"

  trait SearchResultSearch -> SearchResult [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch SearchResult { emit: { success: "SearchResultLoaded", failure: "SearchResultLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Search SearchResults", variant: "h2" }] }, { type: "divider" }, { type: "search-input", placeholder: "Search...", event: "SEARCH" }, { type: "empty-state", icon: "search", title: "Search to find results", description: "Type a query to search across searchresults." }] })
      SEARCH -> loading
        (fetch SearchResult { emit: { success: "SearchResultLoaded", failure: "SearchResultLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: ["str/concat", "Searching for \"", "@payload.query", "\"…"] }] })
    }
    state loading {
      SearchResultLoaded -> searching
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Results", variant: "h2" }] }, { type: "button", label: "Clear", action: "CLEAR", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", variant: "h4", content: "@item.name" }] }] }] })
      SearchResultLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-8", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "body", content: "Search failed" }, { type: "typography", variant: "caption", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "SEARCH", variant: "ghost", icon: "rotate-ccw" }] })
      SEARCH -> loading
        (fetch SearchResult { emit: { success: "SearchResultLoaded", failure: "SearchResultLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state searching {
      SEARCH -> loading
        (fetch SearchResult { emit: { success: "SearchResultLoaded", failure: "SearchResultLoadFailed" } })
        (render-ui main { type: "spinner" })
      CLEAR -> idle
        (fetch SearchResult { emit: { success: "SearchResultLoaded", failure: "SearchResultLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Search SearchResults", variant: "h2" }] }, { type: "divider" }, { type: "search-input", placeholder: "Search...", event: "SEARCH" }, { type: "empty-state", icon: "search", title: "Search to find results", description: "Type a query to search across searchresults." }] })
    }
    state error {
      SEARCH -> loading
        (fetch SearchResult { emit: { success: "SearchResultLoaded", failure: "SearchResultLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
emits {
      SearchResultLoaded
      SearchResultLoadFailed
    }

        listens {
      SEARCH { query : string! }
      SearchResultLoadFailed { error : string, code : string }
    }
  }
  page "/searchresults/search" as SearchResultSearchPage -> SearchResultSearch
}
