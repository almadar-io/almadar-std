app std-search "1.0.0"
"std-search — single primitive: search-input. Owns a SearchResult runtime entity; SEARCH persists @payload.searchTerm (matching SearchInput's emit shape) so cross-trait listeners can route it into data atoms (Browse REFETCH_QUERY)."
orbital SearchResultOrbital {
  uses SearchInputRender from "../../ui/core/molecules/ui-search-input"
  entity SearchResult [runtime] {
    id : string!
    searchTerm : string @description "The text entered by the user in the search field." @synonyms "query, search term, input, text"
  }

  trait SearchInputWrapper = SearchInputRender -> SearchResult { config { event: @config.event, placeholder: @config.placeholder } }

  trait SearchResultSearch -> @rebindable SearchResult [interaction, instance] {
    initial: idle

    state idle {
      INIT -> idle
        (render-ui main @trait.SearchInputWrapper)
      SEARCH -> idle
        (set @entity.searchTerm ?searchTerm)
        (render-ui main @trait.SearchInputWrapper)
    }

    emits {
      SEARCH -> external {
        searchTerm : string!
      }
        @description "Initiates a search operation based on the input term."
        @synonyms "query, lookup, find"
        @tier "domain"
    }

    listens {
      SEARCH {
        searchTerm : string!
      }
        @description "A search query has been submitted and persisted."
        @synonyms "query, request, lookup"
        @tier "domain"
    }

    config {
      placeholder : string = "Search…"
        @label "Placeholder text"
        @description "Hint text shown inside the empty search input"
        @tier "presentation"
      event : string = SEARCH
        @label "Search event"
        @description "Event emitted when the user submits a query"
        @tier "internal"
    }
  }

  page "/searchresults/search" as SearchResultSearchPage -> SearchResultSearch
}