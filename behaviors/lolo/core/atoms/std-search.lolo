app std-search "1.0.0"
"std-search — single primitive: search-input. Owns a SearchResult runtime entity; SEARCH persists @payload.searchTerm (matching SearchInput's emit shape) so cross-trait listeners can route it into data atoms (Browse REFETCH_QUERY)."

orbital SearchResultOrbital {
  entity SearchResult [runtime] {
    id         : string!
    searchTerm : string
  }

  trait SearchResultSearch -> SearchResult [interaction, instance] {
    initial: idle
    config {
      placeholder : string = "Search…"
        @label "Placeholder text"
        @description "Hint text shown inside the empty search input"
        @tier "presentation"
      event       : string = "SEARCH"
        @label "Search event"
        @description "Event emitted when the user submits a query"
        @tier "internal"
    }
    state idle {
      INIT -> idle
        (render-ui main { type: "search-input", placeholder: "@config.placeholder", event: "@config.event" })
      SEARCH -> idle
        (set @entity.searchTerm @payload.searchTerm)
        (render-ui main { type: "search-input", placeholder: "@config.placeholder", event: "@config.event" })
    }
    emits {
      SEARCH -> external { searchTerm : string! }
    }
    listens {
      SEARCH { searchTerm : string! }
    }
  }
  page "/searchresults/search" as SearchResultSearchPage -> SearchResultSearch
}
