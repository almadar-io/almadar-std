app std-image-upload-multi "1.0.0"
"std-image-upload-multi — multi-image upload with drop zone, gallery preview, and per-batch progress."

orbital UploadedImageOrbital {
  entity UploadedImage [persistent: uploadedimages] {
    id         : string!
    url        : string!
    name       : string
    sizeBytes  : number
    mimeType   : string
    width      : number
    height     : number
    parentId   : string
    parentType : string
    uploadedAt : string
  }

  type UploadedImageLoaded     = Event { data : [UploadedImage] }            "Fired when the uploaded-image collection finishes loading"
  type UploadedImageLoadFailed = Event { error : string, code : string }      "Fired when the uploaded-image collection fails to load"
  type UploadedImageCreated    = Event { row : UploadedImage }                "Fired after a new uploaded image persists successfully"
  type UploadedImageDeleted    = Event { id : string }                        "Fired after an uploaded image is removed"

  trait UploadedImageUpload -> UploadedImage [interaction, collection] {
    config {
      title            : string = "Upload Images"
      maxImages        : number = 10
      maxBytesPerImage : number = 10485760
      accept           : string = "image/*"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch UploadedImage { emit: { success: "UploadedImageLoaded", failure: "UploadedImageLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading images…" }] })
      UploadedImageLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "image-plus" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "upload-drop-zone", accept: "@config.accept", maxSize: "@config.maxBytesPerImage", maxFiles: "@config.maxImages", label: "Drop images here", description: "or click to browse", icon: "image-plus", action: "UPLOAD" }, { type: "media-gallery", entity: @payload.data }] })
      UploadedImageLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      UPLOAD -> uploading
        (persist create UploadedImage @payload.files { emit: { success: "UploadedImageCreated", failure: "UploadedImageUploadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "typography", variant: "h3", content: "Uploading images…" }, { type: "progress-bar", value: 0, max: 100, progressType: "linear" }] })
      DELETE -> browsing
        (persist delete UploadedImage @payload.id { emit: { success: "UploadedImageDeleted", failure: "UploadedImageDeleteFailed" } })
      UploadedImageDeleted -> loading
        (fetch UploadedImage { emit: { success: "UploadedImageLoaded", failure: "UploadedImageLoadFailed" } })
      UploadedImageDeleteFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state uploading {
      UploadedImageCreated -> loading
        (fetch UploadedImage { emit: { success: "UploadedImageLoaded", failure: "UploadedImageLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "check-circle", color: "success" }, { type: "typography", variant: "h3", content: "Upload complete" }] })
      UploadedImageUploadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state error {
      UploadedImageLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "image-plus" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "upload-drop-zone", accept: "@config.accept", maxSize: "@config.maxBytesPerImage", maxFiles: "@config.maxImages", label: "Drop images here", description: "or click to browse", icon: "image-plus", action: "UPLOAD" }, { type: "media-gallery", entity: @payload.data }] })
    }
    emits {
      UPLOAD { files : object! }
      DELETE { id : string! }
      UploadedImageLoaded { data : [UploadedImage] }
      UploadedImageLoadFailed { error : string, code : string }
      UploadedImageCreated { row : UploadedImage }
      UploadedImageUploadFailed { error : string, code : string }
      UploadedImageDeleted { id : string! }
      UploadedImageDeleteFailed { error : string, code : string }
    }
    listens {
      UPLOAD { files : object! }
      DELETE { id : string! }
      UploadedImageLoaded { data : [UploadedImage] }
      UploadedImageLoadFailed { error : string, code : string }
      UploadedImageCreated { row : UploadedImage }
      UploadedImageUploadFailed { error : string, code : string }
      UploadedImageDeleted { id : string! }
      UploadedImageDeleteFailed { error : string, code : string }
    }
  }
  page "/uploadedimages/upload" as UploadedImageUploadPage -> UploadedImageUpload
}
