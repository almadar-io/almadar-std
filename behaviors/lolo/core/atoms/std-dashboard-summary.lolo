app std-dashboard-summary "1.0.0"
"Executive dashboard summary — 4 KPI tiles, status pill strip, and a primary line-chart panel. Standalone atom with its own loading/ready/error state machine; fetches a single SummaryRecord and renders inline."
type KpiTile = { label : string!, value : string!, trend : number, icon : string }
type StatusPill = { label : string!, tone : "default" | "primary" | "success" | "warning" | "error" | "info" | "neutral" }
type SeriesPoint = { date : string!, value : number! }
orbital DashboardSummaryOrbital {
    type SummaryRecordLoaded = Event { data : [object] } "Fired when the summary record finishes loading"

    type SummaryRecordLoadFailed = Event { error : string, code : string } "Fired when the summary fetch fails"

  entity SummaryRecord [runtime] {
    id : string!
    title : string! @description "A brief, descriptive name for the record." @synonyms "label, heading, name" = "Performance overview"
    subtitle : string @description "A short descriptive text appearing below the main title." @synonyms "caption, secondary title, description" = ""
    period : string @description "The time period or interval the data represents." @synonyms "date range, timeframe, interval, duration" = "Last 30 days"
    tiles : [KpiTile] @description "A collection of KPI tile configurations." @synonyms "tileset, tile data, KPI definitions" = []
    statuses : [StatusPill] @description "Represents the current operational status." @synonyms "state, condition, level" = []
    chartTitle : string @description "The title displayed for the chart." @synonyms "heading, label, name" = Performance
    chartSubtitle : string @description "A brief descriptive text accompanying the chart title." @synonyms "subtitle, description, caption" = ""
    chartData : [SeriesPoint] @description "Data points for a chart visualization." @synonyms "data, values, measurements, readings" = []
    filterEvent : string @description "Event triggering data filtering or refresh." @synonyms "event, trigger, update" = OPEN_FILTER
    errorMessage : string @description "A textual description of an error condition." @synonyms "error, error message, problem, issue" = ""
  }

  trait DashboardSummary -> SummaryRecord [interaction, instance] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch SummaryRecord {
          emit: { failure: SummaryRecordLoadFailed, success: SummaryRecordLoaded }
          limit: 1
        })
        (render-ui main {
          title: "Loading dashboard…"
          type: loading-state
        })
      SummaryRecordLoaded -> ready
        (set @entity.title (object/get (array/first ?data) title))
        (set @entity.subtitle (object/get (array/first ?data) subtitle))
        (set @entity.period (object/get (array/first ?data) period))
        (set @entity.tiles (object/get (array/first ?data) tiles))
        (set @entity.statuses (object/get (array/first ?data) statuses))
        (set @entity.chartTitle (object/get (array/first ?data) chartTitle))
        (set @entity.chartSubtitle (object/get (array/first ?data) chartSubtitle))
        (set @entity.chartData (object/get (array/first ?data) chartData))
        (set @entity.filterEvent (object/get (array/first ?data) filterEvent))
        (render-ui main {
          children: [{
            align: center
            children: [{
              children: [{
                content: @entity.title
                type: typography
                variant: h3
                weight: semibold
              }, {
                color: muted
                content: @entity.period
                type: typography
                variant: caption
              }]
              direction: vertical
              gap: xs
              type: stack
            }, {
              action: @entity.filterEvent
              icon: filter
              label: Filter
              size: sm
              type: button
              variant: ghost
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, {
            children: [{
              entity: @entity.tiles
              fields: []
              gap: md
              renderItem: (fn tile {
                children: [{
                  children: [{
                    align: center
                    children: [{
                      color: muted
                      content: @tile.label
                      type: typography
                      variant: overline
                      weight: semibold
                    }, {
                      color: muted
                      name: @tile.icon
                      size: sm
                      type: icon
                    }]
                    direction: horizontal
                    gap: xs
                    justify: between
                    type: stack
                  }, {
                    content: @tile.value
                    type: typography
                    variant: h2
                    weight: semibold
                  }, {
                    showValue: true
                    size: sm
                    type: trend-indicator
                    value: @tile.trend
                  }]
                  direction: vertical
                  gap: xs
                  type: stack
                }]
                look: elevated
                padding: md
                type: card
              })
              type: data-list
            }]
            cols: 4
            gap: md
            type: simple-grid
          }, {
            align: center
            children: [{
              entity: @entity.statuses
              fields: []
              gap: sm
              renderItem: (fn pill {
                label: @pill.label
                size: sm
                type: badge
                variant: @pill.tone
              })
              type: data-list
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, {
            children: [{
              children: [{
                align: center
                children: [{
                  children: [{
                    content: @entity.chartTitle
                    type: typography
                    variant: h4
                    weight: semibold
                  }, {
                    color: muted
                    content: @entity.chartSubtitle
                    type: typography
                    variant: caption
                  }]
                  direction: vertical
                  gap: xs
                  type: stack
                }, {
                  label: @entity.period
                  size: sm
                  type: badge
                  variant: default
                }]
                direction: horizontal
                gap: sm
                justify: between
                type: stack
              }, {
                chartType: line
                data: @entity.chartData
                height: 280
                showLegend: false
                type: chart
              }]
              direction: vertical
              gap: md
              type: stack
            }]
            look: elevated
            padding: lg
            type: card
          }]
          direction: vertical
          gap: md
          type: stack
        })
      SummaryRecordLoadFailed -> error
        (set @entity.errorMessage ?error)
        (render-ui main {
          message: @entity.errorMessage
          title: "Failed to load dashboard"
          type: error-state
        })
    }

    state ready {
      OPEN_FILTER -> ready
    }

    state error {
      INIT -> loading
        (render-ui main {
          title: "Retrying…"
          type: loading-state
        })
    }

    emits {
      OPEN_FILTER
        @description "Requests the opening of a filter panel or modal."
        @synonyms "show filter, open filters, filter panel"
        @tier "essential"
      SummaryRecordLoaded {
        data : [object]
      }
        @description "Signals successful data retrieval and component initialization."
        @synonyms "loaded, ready, initialized, data-ready"
        @tier "essential"
      SummaryRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to retrieve the summary data."
        @synonyms "error, failed, problem, issue"
        @tier "internal"
    }

    listens {
      OPEN_FILTER
        @description "A filter selection has been made."
        @synonyms "filter, selection, criteria"
        @tier "customization"
      SummaryRecordLoaded {
        data : [object]
      }
        @description "Data has been successfully retrieved and is ready for display."
        @synonyms "loaded, received, fetched, available"
        @tier "essential"
      SummaryRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to retrieve the summary data."
        @synonyms "error, failed, problem, issue"
        @tier "internal"
    }
  }

  page "/dashboard-summary" as DashboardSummaryPage -> DashboardSummary
}