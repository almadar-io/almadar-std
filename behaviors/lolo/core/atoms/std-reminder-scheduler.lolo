app std-reminder-scheduler "1.0.0"
"std-reminder-scheduler — declarative deadline-reminder rules for a target entity. Periodic tick logs scans to ReminderRunLog. v1.0 ships the knob set + scan topology so the questionnaire surfaces dateField + offsetsHours + template; auto-emit of ReminderDue per matching record lands in v1.1 (loop-with-emit gap — docs/Almadar_Std_Factories.md). Composed alongside std-notify-on-event in organisms once the emit lands."

orbital ReminderSchedulerOrbital {
  entity ReminderRunLog [persistent: reminder_runs] {
    id                   : string!
    targetEntity         : string  = ""
    recordCount          : number  = 0
    ranAt                : number  = 0
    errors               : string  = ""
  }

  type ScanRecordsLoaded   = Event { data : [object] }                         "Internal: target entity collection fetched by the scan tick."
  type ScanFailed          = Event { error : string, code : string }           "Internal: scan fetch failed."
  type ReminderRunLogged   = Event { row : ReminderRunLog }                    "Re-emitted after a run log row persists."
  type ReminderRunFailed   = Event { error : string, code : string }           "Emitted when persisting the run log fails."

  trait ReminderScheduler -> ReminderRunLog [lifecycle, instance] {
    config {
      targetEntity         : string   = ""
        @label "Target entity"
        @description "Entity to scan for upcoming deadlines (e.g. 'ClassSession', 'CourtDeadlineRecord')."
        @tier "essential"
      dateField            : string   = ""
        @label "Deadline field"
        @description "Field on the target entity holding the deadline timestamp (e.g. 'dueAt', 'startsAt')."
        @tier "essential"
      offsetsHours         : [number] = []
        @label "Reminder offsets (hours before deadline)"
        @description "Multi-touch reminder offsets: e.g. [168, 24, 1] for 7d/1d/1h reminders. v1.0 declarative only — emit lands in v1.1 (gap)."
        @tier "essential"
      severity             : string   = "info"
        @label "Severity"
        @description "Severity passed to the notifier when emit lands: info / warning / error."
        @tier "customization"
      template             : string   = ""
        @label "Message template"
        @description "Message body passed to the notifier."
        @tier "customization"
      windowToleranceMinutes : number = 60
        @label "Match tolerance (minutes)"
        @description "How close to the offset a record must be to fire a reminder. Wider = more forgiving but more dupes."
        @tier "advanced"
    }
    initial: idle
    state idle {
      ScanRecordsLoaded -> idle
        (set @entity.targetEntity @config.targetEntity)
        (set @entity.recordCount (array/len @payload.data))
        (set @entity.ranAt 0)
        (persist create ReminderRunLog @entity { emit: { success: "ReminderRunLogged", failure: "ReminderRunFailed" } })
      ScanFailed -> idle
        (set @entity.targetEntity @config.targetEntity)
        (set @entity.recordCount 0)
        (set @entity.errors @payload.error)
        (persist create ReminderRunLog @entity { emit: { success: "ReminderRunLogged", failure: "ReminderRunFailed" } })
      ReminderRunLogged -> idle
      ReminderRunFailed -> idle
    }
    ticks {
      scanCycle every 15 m
        (fetch ReminderRunLog { emit: { success: "ScanRecordsLoaded", failure: "ScanFailed" } })
    }
    emits {
      ScanRecordsLoaded   { data : [object] }
      ScanFailed          { error : string, code : string }
      ReminderRunLogged   { row : ReminderRunLog }
      ReminderRunFailed   { error : string, code : string }
    }
    listens {
      ScanRecordsLoaded   { data : [object] }
      ScanFailed          { error : string, code : string }
      ReminderRunLogged   { row : ReminderRunLog }
      ReminderRunFailed   { error : string, code : string }
    }
  }
  page "/reminders/scheduler" as ReminderSchedulerPage -> ReminderScheduler
}
