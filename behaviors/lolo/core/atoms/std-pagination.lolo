app std-pagination "1.0.0"
"std-pagination as a Function — single primitive: pagination control.
The atom's own PagedItem entity is the UI-state container — every PAGE
transition persists currentPage / pageSize. Visual reflection of
@entity.currentPage on the pagination control needs pattern-registry +
UI component support for a `currentPage` binding-prop (gap #21.G.3 +
#21.H follow-ups)."

orbital PagedItemOrbital {
  entity PagedItem [runtime] {
    id          : string!
    currentPage : number
    pageSize    : number
  }

  trait PagedItemPagination -> PagedItem [interaction, instance] {
    initial: idle
    config {
      totalPages : number = 1
      pageSize   : number = 10
      event      : string = "PAGE"
    }
    state idle {
      INIT -> idle
        (render-ui main { type: "pagination", currentPage: 1, totalPages: "@config.totalPages", onPageChange: "@config.event", showPageSize: false })
      PAGE -> idle
        (set @entity.currentPage @payload.page)
        (set @entity.pageSize @payload.pageSize)
        (render-ui main { type: "pagination", currentPage: 1, totalPages: "@config.totalPages", onPageChange: "@config.event", showPageSize: false })
    }
    emits {
      PAGE { page : number!, pageSize : number! }
    }
    listens {
      PAGE { page : number!, pageSize : number! }
    }
  }
  page "/pageditems/paginated" as PagedItemPaginationPage -> PagedItemPagination
}
