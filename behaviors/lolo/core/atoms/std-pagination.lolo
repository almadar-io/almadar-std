app std-pagination "1.0.0"
"std-pagination as a Function — single primitive: pagination control.
The Pagination UI component emits `{page}` for page changes; the atom's
PAGE event payload matches that shape. ITEMS_LOADED accepts an upstream
data-loaded event payload `{data : [object]}` and derives totalPages =
ceil(len(data) / pageSize). Molecules wire e.g.
`FilteredItemBrowse.BrowseItemLoaded -> ITEMS_LOADED` to keep the
pagination control in lockstep with the data hub. The PagedItem entity
persists currentPage and the derived totalPages so reads from
@entity.totalPages reflect the latest row count."

orbital PagedItemOrbital {
  entity PagedItem [runtime] {
    id          : string!
    currentPage : number = 1
    totalPages  : number = 1
  }

  trait PagedItemPagination -> PagedItem [interaction, instance] {
    initial: idle
    config {
      pageSize : number = 10
      event    : string = "PAGE"
    }
    state idle {
      INIT -> idle
        (render-ui main { type: "pagination", currentPage: "@entity.currentPage", totalPages: "@entity.totalPages", onPageChange: "@config.event", showPageSize: false })
      PAGE -> idle
        (set @entity.currentPage @payload.page)
        (render-ui main { type: "pagination", currentPage: "@entity.currentPage", totalPages: "@entity.totalPages", onPageChange: "@config.event", showPageSize: false })
      ITEMS_LOADED -> idle
        (set @entity.totalPages (math/ceil (/ @payload.totalCount @config.pageSize)))
        (render-ui main { type: "pagination", currentPage: "@entity.currentPage", totalPages: "@entity.totalPages", onPageChange: "@config.event", showPageSize: false })
    }
    emits {
      PAGE { page : number! }
    }
    listens {
      PAGE { page : number! }
      ITEMS_LOADED { data : [object], totalCount : number }
    }
  }
  page "/pageditems/paginated" as PagedItemPaginationPage -> PagedItemPagination
}
