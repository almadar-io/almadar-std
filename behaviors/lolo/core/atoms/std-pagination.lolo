app std-pagination "1.0.0"
"std-pagination as a Function — single primitive: pagination + infinite-scroll-sentinel"

orbital PagedItemOrbital {
  entity PagedItem [runtime] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
  }

  type PagedItemLoaded     = Event { data : [PagedItem] }        "Fired when PagedItem finishes loading; payload.data holds the page"
  type PagedItemLoadFailed = Event { error : string, code : string } "Fired when PagedItem fails to load"

  trait PagedItemPagination -> PagedItem [interaction, collection] {
    initial: loading
    config {
      totalPages : number = 10
      event : string = "PAGE"
    }
    state loading {
      INIT -> loading
        (fetch PagedItem { emit: { success: "PagedItemLoaded", failure: "PagedItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
      PagedItemLoaded -> idle
        (render-ui main { type: "pagination", currentPage: 1, totalPages: "@config.totalPages", onPageChange: "@config.event", showPageSize: false })
      PagedItemLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "pagination", currentPage: 1, totalPages: "@config.totalPages", onPageChange: "@config.event", showPageSize: false }, { type: "typography", variant: "caption", color: "error", content: "@payload.error" }] })
    }
    state idle {
      PAGE -> loading
        (emit PAGE { page: @payload.page, pageSize: @payload.pageSize })
        (fetch PagedItem { emit: { success: "PagedItemLoaded", failure: "PagedItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "pagination", currentPage: 1, totalPages: "@config.totalPages", onPageChange: "@config.event", showPageSize: false }, { type: "spinner", size: "sm" }] })
    }
    state error {
      INIT -> loading
        (fetch PagedItem { emit: { success: "PagedItemLoaded", failure: "PagedItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
emits {
      PAGE { page : number!, pageSize : number! }
      PagedItemLoaded
      PagedItemLoadFailed
    }

        listens {
      PAGE { page : number!, pageSize : number! }
      PagedItemLoadFailed { error : string, code : string }
    }
  }
  page "/pageditems/paginated" as PagedItemPaginationPage -> PagedItemPagination
}
