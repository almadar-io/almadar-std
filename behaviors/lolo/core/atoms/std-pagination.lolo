app std-pagination "1.0.0"
"std-pagination — single primitive: pagination control. PAGE accepts the Pagination component's `{page}` emit; ITEMS_LOADED accepts an upstream `{data:[object]}` payload and derives totalPages = ceil(len/pageSize). Molecules wire `BrowseItemLoaded -> ITEMS_LOADED` to keep it in lockstep with the data hub."

orbital PagedItemOrbital {
  entity PagedItem [runtime] {
    id          : string!
    currentPage : number = 1
    totalPages  : number = 1
  }

  type PagedItemLoaded = Event { data : [PagedItem] } "Fired after the PagedItem entity is fetched on INIT; carries the seeded instance(s) so client-side @entity.currentPage / .totalPages bindings resolve before any user interaction."

  trait PagedItemPagination -> PagedItem [interaction, instance] {
    initial: idle
    config {
      pageSize : number = 10
      event    : string = "PAGE"
    }
    state idle {
      INIT -> idle
        (set @entity.currentPage 1)
        (set @entity.totalPages 1)
        (fetch PagedItem { emit: { success: "PagedItemLoaded" } })
        (render-ui main { type: "pagination", currentPage: "@entity.currentPage", totalPages: "@entity.totalPages", pageChangeEvent: "@config.event", showPageSize: false })
      PagedItemLoaded -> idle
        (render-ui main { type: "pagination", currentPage: "@entity.currentPage", totalPages: "@entity.totalPages", pageChangeEvent: "@config.event", showPageSize: false })
      PAGE -> idle
        (set @entity.currentPage @payload.page)
        (render-ui main { type: "pagination", currentPage: "@entity.currentPage", totalPages: "@entity.totalPages", pageChangeEvent: "@config.event", showPageSize: false })
      ITEMS_LOADED -> idle
        (set @entity.totalPages (math/ceil (/ @payload.totalCount @config.pageSize)))
        (render-ui main { type: "pagination", currentPage: "@entity.currentPage", totalPages: "@entity.totalPages", pageChangeEvent: "@config.event", showPageSize: false })
    }
    emits {
      PAGE          { page : number! }
      PagedItemLoaded { data : [PagedItem] }
    }
    listens {
      PAGE { page : number! }
      ITEMS_LOADED { data : [object], totalCount : number }
      PagedItemLoaded { data : [PagedItem] }
    }
  }
  page "/pageditems/paginated" as PagedItemPaginationPage -> PagedItemPagination
}
