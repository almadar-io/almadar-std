app std-board "1.1.0"
"std-board — generic N-column board primitive. `config.columns` is an array of column definitions ({ key, label, icon, variant }); the trait `array/map`s them on `BoardItemsLoaded` into `@entity.boards` where each board carries its filtered items + a count. The render is a `data-grid` over `@entity.boards` (one card per column) whose `renderItem` lambda nests a `data-list` over `@col.items` (the cards in that stage). N is config-driven — pass any number of columns; the outer `data-grid`'s `cols` is bound to `@config.gridCols` so the grid wraps if you exceed it. Topology = loading / viewing_board / viewing_card / adding / error — distinct from the cookie-cutter `loading/browsing/viewing_single/error` CRUD shape. App-level atoms (e.g. std-pipeline) compose std-board via `uses` and add a sibling persistor + extended source entity."

type ObjectSpec = { id : string, label : string, value : string }
type ColumnSpec = { key : string!, label : string!, icon : string, variant : string }

orbital BoardOrbital {
  type BoardItem = {
    id          : string!
    title       : string
    description : string
    stage       : string
    notes       : string
    position    : number
  }

  type BoardColumn = {
    key     : string!
    label   : string!
    icon    : string
    variant : "default" | "primary" | "success" | "warning" | "error" | "info"
    count   : number
    items   : [BoardItem]
  }

  entity BoardView [persistent: board_items] {
    id                  : string!
    title               : string!
    description         : string = ""
    stage               : "todo" | "doing" | "done" = "todo"
    notes               : string = ""
    position            : number = 0
    boards              : [BoardColumn] = []
    currentId           : string = ""
    currentTitle        : string = ""
    currentDescription  : string = ""
    currentStage        : string = ""
    currentNotes        : string = ""
    errorMessage        : string = ""
  }

  type BoardItemsLoaded     = Event { data : [ObjectSpec] }                "Fired when board items finish loading (from an upstream fetcher / persistor)"
  type BoardItemsLoadFailed = Event { error : string, code : string }  "Fired when the upstream fetch fails"
  type BoardItemsSaved      = Event { row : object }                   "Fired when a board item has been persisted"
  type BoardItemsSaveFailed = Event { error : string, code : string }  "Fired when a persist intent fails"

  trait BoardItemBoard -> @rebindable BoardView [interaction, instance] {
    config {
      title    : string   = "Board"
        @label "Board title"
        @description "Heading shown above the column board"
        @tier "presentation"
      columns  : [ColumnSpec] = [
        { key: "todo",  label: "To Do",       icon: "circle",       variant: "default" },
        { key: "doing", label: "In Progress", icon: "circle-dot",   variant: "primary" },
        { key: "done",  label: "Done",        icon: "check-circle", variant: "success" }
      ]
        @label "Columns"
        @description "Board columns; each row's stage maps to a column key"
        @tier "domain"
      gridCols : number   = 3
        @label "Grid columns"
        @description "Outer grid column count before the board wraps"
        @tier "presentation"
      formFields : [string] = ["title", "description", "stage", "notes"]
        @label "New-card fields"
        @description "Fields shown in the add-card form"
        @tier "presentation"
      cardLook : "elevated" | "flat-bordered" | "borderless-divider" | "ticket" | "invoice" | "chip" | "tile-image-first" = "elevated"
        @label "Card look"
        @description "Layer 2 visual treatment for cards rendered by this board."
        @tier "presentation"
      cardTitleBinding : string = "@item.title"
        @label "Card title binding"
        @description "Per-card binding for the title slot."
        @tier "presentation"
      cardDescriptionBinding : string = "@item.description"
        @label "Card description binding"
        @description "Per-card binding for the description slot."
        @tier "presentation"
      cardStageBinding : string = "@item.stage"
        @label "Card stage binding"
        @description "Per-card binding for the stage/status slot."
        @tier "presentation"
      cardIdBinding : string = "@item.id"
        @label "Card id binding"
        @description "Per-card binding for the id used in action payloads."
        @tier "presentation"
      groupByField : string = "stage"
        @label "Group-by field"
        @description "Entity field whose value matches a column key — items are filtered into columns by it. Default 'stage'; set to 'status' (or any field) for entities that track state under a different name."
        @tier "presentation"
      bodyContent : render-ui = { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "kanban-square" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-grid", entity: "@entity.boards", cols: "@config.gridCols", gap: "md", fields: [], dndRoot: true, renderItem: ["fn", "col", { type: "card", look: "@config.cardLook", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [{ type: "icon", name: "@col.icon" }, { type: "typography", content: "@col.label", variant: "h4" }, { type: "badge", label: "@col.count", variant: "@col.variant" }] }, { type: "data-list", entity: "@col.items", gap: "sm", fields: [], dragGroup: "@col.key", accepts: "*", sortable: true, dropEvent: "MOVE_CARD", reorderEvent: "REORDER_CARD", positionEvent: "REORDER_POSITION", renderItem: ["fn", "item", { type: "card", look: "@config.cardLook", children: [{ type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", content: "@config.cardTitleBinding", variant: "h4" }, { type: "typography", content: "@config.cardDescriptionBinding", variant: "caption", color: "muted" }, { type: "stack", direction: "horizontal", gap: "xs", align: "center", children: [{ type: "button", label: "Open", variant: "ghost", action: "OPEN_CARD", actionPayload: { id: "@config.cardIdBinding", row: "@item" }, icon: "arrow-right" }] }] }] }] }] }] }] }, { type: "floating-action-button", label: "Add item", action: "ADD_CARD", icon: "plus", variant: "primary" }] }
        @label "Body content tree"
        @description "Render-ui SExpr rendered after the board loads. Default is the canonical column data-grid with nested per-column data-lists. Layer 3 variants override this with their own tree (swim-lanes, timeline-roadmap, etc.) while inheriting the same trait, state machine, emits, and listens."
        @tier "internal"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch BoardView { emit: { success: "BoardItemsLoaded", failure: "BoardItemsLoadFailed" } })
        (render-ui main { type: "loading-state", title: "Loading board…" })
      BoardItemsLoaded -> viewing_board
        (set @entity.boards (array/map @config.columns ["fn", "col", {
          key:     (object/get @col "key"),
          label:   (object/get @col "label"),
          icon:    (object/get @col "icon" "circle"),
          variant: (object/get @col "variant" "default"),
          count:   (array/len (array/filter @payload.data ["fn", "item", (= (object/get @item @config.groupByField) (object/get @col "key"))])),
          items:   (array/sort (array/filter @payload.data ["fn", "item", (= (object/get @item @config.groupByField) (object/get @col "key"))]) "position")
        }]))
        (render-ui main @config.bodyContent)
      BoardItemsLoadFailed -> error
        (set @entity.errorMessage @payload.error)
        (render-ui main { type: "error-state", title: "Failed to load board", message: "@entity.errorMessage" })
      BoardItemsSaveFailed -> error
        (set @entity.errorMessage @payload.error)
        (render-ui main { type: "error-state", title: "Save failed", message: "@entity.errorMessage" })
    }
    state viewing_board {
      OPEN_CARD -> viewing_card
        (set @entity.currentId @payload.row.id)
        (set @entity.currentTitle @payload.row.title)
        (set @entity.currentDescription @payload.row.description)
        (set @entity.currentStage @payload.row.stage)
        (set @entity.currentNotes @payload.row.notes)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_CARD", icon: "arrow-left" }, { type: "icon", name: "credit-card" }, { type: "typography", content: "@entity.currentTitle", variant: "h3" }, { type: "badge", label: "@entity.currentStage", variant: "primary" }] }, { type: "divider" }, { type: "card", look: "@config.cardLook", children: [{ type: "stack", direction: "vertical", gap: "sm", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.currentDescription" }, { type: "divider" }, { type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.currentNotes" }] }] }, { type: "divider" }, { type: "typography", variant: "caption", color: "muted", content: "Move to stage:" }, { type: "data-list", entity: "@entity.boards", gap: "sm", variant: "default", fields: [], renderItem: ["fn", "col", { type: "button", label: "@col.label", variant: "secondary", action: "MOVE_CARD", actionPayload: { id: "@entity.currentId", targetGroup: "@col.key" }, icon: "@col.icon" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Delete", variant: "danger", action: "DELETE_CARD", actionPayload: { id: "@entity.currentId" }, icon: "trash-2" }] }] })
      ADD_CARD -> adding
        (set @entity.currentId "")
        (set @entity.currentTitle "")
        (set @entity.currentDescription "")
        (set @entity.currentStage "")
        (set @entity.currentNotes "")
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Cancel", variant: "ghost", action: "CANCEL_ADD", icon: "x" }, { type: "icon", name: "plus" }, { type: "typography", content: "New board item", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: "@entity", mode: "create", submitEvent: "SAVE_CARD", cancelEvent: "CANCEL_ADD", fields: "@config.formFields" }] })
      MOVE_CARD -> viewing_board
        (persist update BoardView { id: @payload.id, stage: @payload.targetGroup } { emit: { success: "BoardItemsSaved", failure: "BoardItemsSaveFailed" } })
      REORDER_CARD -> viewing_board
      REORDER_POSITION -> viewing_board
        (persist update BoardView { id: @payload.id, position: @payload.position } { emit: { success: "BoardItemsSaved", failure: "BoardItemsSaveFailed" } })
      BoardItemsSaved -> viewing_board
        (fetch BoardView { emit: { success: "BoardItemsLoaded", failure: "BoardItemsLoadFailed" } })
      BoardItemsLoaded -> viewing_board
        (set @entity.boards (array/map @config.columns ["fn", "col", {
          key:     (object/get @col "key"),
          label:   (object/get @col "label"),
          icon:    (object/get @col "icon" "circle"),
          variant: (object/get @col "variant" "default"),
          count:   (array/len (array/filter @payload.data ["fn", "item", (= (object/get @item @config.groupByField) (object/get @col "key"))])),
          items:   (array/sort (array/filter @payload.data ["fn", "item", (= (object/get @item @config.groupByField) (object/get @col "key"))]) "position")
        }]))
    }
    state viewing_card {
      CLOSE_CARD -> loading
        (fetch BoardView { emit: { success: "BoardItemsLoaded", failure: "BoardItemsLoadFailed" } })
        (render-ui main { type: "loading-state", title: "Refreshing board…" })
      MOVE_CARD -> loading
        (persist update BoardView { id: @payload.id, stage: @payload.targetGroup } { emit: { success: "BoardItemsSaved", failure: "BoardItemsSaveFailed" } })
        (render-ui main { type: "loading-state", title: "Moving item…" })
      DELETE_CARD -> loading
        (persist delete BoardView @payload.id { emit: { success: "BoardItemsSaved", failure: "BoardItemsSaveFailed" } })
        (render-ui main { type: "loading-state", title: "Deleting item…" })
    }
    state adding {
      SAVE_CARD -> loading
        (persist create BoardView @payload.data { emit: { success: "BoardItemsSaved", failure: "BoardItemsSaveFailed" } })
        (render-ui main { type: "loading-state", title: "Saving…" })
      CANCEL_ADD -> viewing_board
        (render-ui main { type: "loading-state", title: "Cancelling…" })
    }
    state error {
      INIT -> loading
        (render-ui main { type: "loading-state", title: "Retrying…" })
    }
    emits {
      OPEN_CARD              { id : string!, row : object! }
      CLOSE_CARD             { }
      ADD_CARD               { }
      CANCEL_ADD             { }
      SAVE_CARD              { data : object! }
      MOVE_CARD              { id : string!, sourceGroup : string, targetGroup : string!, newIndex : number }
      REORDER_CARD           { id : string!, oldIndex : number, newIndex : number }
      DELETE_CARD            { id : string! }
      BoardItemsLoaded       { data : [ObjectSpec] }
      BoardItemsLoadFailed   { error : string, code : string }
      BoardItemsSaved        { row : object }
      BoardItemsSaveFailed   { error : string, code : string }
    }
    listens {
      OPEN_CARD              { id : string!, row : object! }
      CLOSE_CARD             { }
      ADD_CARD               { }
      CANCEL_ADD             { }
      SAVE_CARD              { data : object! }
      MOVE_CARD              { id : string!, sourceGroup : string, targetGroup : string!, newIndex : number }
      REORDER_CARD           { id : string!, oldIndex : number, newIndex : number }
      REORDER_POSITION       { id : string!, position : number! }
      DELETE_CARD            { id : string! }
      BoardItemsLoaded       { data : [ObjectSpec] }
      BoardItemsLoadFailed   { error : string, code : string }
      BoardItemsSaved        { row : object }
      BoardItemsSaveFailed   { error : string, code : string }
    }
  }
  page "/board" as BoardPage -> BoardItemBoard
}
