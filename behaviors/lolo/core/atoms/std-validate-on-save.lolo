app std-validate-on-save "1.0.0"
"std-validate-on-save as a Function"

orbital ValidateOnSave {
  entity ValidateOnSave [runtime] {
    id : string!
    path : string
    valid : boolean = false
    errors : [string] = []
    warnings : [string] = []
    timestamp : number = 0
    status : string = "idle"
  }
  type ValidateOnSaveLoaded = Event { data : [ValidateOnSave] }
  type ValidateOnSaveLoadFailed = Event { error : string, code : string }
  type ValidateOnSaveOrbitalCliCompleted = Event { result : object }
  type ValidateOnSaveOrbitalCliFailed = Event { error : string, code : string }
  trait OrbFileWatcher -> ValidateOnSave [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ValidateOnSave { emit: { success: "ValidateOnSaveLoaded", failure: "ValidateOnSaveLoadFailed" } })
        (os/watch-files "**/*.orb")
        (os/debounce 500 OS_FILE_MODIFIED)
        (set @entity.status idle)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Watching **/*.orb for changes" })
        (render-ui center { type: "empty-state", title: "Waiting for file changes", description: "Watching **/*.orb. Save an .orb file to trigger validation." })
      OS_FILE_MODIFIED -> validating
        (set @entity.path @payload.path)
        (set @entity.timestamp @now)
        (set @entity.status validating)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Validating..." })
        (render-ui center { type: "loading-state", title: "Running orbital validate..." })
        (call-service orbital-cli validate { path: "@payload.path", onSuccess: "VALIDATION_PASSED", onError: "VALIDATION_FAILED" } { emit: { success: "ValidateOnSaveOrbitalCliCompleted", failure: "ValidateOnSaveOrbitalCliFailed" } })
    }
    state validating {
      VALIDATION_PASSED -> valid
        (set @entity.valid true)
        (set @entity.errors [])
        (set @entity.warnings @payload.warnings)
        (set @entity.status valid)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Validation passed", actions: [{ event: "REFRESH", label: "Validate Now", variant: "primary" }] })
        (render-ui center { type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "caption", content: "path" }, { type: "typography", variant: "body", content: "@entity.path" }, { type: "typography", variant: "caption", content: "valid" }, { type: "typography", variant: "body", content: "@entity.valid" }, { type: "typography", variant: "caption", content: "status" }, { type: "typography", variant: "body", content: "@entity.status" }, { type: "typography", variant: "caption", content: "timestamp" }, { type: "typography", variant: "body", content: "@entity.timestamp" }] })
        (notify success "Schema is valid")
      VALIDATION_FAILED -> invalid
        (set @entity.valid false)
        (set @entity.errors @payload.errors)
        (set @entity.warnings @payload.warnings)
        (set @entity.status invalid)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Validation failed", actions: [{ event: "REFRESH", label: "Validate Now", variant: "primary" }] })
        (render-ui center { type: "stack", direction: "vertical", gap: "md", children: [{ type: "typography", variant: "caption", content: "path" }, { type: "typography", variant: "body", content: "@entity.path" }, { type: "typography", variant: "caption", content: "status" }, { type: "typography", variant: "body", content: "@entity.status" }, { type: "typography", variant: "caption", content: "errors" }, { type: "typography", variant: "body", content: "@entity.errors" }, { type: "typography", variant: "caption", content: "warnings" }, { type: "typography", variant: "body", content: "@entity.warnings" }] })
        (notify error "Schema has errors")
    }
    state valid {
      OS_FILE_MODIFIED -> validating
        (set @entity.path @payload.path)
        (set @entity.timestamp @now)
        (set @entity.status validating)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Re-validating..." })
        (render-ui center { type: "loading-state", title: "Running orbital validate..." })
        (call-service orbital-cli validate { path: "@payload.path", onSuccess: "VALIDATION_PASSED", onError: "VALIDATION_FAILED" } { emit: { success: "ValidateOnSaveOrbitalCliCompleted", failure: "ValidateOnSaveOrbitalCliFailed" } })
      REFRESH -> validating
        (set @entity.status validating)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Re-validating..." })
        (render-ui center { type: "loading-state", title: "Running orbital validate..." })
        (call-service orbital-cli validate { path: "@entity.path", onSuccess: "VALIDATION_PASSED", onError: "VALIDATION_FAILED" } { emit: { success: "ValidateOnSaveOrbitalCliCompleted", failure: "ValidateOnSaveOrbitalCliFailed" } })
    }
    state invalid {
      OS_FILE_MODIFIED -> validating
        (set @entity.path @payload.path)
        (set @entity.timestamp @now)
        (set @entity.status validating)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Re-validating..." })
        (render-ui center { type: "loading-state", title: "Running orbital validate..." })
        (call-service orbital-cli validate { path: "@payload.path", onSuccess: "VALIDATION_PASSED", onError: "VALIDATION_FAILED" } { emit: { success: "ValidateOnSaveOrbitalCliCompleted", failure: "ValidateOnSaveOrbitalCliFailed" } })
      REFRESH -> validating
        (set @entity.status validating)
        (render-ui main { type: "page-header", title: "Orb File Validator", subtitle: "Re-validating..." })
        (render-ui center { type: "loading-state", title: "Running orbital validate..." })
        (call-service orbital-cli validate { path: "@entity.path", onSuccess: "VALIDATION_PASSED", onError: "VALIDATION_FAILED" } { emit: { success: "ValidateOnSaveOrbitalCliCompleted", failure: "ValidateOnSaveOrbitalCliFailed" } })
    }

    emits: [ValidateOnSaveLoadFailed, ValidateOnSaveLoaded, ValidateOnSaveOrbitalCliCompleted, ValidateOnSaveOrbitalCliFailed]
    listens {
      VALIDATION_PASSED { warnings : array }
      VALIDATION_FAILED { errors : array, warnings : array }
      OS_FILE_MODIFIED { path : string }
    
      ValidateOnSaveLoadFailed { error : string, code : string }
    
      ValidateOnSaveOrbitalCliFailed { error : string, code : string }
    }
  }
  page "/validator" as ValidatorPage -> OrbFileWatcher
}