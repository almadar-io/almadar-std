app std-billable-hour "1.0.0"
"std-billable-hour — generic billable-hour timesheet primitive for legal, agency, and consulting domains. Lists entries in `browsing`; opens entry detail in `viewing_single` with Invoice / Write Off actions."

orbital BillableHourOrbital {
  entity BillableHour [persistent: billablehours] {
    id            : string!
    workerId      : string! @description "Unique identifier for the worker." @synonyms "employeeId, staffId, userId"
    workerName    : string @description "The name of the worker associated with the time entry." @synonyms "employee, staff, personnel" = ""
    matterId      : string @description "Unique identifier for the associated case or project." @synonyms "caseId, projectID, reference" = ""
    projectId     : string @description "Identifier for the project associated with the time entry." @synonyms "project, task, reference" = ""
    workDate      : string! @description "The date on which the work was performed." @synonyms "date, transaction date, service date"
    hours         : number @description "The quantity of time recorded." @synonyms "duration, time, amount" = 0
    rate          : number @description "The hourly charge for the work performed." @synonyms "price, cost, amount" = 0
    description   : string @description "A textual explanation of the hour entry." @synonyms "explanation, notes, details, comment" = ""
    isBillable    : boolean @description "Indicates whether the hour is eligible for billing." @synonyms "billable flag, billing status, billable indicator" = true
    invoiceStatus : "unbilled" | "invoiced" | "paid" | "written_off" @description "The current billing status of the hour entry." @synonyms "status, billing status, payment status" = "unbilled"
  }

  type BillableHourLoaded     = Event { data : [BillableHour] }           "Fired when the billable-hour collection finishes loading"
  type BillableHourLoadFailed = Event { error : string, code : string }   "Fired when the billable-hour collection fails to load"

  trait BillableHourTimesheet -> BillableHour [interaction, collection] {
    config {
      title : string = "Time Entries"
        @label "Section title"
        @description "Heading shown above the time-entries list"
        @tier "presentation"
      tableLook : "dense" | "spacious" | "striped" | "borderless" | "card-rows" = "dense"
        @label "Table look"
        @description "Layer 2 visual treatment for the data table rendered by this atom."
        @tier "presentation"
      statLook : "elevated" | "flat" | "progress-backed" | "gauge" | "sparkline" = "elevated"
        @label "Stat display look"
        @description "Layer 2 visual treatment for stat / KPI cards."
        @tier "presentation"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch BillableHour { emit: { success: "BillableHourLoaded", failure: "BillableHourLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading time entries…" }] })
      BillableHourLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "clock" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "simple-grid", cols: 4, children: [{ type: "stat-display", look: "@config.statLook", label: "Total entries", value: "@payload.data.length", icon: "clock" }, { type: "stat-display", look: "@config.statLook", label: "Unbilled hours", value: "248", icon: "hourglass" }, { type: "stat-display", look: "@config.statLook", label: "Invoiced this month", value: "32", icon: "file-text" }, { type: "stat-display", look: "@config.statLook", label: "Written off", value: "4", icon: "x-circle" }] }, { type: "divider" }, { type: "data-grid", look: "@config.tableLook", entity: "@payload.data", fields: [{ name: "workerName", label: "Worker", variant: "caption" }, { name: "matterId", label: "Matter", variant: "caption" }, { name: "workDate", label: "Date", variant: "caption" }, { name: "hours", label: "Hours", variant: "caption" }, { name: "rate", label: "Rate", variant: "caption" }, { name: "invoiceStatus", label: "Status", variant: "badge" }], cols: 1, gap: "sm", itemActions: [{ label: "Open", event: "OPEN_HOURS", variant: "primary", icon: "arrow-right" }, { label: "Write Off", event: "WRITE_OFF_HOURS", variant: "danger" }] }] })
      BillableHourLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      OPEN_HOURS -> viewing_single
        (set @entity.id @payload.row.id)
        (set @entity.workerId @payload.row.workerId)
        (set @entity.workerName @payload.row.workerName)
        (set @entity.matterId @payload.row.matterId)
        (set @entity.projectId @payload.row.projectId)
        (set @entity.workDate @payload.row.workDate)
        (set @entity.hours @payload.row.hours)
        (set @entity.rate @payload.row.rate)
        (set @entity.description @payload.row.description)
        (set @entity.isBillable @payload.row.isBillable)
        (set @entity.invoiceStatus @payload.row.invoiceStatus)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "CLOSE_VIEW" }, { type: "icon", name: "clock" }, { type: "typography", content: "@entity.workerName", variant: "h3" }, { type: "badge", label: "@entity.invoiceStatus", variant: "default" }] }, { type: "divider" }, { type: "stack", direction: "vertical", gap: "sm", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Matter" }, { type: "typography", variant: "body", content: "@entity.matterId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Project" }, { type: "typography", variant: "body", content: "@entity.projectId" }] }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }] }, { type: "divider" }, { type: "simple-grid", cols: 3, children: [{ type: "stat-display", look: "@config.statLook", label: "Hours", value: "@entity.hours", icon: "clock" }, { type: "stat-display", look: "@config.statLook", label: "Rate", value: "@entity.rate", icon: "dollar-sign" }, { type: "stat-display", look: "@config.statLook", label: "Date", value: "@entity.workDate", icon: "calendar" }] }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Invoice", variant: "primary", action: "INVOICE_HOURS", actionPayload: { id: "@entity.id" } }, { type: "button", label: "Write Off", variant: "danger", action: "WRITE_OFF_HOURS", actionPayload: { id: "@entity.id" } }] }] })
      WRITE_OFF_HOURS -> loading
        (set @entity.id @payload.id)
        (fetch BillableHour { emit: { success: "BillableHourLoaded", failure: "BillableHourLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Writing off hours…" }] })
    }
    state viewing_single {
      CLOSE_VIEW -> loading
        (fetch BillableHour { emit: { success: "BillableHourLoaded", failure: "BillableHourLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading time entries…" }] })
      INVOICE_HOURS -> loading
        (set @entity.id @payload.id)
        (fetch BillableHour { emit: { success: "BillableHourLoaded", failure: "BillableHourLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Invoicing hours…" }] })
      WRITE_OFF_HOURS -> loading
        (set @entity.id @payload.id)
        (fetch BillableHour { emit: { success: "BillableHourLoaded", failure: "BillableHourLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Writing off hours…" }] })
    }
    state error {
      INIT -> loading
        (fetch BillableHour { emit: { success: "BillableHourLoaded", failure: "BillableHourLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      OPEN_HOURS      { id : string!, row : BillableHour }
        @description "Signals the display of the hours list."
        @synonyms "show, display, list"
        @tier "essential"
      CLOSE_VIEW      { }
        @description "Indicates the detail view has been dismissed."
        @synonyms "dismiss, close, hide"
        @tier "essential"
      INVOICE_HOURS   { id : string! }
        @description "Signals that billable hours have been invoiced."
        @synonyms "invoice, charge, bill"
        @tier "customization"
      WRITE_OFF_HOURS { id : string! }
        @description "Indicates billable hours have been written off."
        @synonyms "deduct, remove, cancel"
        @tier "customization"
      BillableHourLoaded     { data : [BillableHour] }
        @description "Signals that a billable hour data set has been successfully retrieved."
        @synonyms "loaded, fetched, retrieved, populated"
        @tier "essential"
      BillableHourLoadFailed { error : string, code : string }
        @description "Indicates a failure to load billable hour data."
        @synonyms "error, failed, problem, unsuccessful"
        @tier "internal"
    }
    listens {
      OPEN_HOURS      { id : string!, row : BillableHour }
        @description "Indicates a request to display the hours list."
        @synonyms "show, display, list"
        @tier "essential"
      CLOSE_VIEW      { }
        @description "Dismisses the current view or detail panel."
        @synonyms "close, dismiss, hide, cancel"
        @tier "essential"
      INVOICE_HOURS   { id : string! }
        @description "Hours are marked as ready for invoicing."
        @synonyms "invoice, bill, submit"
        @tier "essential"
      WRITE_OFF_HOURS { id : string! }
        @description "Hours have been marked as non-billable."
        @synonyms "deduct, remove, expense, adjust"
        @tier "customization"
      BillableHourLoaded     { data : [BillableHour] }
        @description "Indicates that billable hour data has been successfully retrieved."
        @synonyms "loaded, fetched, received, populated"
        @tier "essential"
      BillableHourLoadFailed { error : string, code : string }
        @description "Indicates failure to load billable hour data."
        @synonyms "error, failed, problem, unsuccessful"
        @tier "internal"
    }
  }
  page "/timesheet" as BillableHourPage -> BillableHourTimesheet
}
