app std-wizard "2.0.0"
"std-wizard — generic N-step branching wizard. `config.steps` is an array of step definitions (each with its own `fields` list); @entity.currentStepIndex walks through them; ADVANCE/RETREAT self-loop, COMPLETE/CANCEL terminate. Topology = loading / running / completed / cancelled / error — running state owns N via data, not states."

orbital WizardOrbital {
  type StepView = {
    key         : string!
    label       : string!
    description : string
    icon        : string
    number      : number
    status      : "pending" | "current" | "completed"
  }

  entity WizardView [runtime] {
    id                  : string!
    steps               : [StepView] = []
    currentStepIndex    : number = 0
    totalSteps          : number = 0
    completionMessage   : string = ""
    cancelReason        : string = ""
    errorMessage        : string = ""
  }

  type WizardLoaded     = Event { data : [object] }                "Fired when wizard context finishes loading"
  type WizardLoadFailed = Event { error : string, code : string }  "Fired when fetch fails"
  type WizardSaved      = Event { row : object }                   "Fired when a wizard step has been persisted"
  type WizardSaveFailed = Event { error : string, code : string }  "Fired when persist fails"

  trait WizardForm -> WizardView [interaction, instance] {
    config {
      title    : string   = "Wizard"
      steps    : [object] = [
        { key: "details", label: "Details", description: "Basic information",      icon: "file-text",    fields: ["title", "description"] },
        { key: "options", label: "Options", description: "Configure preferences",  icon: "settings",     fields: ["category", "priority"] },
        { key: "review",  label: "Review",  description: "Confirm and submit",     icon: "check-circle", fields: ["notes"] }
      ]
      currentFields : [string] = ["title", "description"]
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch WizardView { emit: { success: "WizardLoaded", failure: "WizardLoadFailed" } })
        (render-ui main { type: "loading-state", title: "Loading wizard…" })
      WizardLoaded -> running
        (set @entity.currentStepIndex 0)
        (set @entity.totalSteps (array/len @config.steps))
        (set @entity.steps (array/map @config.steps ["fn", "step", {
          key:         (object/get @step "key"),
          label:       (object/get @step "label"),
          description: (object/get @step "description" ""),
          icon:        (object/get @step "icon" "circle"),
          number:      1,
          status:      "current"
        }]))
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-checks" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-list", entity: "@entity.steps", gap: "sm", fields: [], renderItem: ["fn", "step", { type: "card", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "@step.icon" }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", content: "@step.label", variant: "h4" }, { type: "typography", content: "@step.description", variant: "caption", color: "muted" }] }, { type: "badge", label: "@step.status", variant: "primary" }] }] }] }, { type: "divider" }, { type: "form-section", entity: "@entity", mode: "edit", submitEvent: "ADVANCE", cancelEvent: "CANCEL", fields: "@config.currentFields" }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "RETREAT", icon: "arrow-left" }, { type: "button", label: "Skip", variant: "secondary", action: "SKIP", icon: "skip-forward" }, { type: "button", label: "Submit", variant: "success", action: "COMPLETE", icon: "check-circle" }, { type: "button", label: "Cancel", variant: "ghost", action: "CANCEL", icon: "x" }] }] })
      WizardLoadFailed -> error
        (set @entity.errorMessage @payload.error)
        (render-ui main { type: "error-state", title: "Failed to load", message: "@entity.errorMessage" })
      WizardSaved -> running
        (render-ui main { type: "loading-state", title: "Refreshing…" })
      WizardSaveFailed -> error
        (set @entity.errorMessage @payload.error)
        (render-ui main { type: "error-state", title: "Save failed", message: "@entity.errorMessage" })
    }
    state running {
      ADVANCE -> running
        (set @entity.currentStepIndex (+ @entity.currentStepIndex 1))
        (set @entity.steps (array/map @config.steps ["fn", "step", {
          key:         (object/get @step "key"),
          label:       (object/get @step "label"),
          description: (object/get @step "description" ""),
          icon:        (object/get @step "icon" "circle"),
          number:      1,
          status:      "current"
        }]))
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list-checks" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "data-list", entity: "@entity.steps", gap: "sm", fields: [], renderItem: ["fn", "step", { type: "card", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "@step.icon" }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", content: "@step.label", variant: "h4" }, { type: "typography", content: "@step.description", variant: "caption", color: "muted" }] }, { type: "badge", label: "@step.status", variant: "primary" }] }] }] }, { type: "divider" }, { type: "form-section", entity: "@entity", mode: "edit", submitEvent: "ADVANCE", cancelEvent: "CANCEL", fields: "@config.currentFields" }, { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "button", label: "Back", variant: "ghost", action: "RETREAT", icon: "arrow-left" }, { type: "button", label: "Skip", variant: "secondary", action: "SKIP", icon: "skip-forward" }, { type: "button", label: "Submit", variant: "success", action: "COMPLETE", icon: "check-circle" }, { type: "button", label: "Cancel", variant: "ghost", action: "CANCEL", icon: "x" }] }] })
      RETREAT -> running
        (set @entity.currentStepIndex (- @entity.currentStepIndex 1))
        (render-ui main { type: "loading-state", title: "Going back…" })
      SKIP -> running
        (set @entity.currentStepIndex (+ @entity.currentStepIndex 1))
        (render-ui main { type: "loading-state", title: "Skipping…" })
      COMPLETE -> completed
        (set @entity.completionMessage "All steps completed")
        (set @entity.steps (array/map @config.steps ["fn", "step", {
          key:         (object/get @step "key"),
          label:       (object/get @step "label"),
          description: (object/get @step "description" ""),
          icon:        (object/get @step "icon" "circle"),
          number:      1,
          status:      "completed"
        }]))
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Complete", variant: "h3" }] }, { type: "divider" }, { type: "data-list", entity: "@entity.steps", gap: "sm", fields: [], renderItem: ["fn", "step", { type: "card", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "@step.icon" }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", content: "@step.label", variant: "h4" }, { type: "typography", content: "@step.description", variant: "caption", color: "muted" }] }, { type: "badge", label: "@step.status", variant: "success" }] }] }] }, { type: "card", children: [{ type: "typography", variant: "body", content: "@entity.completionMessage" }] }, { type: "button", label: "Restart", variant: "secondary", action: "RESTART", icon: "rotate-ccw" }] })
      CANCEL -> cancelled
        (set @entity.cancelReason @payload.reason)
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "x-circle" }, { type: "typography", content: "Cancelled", variant: "h3" }] }, { type: "divider" }, { type: "typography", variant: "body", content: "Wizard cancelled." }, { type: "button", label: "Restart", variant: "secondary", action: "RESTART", icon: "rotate-ccw" }] })
    }
    state completed {
      RESTART -> loading
        (set @entity.currentStepIndex 0)
        (render-ui main { type: "loading-state", title: "Restarting…" })
    }
    state cancelled {
      RESTART -> loading
        (set @entity.currentStepIndex 0)
        (render-ui main { type: "loading-state", title: "Restarting…" })
    }
    state error {
      INIT -> loading
        (render-ui main { type: "loading-state", title: "Retrying…" })
    }
    emits {
      ADVANCE                { data : object }
      RETREAT                { }
      SKIP                   { }
      COMPLETE               { data : object }
      CANCEL                 { reason : string }
      RESTART                { }
      WizardLoaded           { data : [object] }
      WizardLoadFailed       { error : string, code : string }
    }
    listens {
      ADVANCE                { data : object }
      RETREAT                { }
      SKIP                   { }
      COMPLETE               { data : object }
      CANCEL                 { reason : string }
      RESTART                { }
      WizardLoaded           { data : [object] }
      WizardLoadFailed       { error : string, code : string }
      WizardSaved            { row : object }
      WizardSaveFailed       { error : string, code : string }
    }
  }
  page "/wizard" as WizardPage -> WizardForm
}
