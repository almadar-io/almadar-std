app std-gallery "1.0.0"
"std-gallery — image gallery primitive. Browses GalleryItems in a media-gallery grid; opens a lightbox modal for full-size viewing."

orbital GalleryItemOrbital {
  entity GalleryItem [runtime] {
    id          : string!
    name        : string! @description "A user-friendly identifier for the item." @synonyms "title, label, identifier"
    description : string @description "A brief textual summary of the item's content." @synonyms "caption, summary, details, notes"
    status      : "active" | "inactive" | "pending" @description "Indicates the current state of the item." @synonyms "state, condition, flag" = "active"
    createdAt   : string
    imageUrl    : string @description "The URL pointing to the image resource." @synonyms "image, src, path" = "https://picsum.photos/seed/gallery/800/600"
  }

  type GalleryItemLoaded     = Event { data : [GalleryItem] }        "Fired when GalleryItem finishes loading; payload.data holds the gallery"
  type GalleryItemLoadFailed = Event { error : string, code : string } "Fired when GalleryItem fails to load"

  trait GalleryItemGallery -> @rebindable GalleryItem [interaction, collection] {
    config {
      title : string = "Gallery"
        @label "Section title"
        @description "Heading shown above the image gallery"
        @tier "presentation"
    }
    initial: loading
    state loading {
      INIT -> loading
        (fetch GalleryItem { emit: { success: "GalleryItemLoaded", failure: "GalleryItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading gallery…" }] })
      GalleryItemLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "image" }, { type: "typography", content: "@config.title", variant: "h3" }] }, { type: "divider" }, { type: "media-gallery", entity: "@payload.data" }] })
      GalleryItemLoadFailed -> error
        (render-ui main { type: "alert", variant: "error", message: "@payload.error" })
    }
    state browsing {
      VIEW -> viewing
        (set @entity.id @payload.id)
        (set @entity.name @payload.row.name)
        (set @entity.description @payload.row.description)
        (set @entity.imageUrl @payload.row.imageUrl)
        (render-ui modal { type: "lightbox", isOpen: true, closeAction: "CLOSE", images: [{ src: "@entity.imageUrl", alt: "@entity.name", caption: "@entity.name" }], currentIndex: 0, showCounter: true })
    }
    state viewing {
      CLOSE -> loading
        (render-ui modal null)
        (fetch GalleryItem { emit: { success: "GalleryItemLoaded", failure: "GalleryItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading gallery…" }] })
    }
    state error {
      INIT -> loading
        (fetch GalleryItem { emit: { success: "GalleryItemLoaded", failure: "GalleryItemLoadFailed" } })
        (render-ui main { type: "spinner", size: "sm" })
    }
    emits {
      VIEW  -> external { id : string!, row : GalleryItem }
      CLOSE { }
      GalleryItemLoaded     { data : [GalleryItem] }
      GalleryItemLoadFailed { error : string, code : string }
    }
    listens {
      VIEW  { id : string!, row : GalleryItem }
      CLOSE { }
      GalleryItemLoaded     { data : [GalleryItem] }
      GalleryItemLoadFailed { error : string, code : string }
    }
  }
  page "/galleryitems/gallery" as GalleryItemGalleryPage -> GalleryItemGallery
}
