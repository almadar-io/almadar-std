app std-app-layout "1.0.0"
"std-app-layout — dashboard-layout chrome (sidebar nav + app name) with a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data."

orbital AppLayoutOrbital {
  entity AppLayoutState [runtime] {
    id : string!
  }

  trait AppLayout [interaction, instance] {
    initial: composing
    config {
      contentTrait : trait
      appName      : string   = "App"
      navItems     : [object] = []
    }
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "@config.appName", navItems: "@config.navItems", children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: ["@config.contentTrait"] }] })
    }
  }

  page "/app-layout" as AppLayoutPage -> AppLayout
}
