app std-app-layout "1.2.0"
"std-app-layout — dashboard-layout chrome (sidebar nav + top bar with search + topBarActions + notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data, and the consumer can add domain icons (cart / profile / help) via topBarActions."

orbital AppLayoutOrbital {
  entity AppLayoutState [runtime] {
    id : string!
  }

  trait AppLayout [interaction, instance] {
    initial: composing
    config {
      contentTrait           : trait
      appName                : string   = "App"
      navItems               : [object] = []
      searchEvent            : string   = "SEARCH"
      topBarActions          : [object] = []
      notifications          : [object] = []
      notificationClickEvent : string   = "NOTIFY_CLICK"
    }
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "@config.appName", navItems: "@config.navItems", searchEvent: "@config.searchEvent", topBarActions: "@config.topBarActions", notifications: "@config.notifications", notificationClickEvent: "@config.notificationClickEvent", children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: ["@config.contentTrait"] }] })
      SEARCH -> composing
      NOTIFY_CLICK -> composing
    }
    emits {
      SEARCH        -> external { value : string }
      NOTIFY_CLICK  -> external { id : string }
    }
  }

  page "/app-layout" as AppLayoutPage -> AppLayout
}
