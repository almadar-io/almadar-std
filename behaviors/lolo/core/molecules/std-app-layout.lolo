app std-app-layout "1.1.0"
"std-app-layout — dashboard-layout chrome (sidebar nav + top bar with optional search and notifications) wrapping a single contentTrait slot. Use for list-style apps (CMS / helpdesk / CRM): the chrome stays stable while the consumer's content trait renders the data."

orbital AppLayoutOrbital {
  entity AppLayoutState [runtime] {
    id : string!
  }

  trait AppLayout [interaction, instance] {
    initial: composing
    config {
      contentTrait           : trait
      appName                : string   = "App"
      navItems               : [object] = []
      searchEvent            : string
      notifications          : [object] = []
      notificationClickEvent : string
    }
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "@config.appName", navItems: "@config.navItems", searchEvent: "@config.searchEvent", notifications: "@config.notifications", notificationClickEvent: "@config.notificationClickEvent", children: [{ type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: ["@config.contentTrait"] }] })
    }
  }

  page "/app-layout" as AppLayoutPage -> AppLayout
}
