app std-form-advanced "1.0.0"
"std-form-advanced as a Function"

orbital FormEntryOrbital {
  entity FormEntry [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    notes : string = ""
    age : number = 0
    isActive : boolean = false
    birthDate : datetime = ""
    priority : "low" | "medium" | "high" | "critical" = "medium"
    categoryId : relation = ""
  }

  type FormEntryLoaded     = Event FormEntry                  "Fired when FormEntry finishes loading"
  type FormEntryLoadFailed = Event { message : string } "Fired when FormEntry fails to load"
  type FormEntrySaved = Event { id : string }
  type FormEntrySaveFailed = Event { error : string, code : string }
  trait FormEntryFormAdvanced -> FormEntry [interaction, instance] {
    initial: editing
    state editing {
      INIT -> editing
        (fetch FormEntry { emit: { success: "FormEntryLoaded", failure: "FormEntryLoadFailed" }  })
        (fetch FormEntry { emit: { success: "FormEntryLoaded", failure: "FormEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "FormEntry Form", variant: "h2" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SUBMIT", cancelEvent: "INIT", fields: [{ name: "name", label: "Name" }, { name: "description", label: "Description" }, { name: "status", label: "Status", type: "enum", values: ["active", "inactive", "pending"] }, { name: "notes", label: "Notes", type: "textarea" }, { name: "age", label: "Age", type: "number" }, { name: "isActive", label: "Is Active", type: "boolean" }, { name: "birthDate", label: "Birth Date", type: "date" }, { name: "priority", label: "Priority", type: "enum", values: ["low", "medium", "high", "critical"] }, { name: "categoryId", label: "Category ID", type: "relation", relation: { entity: "FormEntry", cardinality: "one" } }] }] })
      SUBMIT -> submitted
        (set @entity.name @payload.data.name)
        (set @entity.description @payload.data.description)
        (set @entity.status @payload.data.status)
        (set @entity.notes @payload.data.notes)
        (set @entity.age @payload.data.age)
        (set @entity.isActive @payload.data.isActive)
        (set @entity.birthDate @payload.data.birthDate)
        (set @entity.priority @payload.data.priority)
        (set @entity.categoryId @payload.data.categoryId)
        (persist create FormEntry @payload.data { emit: { success: "FormEntrySaved", failure: "FormEntrySaveFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Form Submitted", variant: "h2" }, { type: "alert", variant: "success", message: "Your form has been submitted successfully." }, { type: "grid", cols: 2, gap: "md", children: [{ type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Description" }, { type: "typography", variant: "body", content: "@entity.description" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Status" }, { type: "typography", variant: "body", content: "@entity.status" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Notes" }, { type: "typography", variant: "body", content: "@entity.notes" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Age" }, { type: "typography", variant: "body", content: "@entity.age" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Is Active" }, { type: "typography", variant: "body", content: "@entity.isActive" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Birth Date" }, { type: "typography", variant: "body", content: "@entity.birthDate" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Priority" }, { type: "typography", variant: "body", content: "@entity.priority" }] }, { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "typography", variant: "caption", color: "muted", content: "Category ID" }, { type: "typography", variant: "body", content: "@entity.categoryId" }] }] }, { type: "button", label: "New Entry", action: "RESET", variant: "primary", icon: "plus" }] })
    }
    state submitted {
      RESET -> editing
        (fetch FormEntry { emit: { success: "FormEntryLoaded", failure: "FormEntryLoadFailed" }  })
        (fetch FormEntry { emit: { success: "FormEntryLoaded", failure: "FormEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "file-text" }, { type: "typography", content: "FormEntry Form", variant: "h2" }] }, { type: "divider" }, { type: "form-section", mode: "create", submitEvent: "SUBMIT", cancelEvent: "INIT", fields: [{ name: "name", label: "Name" }, { name: "description", label: "Description" }, { name: "status", label: "Status", type: "enum", values: ["active", "inactive", "pending"] }, { name: "notes", label: "Notes", type: "textarea" }, { name: "age", label: "Age", type: "number" }, { name: "isActive", label: "Is Active", type: "boolean" }, { name: "birthDate", label: "Birth Date", type: "date" }, { name: "priority", label: "Priority", type: "enum", values: ["low", "medium", "high", "critical"] }, { name: "categoryId", label: "Category ID", type: "relation", relation: { entity: "FormEntry", cardinality: "one" } }] }] })
    }
emits {
      FormEntryLoaded
      FormEntryLoadFailed
      FormEntrySaved
      FormEntrySaveFailed
    }

        listens {
      SUBMIT { data : object! }
          FormEntryLoadFailed { message : string }
    
      FormEntrySaveFailed { error : string, code : string }
    }
  }
  page "/formentrys/form" as FormEntryFormPage -> FormEntryFormAdvanced
}