app std-dashboard-grid-layout "2.0.0"
"std-dashboard-grid-layout — dashboard-layout chrome with three trait config slots: statsTrait, graphsTrait, feedTrait."

orbital DashboardGridLayoutOrbital {
  entity DashboardGridLayoutState [runtime] {
    id : string!
  }

  trait DashboardGridLayout [interaction, instance] {
    initial: composing
    config {
      statsTrait  : trait
      graphsTrait : trait
      feedTrait   : trait
      appName     : string   = "Dashboard"
      navItems    : [object] = [{ href: "/dashboard", label: "Dashboard", icon: "bar-chart-3" }]
    }
    state composing {
      INIT -> composing
        (render-ui main { type: "dashboard-layout", appName: "@config.appName", navItems: "@config.navItems", children: ["@config.statsTrait", "@config.graphsTrait", { type: "typography", variant: "h4", content: "Recent Activity" }, "@config.feedTrait"] })
    }
  }

  page "/dashboard" as DashboardGridLayoutPage -> DashboardGridLayout
}
