app std-list "1.0.0"
"std-list as a Function"
;;
;; Daisy-chain composition showcase: no `on EVENT { ... }` trait-ref overrides.
;; Modal + Confirmation trait refs are configured via `config: { ... }` at the
;; call site. Side effects (persist) live in a sibling coordinator trait
;; (`ListItemPersistor`) that listens for the modal/confirmation trait emits.
;;
;; Mirrors std-cart's structure. std-list omits the read-only VIEW path that the
;; old version had — form-section's mode set only supports "create" | "edit",
;; and a dedicated detail-view pattern is tracked separately (std-detail).

orbital ListItemOrbital {
  uses Confirmation from "std/behaviors/std-confirmation"
  uses Modal        from "std/behaviors/std-modal"

  entity ListItem [persistent: listitems] {
    id          : string!
    name        : string!
    description : string
    status      : "active" | "inactive" | "pending" = "active"
    createdAt   : string
    pendingId   : string = ""
  }

  type ListItemLoaded     = Event { data : [ListItem] }              "Fired when the ListItem collection finishes loading; payload.data holds the list"
  type ListItemLoadFailed = Event { error : string, code : string } "Fired when the ListItem collection fails to load"

  trait ListItemBrowse -> @rebindable ListItem [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch ListItem { emit: { success: "ListItemLoaded", failure: "ListItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner" }, { type: "typography", variant: "caption", color: "muted", content: "Loading list…" }] })
      ListItemLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "list" }, { type: "typography", content: "ListItems", variant: "h2" }] }, { type: "button", label: "Create", action: "CREATE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-grid", entity: @payload.data, itemActions: [{ label: "Edit", event: "EDIT", variant: "ghost" }, { label: "Delete", event: "DELETE", variant: "danger" }], fields: [{ name: "name", label: "Name", variant: "h4", icon: "list" }, { name: "description", label: "Description", variant: "caption" }, { name: "status", label: "Status", variant: "badge" }] }] })
      ListItemLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load list" }, { type: "typography", variant: "body", color: "muted", content: "@payload.error" }, { type: "button", label: "Retry", action: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch ListItem { emit: { success: "ListItemLoaded", failure: "ListItemLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    state error {
      INIT -> loading
        (fetch ListItem { emit: { success: "ListItemLoaded", failure: "ListItemLoadFailed" } })
        (render-ui main { type: "spinner" })
    }
    emits {
      CREATE
      EDIT { id : string!, row : ListItem }
      DELETE { id : string!, row : ListItem }
      ListItemLoaded
      ListItemLoadFailed
    }
    listens {
      ListItemLoadFailed { error : string!, code : string }
      ListItemPersistor.ITEM_CREATED -> INIT
      ListItemPersistor.ITEM_UPDATED -> INIT
      ListItemPersistor.ITEM_DELETED -> INIT
    }
  }

  ;; Create modal: configured via `config`, no effects overrides.
  ;; SAVE is renamed to LIST_ITEM_CREATED so the Persistor coordinator
  ;; distinguishes Create-SAVE from Edit-SAVE without source-scoped listens.
  trait ListItemCreate = Modal.traits.ModalRecordModal -> ListItem {
    config: {
      icon:  "plus-circle",
      title: "Create ListItem",
      fields: ["name", "description", "status"],
      mode:  "create"
    }
    events {
      OPEN: CREATE
      SAVE: LIST_ITEM_CREATED
    }
    listens {
      ListItemBrowse.CREATE -> CREATE
      CREATE { id : string, row : ListItem }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  ;; Edit modal: configured via `config`, no effects overrides.
  ;; SAVE is renamed to LIST_ITEM_UPDATED so the Persistor coordinator
  ;; distinguishes Edit-SAVE from Create-SAVE.
  trait ListItemEdit = Modal.traits.ModalRecordModal -> ListItem {
    config: {
      icon:  "edit",
      title: "Edit ListItem",
      fields: ["name", "description", "status"],
      mode:  "edit"
    }
    events {
      OPEN: EDIT
      SAVE: LIST_ITEM_UPDATED
    }
    listens {
      ListItemBrowse.EDIT -> EDIT
      EDIT { id : string, row : ListItem }
      SAVE { data : object! }
      ModalRecordLoadFailed { error : string, code : string }
    }
  }

  ;; Delete-confirm: configured via `config`, no effects overrides.
  trait ListItemDelete = Confirmation.traits.ConfirmActionConfirmation -> ListItem {
    config: {
      icon:         "alert-triangle",
      title:        "Delete ListItem",
      alertMessage: "This action cannot be undone.",
      confirmLabel: "Delete"
    }
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }
    listens {
      ListItemBrowse.DELETE -> DELETE
      DELETE { id : string, row : ListItem }
      ConfirmActionLoadFailed { error : string, code : string }
    }
  }

  ;; Coordinator trait: owns the persist side-effects triggered by the
  ;; Modal/Confirmation trait refs' emits. Replaces the old per-ref
  ;; `on SAVE { (persist ...) }` override pattern.
  trait ListItemPersistor -> ListItem [lifecycle, instance] {
    initial: idle
    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create ListItem @payload.data { emit: { success: "ITEM_CREATED" } })
      DO_UPDATE -> idle
        (persist update ListItem @payload.data { emit: { success: "ITEM_UPDATED" } })
      DO_DELETE -> idle
        (persist delete ListItem @payload.id { emit: { success: "ITEM_DELETED" } })
    }
    emits {
      ITEM_CREATED -> external { id : string! }
      ITEM_UPDATED -> external { id : string! }
      ITEM_DELETED -> external { id : string! }
    }
    listens {
      DO_CREATE { data : ListItem! }
      DO_UPDATE { data : ListItem! }
      DO_DELETE { id   : string!   }
      ListItemCreate.LIST_ITEM_CREATED -> DO_CREATE
      ListItemEdit.LIST_ITEM_UPDATED -> DO_UPDATE
      ListItemDelete.CONFIRM_DELETE    -> DO_DELETE
    }
  }

  page "/listitems" as ListItemPage -> ListItemBrowse, ListItemCreate, ListItemEdit, ListItemDelete, ListItemPersistor
}
