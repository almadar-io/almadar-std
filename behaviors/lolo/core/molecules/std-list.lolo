app std-list "1.0.0"
"std-list as a Function"
;;
;; Daisy-chain composition showcase: no `on EVENT { ... }` trait-ref overrides.
;; Modal + Confirmation trait refs are configured via `config: { ... }` at the
;; call site. Side effects (persist) live in a sibling coordinator trait
;; (`ListItemPersistor`) that listens for the modal/confirmation trait emits.
;;
;; Mirrors std-cart's structure. std-list omits the read-only VIEW path that the
;; old version had — form-section's mode set only supports "create" | "edit",
;; and a dedicated detail-view pattern is tracked separately (std-detail).
orbital ListItemOrbital {
  uses Confirmation from "std/behaviors/std-confirmation"

  uses Modal from "std/behaviors/std-modal"

    type ListItemLoaded = Event { data : [ListItem] } "Fired when the ListItem collection finishes loading; payload.data holds the list"

    type ListItemLoadFailed = Event { error : string, code : string } "Fired when the ListItem collection fails to load"

  entity ListItem [persistent: listitems] {
    id : string!
    name : string! @description "The text displayed for this list item." @synonyms "label, text, display"
    description : string @description "A brief explanation of the list item's content." @synonyms "text, details, notes, explanation"
    status : "active" | "inactive" | "pending" @description "Current operational state of the item." @synonyms "state, condition, flag" = active
    createdAt : string
    pendingId : string @description "Identifier for a related, pending item." @synonyms "reference, relatedId, linkId" = ""
  }

  trait ListItemBrowse -> @rebindable ListItem [interaction, collection] {
    initial: loading

    state loading {
      INIT -> loading
        (fetch ListItem {
          emit: { failure: ListItemLoadFailed, success: ListItemLoaded }
        })
        (render-ui main {
          align: center
          children: [{ type: spinner }, {
            color: muted
            content: "Loading list…"
            type: typography
            variant: caption
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
      ListItemLoaded -> browsing
        (render-ui main {
          children: [{
            children: [{
              children: [{ name: list, type: icon }, {
                content: ListItems
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: md
              type: stack
            }, {
              action: CREATE
              icon: plus
              label: Create
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            entity: ?data
            fields: [{
              icon: list
              label: Name
              name: name
              variant: h4
            }, {
              label: Description
              name: description
              variant: caption
            }, {
              label: Status
              name: status
              variant: badge
            }]
            itemActions: [{
              event: EDIT
              label: Edit
              variant: ghost
            }, {
              event: DELETE
              label: Delete
              variant: danger
            }]
            type: data-grid
          }]
          className: "max-w-5xl mx-auto w-full"
          direction: vertical
          gap: lg
          type: stack
        })
      ListItemLoadFailed -> error
        (render-ui main {
          align: center
          children: [{
            color: error
            name: alert-triangle
            type: icon
          }, {
            content: "Failed to load list"
            type: typography
            variant: h3
          }, {
            color: muted
            content: ?error
            type: typography
            variant: body
          }, {
            action: INIT
            icon: rotate-ccw
            label: Retry
            type: button
            variant: primary
          }]
          className: py-12
          direction: vertical
          gap: md
          type: stack
        })
    }

    state browsing {
      INIT -> loading
        (fetch ListItem {
          emit: { failure: ListItemLoadFailed, success: ListItemLoaded }
        })
        (render-ui main { type: spinner })
    }

    state error {
      INIT -> loading
        (fetch ListItem {
          emit: { failure: ListItemLoadFailed, success: ListItemLoaded }
        })
        (render-ui main { type: spinner })
    }

    emits {
      CREATE
        @description "Signals a new item has been successfully created."
        @synonyms "added, new, added, insert"
        @tier "domain"
      EDIT {
        id : string!
        row : { id : string!, name : string!, description : string, status : string, createdAt : string }
      }
      DELETE {
        id : string!
        row : { id : string!, name : string!, description : string, status : string, createdAt : string }
      }
      ListItemLoaded
        @description "Signals a list item has been successfully loaded."
        @synonyms "loaded, fetched, retrieved"
        @tier "domain"
      ListItemLoadFailed
        @description "Indicates a failure to load a list item."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }

    listens {
      ListItemLoadFailed {
        error : string!
        code : string
      }
        @description "Indicates a failure to load a list item."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
      ListItemPersistor.ITEM_CREATED -> INIT
      ListItemPersistor.ITEM_UPDATED -> INIT
      ListItemPersistor.ITEM_DELETED -> INIT
    }
  }

  ;; row carries the public display contract (no internal pendingId)
  ;; so EDIT/DELETE agree with other browse emitters app-wide.
  ;; Create modal: configured via `config`, no effects overrides.
  ;; SAVE is renamed to LIST_ITEM_CREATED so the Persistor coordinator
  ;; distinguishes Create-SAVE from Edit-SAVE without source-scoped listens.
  trait ListItemCreate = Modal.traits.ModalRecordModal -> ListItem {
    events {
      OPEN: CREATE
      SAVE: LIST_ITEM_CREATED
    }

    config {
      icon: plus-circle
      title: "Create ListItem"
      fields: (name description status)
      mode: create
    }

    listens {
      ListItemBrowse.CREATE -> CREATE
      CREATE {
        id : string
        row : ListItem
      }
        @description "Indicates a new item has been created."
        @synonyms "add, new, insert"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been successfully saved."
        @synonyms "persist, store, commit"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load a record for a modal."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }
  }

  ;; Edit modal: configured via `config`, no effects overrides.
  ;; SAVE is renamed to LIST_ITEM_UPDATED so the Persistor coordinator
  ;; distinguishes Edit-SAVE from Create-SAVE.
  trait ListItemEdit = Modal.traits.ModalRecordModal -> ListItem {
    events {
      OPEN: EDIT
      SAVE: LIST_ITEM_UPDATED
    }

    config {
      icon: edit
      title: "Edit ListItem"
      fields: (name description status)
      mode: edit
    }

    listens {
      ListItemBrowse.EDIT -> EDIT
      EDIT {
        id : string
        row : ListItem
      }
        @description "Indicates a request to modify an existing item."
        @synonyms "modify, update, change"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted successfully."
        @synonyms "persist, store, commit, update"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }
  }

  ;; Delete-confirm: configured via `config`, no effects overrides.
  trait ListItemDelete = Confirmation.traits.ConfirmActionConfirmation -> ListItem {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete ListItem"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      ListItemBrowse.DELETE -> DELETE
      DELETE {
        id : string
        row : ListItem
      }
        @description "Indicates a record has been removed from the list."
        @synonyms "remove, discard, clear"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load data for an action."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }
  }

  ;; Coordinator trait: owns the persist side-effects triggered by the
  ;; Modal/Confirmation trait refs' emits. Replaces the old per-ref
  ;; `on SAVE { (persist ...) }` override pattern.
  trait ListItemPersistor -> ListItem [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create ListItem ?data {
          emit: { success: ITEM_CREATED }
        })
      DO_UPDATE -> idle
        (persist update ListItem ?data {
          emit: { success: ITEM_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete ListItem ?id {
          emit: { success: ITEM_DELETED }
        })
    }

    emits {
      ITEM_CREATED -> external {
        id : string!
      }
        @description "Signals a new item has been added to the list."
        @synonyms "added, new, appended"
        @tier "domain"
      ITEM_UPDATED -> external {
        id : string!
      }
        @description "Signals a change in an item's data."
        @synonyms "modified, changed, refreshed"
        @tier "presentation"
      ITEM_DELETED -> external {
        id : string!
      }
        @description "Signals that a list item has been removed."
        @synonyms "removed, discarded, purged"
        @tier "domain"
    }

    listens {
      DO_CREATE {
        data : ListItem!
      }
        @description "Indicates a request to create a new item."
        @synonyms "add, new, insert"
        @tier "domain"
      DO_UPDATE {
        data : ListItem!
      }
        @description "Indicates a data item has been modified."
        @synonyms "modified, changed, refreshed"
        @tier "domain"
      DO_DELETE {
        id : string!
      }
        @description "Indicates a request to remove an item from the list."
        @synonyms "remove, discard, erase"
        @tier "domain"
      ListItemCreate.LIST_ITEM_CREATED -> DO_CREATE
      ListItemEdit.LIST_ITEM_UPDATED -> DO_UPDATE
      ListItemDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/listitems" as ListItemPage -> ListItemBrowse, ListItemCreate, ListItemEdit, ListItemDelete, ListItemPersistor
}