app std-tabs-layout "2.0.0"
"std-tabs-layout — chrome with std-tabs strip; consumer overrides config.tabs[].content with @trait.X references."

orbital TabsLayoutOrbital {
  uses Tabs from "std/behaviors/std-tabs"

  entity TabsLayoutState [runtime] {
    id : string!
  }

  trait TabsLayoutTabs = Tabs.traits.TabsItemTabs {
  }

  trait TabsLayout [interaction, instance] {
    initial: composing
    config {
      title : string = "Tabbed View"
        @label "Page title"
        @description "Heading shown above the tab strip"
        @tier "customization"
      icon  : string = "layout"
        @label "Header icon"
        @description "Icon name displayed next to the title"
        @tier "customization"
    }
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-6xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "@config.icon" }, { type: "typography", variant: "h2", content: "@config.title" }] }, { type: "divider" }, "@trait.TabsLayoutTabs"] })
    }
  }

  page "/tabs-layout" as TabsLayoutPage -> TabsLayout, TabsLayoutTabs
}
