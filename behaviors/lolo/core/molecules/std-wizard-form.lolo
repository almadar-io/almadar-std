app std-wizard-form "1.0.0"
"std-wizard-form — canonical molecule-level wizard example (3-step sign-up flow). Wizards own their state machine at molecule tier."

orbital WizardFormOrbital {
  entity WizardFormEntry [persistent: wizardformentries] {
    id    : string!
    name  : string
    email : string
    theme : string
  }

  type WizardFormSaved      = Event { id : string }                   "Fired when wizard flow completes successfully"
  type WizardFormSaveFailed = Event { error : string, code : string } "Fired when the final persist fails"
  type WizardFormEntryLoaded = Event { data : [WizardFormEntry] }
  type WizardFormEntryLoadFailed = Event { error : string, code : string }

  trait WizardFormFlow -> WizardFormEntry [interaction, instance] {
    initial: personal
    state personal {
      INIT -> personal
        (fetch WizardFormEntry { emit: { success: "WizardFormEntryLoaded", failure: "WizardFormEntryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", variant: "h3", content: "Sign-up" }] },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h4", content: "Personal Info" },
          { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["name", "email"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 3, showBack: false, showNext: true, showComplete: false, onNext: "NEXT" }
        ] })
      NEXT -> preferences
        (set @entity.name @payload.data.name)
        (set @entity.email @payload.data.email)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", variant: "h3", content: "Sign-up" }] },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h4", content: "Preferences" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["theme"] },
          { type: "wizard-navigation", currentStep: 1, totalSteps: 3, showBack: true, showNext: true, showComplete: false, onBack: "PREV", onNext: "NEXT" }
        ] })
    }
    state preferences {
      NEXT -> review
        (set @entity.theme @payload.data.theme)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", variant: "h3", content: "Sign-up" }] },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 2 },
          { type: "divider" },
          { type: "typography", variant: "h4", content: "Review" },
          { type: "stack", direction: "vertical", gap: "sm", children: [
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", color: "muted", content: "Name" }, { type: "typography", variant: "body", content: "@entity.name" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", color: "muted", content: "Email" }, { type: "typography", variant: "body", content: "@entity.email" }] },
            { type: "stack", direction: "horizontal", gap: "md", justify: "between", children: [{ type: "typography", variant: "caption", color: "muted", content: "Theme" }, { type: "typography", variant: "body", content: "@entity.theme" }] }
          ] },
          { type: "wizard-navigation", currentStep: 2, totalSteps: 3, showBack: true, showNext: false, showComplete: true, onBack: "PREV", onComplete: "COMPLETE" }
        ] })
      PREV -> personal
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", variant: "h3", content: "Sign-up" }] },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h4", content: "Personal Info" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["name", "email"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 3, showBack: false, showNext: true, showComplete: false, onNext: "NEXT" }
        ] })
    }
    state review {
      COMPLETE -> persisting
        (persist create WizardFormEntry @payload.data { emit: { success: "WizardFormSaved", failure: "WizardFormSaveFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "spinner" },
          { type: "typography", variant: "caption", color: "muted", content: "Completing sign-up…" }
        ] })
      PREV -> preferences
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", variant: "h3", content: "Sign-up" }] },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 1 },
          { type: "divider" },
          { type: "typography", variant: "h4", content: "Preferences" },
          { type: "form-section", entity: @entity, mode: "edit", submitEvent: "NEXT", cancelEvent: "PREV", fields: ["theme"] },
          { type: "wizard-navigation", currentStep: 1, totalSteps: 3, showBack: true, showNext: true, showComplete: false, onBack: "PREV", onNext: "NEXT" }
        ] })
    }
    state persisting {
      WizardFormSaved -> complete
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "icon", name: "check-circle" },
          { type: "typography", variant: "h3", content: "Welcome!" },
          { type: "typography", variant: "body", color: "muted", content: "Your account has been created." },
          { type: "button", label: "Start Over", action: "RESTART", variant: "ghost", icon: "rotate-ccw" }
        ] })
      WizardFormSaveFailed -> review
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", className: "max-w-xl mx-auto w-full py-12", children: [
          { type: "icon", name: "alert-triangle", color: "destructive" },
          { type: "typography", variant: "h3", content: "Sign-up Failed" },
          { type: "alert", variant: "error", message: "@payload.error" },
          { type: "button", label: "Retry", action: "COMPLETE", variant: "primary", icon: "refresh-cw" }
        ] })
    }
    state complete {
      RESTART -> personal
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-xl mx-auto w-full", children: [
          { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "user-plus" }, { type: "typography", variant: "h3", content: "Sign-up" }] },
          { type: "wizard-progress", steps: ["Personal", "Preferences", "Review"], currentStep: 0 },
          { type: "divider" },
          { type: "typography", variant: "h4", content: "Personal Info" },
          { type: "form-section", mode: "create", submitEvent: "NEXT", cancelEvent: "INIT", fields: ["name", "email"] },
          { type: "wizard-navigation", currentStep: 0, totalSteps: 3, showBack: false, showNext: true, showComplete: false, onNext: "NEXT" }
        ] })
    }
    emits {
      WizardFormSaved
      WizardFormSaveFailed
      WizardFormEntryLoaded
      WizardFormEntryLoadFailed
    }
    listens {
      NEXT                   { data : object! }
      PREV                   { }
      COMPLETE               { data : object! }
      RESTART                { }
      WizardFormSaveFailed   { error : string, code : string }
      WizardFormEntryLoadFailed { error : string, code : string }
    }
  }

  page "/wizard-form" as WizardForm -> WizardFormFlow
}
