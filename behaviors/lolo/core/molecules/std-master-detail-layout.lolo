app std-master-detail-layout "2.0.0"
"std-master-detail-layout — chrome with std-drawer side-panel + masterTrait config slot for the consumer's master list."

orbital MasterDetailLayoutOrbital {
  uses Drawer from "std/behaviors/std-drawer"

  entity MasterDetailLayoutState [runtime] {
    id : string!
  }

  trait MasterDetailDrawer = Drawer.traits.DrawerContentDrawer {
  }

  trait MasterDetailLayout [interaction, instance] {
    initial: composing
    config {
      masterTrait : trait
      title       : string = "Master / Detail"
      icon        : string = "list"
    }
    state composing {
      INIT -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-6xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "@config.icon" }, { type: "typography", variant: "h2", content: "@config.title" }] }, { type: "divider" }, "@config.masterTrait"] })
    }
  }

  page "/master-detail" as MasterDetailPage -> MasterDetailLayout, MasterDetailDrawer
}
