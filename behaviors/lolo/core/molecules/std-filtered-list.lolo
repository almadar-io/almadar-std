app std-filtered-list "1.0.0"
"std-filtered-list — molecule composing slim Search/Filter/Browse/Pagination atoms"
;;
;; Layout owns the page chrome (single h2 page-title, divider). Each
;; trait reference passes config: { ... } so the slim atoms know what
;; to render. Browse is the data hub: its listens block (added at the
;; molecule call-site, not on the atom) wires Search SEARCH / Filter
;; FILTER / Pagination PAGE → REFETCH so Browse refetches the list
;; when any sibling intent fires. This is the "shared state across
;; siblings" composition — atoms emit user-intent events, Browse owns
;; the resulting list, the molecule wires the bridge.

orbital FilteredListItemOrbital {
  uses Search     from "std/behaviors/std-search"
  uses Filter     from "std/behaviors/std-filter"
  uses Browse     from "std/behaviors/std-browse"
  uses Pagination from "std/behaviors/std-pagination"

  entity FilteredListItem [persistent: filteredlistitems] {
    id : string!
    name : string @description "The displayed text for the list item." @synonyms "label, title, display_name"
    description : string @description "A textual explanation of the list item's content." @synonyms "text, details, explanation, summary"
    status : "active" | "inactive" | "pending" @description "Indicates the current operational state of the item." @synonyms "state, condition, enabled, disabled" = "active"
  }
  type FilteredListItemLoaded = Event { data : [FilteredListItem] }
  type FilteredListItemLoadFailed = Event { error : string, code : string }

  ;; Gap #22 — atoms keep their own entity (SearchResult / FilterTarget /
  ;; PagedItem) as UI-state containers. NO `-> FilteredListItem` rebind on
  ;; Search / Filter / Pagination. Browse alone rebinds because Browse owns
  ;; the rows. The auxiliary entities surface in the inline phase via
  ;; `auxiliaryEntities`, register persistence at runtime, and let
  ;; `(set @entity.searchTerm @payload.searchTerm)` persist user input
  ;; across transitions. Pagination listens for BrowseItemLoaded to
  ;; derive totalPages from the live row count instead of a hardcoded
  ;; config value.
  trait FilteredItemSearch = Search.traits.SearchResultSearch {
    config: {
      placeholder: "Search filtered items…",
      event: "SEARCH"
    }
  }

  trait FilteredItemFilter = Filter.traits.FilterTargetFilter {
    config: {
      filters: [{ field: "status", label: "Status", options: ["active", "inactive", "pending"], filterType: "select" }],
      event: "FILTER"
    }
  }

  trait FilteredItemBrowse = Browse.traits.BrowseItemBrowse -> FilteredListItem {
    config: {
      pageSize: 3,
      fields: [
        { name: "name",        label: "Name",        variant: "h4" },
        { name: "description", label: "Description", variant: "caption" },
        { name: "status",      label: "Status",      variant: "badge" }
      ]
    }
    ;; Server-side pagination: Pagination's PAGE drives Browse to refetch
    ;; with offset/limit derived from @payload.page and @config.pageSize.
    ;; The fetch result includes totalCount (pre-pagination filter total)
    ;; which propagates through BrowseItemLoaded so Pagination computes
    ;; totalPages without a separate count round-trip. To switch back to
    ;; visual-only pagination, drop the PAGE wire and the data-grid will
    ;; slice client-side using its own pageSize prop.
    listens {
      FilteredItemSearch.SEARCH -> REFETCH_QUERY
      FilteredItemFilter.FILTER -> REFETCH_FILTER
      FilteredItemPagination.PAGE -> REFETCH_PAGE
    }
  }

  trait FilteredItemPagination = Pagination.traits.PagedItemPagination {
    config: {
      pageSize: 3,
      event: "PAGE"
    }
    listens {
      FilteredItemBrowse.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait FilteredListLayout -> FilteredListItem [interaction, collection] {
    state composing {
      INIT -> composing
        (fetch FilteredListItem { emit: { success: "FilteredListItemLoaded", failure: "FilteredListItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "list" }, { type: "typography", variant: "h2", content: "Filtered List" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: ["@trait.FilteredItemSearch", "@trait.FilteredItemFilter"] }, "@trait.FilteredItemBrowse", "@trait.FilteredItemPagination"] })
    }
    emits {
      FilteredListItemLoadFailed
      FilteredListItemLoaded
    }
}

  ;; All 5 traits page-bound so each gets a useTraitStateMachine hook on
  ;; the client. Without binding the atoms, their state machines never
  ;; advance past `loading` because no client subscriber re-POSTs the
  ;; success events (BrowseItemLoaded, FilterTargetLoaded, ...) that
  ;; come back from the server in `emittedEvents[]`. See
  ;; docs/Almadar_Std_Verification.md gap #19.B.
  page "/filtered-list" as FilteredList -> FilteredListLayout, FilteredItemSearch, FilteredItemFilter, FilteredItemBrowse, FilteredItemPagination
}
