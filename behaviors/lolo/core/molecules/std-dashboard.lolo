app std-dashboard "1.0.0"
"std-dashboard — molecule composing std-stats + std-graphs + std-browse (stat cards top, charts middle, data list bottom). Browse is the data hub; Stats and Graphs listen for `BrowseItemLoaded -> ITEMS_LOADED`."
orbital DashboardItemOrbital {
  uses Stats from "std/behaviors/std-stats"

  uses Graphs from "std/behaviors/std-graphs"

  uses Browse from "std/behaviors/std-browse"

  uses Icon from "std/behaviors/ui-icon"
  uses Typography from "std/behaviors/ui-typography"
  uses Divider from "std/behaviors/ui-divider"
  uses SimpleGrid from "std/behaviors/ui-simple-grid"

    type DashboardItemLoaded = Event { data : [DashboardItem] }

    type DashboardItemLoadFailed = Event { error : string, code : string }

  entity DashboardItem [persistent: dashboarditems] {
    id : string!
    name : string @description "A human-readable identifier for the item." @synonyms "title, label, identifier"
    category : string @description "The type or classification of the dashboard item." @synonyms "type, kind, group"
    status : "active" | "inactive" | "pending" @description "Indicates the current operational state of the item." @synonyms "state, condition, enabled, disabled" = active
    amount : number @description "The numerical value being represented." @synonyms "value, quantity, count, total" = 0
    units : number @description "Represents a numerical measurement or quantity." @synonyms "value, count, measure" = 0
  }

  trait DashboardSummary = Stats.traits.StatsItemStats {
    config {
      title: Summary
      metrics: [{
        aggregation: count
        format: number
        icon: list
        label: "Total Items"
        variant: primary
      }, {
        aggregation: count
        filter: (fn row ["=", @row.status, active])
        format: number
        icon: check-circle
        label: Active
        variant: success
      }, {
        aggregation: sum
        field: amount
        format: currency
        icon: dollar-sign
        label: "Total Revenue"
        target: 10000
        variant: info
      }, {
        aggregation: avg
        field: units
        format: number
        icon: trending-up
        label: "Avg Units"
        suffix: " units"
        variant: default
      }]
    }

    listens {
      DashboardItemBrowse.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait DashboardCategoryChart = Graphs.traits.GraphItemGraph {
    config {
      title: "Items by Category"
      subtitle: "Count across categories"
      chartType: bar
      categoryField: category
      aggregation: count
      height: 280
      showLegend: false
    }

    listens {
      DashboardItemBrowse.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait DashboardStatusChart = Graphs.traits.GraphItemGraph {
    config {
      title: "Status Mix"
      chartType: donut
      categoryField: status
      aggregation: count
      height: 280
      showLegend: true
    }

    listens {
      DashboardItemBrowse.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait DashboardItemBrowse = Browse.traits.BrowseItemBrowse -> DashboardItem {
    config {
      pageSize: 100
      displayPageSize: 5
      fields: [{
        label: Name
        name: name
        variant: h4
      }, {
        label: Category
        name: category
        variant: caption
      }, {
        label: Status
        name: status
        variant: badge
      }, {
        label: Amount
        name: amount
        variant: caption
      }]
    }
  }

  trait Icon1 = Icon.traits.IconRender -> DashboardItem {
    config {
      name: bar-chart-2
    }
  }

  trait Typography1 = Typography.traits.TypographyRender -> DashboardItem {
    config {
      content: Dashboard
      variant: h2
    }
  }

  trait Divider1 = Divider.traits.DividerRender -> DashboardItem {
    config {}
  }

  trait SimpleGrid1 = SimpleGrid.traits.SimpleGridRender -> DashboardItem {
    config {
      children: [@trait.DashboardCategoryChart, @trait.DashboardStatusChart]
      cols: 2
      gap: md
    }
  }

  trait Typography2 = Typography.traits.TypographyRender -> DashboardItem {
    config {
      content: "Recent Items"
      variant: h3
    }
  }

  trait DashboardLayout -> DashboardItem [interaction, collection] {
    state composing {
      INIT -> composing
        (fetch DashboardItem {
          emit: { failure: DashboardItemLoadFailed, success: DashboardItemLoaded }
        })
        (render-ui main {
          children: [{
            align: center
            children: [@trait.Icon1, @trait.Typography1]
            direction: horizontal
            gap: sm
            type: stack
          }, @trait.Divider1, @trait.DashboardSummary, @trait.SimpleGrid1, @trait.Divider1, @trait.Typography2, @trait.DashboardItemBrowse]
          className: "max-w-6xl mx-auto w-full p-4"
          direction: vertical
          gap: lg
          type: stack
        })
    }

    emits {
      DashboardItemLoaded
        @description "Signals a data item has been successfully loaded."
        @synonyms "loaded, received, fetched"
        @tier "domain"
      DashboardItemLoadFailed
        @description "Indicates a failure to load a dashboard item."
        @synonyms "error, failure, problem, load failed"
        @tier "internal"
    }
  }

  page "/dashboard" as Dashboard -> DashboardLayout, DashboardSummary, DashboardCategoryChart, DashboardStatusChart, DashboardItemBrowse, Icon1, Typography1, Divider1, SimpleGrid1, Typography2
}