app std-generic-app "1.0.0"
"Generic fallback app: 8 reusable orbital factories (Contact, Item, Activity, Task, CalendarEvent, Widget, FeedPost, Note) under shared AppShell chrome. Picked by orbital-agent when no domain-specific organism is a confident match — agent maps prompt nouns to orbitals and supplies entity/title overrides via standard factory params."
orbital ContactOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Search from "std/behaviors/std-search"

  uses Filter from "std/behaviors/std-filter"

  uses Browse from "std/behaviors/std-browse"

  entity Contact [persistent: contacts] {
    id : string!
    name : string! @description "The identifier or label for the contact." @synonyms "label, identifier, designation"
    email : string @description "The electronic mail address for contact." @synonyms "email address, mail, contact email" = ""
    phone : string @description "The phone number associated with the entity." @synonyms "telephone, number, contact number" = ""
    company : string @description "The organization or business associated with the contact." @synonyms "organization, employer, business" = ""
    role : string @description "The function or position of this entity within a relationship." @synonyms "function, position, relationship, type" = ""
    notes : string @description "Free-form text providing additional information." @synonyms "comments, remarks, details, information" = ""
    pendingId : string @description "A unique identifier awaiting confirmation or processing." @synonyms "tempId, provisionalId, draftId" = ""
  }

  trait ContactAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: CONTACT_SEARCH
      NOTIFY_CLICK: CONTACT_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.ContactCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: CONTACT_SEARCH
      notifications: []
      notificationClickEvent: CONTACT_NOTIFICATIONS_OPEN
    }
  }

  trait ContactCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: users, type: icon }, {
                content: Contacts
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: CREATE
              icon: plus
              label: "New Contact"
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            align: center
            children: [@trait.ContactSearch, @trait.ContactFilter]
            direction: horizontal
            gap: md
            type: stack
          }, { type: divider }, @trait.ContactBrowseList]
          direction: vertical
          gap: lg
          type: stack
        })
      CONTACT_SEARCH -> composing
      CONTACT_NOTIFICATIONS_OPEN -> composing
        (render-ui main {
          align: center
          children: [{ name: bell, type: icon }, {
            content: "No notifications"
            type: typography
            variant: h3
          }, {
            action: INIT
            label: Back
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      CREATE -> external {
        source : string
      }
        @description "Signals the creation of a new record."
        @synonyms "new, add, initialize, generate"
        @tier "domain"
    }

    listens {
      ContactAppLayout.CONTACT_SEARCH -> CONTACT_SEARCH
      ContactAppLayout.CONTACT_NOTIFICATIONS_OPEN -> CONTACT_NOTIFICATIONS_OPEN
      CONTACT_SEARCH {
        value : string
      }
        @description "Triggers a search for contacts."
        @synonyms "find, query, lookup, search"
        @tier "domain"
      CONTACT_NOTIFICATIONS_OPEN {
        id : string
      }
        @description "Indicates new contact notifications are available."
        @synonyms "alerts, updates, reminders, news"
        @tier "presentation"
    }
  }

  trait ContactSearch = Search.traits.SearchResultSearch {
    config {
      placeholder: "Search contacts…"
      event: CONTACT_SEARCH
    }
  }

  trait ContactFilter = Filter.traits.FilterTargetFilter {
    config {
      filters: [{
        field: company
        filterType: select
        label: Company
        options: []
      }]
      event: CONTACT_FILTER
    }
  }

  trait ContactBrowseList = Browse.traits.BrowseItemBrowse -> Contact {
    config {
      fields: [{
        icon: user
        name: name
        variant: h3
      }, { name: email, variant: body }, { name: phone, variant: caption }, { name: company, variant: badge }, { name: role, variant: caption }]
      itemActions: [{
        event: VIEW
        label: View
        variant: ghost
      }, {
        event: EDIT
        label: Edit
        variant: ghost
      }, {
        event: DELETE
        label: Delete
        variant: danger
      }]
      cols: 1
      gap: sm
    }

    listens {
      ContactSearch.SEARCH -> REFETCH_QUERY
      ContactFilter.FILTER -> REFETCH_FILTER
      ContactPersistor.CONTACT_CREATED -> INIT
      ContactPersistor.CONTACT_UPDATED -> INIT
      ContactPersistor.CONTACT_DELETED -> INIT
    }
  }

  trait ContactCreate = Modal.traits.ModalRecordModal -> Contact {
    events {
      OPEN: CREATE
    }

    config {
      icon: plus-circle
      title: "New Contact"
      mode: create
      fields: (name email phone company role notes)
    }

    listens {
      ContactCatalog.CREATE -> CREATE
      CREATE {
        id : string
        row : Contact
      }
        @description "A new record is being created."
        @synonyms "new, add, initialize, generate"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data persistence or storage has been successfully completed."
        @synonyms "persist, store, commit, update"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data fetch failure"
        @tier "internal"
    }
  }

  trait ContactEdit = Modal.traits.ModalRecordModal -> Contact {
    events {
      OPEN: EDIT
    }

    config {
      icon: edit
      title: "Edit Contact"
      mode: edit
      fields: (name email phone company role notes)
    }

    listens {
      ContactBrowseList.EDIT -> EDIT
      EDIT {
        id : string
        row : Contact
      }
        @description "Indicates a record is being modified."
        @synonyms "update, change, modify"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data persistence triggered by user action."
        @synonyms "persist, store, commit, update"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data retrieval failure"
        @tier "internal"
    }
  }

  trait ContactView = Modal.traits.ModalRecordModal -> Contact {
    events {
      OPEN: VIEW
    }

    config {
      icon: eye
      title: "View Contact"
      mode: edit
      fields: (name email phone company role notes)
    }

    listens {
      ContactBrowseList.VIEW -> VIEW
      VIEW {
        id : string
        row : Contact
      }
        @description "Indicates a record has been displayed or is visible."
        @synonyms "display, show, present"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "A record has been persisted or updated."
        @synonyms "persist, update, store, commit"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data retrieval failure"
        @tier "internal"
    }
  }

  trait ContactDelete = Confirmation.traits.ConfirmActionConfirmation -> Contact {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete Contact"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      ContactBrowseList.DELETE -> DELETE
      DELETE {
        id : string
        row : Contact
      }
        @description "Indicates a record has been removed."
        @synonyms "remove, discard, erase"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load requested data."
        @synonyms "error, failure, failed, problem"
        @tier "internal"
    }
  }

  trait ContactPersistor -> Contact [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Contact ?data {
          emit: { success: CONTACT_CREATED }
        })
      DO_UPDATE -> idle
        (persist update Contact ?data {
          emit: { success: CONTACT_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete Contact ?id {
          emit: { success: CONTACT_DELETED }
        })
    }

    emits {
      CONTACT_CREATED -> external {
        id : string
      }
        @description "Signals the creation of a new contact record."
        @synonyms "new contact, add contact, contact added"
        @tier "domain"
      CONTACT_UPDATED -> external {
        id : string
      }
        @description "Signals that a contact's details have been modified."
        @synonyms "modified, changed, refreshed"
        @tier "domain"
      CONTACT_DELETED -> external {
        id : string
      }
        @description "Signals a contact record has been removed."
        @synonyms "removed, purged, archived"
        @tier "domain"
    }

    listens {
      DO_CREATE {
        data : object!
      }
        @description "Initiates the creation of a new record."
        @synonyms "new, add, generate, initiate"
        @tier "domain"
      DO_UPDATE {
        data : object!
      }
        @description "Indicates data has been modified and needs to be refreshed."
        @synonyms "refresh, reload, update, sync"
        @tier "domain"
      DO_DELETE {
        id : string
      }
        @description "Initiates the removal of a record."
        @synonyms "remove, discard, purge"
        @tier "domain"
      ContactCreate.SAVE -> DO_CREATE
      ContactEdit.SAVE -> DO_UPDATE
      ContactDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/contacts" as ContactsPage -> ContactAppLayout, ContactCatalog, ContactSearch, ContactFilter, ContactBrowseList, ContactCreate, ContactEdit, ContactView, ContactDelete, ContactPersistor
}

orbital ItemOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Search from "std/behaviors/std-search"

  uses Filter from "std/behaviors/std-filter"

  uses Browse from "std/behaviors/std-browse"

  uses Approval from "std/behaviors/std-approval-gate"

  uses Erasure from "std/behaviors/std-data-erasure"

  uses ModQueue from "std/behaviors/std-mod-queue"

  uses Audit from "std/behaviors/std-audit-capture"

  entity Item [persistent: items] {
    id : string!
    name : string! @description "The identifier or label for the contact." @synonyms "label, identifier, designation"
    description : string @description "A textual explanation or summary of the item." @synonyms "summary, details, explanation, about" = ""
    sku : string @description "Unique identifier for a product or item." @synonyms "product code, item number, part number" = ""
    price : number @description "The monetary cost associated with the item." @synonyms "cost, amount, value, rate" = 0
    quantity : number @description "The number of items or units." @synonyms "count, amount, number, size" = 0
    category : string @description "Classification or type of the item." @synonyms "type, kind, classification" = ""
    pendingId : string @description "A unique identifier awaiting final assignment or processing." @synonyms "tempId, provisionalId, draftId" = ""
    status : "active" | "pending" | "approved" @description "Approval/workflow state of the item." @synonyms "state, stage, condition, review status" = active
  }

  trait ItemAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: ITEM_SEARCH
      NOTIFY_CLICK: ITEM_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.ItemCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: ITEM_SEARCH
      topBarActions: [{
        event: OPEN_APPROVALS
        icon: shield-check
        label: Approvals
        variant: default
      }]
      notifications: []
      notificationClickEvent: ITEM_NOTIFICATIONS_OPEN
    }
  }

  trait ItemCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: package, type: icon }, {
                content: Items
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: CREATE
              icon: plus
              label: "New Item"
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, {
            align: center
            children: [@trait.ItemSearch, @trait.ItemFilter]
            direction: horizontal
            gap: md
            type: stack
          }, @trait.ItemBrowseList]
          direction: vertical
          gap: lg
          type: stack
        })
      ITEM_SEARCH -> composing
      ITEM_NOTIFICATIONS_OPEN -> composing
        (render-ui main {
          align: center
          children: [{ name: bell, type: icon }, {
            content: "No notifications"
            type: typography
            variant: h3
          }, {
            action: INIT
            label: Back
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      CREATE -> external {
        source : string
      }
        @description "Signals the creation of a new record."
        @synonyms "new, add, generate, initialize"
        @tier "domain"
    }

    listens {
      ItemAppLayout.ITEM_SEARCH -> ITEM_SEARCH
      ItemAppLayout.ITEM_NOTIFICATIONS_OPEN -> ITEM_NOTIFICATIONS_OPEN
      ITEM_SEARCH {
        value : string
      }
        @description "A search query for items has been submitted."
        @synonyms "query, find, lookup, browse"
        @tier "domain"
      ITEM_NOTIFICATIONS_OPEN {
        id : string
      }
        @description "Indicates new notifications are available for items."
        @synonyms "alerts, notification, updates, new"
        @tier "presentation"
    }
  }

  trait ItemSearch = Search.traits.SearchResultSearch {
    config {
      placeholder: "Search items…"
      event: ITEM_SEARCH
    }
  }

  trait ItemFilter = Filter.traits.FilterTargetFilter {
    config {
      filters: [{
        field: category
        filterType: select
        label: Category
        options: []
      }]
      event: ITEM_FILTER
    }
  }

  trait ItemBrowseList = Browse.traits.BrowseItemBrowse -> Item {
    config {
      fields: [{
        icon: package
        name: name
        variant: h3
      }, { name: description, variant: body }, { name: sku, variant: caption }, {
        format: currency
        name: price
        variant: badge
      }, { name: quantity, variant: badge }, { name: category, variant: caption }, { name: status, variant: badge }]
      itemActions: [{
        event: VIEW
        label: View
        variant: ghost
      }, {
        event: EDIT
        label: Edit
        variant: ghost
      }, {
        event: DELETE
        label: Delete
        variant: danger
      }]
      cols: 2
      gap: sm
    }

    listens {
      ItemSearch.SEARCH -> REFETCH_QUERY
      ItemFilter.FILTER -> REFETCH_FILTER
      ItemPersistor.ITEM_CREATED -> INIT
      ItemPersistor.ITEM_UPDATED -> INIT
      ItemPersistor.ITEM_DELETED -> INIT
    }
  }

  trait ItemCreate = Modal.traits.ModalRecordModal -> Item {
    events {
      OPEN: CREATE
    }

    config {
      icon: plus-circle
      title: "New Item"
      mode: create
      fields: (name description sku price quantity category)
    }

    listens {
      ItemCatalog.CREATE -> CREATE
      CREATE {
        id : string
        row : Item
      }
        @description "A new record is being created."
        @synonyms "add, new, initialize, generate"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, update, commit"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data fetch failure"
        @tier "internal"
    }
  }

  trait ItemEdit = Modal.traits.ModalRecordModal -> Item {
    events {
      OPEN: EDIT
    }

    config {
      icon: edit
      title: "Edit Item"
      mode: edit
      fields: (name description sku price quantity category)
    }

    listens {
      ItemBrowseList.EDIT -> EDIT
      EDIT {
        id : string
        row : Item
      }
        @description "Indicates a record is being modified."
        @synonyms "update, change, modify"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, update, synchronize"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load a record into a modal window."
        @synonyms "load error, failed load, data fetch failure"
        @tier "internal"
    }
  }

  trait ItemView = Modal.traits.ModalRecordModal -> Item {
    events {
      OPEN: VIEW
    }

    config {
      icon: eye
      title: "View Item"
      mode: edit
      fields: (name description sku price quantity category)
    }

    listens {
      ItemBrowseList.VIEW -> VIEW
      VIEW {
        id : string
        row : Item
      }
        @description "Indicates a record has been displayed or is visible."
        @synonyms "display, show, present"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, update, synchronize"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data retrieval failure"
        @tier "internal"
    }
  }

  trait ItemDelete = Confirmation.traits.ConfirmActionConfirmation -> Item {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete Item"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      ItemBrowseList.DELETE -> DELETE
      DELETE {
        id : string
        row : Item
      }
        @description "Indicates a record has been removed."
        @synonyms "remove, discard, erase"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure during data loading for an action."
        @synonyms "error, failure, failed, problem"
        @tier "internal"
    }
  }

  trait ItemPersistor -> Item [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_CREATE -> idle when (not @config.requireApproval)
        (persist create Item ?data {
          emit: { success: ITEM_CREATED }
        })
      DO_CREATE -> idle when @config.requireApproval
        (persist create ApprovalRequest {
          gatedEvent: ITEM_CREATE
          payload: ?data
          status: pending
        })
      DO_UPDATE -> idle
        (persist update Item ?data {
          emit: { success: ITEM_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete Item ?id {
          emit: { success: ITEM_DELETED }
        })
      GRANTED -> idle
        (persist create Item ?payload {
          emit: { success: ITEM_CREATED }
        })
    }

    emits {
      ITEM_CREATED -> external {
        id : string
      }
        @description "Signals a new item has been created."
        @synonyms "added, new, added, instantiate"
        @tier "domain"
      ITEM_UPDATED -> external {
        id : string
      }
        @description "Signals that an item's data has been modified and persisted."
        @synonyms "modified, changed, refreshed, updated"
        @tier "domain"
      ITEM_DELETED -> external {
        id : string
      }
        @description "Signals that an item has been removed."
        @synonyms "removed, purged, discarded"
        @tier "domain"
    }

    listens {
      DO_CREATE {
        data : object!
      }
        @description "Initiates the creation of a new record."
        @synonyms "new, add, generate, initialize"
        @tier "domain"
      DO_UPDATE {
        data : object!
      }
        @description "Signals that data has been modified and should be refreshed."
        @synonyms "refresh, changed, modified, updated"
        @tier "domain"
      DO_DELETE {
        id : string
      }
        @description "Initiates the removal of a record."
        @synonyms "remove, discard, erase"
        @tier "domain"
      GRANTED {
        requestId : string
        payload : object
      }
        @description "An approver granted a held item request; replay the create from the carried payload."
        @synonyms "approved, granted, authorized"
        @tier "domain"
      ItemCreate.SAVE -> DO_CREATE
      ItemEdit.SAVE -> DO_UPDATE
      ItemDelete.CONFIRM_DELETE -> DO_DELETE
      ItemApproval.ApprovalGranted -> GRANTED
    }

    config {
      requireApproval : boolean = false
        @label "Require approval before new items go live"
        @description "When on, a new item is held as a pending approval request until an approver grants it; only then is the item created. Off by default."
        @synonyms "gate, sign-off, review before create, approval required, hold for review"
        @tier "policy"
    }
  }

  ;; Governance policies. The review queues render into the `modal` overlay and
  ;; are SUMMONED via OPEN (never seize `main`): the layout's "Approvals" top-bar
  ;; action emits OPEN_APPROVALS, which the approval trait's OPEN listens for
  ;; (co-located key-match). The studio questionnaire toggles enabled (@tier "policy").
  trait ItemApproval = Approval.traits.ApprovalGateReview {
    events {
      OPEN: OPEN_APPROVALS
    }

    config {
      enabled: true
        @label "Enable approval workflow"
        @description "When enabled, items must be approved before they become active."
        @tier "policy"
    }
  }

  trait ItemErasure = Erasure.traits.ErasureWorkflow {
    config {
      enabled: false
        @label "Enable erasure workflow"
        @description "When enabled, admins can permanently erase items on request (e.g., GDPR right-to-be-forgotten)."
        @tier "policy"
      targetEntity: Item
    }
  }

  trait ItemModeration = ModQueue.traits.ModQueueItemReview {
    config {
      enabled: false
        @label "Enable moderation queue"
        @description "When enabled, submitted items enter a moderation queue before publication."
        @tier "policy"
    }
  }

  ;; Audit trail — a dotted-source listen subscribes the audit interceptor to the
  ;; persistor's real ITEM_UPDATED mutation (a plain sentinel rename would be
  ;; source:None and never subscribe). Persists an AuditEntry per change; renders
  ;; nothing, so it is safe to mount on the page.
  trait ItemAudit = Audit.traits.AuditCaptureListener {
    config {
      enabled: true
      captureEntity: Item
      captureBeforeAfter: true
    }

    listens {
      ItemPersistor.ITEM_UPDATED -> EntityMutated
    }
  }

  page "/items" as ItemsPage -> ItemAppLayout, ItemCatalog, ItemSearch, ItemFilter, ItemBrowseList, ItemCreate, ItemEdit, ItemView, ItemDelete, ItemPersistor, ItemApproval, ItemAudit
}

orbital ActivityOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Browse from "std/behaviors/std-browse"

  entity Activity [persistent: activities] {
    id : string!
    title : string! @description "The descriptive name or heading for the item." @synonyms "label, heading, name"
    type : string @description "Specifies the kind or category of the item." @synonyms "kind, category, class, itemType" = ""
    actor : string @description "The individual or system performing an action." @synonyms "performer, agent, initiator, user" = ""
    timestamp : string @description "Date and time of the record's creation or last modification." @synonyms "date, time, created, modified, last updated" = ""
    status : string @description "Current state or condition of the item." @synonyms "state, condition, progress" = ""
    notes : string @description "Free-form text containing additional information." @synonyms "comments, remarks, details, text" = ""
  }

  trait ActivityAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: ACTIVITY_SEARCH
      NOTIFY_CLICK: ACTIVITY_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.ActivityCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: ACTIVITY_SEARCH
      notifications: []
      notificationClickEvent: ACTIVITY_NOTIFICATIONS_OPEN
    }
  }

  trait ActivityCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{ name: activity, type: icon }, {
              content: Activities
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, @trait.ActivityBrowseList]
          direction: vertical
          gap: lg
          type: stack
        })
      ACTIVITY_SEARCH -> composing
      ACTIVITY_NOTIFICATIONS_OPEN -> composing
        (render-ui main {
          align: center
          children: [{ name: bell, type: icon }, {
            content: "No notifications"
            type: typography
            variant: h3
          }, {
            action: INIT
            label: Back
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: md
          type: stack
        })
    }

    listens {
      ActivityAppLayout.ACTIVITY_SEARCH -> ACTIVITY_SEARCH
      ActivityAppLayout.ACTIVITY_NOTIFICATIONS_OPEN -> ACTIVITY_NOTIFICATIONS_OPEN
      ACTIVITY_SEARCH {
        value : string
      }
        @description "Triggers a search operation for activity records."
        @synonyms "find, query, lookup, browse"
        @tier "domain"
      ACTIVITY_NOTIFICATIONS_OPEN {
        id : string
      }
        @description "Indicates new activity notifications are available."
        @synonyms "notify, alert, update, new"
        @tier "presentation"
    }
  }

  trait ActivityBrowseList = Browse.traits.BrowseItemBrowse -> Activity {
    config {
      fields: [{
        icon: activity
        name: title
        variant: h4
      }, { name: type, variant: badge }, { name: actor, variant: caption }, {
        format: date
        name: timestamp
        variant: caption
      }, { name: status, variant: badge }]
      itemActions: [{
        event: VIEW
        label: View
        variant: ghost
      }, {
        event: EDIT
        label: Edit
        variant: ghost
      }, {
        event: DELETE
        label: Delete
        variant: danger
      }]
      cols: 1
      gap: sm
    }

    listens {
      ActivityPersistor.ACTIVITY_CREATED -> INIT
      ActivityPersistor.ACTIVITY_UPDATED -> INIT
      ActivityPersistor.ACTIVITY_DELETED -> INIT
    }
  }

  trait ActivityView = Modal.traits.ModalRecordModal -> Activity {
    events {
      OPEN: VIEW
    }

    config {
      icon: eye
      title: "View Activity"
      mode: edit
      fields: (title type actor timestamp status notes)
    }

    listens {
      ActivityBrowseList.VIEW -> VIEW
      VIEW {
        id : string
        row : Activity
      }
        @description "Indicates a record has been displayed or is visible."
        @synonyms "display, show, present, render"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data persistence triggered by user action."
        @synonyms "persist, store, commit"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data error"
        @tier "internal"
    }
  }

  trait ActivityEdit = Modal.traits.ModalRecordModal -> Activity {
    events {
      OPEN: EDIT
    }

    config {
      icon: edit
      title: "Edit Activity"
      mode: edit
      fields: (title type actor timestamp status notes)
    }

    listens {
      ActivityBrowseList.EDIT -> EDIT
      EDIT {
        id : string
        row : Activity
      }
        @description "Indicates a record is being modified."
        @synonyms "modify, change, update"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, update, synchronize"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data error"
        @tier "internal"
    }
  }

  trait ActivityDelete = Confirmation.traits.ConfirmActionConfirmation -> Activity {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete Activity"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      ActivityBrowseList.DELETE -> DELETE
      DELETE {
        id : string
        row : Activity
      }
        @description "Indicates a record has been removed."
        @synonyms "remove, discard, purge"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load requested data."
        @synonyms "error, failure, failed, problem"
        @tier "internal"
    }
  }

  trait ActivityPersistor -> Activity [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_UPDATE -> idle
        (persist update Activity ?data {
          emit: { success: ACTIVITY_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete Activity ?id {
          emit: { success: ACTIVITY_DELETED }
        })
    }

    emits {
      ACTIVITY_CREATED -> external {
        id : string
      }
        @description "Signals a new activity has been created."
        @synonyms "new, added, generated"
        @tier "domain"
      ACTIVITY_UPDATED -> external {
        id : string
      }
        @description "Signals that an activity has been modified and saved."
        @synonyms "modified, changed, updated, refreshed"
        @tier "domain"
      ACTIVITY_DELETED -> external {
        id : string
      }
        @description "Signals that an activity record has been removed."
        @synonyms "removed, purged, discarded"
        @tier "domain"
    }

    listens {
      DO_UPDATE {
        data : object!
      }
        @description "Indicates data has been modified and should be synchronized."
        @synonyms "refresh, sync, change, modify"
        @tier "domain"
      DO_DELETE {
        id : string
      }
        @description "Initiates the removal of a record."
        @synonyms "remove, discard, erase"
        @tier "domain"
      ActivityEdit.SAVE -> DO_UPDATE
      ActivityDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/activities" as ActivitiesPage -> ActivityAppLayout, ActivityCatalog, ActivityBrowseList, ActivityView, ActivityEdit, ActivityDelete, ActivityPersistor
}

orbital TaskOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Selection from "std/behaviors/std-selection"

  uses Browse from "std/behaviors/std-browse"

  entity Task [persistent: tasks] {
    id : string!
    title : string! @description "A short, user-facing name for the item." @synonyms "label, heading, subject"
    description : string @description "A textual explanation or summary of the item." @synonyms "summary, details, explanation, about" = ""
    assignee : string @description "The person or system responsible for a task or item." @synonyms "owner, responsible, assignedTo" = ""
    dueDate : string @description "The date and time when something is expected to be completed." @synonyms "deadline, completionDate, targetDate" = ""
    priority : "low" | "medium" | "high" @description "Indicates the level of importance or urgency." @synonyms "level, importance, urgency" = medium
    status : "todo" | "doing" | "done" @description "Current progress or state of the item." @synonyms "state, progress, stage" = todo
    pendingId : string @description "A unique identifier awaiting final assignment or processing." @synonyms "tempId, provisionalId, draftId" = ""
  }

  trait TaskAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: TASK_SEARCH
      NOTIFY_CLICK: TASK_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.TaskCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: TASK_SEARCH
      notifications: []
      notificationClickEvent: TASK_NOTIFICATIONS_OPEN
    }
  }

  trait TaskCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: check-square, type: icon }, {
                content: Tasks
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: CREATE
              icon: plus
              label: "New Task"
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, @trait.TaskSelection, { type: divider }, @trait.TaskBrowseList]
          direction: vertical
          gap: lg
          type: stack
        })
      TASK_SEARCH -> composing
      TASK_NOTIFICATIONS_OPEN -> composing
        (render-ui main {
          align: center
          children: [{ name: bell, type: icon }, {
            content: "No notifications"
            type: typography
            variant: h3
          }, {
            action: INIT
            label: Back
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      CREATE -> external {
        source : string
      }
        @description "Indicates a new record has been created."
        @synonyms "new, add, generate, instantiate"
        @tier "domain"
    }

    listens {
      TaskAppLayout.TASK_SEARCH -> TASK_SEARCH
      TaskAppLayout.TASK_NOTIFICATIONS_OPEN -> TASK_NOTIFICATIONS_OPEN
      TASK_SEARCH {
        value : string
      }
        @description "Triggers a search operation for tasks."
        @synonyms "find, query, lookup, search"
        @tier "domain"
      TASK_NOTIFICATIONS_OPEN {
        id : string
      }
        @description "Indicates new task notifications are available."
        @synonyms "alert, notify, update, reminder"
        @tier "presentation"
    }
  }

  trait TaskSelection = Selection.traits.SelectableItemSelection {
    config {
      title: "Filter by status"
      options: [{
        label: "To Do"
        value: todo
      }, { label: Doing, value: doing }, { label: Done, value: done }]
      event: TASK_STATUS_SELECT
    }
  }

  trait TaskBrowseList = Browse.traits.BrowseItemBrowse -> Task {
    config {
      fields: [{
        icon: check-square
        name: title
        variant: h4
      }, { name: description, variant: body }, { name: assignee, variant: caption }, {
        format: date
        name: dueDate
        variant: caption
      }, { name: priority, variant: badge }, { name: status, variant: badge }]
      itemActions: [{
        event: VIEW
        label: View
        variant: ghost
      }, {
        event: EDIT
        label: Edit
        variant: ghost
      }, {
        event: DELETE
        label: Delete
        variant: danger
      }]
      cols: 1
      gap: sm
    }

    listens {
      TaskPersistor.TASK_CREATED -> INIT
      TaskPersistor.TASK_UPDATED -> INIT
      TaskPersistor.TASK_DELETED -> INIT
    }
  }

  trait TaskCreate = Modal.traits.ModalRecordModal -> Task {
    events {
      OPEN: CREATE
    }

    config {
      icon: plus-circle
      title: "New Task"
      mode: create
      fields: (title description assignee dueDate priority status)
    }

    listens {
      TaskCatalog.CREATE -> CREATE
      CREATE {
        id : string
        row : Task
      }
        @description "A new record is being created."
        @synonyms "add, new, initialize, generate"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data persistence triggered by user action."
        @synonyms "persist, store, update, commit"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data retrieval failure"
        @tier "internal"
    }
  }

  trait TaskEdit = Modal.traits.ModalRecordModal -> Task {
    events {
      OPEN: EDIT
    }

    config {
      icon: edit
      title: "Edit Task"
      mode: edit
      fields: (title description assignee dueDate priority status)
    }

    listens {
      TaskBrowseList.EDIT -> EDIT
      EDIT {
        id : string
        row : Task
      }
        @description "Indicates a record is being modified."
        @synonyms "update, change, modify"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data changes have been persisted."
        @synonyms "persist, store, commit, update"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates that loading a record failed."
        @synonyms "error, failure, problem, unsuccessful"
        @tier "internal"
    }
  }

  trait TaskView = Modal.traits.ModalRecordModal -> Task {
    events {
      OPEN: VIEW
    }

    config {
      icon: eye
      title: "View Task"
      mode: edit
      fields: (title description assignee dueDate priority status)
    }

    listens {
      TaskBrowseList.VIEW -> VIEW
      VIEW {
        id : string
        row : Task
      }
        @description "Indicates a record or item is being displayed."
        @synonyms "display, show, present, render"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data persistence triggered by user action."
        @synonyms "persist, store, commit, update"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record for display."
        @synonyms "error, failed, problem, unsuccessful"
        @tier "internal"
    }
  }

  trait TaskDelete = Confirmation.traits.ConfirmActionConfirmation -> Task {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete Task"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      TaskBrowseList.DELETE -> DELETE
      DELETE {
        id : string
        row : Task
      }
        @description "Indicates a record is being removed."
        @synonyms "remove, discard, erase"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load requested data."
        @synonyms "error, failure, failed, problem"
        @tier "internal"
    }
  }

  trait TaskPersistor -> Task [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create Task ?data {
          emit: { success: TASK_CREATED }
        })
      DO_UPDATE -> idle
        (persist update Task ?data {
          emit: { success: TASK_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete Task ?id {
          emit: { success: TASK_DELETED }
        })
    }

    emits {
      TASK_CREATED -> external {
        id : string
      }
        @description "A new task has been created."
        @synonyms "new task, task added, task initiation"
        @tier "domain"
      TASK_UPDATED -> external {
        id : string
      }
        @description "Signals a task has been modified."
        @synonyms "modified, changed, altered"
        @tier "domain"
      TASK_DELETED -> external {
        id : string
      }
        @description "Signals that a task has been removed."
        @synonyms "removed, purged, archived"
        @tier "domain"
    }

    listens {
      DO_CREATE {
        data : object!
      }
        @description "Initiates the creation of a new record."
        @synonyms "new, add, generate, initiate"
        @tier "domain"
      DO_UPDATE {
        data : object!
      }
        @description "Indicates data has been modified and should be refreshed."
        @synonyms "refresh, reload, update, sync"
        @tier "domain"
      DO_DELETE {
        id : string
      }
        @description "Initiates the removal of a record."
        @synonyms "remove, discard, erase"
        @tier "domain"
      TaskCreate.SAVE -> DO_CREATE
      TaskEdit.SAVE -> DO_UPDATE
      TaskDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/tasks" as TasksPage -> TaskAppLayout, TaskCatalog, TaskSelection, TaskBrowseList, TaskCreate, TaskEdit, TaskView, TaskDelete, TaskPersistor
}

orbital CalendarOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Calendar from "std/behaviors/std-calendar"

  uses Browse from "std/behaviors/std-browse"

  entity ScheduledEvent [persistent: scheduledevents] {
    id : string!
    title : string! @description "The descriptive name or heading for the item." @synonyms "label, heading, name"
    startTime : string! @description "The date and time when an event or activity begins." @synonyms "start, beginTime, eventStart"
    endTime : string @description "The date and time when an event concludes." @synonyms "end date, finish time, completion time" = ""
    location : string @description "Physical or digital address of the contact." @synonyms "address, place, whereabouts" = ""
    attendees : string @description "List of individuals participating in an event or interaction." @synonyms "participants, guests, members" = ""
    description : string @description "A textual explanation or summary of the item." @synonyms "summary, details, explanation, about" = ""
    pendingId : string @description "A unique identifier awaiting confirmation or processing." @synonyms "tempId, provisionalId, draftId" = ""
  }

  trait CalendarAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: CAL_SEARCH
      NOTIFY_CLICK: CAL_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.CalendarCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: CAL_SEARCH
      notifications: []
      notificationClickEvent: CAL_NOTIFICATIONS_OPEN
    }
  }

  trait CalendarCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: calendar, type: icon }, {
                content: Calendar
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: CREATE
              icon: plus
              label: "New Event"
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, @trait.CalendarView, { type: divider }, @trait.CalendarBrowseList]
          direction: vertical
          gap: lg
          type: stack
        })
      CAL_SEARCH -> composing
      CAL_NOTIFICATIONS_OPEN -> composing
        (render-ui main {
          align: center
          children: [{ name: bell, type: icon }, {
            content: "No notifications"
            type: typography
            variant: h3
          }, {
            action: INIT
            label: Back
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      CREATE -> external {
        source : string
      }
        @description "Signals a new record has been created."
        @synonyms "new, add, initialize, generate"
        @tier "domain"
    }

    listens {
      CalendarAppLayout.CAL_SEARCH -> CAL_SEARCH
      CalendarAppLayout.CAL_NOTIFICATIONS_OPEN -> CAL_NOTIFICATIONS_OPEN
      CAL_SEARCH {
        value : string
      }
        @description "Triggers a search operation for calendar entries."
        @synonyms "find, query, lookup, browse"
        @tier "domain"
      CAL_NOTIFICATIONS_OPEN {
        id : string
      }
        @description "Indicates new calendar notifications are available."
        @synonyms "alert, notify, reminder"
        @tier "domain"
    }
  }

  trait CalendarView = Calendar.traits.CalendarEventCalendar {
    config {
      title: Schedule
      dateField: startTime
      labelField: title
    }

    listens {
      CalendarBrowseList.BrowseItemLoaded -> INIT
    }
  }

  trait CalendarBrowseList = Browse.traits.BrowseItemBrowse -> ScheduledEvent {
    config {
      fields: [{
        icon: calendar
        name: title
        variant: h4
      }, {
        format: date
        name: startTime
        variant: caption
      }, {
        format: date
        name: endTime
        variant: caption
      }, { name: location, variant: body }, { name: attendees, variant: caption }]
      itemActions: [{
        event: VIEW
        label: View
        variant: ghost
      }, {
        event: EDIT
        label: Edit
        variant: ghost
      }, {
        event: DELETE
        label: Delete
        variant: danger
      }]
      cols: 1
      gap: sm
    }

    listens {
      CalendarPersistor.CAL_CREATED -> INIT
      CalendarPersistor.CAL_UPDATED -> INIT
      CalendarPersistor.CAL_DELETED -> INIT
    }
  }

  trait CalendarCreate = Modal.traits.ModalRecordModal -> ScheduledEvent {
    events {
      OPEN: CREATE
    }

    config {
      icon: plus-circle
      title: "New Event"
      mode: create
      fields: (title startTime endTime location attendees description)
    }

    listens {
      CalendarCatalog.CREATE -> CREATE
      CREATE {
        id : string
        row : ScheduledEvent
      }
        @description "A new record is being created."
        @synonyms "new, add, insert, generate"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data persistence triggered by user action."
        @synonyms "persist, store, commit, update"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data fetch failed"
        @tier "internal"
    }
  }

  trait CalendarEdit = Modal.traits.ModalRecordModal -> ScheduledEvent {
    events {
      OPEN: EDIT
    }

    config {
      icon: edit
      title: "Edit Event"
      mode: edit
      fields: (title startTime endTime location attendees description)
    }

    listens {
      CalendarBrowseList.EDIT -> EDIT
      EDIT {
        id : string
        row : ScheduledEvent
      }
        @description "Indicates a record is being modified."
        @synonyms "update, change, modify"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data persistence or synchronization has completed."
        @synonyms "persist, store, update, synchronize"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data fetch failure"
        @tier "internal"
    }
  }

  trait CalendarDelete = Confirmation.traits.ConfirmActionConfirmation -> ScheduledEvent {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete Event"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      CalendarBrowseList.DELETE -> DELETE
      DELETE {
        id : string
        row : ScheduledEvent
      }
        @description "Indicates a record has been removed."
        @synonyms "remove, discard, erase"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load requested data."
        @synonyms "error, failed, problem, unsuccessful"
        @tier "internal"
    }
  }

  trait CalendarPersistor -> CalendarEvent [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create ScheduledEvent ?data {
          emit: { success: CAL_CREATED }
        })
      DO_UPDATE -> idle
        (persist update ScheduledEvent ?data {
          emit: { success: CAL_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete ScheduledEvent ?id {
          emit: { success: CAL_DELETED }
        })
    }

    emits {
      CAL_CREATED -> external {
        id : string
      }
        @description "A new calendar entry has been created."
        @synonyms "new, added, scheduled"
        @tier "domain"
      CAL_UPDATED -> external {
        id : string
      }
        @description "Signals a change or update to calendar data."
        @synonyms "modified, changed, refreshed"
        @tier "domain"
      CAL_DELETED -> external {
        id : string
      }
        @description "Signals that a calendar item has been removed."
        @synonyms "removed, purged, discarded"
        @tier "domain"
    }

    listens {
      DO_CREATE {
        data : object!
      }
        @description "Initiates the creation of a new record."
        @synonyms "new, add, generate, initiate"
        @tier "domain"
      DO_UPDATE {
        data : object!
      }
        @description "Indicates a record has been modified and changes are pending."
        @synonyms "modified, changed, altered, updated"
        @tier "presentation"
      DO_DELETE {
        id : string
      }
        @description "Initiates the removal of a record."
        @synonyms "remove, discard, purge"
        @tier "domain"
      CalendarCreate.SAVE -> DO_CREATE
      CalendarEdit.SAVE -> DO_UPDATE
      CalendarDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/calendar" as CalendarPage -> CalendarAppLayout, CalendarCatalog, CalendarView, CalendarBrowseList, CalendarCreate, CalendarEdit, CalendarDelete, CalendarPersistor
}

orbital WidgetOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Browse from "std/behaviors/std-browse"

  uses Stats from "std/behaviors/std-stats"

  uses Graphs from "std/behaviors/std-graphs"

  entity Widget [persistent: widgets] {
    id : string!
    title : string! @description "The descriptive name or heading for the item." @synonyms "label, heading, name"
    type : string @description "Specifies the kind or category of the data." @synonyms "kind, category, class, record type" = metric
    dataSource : string @description "The origin or system providing the data." @synonyms "source, origin, provider" = ""
    value : number @description "Numerical data representing a specific value." @synonyms "amount, quantity, count, score" = 0
    label : string @description "A short, user-facing text identifying the item." @synonyms "title, heading, display name" = ""
    refreshInterval : number @description "Time between data updates, typically in seconds." @synonyms "interval, update frequency, refresh rate" = 0
  }

  trait WidgetAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: WIDGET_SEARCH
      NOTIFY_CLICK: WIDGET_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.WidgetCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: WIDGET_SEARCH
      notifications: []
      notificationClickEvent: WIDGET_NOTIFICATIONS_OPEN
    }
  }

  trait WidgetCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{ name: layout-dashboard, type: icon }, {
              content: Dashboard
              type: typography
              variant: h2
            }]
            direction: horizontal
            gap: sm
            type: stack
          }, { type: divider }, @trait.WidgetStats, @trait.WidgetGraphs, { type: divider }, @trait.WidgetBrowseList]
          direction: vertical
          gap: lg
          type: stack
        })
      WIDGET_SEARCH -> composing
      WIDGET_NOTIFICATIONS_OPEN -> composing
        (render-ui main {
          align: center
          children: [{ name: bell, type: icon }, {
            content: "No notifications"
            type: typography
            variant: h3
          }, {
            action: INIT
            label: Back
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: md
          type: stack
        })
    }

    listens {
      WidgetAppLayout.WIDGET_SEARCH -> WIDGET_SEARCH
      WidgetAppLayout.WIDGET_NOTIFICATIONS_OPEN -> WIDGET_NOTIFICATIONS_OPEN
      WIDGET_SEARCH {
        value : string
      }
        @description "Triggers a search for widgets based on a query."
        @synonyms "find, query, lookup, browse"
        @tier "domain"
      WIDGET_NOTIFICATIONS_OPEN {
        id : string
      }
        @description "Indicates new notifications are available for widgets."
        @synonyms "notify, alert, update, message"
        @tier "presentation"
    }
  }

  trait WidgetStats = Stats.traits.StatsItemStats {
    config {
      title: "Key Metrics"
      metrics: [{
        aggregation: count
        format: number
        icon: layout-dashboard
        label: Widgets
        variant: primary
      }, {
        aggregation: sum
        field: value
        format: number
        icon: trending-up
        label: "Total Value"
        variant: success
      }]
    }

    listens {
      WidgetBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait WidgetGraphs = Graphs.traits.GraphItemGraph {
    config {
      title: "Widgets by type"
      subtitle: Distribution
      chartType: pie
      categoryField: type
      aggregation: count
      height: 240
      showLegend: true
    }

    listens {
      WidgetBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait WidgetBrowseList = Browse.traits.BrowseItemBrowse -> Widget {
    config {
      fields: [{
        icon: layout-dashboard
        name: title
        variant: h4
      }, { name: type, variant: badge }, { name: label, variant: caption }, {
        format: number
        name: value
        variant: badge
      }, { name: dataSource, variant: caption }]
      itemActions: [{
        event: VIEW
        label: View
        variant: ghost
      }, {
        event: EDIT
        label: Edit
        variant: ghost
      }, {
        event: DELETE
        label: Delete
        variant: danger
      }]
      cols: 2
      gap: sm
    }

    listens {
      WidgetPersistor.WIDGET_CREATED -> INIT
      WidgetPersistor.WIDGET_UPDATED -> INIT
      WidgetPersistor.WIDGET_DELETED -> INIT
    }
  }

  trait WidgetView = Modal.traits.ModalRecordModal -> Widget {
    events {
      OPEN: VIEW
    }

    config {
      icon: eye
      title: "View Widget"
      mode: edit
      fields: (title type label value dataSource refreshInterval)
    }

    listens {
      WidgetBrowseList.VIEW -> VIEW
      VIEW {
        id : string
        row : Widget
      }
        @description "Indicates a record or item is being displayed."
        @synonyms "display, show, present, render"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, update, synchronize"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, loading problem"
        @tier "internal"
    }
  }

  trait WidgetEdit = Modal.traits.ModalRecordModal -> Widget {
    events {
      OPEN: EDIT
    }

    config {
      icon: edit
      title: "Edit Widget"
      mode: edit
      fields: (title type label value dataSource refreshInterval)
    }

    listens {
      WidgetBrowseList.EDIT -> EDIT
      EDIT {
        id : string
        row : Widget
      }
        @description "Indicates a record is being modified."
        @synonyms "modify, change, update"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, update, synchronize"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, data error"
        @tier "internal"
    }
  }

  trait WidgetDelete = Confirmation.traits.ConfirmActionConfirmation -> Widget {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete Widget"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      WidgetBrowseList.DELETE -> DELETE
      DELETE {
        id : string
        row : Widget
      }
        @description "Indicates a record has been removed."
        @synonyms "remove, discard, erase"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load an action or related data."
        @synonyms "error, failure, failed, problem"
        @tier "internal"
    }
  }

  trait WidgetPersistor -> Widget [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_UPDATE -> idle
        (persist update Widget ?data {
          emit: { success: WIDGET_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete Widget ?id {
          emit: { success: WIDGET_DELETED }
        })
    }

    emits {
      WIDGET_CREATED -> external {
        id : string
      }
        @description "A new widget has been generated or added."
        @synonyms "new, added, generated, created"
        @tier "domain"
      WIDGET_UPDATED -> external {
        id : string
      }
        @description "Signals a widget's data or appearance has been modified."
        @synonyms "refresh, change, update"
        @tier "presentation"
      WIDGET_DELETED -> external {
        id : string
      }
        @description "Signals a widget has been removed."
        @synonyms "removed, discarded, purged"
        @tier "presentation"
    }

    listens {
      DO_UPDATE {
        data : object!
      }
        @description "Indicates data has been modified and needs to be refreshed."
        @synonyms "refresh, reload, update, sync"
        @tier "domain"
      DO_DELETE {
        id : string
      }
        @description "Initiates the removal of a record."
        @synonyms "remove, discard, erase"
        @tier "domain"
      WidgetEdit.SAVE -> DO_UPDATE
      WidgetDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/widgets" as WidgetsPage -> WidgetAppLayout, WidgetCatalog, WidgetStats, WidgetGraphs, WidgetBrowseList, WidgetView, WidgetEdit, WidgetDelete, WidgetPersistor
}

orbital FeedOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Pagination from "std/behaviors/std-pagination"

  uses Browse from "std/behaviors/std-browse"

  entity FeedPost [persistent: feedposts] {
    id : string!
    title : string! @description "The descriptive name or heading for the item." @synonyms "label, heading, name"
    body : string @description "The main content or text of a message or note." @synonyms "content, text, message, details" = ""
    author : string @description "The individual or system creating the content." @synonyms "creator, originator, contributor" = ""
    postedAt : string @description "The date and time when the item was originally published." @synonyms "published date, creation date, posted date" = ""
    tags : string @description "Keywords or labels associated with the entity." @synonyms "keywords, labels, categories, tags" = ""
    pendingId : string @description "A unique identifier awaiting final assignment or processing." @synonyms "tempId, provisionalId, draftId" = ""
  }

  trait FeedAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: FEED_SEARCH
      NOTIFY_CLICK: FEED_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.FeedCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: FEED_SEARCH
      notifications: []
      notificationClickEvent: FEED_NOTIFICATIONS_OPEN
    }
  }

  trait FeedCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: rss, type: icon }, {
                content: Feed
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: CREATE
              icon: plus
              label: "New Post"
              type: button
              variant: primary
            }]
            direction: horizontal
            gap: md
            justify: between
            type: stack
          }, { type: divider }, @trait.FeedBrowseList, @trait.FeedPagination]
          direction: vertical
          gap: lg
          type: stack
        })
      FEED_SEARCH -> composing
      FEED_NOTIFICATIONS_OPEN -> composing
        (render-ui main {
          align: center
          children: [{ name: bell, type: icon }, {
            content: "No notifications"
            type: typography
            variant: h3
          }, {
            action: INIT
            label: Back
            type: button
            variant: ghost
          }]
          className: py-8
          direction: vertical
          gap: md
          type: stack
        })
    }

    emits {
      CREATE -> external {
        source : string
      }
        @description "Signals the creation of a new record."
        @synonyms "new, add, generate, initialize"
        @tier "domain"
    }

    listens {
      FeedAppLayout.FEED_SEARCH -> FEED_SEARCH
      FeedAppLayout.FEED_NOTIFICATIONS_OPEN -> FEED_NOTIFICATIONS_OPEN
      FEED_SEARCH {
        value : string
      }
        @description "Triggers a search operation within a feed."
        @synonyms "query, find, lookup"
        @tier "domain"
      FEED_NOTIFICATIONS_OPEN {
        id : string
      }
        @description "Indicates new feed notifications are available."
        @synonyms "notify, alert, update, message"
        @tier "presentation"
    }
  }

  trait FeedPagination = Pagination.traits.PagedItemPagination {
    config {
      pageSize: 10
    }

    listens {
      FeedBrowseList.BrowseItemLoaded -> ITEMS_LOADED
    }
  }

  trait FeedBrowseList = Browse.traits.BrowseItemBrowse -> FeedPost {
    config {
      fields: [{
        icon: rss
        name: title
        variant: h3
      }, { name: body, variant: body }, { name: author, variant: caption }, {
        format: date
        name: postedAt
        variant: caption
      }, { name: tags, variant: badge }]
      itemActions: [{
        event: VIEW
        label: View
        variant: ghost
      }, {
        event: EDIT
        label: Edit
        variant: ghost
      }, {
        event: DELETE
        label: Delete
        variant: danger
      }]
      cols: 1
      gap: sm
    }

    listens {
      FeedPersistor.FEED_CREATED -> INIT
      FeedPersistor.FEED_UPDATED -> INIT
      FeedPersistor.FEED_DELETED -> INIT
    }
  }

  trait FeedCreate = Modal.traits.ModalRecordModal -> FeedPost {
    events {
      OPEN: CREATE
    }

    config {
      icon: plus-circle
      title: "New Post"
      mode: create
      fields: (title body author postedAt tags)
    }

    listens {
      FeedCatalog.CREATE -> CREATE
      CREATE {
        id : string
        row : FeedPost
      }
        @description "A new record is being created."
        @synonyms "add, new, initiate, generate"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, synchronize, update"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load a record into a modal window."
        @synonyms "load error, failed load, record load failure"
        @tier "internal"
    }
  }

  trait FeedEdit = Modal.traits.ModalRecordModal -> FeedPost {
    events {
      OPEN: EDIT
    }

    config {
      icon: edit
      title: "Edit Post"
      mode: edit
      fields: (title body author postedAt tags)
    }

    listens {
      FeedBrowseList.EDIT -> EDIT
      EDIT {
        id : string
        row : FeedPost
      }
        @description "Indicates a record is being modified."
        @synonyms "update, change, modify"
        @tier "domain"
      SAVE {
        data : object!
      }
        @description "Data has been persisted or synchronized."
        @synonyms "persist, store, update, synchronize"
        @tier "domain"
      ModalRecordLoadFailed {
        error : string
        code : string
      }
        @description "Indicates failure to load a record into a modal window."
        @synonyms "load error, failed load, data error"
        @tier "internal"
    }
  }

  trait FeedDelete = Confirmation.traits.ConfirmActionConfirmation -> FeedPost {
    events {
      REQUEST: DELETE
      CONFIRM: CONFIRM_DELETE
    }

    config {
      icon: alert-triangle
      title: "Delete Post"
      alertMessage: "This action cannot be undone."
      confirmLabel: Delete
    }

    listens {
      FeedBrowseList.DELETE -> DELETE
      DELETE {
        id : string
        row : FeedPost
      }
        @description "Indicates a record is being removed."
        @synonyms "remove, erase, discard"
        @tier "domain"
      ConfirmActionLoadFailed {
        error : string
        code : string
      }
        @description "Indicates a failure to load requested data."
        @synonyms "error, failure, failed, problem"
        @tier "internal"
    }
  }

  trait FeedPersistor -> FeedPost [lifecycle, instance] {
    initial: idle

    state idle {
      INIT -> idle
      DO_CREATE -> idle
        (persist create FeedPost ?data {
          emit: { success: FEED_CREATED }
        })
      DO_UPDATE -> idle
        (persist update FeedPost ?data {
          emit: { success: FEED_UPDATED }
        })
      DO_DELETE -> idle
        (persist delete FeedPost ?id {
          emit: { success: FEED_DELETED }
        })
    }

    emits {
      FEED_CREATED -> external {
        id : string
      }
        @description "A new feed item has been created."
        @synonyms "posted, published, added"
        @tier "domain"
      FEED_UPDATED -> external {
        id : string
      }
        @description "Signals that the feed data has been refreshed or modified."
        @synonyms "refresh, update, new, changed"
        @tier "presentation"
      FEED_DELETED -> external {
        id : string
      }
        @description "Signals a feed item has been removed."
        @synonyms "removed, purged, archived"
        @tier "presentation"
    }

    listens {
      DO_CREATE {
        data : object!
      }
        @description "Initiates the creation of a new record."
        @synonyms "new, add, generate, initialize"
        @tier "domain"
      DO_UPDATE {
        data : object!
      }
        @description "Indicates data has been modified and requires synchronization."
        @synonyms "refresh, sync, changed, modified"
        @tier "domain"
      DO_DELETE {
        id : string
      }
        @description "Initiates the removal of a record."
        @synonyms "remove, discard, erase"
        @tier "domain"
      FeedCreate.SAVE -> DO_CREATE
      FeedEdit.SAVE -> DO_UPDATE
      FeedDelete.CONFIRM_DELETE -> DO_DELETE
    }
  }

  page "/feed" as FeedPage -> FeedAppLayout, FeedCatalog, FeedPagination, FeedBrowseList, FeedCreate, FeedEdit, FeedDelete, FeedPersistor
}

orbital NoteOrbital {
  uses AppShell from "std/behaviors/std-app-layout"

  uses Modal from "std/behaviors/std-modal"

  uses Confirmation from "std/behaviors/std-confirmation"

  uses Search from "std/behaviors/std-search"

  uses Browse from "std/behaviors/std-browse"

  entity Note [persistent: notes] {
    id : string!
    title : string! @description "The descriptive name or heading for the item." @synonyms "label, heading, name"
    body : string @description "The main content or text of a message or note." @synonyms "content, text, message, details" = ""
    tags : string @description "Keywords or labels associated with the entity." @synonyms "keywords, labels, categories, markers" = ""
    createdAt : string = ""
    updatedAt : string = ""
    pendingId : string @description "A unique identifier awaiting final assignment or processing." @synonyms "tempId, provisionalId, draftId" = ""
  }

  trait NoteAppLayout = AppShell.traits.AppLayout {
    events {
      SEARCH: NOTE_SEARCH
      NOTIFY_CLICK: NOTE_NOTIFICATIONS_OPEN
    }

    config {
      contentTrait: @trait.NoteCatalog
      appName: App
      navItems: [{
        href: "/contacts"
        icon: users
        label: Contacts
      }, {
        href: "/items"
        icon: package
        label: Items
      }, {
        href: "/activities"
        icon: activity
        label: Activities
      }, {
        href: "/tasks"
        icon: check-square
        label: Tasks
      }, {
        href: "/calendar"
        icon: calendar
        label: Calendar
      }, {
        href: "/widgets"
        icon: layout-dashboard
        label: Dashboard
      }, {
        href: "/feed"
        icon: rss
        label: Feed
      }, {
        href: "/notes"
        icon: file-text
        label: Notes
      }]
      searchEvent: NOTE_SEARCH
      notifications: []
      notificationClickEvent: NOTE_NOTIFICATIONS_OPEN
    }
  }

  trait NoteCatalog [interaction, instance] {
    initial: composing

    state composing {
      INIT -> composing
        (render-ui main {
          children: [{
            align: center
            children: [{
              align: center
              children: [{ name: file-text, type: icon }, {
                content: Notes
                type: typography
                variant: h2
              }]
              direction: horizontal
              gap: sm
              type: stack
            }, {
              action: CREATE
              icon: plus
