app std-game-hud "1.0.0"
"std-game-hud as a Function"

orbital HudStateOrbital {
  entity HudState [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
  }
  trait HudStateHud -> HudState [interaction] {
    state idle {
      INIT -> idle
        (fetch HudState)
        (render-ui main { type: "game-hud", position: "top-left", size: "md", transparent: false, stats: [{ label: "Name", value: "@entity.name" }, { label: "Description", value: "@entity.description" }, { label: "Status", value: "@entity.status" }, { label: "CreatedAt", value: "@entity.createdAt" }] })
      REFRESH -> idle
        (fetch HudState)
        (render-ui main { type: "game-hud", position: "top-left", size: "md", transparent: false, stats: [{ label: "Name", value: "@entity.name" }, { label: "Description", value: "@entity.description" }, { label: "Status", value: "@entity.status" }, { label: "CreatedAt", value: "@entity.createdAt" }] })
    }
  }
  page "/hudstates" as HudStateHudPage -> HudStateHud
}