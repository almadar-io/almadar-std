app std-push "1.0.0"
"std-push as a Function"
;;
;; External-event subscription atom. Wraps os/watch-http with a small
;; lifecycle state machine (idle -> subscribed ↔ reconnecting) using the
;; emit: config to turn incoming messages + failures into closed-circuit
;; events on the orbital's bus.
;;
;; Intra-frame: embed @trait.PushIndicator in a layout to show a live
;; connection status pill (see molecule std-push-activity-log).
;; Inter-frame: any trait can listens: PUSH_RECEIVED and react to payloads.

orbital PushSubscriberOrbital {
  entity PushSubscriber [runtime] {
    id : string!
    status : string
  }

  type PushReceived     = Event { message : string } "Fired on every incoming push frame"
  type PushDisconnected = Event { reason : string }  "Fired when the push connection drops"

  trait PushSubscriberIndicator -> PushSubscriber [interaction, instance] {
    initial: idle
    state idle {
      INIT -> connecting
        (fetch PushSubscriber)
        (os/watch-http "wss://push.example.com" {
          emit: {
            on_message: "PUSH_RECEIVED",
            failure: "PUSH_DISCONNECTED"
          }
        })
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "spinner", size: "sm" }, { type: "typography", content: "Connecting…", variant: "caption" }] })
    }
    state connecting {
      PUSH_RECEIVED -> subscribed
        (set @entity.status "subscribed")
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wifi", size: "sm", color: "success" }, { type: "typography", content: "Connected", variant: "caption" }] })
      PUSH_DISCONNECTED -> reconnecting
        (set @entity.status "reconnecting")
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wifi-off", size: "sm", color: "warning" }, { type: "typography", content: "Reconnecting…", variant: "caption" }] })
    }
    state subscribed {
      PUSH_RECEIVED -> subscribed
        (set @entity.status "subscribed")
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wifi", size: "sm", color: "success" }, { type: "typography", content: "Connected", variant: "caption" }] })
      PUSH_DISCONNECTED -> reconnecting
        (set @entity.status "reconnecting")
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wifi-off", size: "sm", color: "warning" }, { type: "typography", content: "Reconnecting…", variant: "caption" }] })
    }
    state reconnecting {
      PUSH_RECEIVED -> subscribed
        (set @entity.status "subscribed")
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wifi", size: "sm", color: "success" }, { type: "typography", content: "Connected", variant: "caption" }] })
      PUSH_DISCONNECTED -> reconnecting
        (render-ui main { type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "wifi-off", size: "sm", color: "destructive" }, { type: "typography", content: "Disconnected", variant: "caption" }] })
    }
    ;; consumers: any trait that needs live push feed (e.g. std-push-activity-log)
    emits {
      PUSH_RECEIVED external { message : string }
      PUSH_DISCONNECTED external { reason : string }
    }
    emits: [PushReceived, PushDisconnected]
    listens {
      PUSH_RECEIVED { message : string }
      PUSH_DISCONNECTED { reason : string }
    }
  }

  page "/push" as Push -> PushSubscriberIndicator
}
