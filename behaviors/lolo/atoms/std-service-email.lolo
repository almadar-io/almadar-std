;; app std-service-email

orbital ServiceEmailOrbital {
  entity ServiceEmail [runtime] {
    id : string
    name : string
    description : string
    status : string
    createdAt : string
    to : string
    subject : string
    body : string
    from : string
    sendStatus : string
    messageId : string
    error : string
  }
  trait ServiceEmailEmail -> ServiceEmail [interaction] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ServiceEmail)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "mail", size: "lg" }, { type: "typography", content: "ServiceEmail Email", variant: "h2" }] }, { type: "divider" }, { type: "input", label: "To", bind: "@entity.to", placeholder: "recipient@example.com" }, { type: "input", label: "Subject", bind: "@entity.subject", placeholder: "Email subject" }, { type: "textarea", label: "Body", bind: "@entity.body", placeholder: "Write your message..." }, { type: "button", label: "Send", event: "SEND", variant: "primary", icon: "send" }] })
      SEND -> sending
        (render-ui main { type: "loading-state", title: "Sending email...", message: "Delivering serviceemail email..." })
        (call-service email send { to: "@entity.to", subject: "@entity.subject", body: "@entity.body" })
    }
    state sending {
      SENT -> sent
        (set @entity.sendStatus sent)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle", size: "lg" }, { type: "alert", variant: "success", message: "Email sent successfully" }, { type: "button", label: "Send Another", event: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.sendStatus error)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "error-state", title: "Send Failed", message: "Could not deliver the email.", onRetry: "RETRY" }, { type: "stack", direction: "horizontal", gap: "sm", justify: "center", children: [{ type: "button", label: "Retry", event: "RETRY", variant: "primary", icon: "refresh-cw" }, { type: "button", label: "Reset", event: "RESET", variant: "ghost", icon: "rotate-ccw" }] }] })
    }
    state sent {
      RESET -> idle
        (set @entity.sendStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "mail", size: "lg" }, { type: "typography", content: "ServiceEmail Email", variant: "h2" }] }, { type: "divider" }, { type: "input", label: "To", bind: "@entity.to", placeholder: "recipient@example.com" }, { type: "input", label: "Subject", bind: "@entity.subject", placeholder: "Email subject" }, { type: "textarea", label: "Body", bind: "@entity.body", placeholder: "Write your message..." }, { type: "button", label: "Send", event: "SEND", variant: "primary", icon: "send" }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "mail", size: "lg" }, { type: "typography", content: "ServiceEmail Email", variant: "h2" }] }, { type: "divider" }, { type: "input", label: "To", bind: "@entity.to", placeholder: "recipient@example.com" }, { type: "input", label: "Subject", bind: "@entity.subject", placeholder: "Email subject" }, { type: "textarea", label: "Body", bind: "@entity.body", placeholder: "Write your message..." }, { type: "button", label: "Send", event: "SEND", variant: "primary", icon: "send" }] })
      RESET -> idle
        (set @entity.sendStatus idle)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "stretch", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "mail", size: "lg" }, { type: "typography", content: "ServiceEmail Email", variant: "h2" }] }, { type: "divider" }, { type: "input", label: "To", bind: "@entity.to", placeholder: "recipient@example.com" }, { type: "input", label: "Subject", bind: "@entity.subject", placeholder: "Email subject" }, { type: "textarea", label: "Body", bind: "@entity.body", placeholder: "Write your message..." }, { type: "button", label: "Send", event: "SEND", variant: "primary", icon: "send" }] })
    }
  }
  page "/serviceemails" -> ServiceEmailEmail
}