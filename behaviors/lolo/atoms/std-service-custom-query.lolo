app std-service-custom-query "1.0.0"
"std-service-custom-query as a Function"

orbital ServiceCustomQueryOrbital {
  entity ServiceCustomQuery [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    endpoint : string
    method : string = "GET"
    requestBody : string
    responseData : string
    statusCode : number = 0
    callStatus : string = "idle"
    error : string
  }

  type ServiceCustomQueryLoaded     = Event ServiceCustomQuery                  "Fired when ServiceCustomQuery finishes loading"
  type ServiceCustomQueryLoadFailed = Event { message : string } "Fired when ServiceCustomQuery fails to load"
  type ServiceCustomQueryCustomQueryApiCompleted = Event { result : object }
  type ServiceCustomQueryCustomQueryApiFailed = Event { error : string, code : string }
  trait ServiceCustomQueryCustomQuery -> ServiceCustomQuery [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ServiceCustomQuery { emit: { success: "ServiceCustomQueryLoaded", failure: "ServiceCustomQueryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Query Auth API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
      CALL_API -> calling
        (render-ui main { type: "loading-state", title: "Calling API...", message: "Sending request to servicecustomquery endpoint..." })
        (call-service custom-query-api execute { endpoint: "@entity.endpoint", method: "@entity.method", body: "@entity.requestBody" } { emit: { success: "ServiceCustomQueryCustomQueryApiCompleted", failure: "ServiceCustomQueryCustomQueryApiFailed" } })
    }
    state calling {
      API_RESPONSE -> complete
        (set @entity.responseData @payload.data)
        (set @entity.statusCode @payload.statusCode)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Response", variant: "h2" }, { type: "badge", label: "@entity.statusCode", variant: "info" }, { type: "code", content: "@entity.responseData", language: "json" }, { type: "button", label: "New Request", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "error-state", title: "Request Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state complete {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Query Auth API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Query Auth API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "search" }, { type: "typography", content: "Query Auth API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
    }
    listens {
      API_RESPONSE { data : string!, statusCode : number! }
      FAILED { error : string! }
          ServiceCustomQueryLoadFailed { message : string }
    
      ServiceCustomQueryCustomQueryApiFailed { error : string, code : string }
    }
    emits: [ServiceCustomQueryLoaded, ServiceCustomQueryLoadFailed, ServiceCustomQueryCustomQueryApiCompleted, ServiceCustomQueryCustomQueryApiFailed]
  }
  page "/servicecustomquerys" as ServiceCustomQueryPage -> ServiceCustomQueryCustomQuery
}