;; app std-agent-completion

orbital AgentCompletionOrbital {
  entity AgentCompletion [persistent: agentcompletions] {
    id : string
    name : string
    description : string
    status : string
    createdAt : string
    prompt : string
    response : string
    provider : string
    model : string
    error : string
    message : string
    notificationType : string
  }
  trait AgentCompletionModal -> AgentCompletion [interaction] {
    initial: closed
    state closed {
      INIT -> closed
        (ref AgentCompletion)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "AgentCompletion", variant: "h2" }] }, { type: "button", label: "Open", event: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      GENERATE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "sparkles", size: "md" }, { type: "typography", content: "AgentCompletion", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "badge", label: "@entity.provider" }, { type: "badge", label: "@entity.model" }] }, { type: "form-section", entity: "AgentCompletion", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["prompt"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (ref AgentCompletion)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "AgentCompletion", variant: "h2" }] }, { type: "button", label: "Open", event: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      SAVE -> closed
        (persist create AgentCompletion @payload.data)
        (render-ui modal null)
        (emit GENERATED)
        (ref AgentCompletion)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "AgentCompletion", variant: "h2" }] }, { type: "button", label: "Open", event: "GENERATE", variant: "primary", icon: "sparkles" }] }, { type: "divider" }, { type: "empty-state", icon: "sparkles", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
    }
    emits {
      SAVE
      GENERATED
    }
  }
  trait AgentCompletionNotification -> AgentCompletion [interaction] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch AgentCompletion)
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "AgentCompletion Status", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "sparkles", size: "lg" }, { type: "typography", content: "AgentCompletion Status", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] })
      HIDE -> hidden
        (set @entity.message "")
    }
  }
  trait AgentCompletionAgent -> AgentCompletion [interaction] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentCompletion)
        (render-ui main { type: "empty-state", icon: "sparkles", title: "Completion", description: "Completion is ready" })
      DO_GENERATE -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
      GENERATED -> generating
        (set @entity.status generating)
        (agent/generate @entity.prompt)
    }
    state generating {
      DO_GENERATE -> completed
        (set @entity.response @payload.data.prompt)
        (set @entity.status completed)
        (emit SHOW)
      RESET -> error
        ? (= @entity.status generating)
        (set @entity.status error)
        (set @entity.error "Generation was cancelled")
    }
    state completed {
      RESET -> idle
        (set @entity.status idle)
        (set @entity.response "")
        (set @entity.prompt "")
    }
    state error {
      RETRY -> generating
        ? (= @entity.status error)
        (set @entity.status generating)
        (set @entity.error "")
        (agent/generate @entity.prompt)
      RESET -> idle
        (set @entity.status idle)
        (set @entity.error "")
    }
    emits {
      SHOW internal { response: string }
    }
    listens {
      * GENERATED -> GENERATED
    }
  }
  page "/agentcompletions" -> AgentCompletionModal, AgentCompletionNotification, AgentCompletionAgent
}