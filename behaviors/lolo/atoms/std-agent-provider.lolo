;; app std-agent-provider

orbital AgentProviderOrbital {
  entity AgentProvider [persistent: agentproviders] {
    id : string
    name : string
    description : string
    status : string
    createdAt : string
    currentProvider : string
    currentModel : string
    fallbackProvider : string
    requestCount : number
    message : string
    notificationType : string
  }
  trait AgentProviderModal -> AgentProvider [interaction] {
    initial: closed
    state closed {
      INIT -> closed
        (ref AgentProvider)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", event: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      SWITCH -> open
        (fetch AgentProvider)
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "repeat", size: "md" }, { type: "typography", content: "Switch Provider", variant: "h3" }] }, { type: "divider" }, { type: "stack", direction: "horizontal", gap: "md", children: [{ type: "typography", variant: "caption", content: "Current:" }, { type: "badge", label: "@entity.currentProvider" }, { type: "badge", label: "@entity.currentModel" }] }, { type: "form-section", entity: "AgentProvider", mode: "edit", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["currentProvider", "currentModel"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (notify Cancelled info)
        (ref AgentProvider)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", event: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
      SAVE -> closed
        (persist update AgentProvider @payload.data)
        (render-ui modal null)
        (emit SWITCHED)
        (ref AgentProvider)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", children: [{ type: "stack", direction: "horizontal", gap: "md", children: [{ type: "icon", name: "repeat", size: "lg" }, { type: "typography", content: "Switch Provider", variant: "h2" }] }, { type: "button", label: "Open", event: "SWITCH", variant: "primary", icon: "repeat" }] }, { type: "divider" }, { type: "empty-state", icon: "repeat", title: "Nothing open", description: "Click Open to view details in a modal overlay." }] })
    }
    emits {
      SAVE
      SWITCHED
    }
  }
  trait AgentProviderNotification -> AgentProvider [interaction] {
    initial: hidden
    state hidden {
      INIT -> hidden
        (fetch AgentProvider)
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "server", size: "lg" }, { type: "typography", content: "Provider Status", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] })
    }
    state visible {
      SHOW -> visible
        (set @entity.message @payload.message)
        (set @entity.notificationType @payload.notificationType)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "md", align: "center", children: [{ type: "icon", name: "server", size: "lg" }, { type: "typography", content: "Provider Status", variant: "h2" }] }, { type: "button", label: "Dismiss", event: "HIDE", variant: "ghost", icon: "x" }] }, { type: "divider" }, { type: "alert", variant: ["object/get", ["array/first", "@entity"], "notificationType"], message: ["object/get", ["array/first", "@entity"], "message"] }, { type: "toast-slot", position: "top-right" }, { type: "violation-alert", severity: "warning", message: ["object/get", ["array/first", "@entity"], "message"], category: "compliance" }] })
      HIDE -> hidden
        (set @entity.message "")
    }
  }
  trait AgentProviderAgent -> AgentProvider [interaction] {
    initial: idle
    state idle {
      INIT -> active
        (fetch AgentProvider)
        (agent/provider)
        (agent/model)
        (render-ui main { type: "empty-state", icon: "repeat", title: "Provider", description: "Provider is ready" })
      DO_SWITCH -> switching
        (agent/switch-provider @payload.data.currentProvider @payload.data.currentModel)
        (set @entity.currentProvider @payload.data.currentProvider)
        (set @entity.currentModel @payload.data.currentModel)
    }
    state active {
      DO_SWITCH -> switching
        (agent/switch-provider @payload.data.currentProvider @payload.data.currentModel)
        (set @entity.currentProvider @payload.data.currentProvider)
        (set @entity.currentModel @payload.data.currentModel)
      SWITCHED -> switching
        (agent/switch-provider @entity.currentProvider @entity.currentModel)
      SWITCH_AUTO -> switching
        (agent/switch-provider @entity.fallbackProvider)
        (set @entity.currentProvider @entity.fallbackProvider)
    }
    state switching {
      INIT -> active
        (agent/provider)
        (agent/model)
        (set @entity.requestCount (+ @entity.requestCount 1))
        (emit SHOW)
    }
    emits {
      SHOW internal { provider: string, model: string }
    }
    listens {
      * SWITCHED -> SWITCHED
    }
  }
  page "/agentproviders" -> AgentProviderModal, AgentProviderNotification, AgentProviderAgent
}