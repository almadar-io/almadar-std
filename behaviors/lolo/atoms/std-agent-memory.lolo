app std-agent-memory "1.0.0"
"std-agent-memory as a Function"

orbital AgentMemoryOrbital {
  entity AgentMemory [persistent: agentmemorys] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    content : string = ""
    category : string = "general"
    strength : number = 1
    pinned : boolean = false
    scope : string = "session"
    lastAccessedAt : string = ""
  }

  type AgentMemoryLoaded     = Event AgentMemory          "Fired when AgentMemory finishes loading"
  type AgentMemoryLoadFailed = Event { message : string } "Fired when AgentMemory fails to load"
  type Memorized             = Event { id : string }      "Fired after an agent memory is created"
  type Pinned                = Event { id : string }      "Fired after a memory is pinned"
  type Forgot                = Event { id : string }      "Fired after a memory is forgotten"
  type Reinforced            = Event { id : string }      "Fired after a memory is reinforced"
  type Decayed               = Event { id : string }      "Fired after the decay sweep completes"

  trait AgentMemoryBrowse -> AgentMemory [interaction, collection] {
    initial: loading
    state loading {
      INIT -> loading
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "spinner", size: "lg" }, { type: "typography", variant: "caption", color: "muted", content: "Loading memories…" }] })
      AgentMemoryLoaded -> browsing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "brain", size: "lg" }, { type: "typography", content: "AgentMemory Manager", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Memorize", event: "MEMORIZE", variant: "primary", icon: "plus" }, { type: "button", label: "Recall", event: "RECALL", variant: "secondary", icon: "search" }, { type: "button", label: "Decay All", event: "DECAY", variant: "ghost", icon: "clock" }] }] }, { type: "divider" }, { type: "data-grid", entity: "AgentMemory", emptyIcon: "inbox", emptyTitle: "No memories yet", emptyDescription: "Create your first memory to get started.", itemActions: [{ label: "Pin", event: "PIN", variant: "ghost", size: "sm" }, { label: "Reinforce", event: "REINFORCE", variant: "ghost", size: "sm" }, { label: "Forget", event: "FORGET", variant: "danger", size: "sm" }], columns: [{ name: "content", label: "Content", variant: "h4", icon: "brain" }, { name: "category", label: "Category", variant: "badge" }, { name: "strength", label: "Strength", variant: "caption" }] }] })
      AgentMemoryLoadFailed -> error
        (render-ui main { type: "stack", direction: "vertical", gap: "md", align: "center", className: "py-12", children: [{ type: "icon", name: "alert-triangle", size: "xl", color: "destructive" }, { type: "typography", variant: "h3", content: "Failed to load memories" }, { type: "typography", variant: "body", color: "muted", content: "@payload.message" }, { type: "button", label: "Retry", event: "INIT", variant: "primary", icon: "rotate-ccw" }] })
    }
    state browsing {
      INIT -> loading
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "spinner", size: "lg" })
    }
    state error {
      INIT -> loading
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "spinner", size: "lg" })
    }
    listens {
      * MEMORIZED -> INIT
      AgentMemoryAgent PINNED -> INIT
      AgentMemoryAgent FORGOT -> INIT
      AgentMemoryAgent REINFORCED -> INIT
      AgentMemoryAgent DECAYED -> INIT
      PIN { id : string!, row : object }
      REINFORCE { id : string!, row : object }
      FORGET { id : string!, row : object }
      AgentMemoryLoadFailed { message : string }
    }
    emits: [AgentMemoryLoaded, AgentMemoryLoadFailed]
  }
  trait AgentMemoryCreate -> AgentMemory [interaction, instance] {
    initial: closed
    state closed {
      INIT -> closed
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
      MEMORIZE -> open
        (render-ui modal { type: "stack", direction: "vertical", gap: "md", children: [{ type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "icon", name: "plus-circle", size: "md" }, { type: "typography", content: "Memorize", variant: "h3" }] }, { type: "divider" }, { type: "form-section", entity: "AgentMemory", mode: "create", submitEvent: "SAVE", cancelEvent: "CLOSE", fields: ["content", "category", "scope"] }] })
    }
    state open {
      CLOSE -> closed
        (render-ui modal null)
        (render-ui main { type: "box" })
        (notify Cancelled info)
      SAVE -> closed
        (persist create AgentMemory @payload.data)
        (emit MEMORIZED { id: "@payload.data.id" })
        (render-ui modal null)
        (render-ui main { type: "box" })
    }
    ;; consumers: AgentMemoryBrowse.listens * MEMORIZED -> INIT triggers refresh; downstream agents may listen
    emits {
      MEMORIZED external { id: string }
    }
    emits: [AgentMemoryLoaded, AgentMemoryLoadFailed]
    listens {
      SAVE { data : object! }
    }
  }
  trait AgentMemoryAgent -> AgentMemory [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "brain", title: "Memory", description: "Memory is ready" })
      DO_MEMORIZE -> active
        (agent/memorize @payload.data.content @payload.data.category)
        (persist create AgentMemory @payload.data)
        (emit MEMORIZED { id: "@payload.data.id" })
      DECAY -> idle
        (agent/decay)
        (emit DECAYED { id: "" })
      MEMORIZED -> active
        (fetch AgentMemory { emit: { success: "AgentMemoryLoaded", failure: "AgentMemoryLoadFailed" } })
    }
    state active {
      RECALL -> active
        (agent/recall @payload.query)
      PIN -> active when (not (agent/is-pinned @payload.id))
        (agent/pin @payload.id)
        (set @entity.pinned true)
        (emit PINNED { id: "@payload.id" })
      FORGET -> idle
        (agent/forget @payload.id)
        (emit FORGOT { id: "@payload.id" })
      REINFORCE -> active
        (agent/reinforce @payload.id)
        (emit REINFORCED { id: "@payload.id" })
      DECAY -> active
        (agent/decay)
        (emit DECAYED { id: "" })
    }
    ;; consumers: AgentMemoryBrowse.listens * wildcards pick up each emit
    emits {
      FORGOT external { id: string }
      REINFORCED external { id: string }
      DECAYED external { id: string }
      PINNED external { id: string }
      MEMORIZED external { id: string }
    }
    emits: [AgentMemoryLoaded, AgentMemoryLoadFailed]
    listens {
      DO_MEMORIZE { data : object! }
      RECALL { query : string! }
      PIN { id : string! }
      FORGET { id : string! }
      REINFORCE { id : string! }
      MEMORIZED { data : object! }
    }
  }
  page "/agentmemorys" as AgentMemoryPage -> AgentMemoryBrowse, AgentMemoryCreate, AgentMemoryAgent
}