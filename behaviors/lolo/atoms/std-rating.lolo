app std-rating "1.0.0"
"std-rating as a Function"

orbital ReviewOrbital {
  entity Review [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    rating : number = 0
    comment : string = ""
  }

  type ReviewLoaded     = Event Review                  "Fired when Review finishes loading"
  type ReviewLoadFailed = Event { message : string } "Fired when Review fails to load"
  trait ReviewRating -> Review [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch Review { emit: { success: "ReviewLoaded", failure: "ReviewLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "star" }, { type: "typography", content: "Rating", variant: "h2" }] }, { type: "divider" }, { type: "typography", variant: "body", color: "muted", content: "How would you rate this?" }, { type: "star-rating", value: ["object/get", ["array/first", "@entity"], "rating"], max: 5, action: "RATE" }, { type: "button", label: "Submit Rating", action: "RATE", variant: "primary", icon: "star" }] })
      RATE -> rated
        (set @entity.rating @payload.rating)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Thank You!", variant: "h2" }] }, { type: "divider" }, { type: "star-rating", value: ["object/get", ["array/first", "@entity"], "rating"], max: 5, readOnly: true }, { type: "alert", variant: "success", message: "Your rating has been recorded." }, { type: "button", label: "Rate Again", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
    }
    state rated {
      RESET -> idle
        (set @entity.rating 0)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "star" }, { type: "typography", content: "Rating", variant: "h2" }] }, { type: "divider" }, { type: "typography", variant: "body", color: "muted", content: "How would you rate this?" }, { type: "star-rating", value: ["object/get", ["array/first", "@entity"], "rating"], max: 5, action: "RATE" }, { type: "button", label: "Submit Rating", action: "RATE", variant: "primary", icon: "star" }] })
    }
    listens {
      RATE { rating : number! }
          ReviewLoadFailed { message : string }
    }
    emits: [ReviewLoaded, ReviewLoadFailed]
  }
  page "/reviews/rating" as ReviewRatingPage -> ReviewRating
}