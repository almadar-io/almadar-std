app std-agent-chat-thread "1.0.0"
"std-agent-chat-thread as a Function"

orbital AgentChatThreadOrbital {
  entity AgentChatThread [persistent: agentchatthreads] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    role : string = "user"
    content : string = ""
    timestamp : string = ""
    toolName : string = ""
  }

  type AgentChatThreadLoaded     = Event AgentChatThread                  "Fired when AgentChatThread finishes loading"
  type AgentChatThreadLoadFailed = Event { message : string } "Fired when AgentChatThread fails to load"
  type AgentChatThreadDeleted = Event { id : string }
  type AgentChatThreadDeleteFailed = Event { error : string, code : string }
  type AgentChatThreadSaved = Event { id : string }
  type AgentChatThreadSaveFailed = Event { error : string, code : string }
  trait AgentChatThreadThread -> AgentChatThread [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentChatThread { emit: { success: "AgentChatThreadLoaded", failure: "AgentChatThreadLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle"}, { type: "typography", content: "AgentChatThread Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-list", entity: "@entity", fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "outline" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }] })
      COMPOSE -> composing
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle"}, { type: "typography", content: "AgentChatThread Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus"}] }, { type: "divider" }, { type: "data-list", entity: "@entity", fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "outline" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }, { type: "form-section", fields: [], title: "Compose Message", children: [{ type: "textarea", placeholder: "Type your message..." }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Send", action: "SEND", variant: "primary", icon: "send" }] }] }] })
      CLEAR -> idle
        (persist delete AgentChatThread  { emit: { success: "AgentChatThreadDeleted", failure: "AgentChatThreadDeleteFailed" } })
        (fetch AgentChatThread { emit: { success: "AgentChatThreadLoaded", failure: "AgentChatThreadLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle"}, { type: "typography", content: "AgentChatThread Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-list", entity: "@entity", fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "outline" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }] })
    }
    state composing {
      SEND -> idle
        (set @entity.content @payload.content)
        (set @entity.role user)
        (set @entity.timestamp @now)
        (set @entity.status sent)
        (persist create AgentChatThread { role: "user", content: "@payload.content", timestamp: "@now", status: "sent" } { emit: { success: "AgentChatThreadSaved", failure: "AgentChatThreadSaveFailed" } })
        (emit SEND_MESSAGE)
        (fetch AgentChatThread { emit: { success: "AgentChatThreadLoaded", failure: "AgentChatThreadLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle"}, { type: "typography", content: "AgentChatThread Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-list", entity: "@entity", fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "outline" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }] })
      CLEAR -> idle
        (persist delete AgentChatThread  { emit: { success: "AgentChatThreadDeleted", failure: "AgentChatThreadDeleteFailed" } })
        (fetch AgentChatThread { emit: { success: "AgentChatThreadLoaded", failure: "AgentChatThreadLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "sm", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "message-circle"}, { type: "typography", content: "AgentChatThread Thread", variant: "h2" }] }, { type: "button", label: "New Message", action: "COMPOSE", variant: "primary", icon: "plus" }] }, { type: "divider" }, { type: "data-list", entity: "@entity", fields: [], renderItem: ["fn", "item", { type: "stack", direction: "vertical", gap: "xs", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "badge", label: "@item.role" }, { type: "badge", label: "@item.status", variant: "outline" }, { type: "typography", variant: "caption", color: "muted", content: "@item.timestamp" }] }, { type: "typography", variant: "body", content: "@item.content" }] }] }] })
    }
    emits {
      SEND_MESSAGE internal { content: string }
    }
    listens {
      SEND { content : string! }
          AgentChatThreadLoadFailed { message : string }
    
      AgentChatThreadDeleteFailed { error : string, code : string }
      AgentChatThreadSaveFailed { error : string, code : string }
    }
    emits: [AgentChatThreadLoaded, AgentChatThreadLoadFailed, AgentChatThreadDeleted, AgentChatThreadDeleteFailed, AgentChatThreadSaved, AgentChatThreadSaveFailed]
  }
  page "/agentchatthreads" as AgentChatThreadPage -> AgentChatThreadThread
}