app std-service-custom-header "1.0.0"
"std-service-custom-header as a Function"

orbital ServiceCustomHeaderOrbital {
  entity ServiceCustomHeader [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    endpoint : string
    method : string = "GET"
    requestBody : string
    responseData : string
    statusCode : number = 0
    callStatus : string = "idle"
    error : string
  }

  type ServiceCustomHeaderLoaded     = Event ServiceCustomHeader                  "Fired when ServiceCustomHeader finishes loading"
  type ServiceCustomHeaderLoadFailed = Event { message : string } "Fired when ServiceCustomHeader fails to load"
  trait ServiceCustomHeaderCustomHeader -> ServiceCustomHeader [interaction, instance] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch ServiceCustomHeader { emit: { success: "ServiceCustomHeaderLoaded", failure: "ServiceCustomHeaderLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", bind: "@entity.method", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
      CALL_API -> calling
        (render-ui main { type: "loading-state", title: "Calling API...", message: "Sending request to servicecustomheader endpoint..." })
        (call-service custom-header-api execute { endpoint: "@entity.endpoint", method: "@entity.method", body: "@entity.requestBody" })
    }
    state calling {
      API_RESPONSE -> complete
        (set @entity.responseData @payload.data)
        (set @entity.statusCode @payload.statusCode)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "check-circle" }, { type: "typography", content: "Response", variant: "h2" }, { type: "badge", content: "@entity.statusCode", variant: "info" }, { type: "code", content: "@entity.responseData", language: "json" }, { type: "button", label: "New Request", action: "RESET", variant: "ghost", icon: "rotate-ccw" }] })
      FAILED -> error
        (set @entity.error @payload.error)
        (render-ui main { type: "error-state", title: "Request Failed", message: "@entity.error", onRetry: "RETRY" })
    }
    state complete {
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", bind: "@entity.method", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
    }
    state error {
      RETRY -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", bind: "@entity.method", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
      RESET -> idle
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", align: "center", children: [{ type: "icon", name: "globe" }, { type: "typography", content: "API Tester", variant: "h2" }, { type: "input", placeholder: "/users" }, { type: "select", bind: "@entity.method", options: [{ label: "GET", value: "GET" }, { label: "POST", value: "POST" }, { label: "PUT", value: "PUT" }, { label: "DELETE", value: "DELETE" }] }, { type: "textarea", placeholder: "JSON request body" }, { type: "button", label: "Send Request", action: "CALL_API", variant: "primary", icon: "send" }] })
    }
    listens {
      API_RESPONSE { data : string!, statusCode : number! }
      FAILED { error : string! }
          ServiceCustomHeaderLoadFailed { message : string }
    }
    emits: [ServiceCustomHeaderLoaded, ServiceCustomHeaderLoadFailed]
  }
  page "/servicecustomheaders" as ServiceCustomHeaderPage -> ServiceCustomHeaderCustomHeader
}