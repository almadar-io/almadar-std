app std-gallery "1.0.0"
"std-gallery as a Function"

orbital GalleryItemOrbital {
  entity GalleryItem [runtime] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    imageUrl : string = "https://picsum.photos/seed/gallery/800/600"
  }

  type GalleryItemLoaded     = Event GalleryItem                  "Fired when GalleryItem finishes loading"
  type GalleryItemLoadFailed = Event { message : string } "Fired when GalleryItem fails to load"
  trait GalleryItemGallery -> GalleryItem [interaction, collection] {
    initial: browsing
    state browsing {
      INIT -> browsing
        (fetch GalleryItem { emit: { success: "GalleryItemLoaded", failure: "GalleryItemLoadFailed" } })
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "image" }, { type: "typography", content: "GalleryItems Gallery", variant: "h2" }] }, { type: "typography", variant: "caption", color: "muted", content: "Click any image to view full size" }] }, { type: "divider" }, { type: "data-grid", entity: "GalleryItem", cols: 3, gap: "md", imageField: "imageUrl", itemActions: [{ label: "View", event: "VIEW", icon: "maximize" }], fields: [{ name: "name", label: "Title", variant: "h4" }, { name: "status", label: "Status", variant: "badge" }] }] })
      VIEW -> viewing
        (render-ui modal { type: "lightbox", isOpen: true, closeAction: "CLOSE", images: [{ src: "https://picsum.photos/seed/gallery1/800/600", alt: "Mountain landscape", caption: "Mountain landscape" }, { src: "https://picsum.photos/seed/gallery2/800/600", alt: "Ocean sunset", caption: "Ocean sunset" }, { src: "https://picsum.photos/seed/gallery3/800/600", alt: "Forest trail", caption: "Forest trail" }], currentIndex: 0, showCounter: true })
    }
    state viewing {
      CLOSE -> browsing
        (render-ui modal null)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "image" }, { type: "typography", content: "GalleryItems Gallery", variant: "h2" }] }, { type: "typography", variant: "caption", color: "muted", content: "Click any image to view full size" }] }, { type: "divider" }, { type: "data-grid", entity: "GalleryItem", cols: 3, gap: "md", imageField: "imageUrl", itemActions: [{ label: "View", event: "VIEW", icon: "maximize" }], fields: [{ name: "name", label: "Title", variant: "h4" }, { name: "status", label: "Status", variant: "badge" }] }] })
    }
    listens {
      VIEW { id : string! }
          GalleryItemLoadFailed { message : string }
    }
    emits: [GalleryItemLoaded, GalleryItemLoadFailed]
  }
  page "/galleryitems/gallery" as GalleryItemGalleryPage -> GalleryItemGallery
}