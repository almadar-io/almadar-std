;; app std-agent-search

orbital AgentSearchOrbital {
  entity AgentSearch [persistent: agentsearchs] {
    id : string
    name : string
    description : string
    status : string
    createdAt : string
    query : string
    results : [string]
    language : string
    resultCount : number
  }
  trait AgentSearchBrowse -> AgentSearch [interaction] {
    state browsing {
      INIT -> browsing
        (ref AgentSearch)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "space-between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "search", size: "lg" }, { type: "typography", content: "AgentSearch", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Search", event: "SEARCH", variant: "primary", icon: "search" }, { type: "button", label: "Clear", event: "CLEAR", variant: "ghost", icon: "x" }] }] }, { type: "divider" }, { type: "data-grid", entity: "AgentSearch", emptyIcon: "inbox", emptyTitle: "No search results", emptyDescription: "Enter a query to search the codebase.", itemActions: [{ label: "View", event: "VIEW", variant: "ghost", size: "sm" }], columns: [{ name: "query", label: "Query", variant: "h4", icon: "search" }, { name: "language", label: "Language", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "resultCount", label: "Result Count", variant: "caption" }] }] })
    }
    listens {
      * SEARCHED -> INIT
    }
  }
  trait AgentSearchAgent -> AgentSearch [interaction] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentSearch)
        (render-ui main { type: "empty-state", icon: "search", title: "Code Search", description: "Code Search is ready" })
      SEARCH -> searching
        (set @entity.query @payload.query)
        (set @entity.language @payload.language)
        (agent/search-code @payload.query @payload.language)
    }
    state searching {
      SEARCH -> results
        (fetch AgentSearch)
        (emit SEARCHED)
    }
    state results {
      SEARCH -> searching
        (set @entity.query @payload.query)
        (set @entity.language @payload.language)
        (agent/search-code @payload.query @payload.language)
      CLEAR -> idle
        (set @entity.query "")
        (set @entity.results [])
        (set @entity.language "")
        (set @entity.resultCount 0)
    }
    emits {
      SEARCHED external { query: string, resultCount: number }
    }
    listens {
      * SEARCHED -> INIT
    }
  }
  page "/agentsearchs" -> AgentSearchBrowse, AgentSearchAgent
}