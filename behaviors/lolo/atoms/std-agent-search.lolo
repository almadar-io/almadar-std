app std-agent-search "1.0.0"
"std-agent-search as a Function"

orbital AgentSearchOrbital {
  entity AgentSearch [persistent: agentsearchs] {
    id : string
    name : string
    description : string
    status : "active" | "inactive" | "pending" = "active"
    createdAt : string
    query : string = ""
    results : [string] = []
    language : string = ""
    resultCount : number = 0
  }

  type AgentSearchLoaded     = Event AgentSearch                  "Fired when AgentSearch finishes loading"
  type AgentSearchLoadFailed = Event { message : string } "Fired when AgentSearch fails to load"
  trait AgentSearchBrowse -> AgentSearch [interaction, collection] {
    state browsing {
      INIT -> browsing
        (ref AgentSearch)
        (render-ui main { type: "stack", direction: "vertical", gap: "lg", className: "max-w-5xl mx-auto w-full", children: [{ type: "stack", direction: "horizontal", gap: "md", justify: "between", align: "center", children: [{ type: "stack", direction: "horizontal", gap: "sm", align: "center", children: [{ type: "icon", name: "search"}, { type: "typography", content: "AgentSearch", variant: "h2" }] }, { type: "stack", direction: "horizontal", gap: "sm", children: [{ type: "button", label: "Search", action: "SEARCH", variant: "primary", icon: "search" }, { type: "button", label: "Clear", action: "CLEAR", variant: "ghost", icon: "x" }] }] }, { type: "divider" }, { type: "data-grid", entity: "AgentSearch", itemActions: [{ label: "View", event: "VIEW", variant: "ghost"}], fields: [{ name: "query", label: "Query", variant: "h4", icon: "search" }, { name: "language", label: "Language", variant: "badge", colorMap: { active: "success", completed: "success", done: "success", pending: "warning", draft: "warning", scheduled: "warning", inactive: "neutral", archived: "neutral", disabled: "neutral", error: "destructive", cancelled: "destructive", failed: "destructive" } }, { name: "resultCount", label: "Result Count", variant: "caption" }] }] })
    }
    listens {
      AgentSearchAgent SEARCHED -> INIT
      VIEW { id : string!, row : object }
          AgentSearchLoadFailed { message : string }
    }
    emits: [AgentSearchLoaded, AgentSearchLoadFailed]
  }
  trait AgentSearchAgent -> AgentSearch [interaction, collection] {
    initial: idle
    state idle {
      INIT -> idle
        (fetch AgentSearch { emit: { success: "AgentSearchLoaded", failure: "AgentSearchLoadFailed" } })
        (render-ui main { type: "empty-state", icon: "search", title: "Code Search", description: "Code Search is ready" })
      SEARCH -> searching
        (set @entity.query @payload.query)
        (set @entity.language @payload.language)
        (agent/search-code @payload.query @payload.language)
    }
    state searching {
      SEARCH -> results
        (fetch AgentSearch { emit: { success: "AgentSearchLoaded", failure: "AgentSearchLoadFailed" } })
        (emit SEARCHED)
    }
    state results {
      SEARCH -> searching
        (set @entity.query @payload.query)
        (set @entity.language @payload.language)
        (agent/search-code @payload.query @payload.language)
      CLEAR -> idle
        (set @entity.query "")
        (set @entity.results [])
        (set @entity.language "")
        (set @entity.resultCount 0)
    }
    emits {
      SEARCHED external { query: string, resultCount: number }
    }
    listens {
      AgentSearchAgent SEARCHED -> INIT
      SEARCH { query : string!, language : string }
          AgentSearchLoadFailed { message : string }
    }
    emits: [AgentSearchLoaded, AgentSearchLoadFailed]
  }
  page "/agentsearchs" as AgentSearchPage -> AgentSearchBrowse, AgentSearchAgent
}