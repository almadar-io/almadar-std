                            {
                              "name": "@step.icon",
                              "size": "md",
                              "type": "icon"
                            },
                            {
                              "children": [
                                {
                                  "content": "@step.label",
                                  "type": "typography",
                                  "variant": "h4"
                                },
                                {
                                  "color": "muted",
                                  "content": "@step.description",
                                  "type": "typography",
                                  "variant": "caption"
                                }
                              ],
                              "direction": "vertical",
                              "gap": "xs",
                              "type": "stack"
                            }
                          ],
                          "className": "p-card-md",
                          "direction": "horizontal",
                          "gap": "md",
                          "type": "stack"
                        }
                      ],
                      "look": "@config.cardLook",
