                      "label": "Back",
                      "type": "button",
                      "variant": "ghost"
                    },
                    {
                      "align": "center",
                      "children": [
                        {
                          "action": "REJECT",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "icon": "x",
                          "label": "Reject",
                          "type": "button",
                          "variant": "ghost"
                        },
                        {
                          "action": "ESCALATE",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "icon": "alert-triangle",
                          "label": "Escalate",
                          "type": "button",
                          "variant": "ghost"
                        },
                        {
                          "action": "ADVANCE",
                          "actionPayload": {
                            "id": "@entity.id"
                          },
                          "icon": "@entity.primaryActionIcon",
                          "label": "@entity.primaryActionLabel",
