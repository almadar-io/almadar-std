[
  {
    "organism": "std-thread-comments-linear",
    "orbital": "CommentsLinearOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core-variations/atoms/std-thread-comments-linear.ts",
    "entities": [
      {
        "name": "CommentsLinearPost",
        "fields": [
          {
            "name": "parentId",
            "type": "string",
            "required": false,
            "description": "Identifier of the comment this comment replies to.",
            "synonyms": "parent, replyTo, source"
          },
          {
            "name": "threadRootId",
            "type": "string",
            "required": true,
            "description": "Identifier of the top-level comment in the thread.",
            "synonyms": "rootId, topLevelId, originId"
          },
          {
            "name": "authorId",
            "type": "string",
            "required": true,
            "description": "Unique identifier for the comment's author.",
            "synonyms": "user identifier, author reference, contributor ID"
          },
          {
            "name": "authorName",
            "type": "string",
            "required": true,
            "description": "The name of the comment's author.",
            "synonyms": "author, user, contributor"
          },
          {
            "name": "content",
            "type": "string",
            "required": true,
            "description": "The text of the comment or post.",
            "synonyms": "text, body, message, postContent"
          },
          {
            "name": "voteCount",
            "type": "number",
            "required": false,
            "description": "The number of votes or ratings associated with the comment.",
            "synonyms": "rating, score, likes, upvotes"
          },
          {
            "name": "replyCount",
            "type": "number",
            "required": false,
            "description": "The number of replies to this comment.",
            "synonyms": "child comments, responses, sub-comments"
          },
          {
            "name": "replies",
            "type": "relation",
            "required": false,
            "description": "A list of child comments in the thread.",
            "synonyms": "replies, children, descendants"
          },
          {
            "name": "focusedRow",
            "type": "object",
            "required": false,
            "description": "The currently selected comment within the comment thread.",
            "synonyms": "selected, active, highlighted"
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "CommentsLinear",
        "emittedEvents": [],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "bodyContent",
            "type": "unknown",
            "default": {
              "children": [
                {
                  "align": "center",
                  "children": [
                    {
                      "name": "message-square",
                      "size": "md",
                      "type": "icon"
                    },
                    {
                      "content": "@config.sectionTitle",
                      "type": "typography",
                      "variant": "h3"
                    }
                  ],
                  "direction": "horizontal",
                  "gap": "sm",
                  "type": "stack"
                },
                {
                  "children": {
                    "children": [
                      {
                        "content": "Add a comment",
                        "type": "typography",
                        "variant": "label"
                      },
                      {
                        "action": "EDIT_REPLY",
                        "inputType": "textarea",
                        "placeholder": "Share your thoughts…",
                        "rows": 3,
                        "type": "input"
                      },
                      {
                        "children": [
                          {
                            "action": "CANCEL_REPLY",
                            "label": "Cancel",
                            "size": "sm",
                            "type": "button",
                            "variant": "ghost"
                          },
                          {
                            "action": "SUBMIT_REPLY",
                            "icon": "send",
                            "label": "Comment",
                            "size": "sm",
                            "type": "button",
                            "variant": "primary"
                          }
                        ],
                        "direction": "horizontal",
                        "gap": "sm",
                        "justify": "end",
                        "type": "stack"
                      }
                    ],
                    "direction": "vertical",
                    "gap": "sm",
                    "type": "stack"
                  },
                  "look": "flat-bordered",
                  "padding": "md",
                  "type": "card"
                },
                {
                  "nodes": "@payload.data",
                  "replyEvent": "REPLY",
                  "showActions": true,
                  "type": "reply-tree"
                }
              ],
              "className": "w-full px-card-md py-section",
              "direction": "vertical",
              "gap": "lg",
              "type": "stack"
            }
          }
        ],
        "capabilities": [],
        "ref": "Thread.traits.ThreadPostBrowse"
      }
    ],
    "pages": [
      {
        "name": "CommentsLinearPage",
        "defaultPath": "/comments-thread",
        "primaryEntity": "CommentsLinearPost"
      }
    ],
    "emittedEvents": [],
    "listenedEvents": []
  }
]
