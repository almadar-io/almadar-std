            "type": "unknown",
            "default": "Cancel Request"
          },
          {
            "key": "icon",
            "type": "unknown",
            "default": "alert-triangle"
          },
          {
            "key": "title",
            "type": "unknown",
            "default": "Cancel Signature Request"
          }
