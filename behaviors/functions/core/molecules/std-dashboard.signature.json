[
  {
    "organism": "std-dashboard",
    "orbital": "DashboardItemOrbital",
    "tier": "molecules",
    "factoryPath": "behaviors/functions/core/molecules/std-dashboard.ts",
    "entities": [
      {
        "name": "DashboardItem",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": false,
            "description": "A human-readable identifier for the item.",
            "synonyms": "title, label, identifier"
          },
          {
            "name": "category",
            "type": "string",
            "required": false,
            "description": "The type or classification of the dashboard item.",
            "synonyms": "type, kind, group"
          },
          {
            "name": "status",
            "type": "string",
            "required": false,
            "description": "Indicates the current operational state of the item.",
            "synonyms": "state, condition, enabled, disabled"
          },
          {
            "name": "amount",
            "type": "number",
            "required": false,
            "description": "The numerical value being represented.",
            "synonyms": "value, quantity, count, total"
          },
          {
            "name": "units",
            "type": "number",
            "required": false,
            "description": "Represents a numerical measurement or quantity.",
            "synonyms": "value, count, measure"
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "DashboardSummary",
        "emittedEvents": [],
        "listenedEvents": [
          "BrowseItemLoaded"
        ],
        "overridableConfigKeys": [
          {
            "key": "metrics",
            "type": "unknown",
            "default": [
              {
                "aggregation": "count",
                "label": "Total Items",
                "icon": "list",
                "format": "number",
                "variant": "primary"
              },
              {
                "aggregation": "count",
                "variant": "success",
                "format": "number",
                "label": "Active",
                "icon": "check-circle",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ]
              },
              {
                "field": "amount",
                "target": 10000,
                "aggregation": "sum",
                "label": "Total Revenue",
                "variant": "info",
                "icon": "dollar-sign",
                "format": "currency"
              },
              {
                "label": "Avg Units",
                "icon": "trending-up",
                "aggregation": "avg",
                "field": "units",
                "variant": "default",
                "suffix": " units",
                "format": "number"
              }
            ]
          },
          {
            "key": "title",
            "type": "unknown",
            "default": "Summary"
          }
        ],
        "capabilities": [],
        "ref": "Stats.traits.StatsItemStats"
      },
      {
        "name": "DashboardCategoryChart",
        "emittedEvents": [],
        "listenedEvents": [
          "BrowseItemLoaded"
        ],
        "overridableConfigKeys": [
          {
            "key": "aggregation",
            "type": "unknown",
            "default": "count"
          },
          {
            "key": "categoryField",
            "type": "unknown",
            "default": "category"
          },
          {
            "key": "chartType",
            "type": "unknown",
            "default": "bar"
          },
          {
            "key": "height",
            "type": "unknown",
            "default": 280
          },
          {
            "key": "showLegend",
            "type": "unknown",
            "default": false
          },
          {
            "key": "subtitle",
            "type": "unknown",
            "default": "Count across categories"
          },
          {
            "key": "title",
            "type": "unknown",
            "default": "Items by Category"
          }
        ],
        "capabilities": [],
        "ref": "Graphs.traits.GraphItemGraph"
      },
      {
        "name": "DashboardStatusChart",
        "emittedEvents": [],
        "listenedEvents": [
          "BrowseItemLoaded"
        ],
        "overridableConfigKeys": [
          {
            "key": "aggregation",
            "type": "unknown",
            "default": "count"
          },
          {
            "key": "categoryField",
            "type": "unknown",
            "default": "status"
          },
          {
            "key": "chartType",
            "type": "unknown",
            "default": "donut"
          },
          {
            "key": "height",
            "type": "unknown",
            "default": 280
          },
          {
            "key": "showLegend",
            "type": "unknown",
            "default": true
          },
          {
            "key": "title",
            "type": "unknown",
            "default": "Status Mix"
          }
        ],
        "capabilities": [],
        "ref": "Graphs.traits.GraphItemGraph"
      },
      {
        "name": "DashboardItemBrowse",
        "emittedEvents": [],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "displayPageSize",
            "type": "unknown",
            "default": 5
          },
          {
            "key": "fields",
            "type": "unknown",
            "default": [
              {
                "label": "Name",
                "variant": "h4",
                "name": "name"
              },
              {
                "name": "category",
                "label": "Category",
                "variant": "caption"
              },
              {
                "variant": "badge",
                "name": "status",
                "label": "Status"
              },
              {
                "name": "amount",
                "label": "Amount",
                "variant": "caption"
              }
            ]
          },
          {
            "key": "pageSize",
            "type": "unknown",
            "default": 100
          }
        ],
        "capabilities": [],
        "ref": "Browse.traits.BrowseItemBrowse"
      },
      {
        "name": "DashboardLayout",
        "emittedEvents": [
          "DashboardItemLoaded",
          "DashboardItemLoadFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "Dashboard",
        "defaultPath": "/dashboard",
        "primaryEntity": "DashboardItem"
      }
    ],
    "emittedEvents": [
      "DashboardItemLoadFailed",
      "DashboardItemLoaded"
    ],
    "listenedEvents": [
      "BrowseItemLoaded"
    ]
  }
]
