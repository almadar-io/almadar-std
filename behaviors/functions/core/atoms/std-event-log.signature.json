          },
          {
            "name": "date",
            "type": "string",
            "required": false,
            "description": "The timestamp associated with the event.",
            "synonyms": "timestamp, time, occurred"
          },
          {
            "name": "allEntries",
            "type": "array",
            "required": false,
            "description": "An array of log entry objects.",
            "synonyms": "entries, records, items, data"
          },
          {
            "name": "entries",
