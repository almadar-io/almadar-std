          },
          {
            "name": "replyCount",
            "type": "number",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "ThreadPostBrowse",
        "emittedEvents": [
          "REPLY",
          "EDIT_REPLY",
          "SUBMIT_REPLY",
          "CANCEL_REPLY",
          "ThreadPostLoaded",
          "ThreadPostLoadFailed",
          "ThreadPostCreated",
          "ThreadPostCreateFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "bodyContent",
            "type": "render-ui",
            "default": {
              "type": "stack",
              "children": [
                {
                  "variant": "card",
                  "type": "data-list",
                  "look": "@config.tableLook",
                  "fields": [
                    {
                      "label": "Author",
                      "variant": "h4",
                      "name": "authorName"
                    },
                    {
                      "label": "",
                      "variant": "body",
                      "name": "content"
                    },
                    {
                      "label": "Votes",
                      "name": "voteCount",
                      "variant": "caption"
                    }
                  ],
                  "itemActions": [
                    {
                      "icon": "message-square",
                      "event": "REPLY",
                      "label": "Reply"
                    }
                  ],
                  "entity": "@payload.data",
                  "gap": "sm"
                }
              ],
              "gap": "md",
              "direction": "vertical"
            },
            "label": "Body content tree",
            "description": "Render-ui SExpr rendered after thread posts load. Default is the canonical forum-style data-list. Layer 3 variants override this with their own tree (chat bubbles, email-threaded cards, linear comment stacks, etc.) to deliver entirely different thread UX while inheriting the same trait, state machine, emits, and listens.",
            "tier": "internal"
          },
          {
            "key": "flat",
            "type": "boolean",
            "default": false,
            "label": "Flat thread",
            "description": "Render replies as a linear list instead of nested tree",
            "tier": "presentation"
          },
          {
            "key": "tableLook",
            "type": "string",
            "default": "dense",
            "label": "Table look",
            "description": "Layer 2 visual treatment for the data table rendered by this atom.",
            "tier": "presentation",
            "enumValues": [
              "dense",
              "spacious",
              "striped",
              "borderless",
              "card-rows"
            ]
          },
          {
            "key": "threadRootId",
            "type": "string",
            "default": "",
            "label": "Root post id",
            "description": "Top-level post whose descendants are loaded (blank = all roots)",
            "tier": "domain"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "ThreadPostBrowsePage",
