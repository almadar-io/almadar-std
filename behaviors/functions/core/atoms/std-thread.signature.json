[
  {
    "organism": "std-thread",
    "orbital": "ThreadPostOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-thread.ts",
    "entities": [
      {
        "name": "ThreadPost",
        "fields": [
          {
            "name": "parentId",
            "type": "string",
            "required": false
          },
          {
            "name": "threadRootId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorId",
            "type": "string",
            "required": true
          },
          {
            "name": "authorName",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "voteCount",
            "type": "number",
