[
  {
    "organism": "std-audit-capture",
    "orbital": "AuditCaptureOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-audit-capture.ts",
    "entities": [
      {
        "name": "AuditEntry",
        "fields": [
          {
            "name": "actor",
            "type": "string",
            "required": false
          },
          {
            "name": "action",
            "type": "string",
            "required": false
          },
          {
            "name": "entityType",
            "type": "string",
            "required": false
          },
          {
            "name": "entityId",
            "type": "string",
            "required": false
          },
          {
            "name": "recordedAt",
            "type": "number",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "AuditCaptureListener",
        "emittedEvents": [
          "AuditRecorded"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "captureEntity",
            "type": "string",
