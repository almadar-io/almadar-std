            "items": {
              "type": "string"
            }
          }
        ],
        "capabilities": [
          "audit",
          "compliance"
        ]
      }
    ],
    "pages": [
      {
        "name": "AuditCapturePage",
        "defaultPath": "/audit-capture",
        "primaryEntity": "AuditEntry"
