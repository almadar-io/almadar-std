                "value": {
                  "name": "value",
                  "required": false,
                  "type": "number"
                },
                "trend": {
                  "name": "trend",
                  "required": false,
                  "type": "number"
                },
                "prefix": {
                  "name": "prefix",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
