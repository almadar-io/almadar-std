[
  {
    "organism": "std-autocomplete",
    "orbital": "AutocompleteOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-autocomplete.ts",
    "entities": [
      {
        "name": "AutoTarget",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": false,
            "description": "The primary label matched + shown per suggestion.",
            "synonyms": "title, label, productName"
          },
          {
            "name": "searchTerm",
            "type": "string",
            "required": false,
            "intrinsic": true,
            "description": "The current typed query.",
            "synonyms": "query, term, q"
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "Autocomplete",
        "emittedEvents": [
          "AutoLoaded",
          "AutoFailed",
          "AUTO_SELECTED"
        ],
        "listenedEvents": [],
        "events": [
          {
            "name": "AutoLoaded",
            "direction": "emit",
            "description": "Suggestion matches loaded"
          },
          {
            "name": "AutoFailed",
            "direction": "emit",
            "description": "Suggestion fetch failed"
          },
          {
            "name": "AUTO_SELECTED",
            "direction": "emit",
            "description": "A suggestion was picked; carries the chosen record id for the consumer to open or bind.",
            "synonyms": "select, choose, pick",
            "tier": "domain"
          },
          {
            "name": "INIT",
            "direction": "listen"
          },
          {
            "name": "AUTO_QUERY",
            "direction": "listen",
            "description": "The user typed/submitted a query in the typeahead input.",
            "synonyms": "type, query, search",
            "tier": "domain"
          },
          {
            "name": "AUTO_SELECT",
            "direction": "listen",
            "description": "The user clicked a suggestion.",
            "synonyms": "pick, choose, open",
            "tier": "domain"
          }
        ],
        "overridableConfigKeys": [
          {
            "key": "placeholder",
            "type": "string",
            "default": "Search…",
            "label": "Placeholder",
            "description": "Hint text in the empty typeahead input.",
            "tier": "presentation"
          },
          {
            "key": "searchField",
            "type": "string",
            "default": "name",
            "label": "Search field",
            "description": "Entity field matched against the typed query (case-insensitive substring).",
            "tier": "presentation"
          },
          {
            "key": "suggestionFields",
            "type": "[AutoSuggestSpec]",
            "default": [
              {
                "label": "Name",
                "name": "name",
                "variant": "body"
              }
            ],
            "label": "Suggestion fields",
            "description": "Fields shown per suggestion row.",
            "tier": "presentation",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          }
        ],
        "capabilities": [],
        "entityRebindable": true,
        "entityContract": {
          "requires": [],
          "provides": [
            "searchTerm"
          ]
        }
      }
    ],
    "pages": [
      {
        "name": "AutocompletePage",
        "defaultPath": "/autocomplete",
        "primaryEntity": "AutoTarget"
      }
    ],
    "emittedEvents": [
      "AUTO_SELECTED",
      "AutoFailed",
      "AutoLoaded"
    ],
    "listenedEvents": []
  }
]
