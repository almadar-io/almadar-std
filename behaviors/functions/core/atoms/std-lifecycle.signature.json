                    },
                    "dateField": {
                      "name": "dateField",
                      "required": false,
                      "type": "string"
                    },
                    "kind": {
                      "name": "kind",
                      "required": false,
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "fromStatus": {
                  "name": "fromStatus",
                  "required": false,
                  "type": "string"
                },
                "toStatus": {
                  "name": "toStatus",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "targetEntity",
            "type": "string",
            "default": "",
