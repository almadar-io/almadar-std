[
  {
    "organism": "std-image-upload-multi",
    "orbital": "UploadedImageOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-image-upload-multi.ts",
    "entities": [
      {
        "name": "UploadedImage",
        "fields": [
          {
            "name": "url",
            "type": "string",
            "required": true,
            "description": "The accessible address for retrieving the image data.",
            "synonyms": "link, path, address"
          },
          {
            "name": "name",
            "type": "string",
            "required": false,
            "description": "The filename or identifier for the uploaded image.",
            "synonyms": "filename, originalName, identifier"
          },
          {
            "name": "sizeBytes",
            "type": "number",
            "required": false,
            "description": "The file size in bytes.",
            "synonyms": "length, filesize, bytes"
          },
          {
            "name": "mimeType",
            "type": "string",
            "required": false,
            "description": "The file's internet media type.",
            "synonyms": "type, format, media type"
          },
          {
            "name": "width",
            "type": "number",
            "required": false,
            "description": "The image's width in pixels.",
            "synonyms": "imageWidth, pixelWidth"
          },
          {
            "name": "height",
            "type": "number",
            "required": false,
            "description": "The vertical dimension of the image, in pixels.",
            "synonyms": "vertical, y, dimension"
          },
          {
            "name": "parentId",
            "type": "string",
            "required": false,
            "description": "Identifier of the parent resource this image belongs to.",
            "synonyms": "parent, reference, source"
          },
          {
            "name": "parentType",
            "type": "string",
            "required": false,
            "description": "Identifies the type of the parent entity.",
            "synonyms": "parent, type, category"
          },
          {
            "name": "uploadedAt",
            "type": "string",
            "required": false,
            "description": "Timestamp indicating when the image was uploaded.",
            "synonyms": "date, timestamp, upload time"
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "UploadedImageUpload",
        "emittedEvents": [
          "UPLOAD",
          "DELETE",
          "UploadedImageLoaded",
          "UploadedImageLoadFailed",
          "UploadedImageCreated",
          "UploadedImageUploadFailed",
          "UploadedImageDeleted",
          "UploadedImageDeleteFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "accept",
            "type": "string",
            "default": "image/*",
            "label": "MIME filter",
            "description": "Browser accept filter for the file picker",
            "tier": "domain"
          },
          {
            "key": "maxBytesPerImage",
            "type": "number",
            "default": 10485760,
            "label": "Size limit (bytes)",
            "description": "Per-image upload size cap",
            "tier": "domain"
          },
          {
            "key": "maxImages",
            "type": "number",
            "default": 10,
            "label": "Max images",
            "description": "Maximum number of images accepted per upload batch",
            "tier": "domain"
          },
          {
            "key": "title",
            "type": "string",
            "default": "Upload Images",
            "label": "Section title",
            "description": "Heading shown above the upload zone",
            "tier": "presentation"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "UploadedImageUploadPage",
        "defaultPath": "/uploadedimages/upload",
        "primaryEntity": "UploadedImage"
      }
    ],
    "emittedEvents": [
      "DELETE",
      "UPLOAD",
      "UploadedImageCreated",
      "UploadedImageDeleteFailed",
      "UploadedImageDeleted",
      "UploadedImageLoadFailed",
      "UploadedImageLoaded",
      "UploadedImageUploadFailed"
    ],
    "listenedEvents": []
  }
