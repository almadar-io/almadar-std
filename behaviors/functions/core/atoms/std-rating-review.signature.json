[
  {
    "organism": "std-rating-review",
    "orbital": "RatingReviewOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-rating-review.ts",
    "entities": [
      {
        "name": "ReviewView",
        "fields": [
          {
            "name": "reviews",
            "type": "array",
            "required": false,
            "description": "A list of individual review entries.",
            "synonyms": "reviews, entries, items"
          },
          {
            "name": "reviewsSource",
            "type": "array",
            "required": false,
            "description": "Collection of individual review entries.",
            "synonyms": "items, records, data"
          },
          {
            "name": "totalReviews",
            "type": "number",
            "required": false,
            "description": "The total count of reviews associated with this view.",
            "synonyms": "count, number, total, size"
          },
          {
            "name": "averageRating",
            "type": "number",
            "required": false,
            "description": "The average numerical rating value.",
            "synonyms": "rating, score, value"
          },
          {
            "name": "starDistribution",
            "type": "array",
            "required": false,
            "description": "Distribution of reviews across star ratings.",
            "synonyms": "star counts, rating breakdown, star frequency"
          },
          {
            "name": "currentSort",
            "type": "string",
            "required": false,
            "description": "Specifies the current sorting order applied to the reviews.",
            "synonyms": "sort, order, arrangement"
          },
          {
            "name": "draftRating",
            "type": "number",
            "required": false,
            "description": "The user's tentative star rating for the review.",
            "synonyms": "rating, star_value, score"
          },
          {
            "name": "draftComment",
            "type": "string",
            "required": false,
            "description": "The text content of a review in draft state.",
            "synonyms": "comment, text, body, content"
          },
          {
            "name": "errorMessage",
            "type": "string",
            "required": false,
            "description": "Text displayed when an error occurs during review submission.",
            "synonyms": "error text, error message, failure message"
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "RatingReviewBoard",
        "emittedEvents": [
          "WRITE_REVIEW",
          "RATE_DRAFT",
          "SUBMIT_REVIEW",
          "CANCEL_REVIEW",
          "CHANGE_SORT",
          "MARK_HELPFUL",
          "RESTART",
          "ReviewsLoaded",
          "ReviewsLoadFailed",
          "ReviewSaved",
          "ReviewSaveFailed"
        ],
        "listenedEvents": [],
        "events": [
          {
            "name": "WRITE_REVIEW",
            "direction": "emit",
            "description": "Initiates the review composition flow.",
            "synonyms": "compose, create, add",
            "tier": "essential"
          },
          {
            "name": "RATE_DRAFT",
            "direction": "emit",
            "description": "Signals a draft rating has been created or modified.",
            "synonyms": "draft, update, modify, change",
            "tier": "customization"
          },
          {
            "name": "SUBMIT_REVIEW",
            "direction": "emit",
            "description": "Signals a review has been successfully submitted.",
            "synonyms": "saved, posted, sent",
            "tier": "essential"
          },
          {
            "name": "CANCEL_REVIEW",
            "direction": "emit",
            "description": "Aborts the review composition process.",
            "synonyms": "discard, abandon, close, revert",
            "tier": "customization"
          },
          {
            "name": "CHANGE_SORT",
            "direction": "emit",
            "description": "Signals a change in the review sorting criteria.",
            "synonyms": "sort, order, filter",
            "tier": "customization"
          },
          {
            "name": "MARK_HELPFUL",
            "direction": "emit",
            "description": "Indicates a review has been marked as helpful.",
            "synonyms": "helpful, useful, thumbs up, agree",
            "tier": "customization"
          },
          {
            "name": "RESTART",
            "direction": "emit",
            "description": "Triggers a full refresh of the review data and UI.",
            "synonyms": "refresh, reload, reset",
            "tier": "internal"
          },
          {
            "name": "ReviewsLoaded",
            "direction": "emit",
            "description": "Signals that the reviews data has been successfully retrieved.",
            "synonyms": "loaded, fetched, ready, available",
            "tier": "essential"
          },
          {
            "name": "ReviewsLoadFailed",
            "direction": "emit",
            "description": "Indicates that loading reviews was unsuccessful.",
            "synonyms": "failed, error, problem, unsuccessful",
            "tier": "internal"
          },
          {
            "name": "ReviewSaved",
            "direction": "emit",
            "description": "Indicates a review has been successfully saved.",
            "synonyms": "saved, persisted, updated",
            "tier": "essential"
          },
          {
            "name": "ReviewSaveFailed",
            "direction": "emit",
            "description": "Indicates a review save operation failed.",
            "synonyms": "failed, error, unsuccessful",
            "tier": "internal"
          },
          {
            "name": "INIT",
            "direction": "listen"
          }
        ],
        "overridableConfigKeys": [
          {
            "key": "cancelLabel",
            "type": "string",
            "default": "Cancel",
            "label": "Cancel button",
            "description": "Label on the cancel button inside the compose form",
            "tier": "presentation"
          },
          {
            "key": "cardLook",
            "type": "string",
            "default": "elevated",
            "label": "Card look",
            "description": "Layer 2 visual treatment for cards rendered by this atom.",
            "tier": "presentation",
            "enumValues": [
              "elevated",
              "flat-bordered",
              "borderless-divider",
              "ticket",
              "invoice",
              "chip",
              "tile-image-first"
            ]
          },
          {
            "key": "reviewFields",
            "type": "[string]",
            "default": [
              "draftComment"
            ],
            "label": "Review form fields",
            "description": "Inputs shown in the review compose form",
            "tier": "presentation",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "sortOptions",
            "type": "[SortOption]",
            "default": [
              {
                "icon": "clock",
                "id": "recent",
                "label": "Most recent"
              },
              {
                "icon": "star",
                "id": "highest",
                "label": "Top rated"
              },
              {
                "icon": "trending-down",
                "id": "lowest",
                "label": "Lowest"
              }
            ],
            "label": "Sort tabs",
            "description": "Sort modes shown as tabs above the reviews list",
            "tier": "presentation",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "id": {
                  "name": "id",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "starDistribution",
            "type": "[StarBucket]",
            "default": [
              {
                "label": "5 stars",
                "percentage": 74
              },
              {
                "label": "4 stars",
                "percentage": 18
              },
              {
                "label": "3 stars",
                "percentage": 5
              },
              {
                "label": "2 stars",
                "percentage": 2
              },
              {
                "label": "1 star",
                "percentage": 1
              }
            ],
            "label": "Star bars",
            "description": "Per-star distribution displayed as horizontal progress bars",
            "tier": "presentation",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "percentage": {
                  "name": "percentage",
                  "required": true,
                  "type": "number"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "subjectTitle",
            "type": "string",
            "default": "Bali Sunset Villa · 3 nights",
            "label": "Subject title",
            "description": "Name of the item being reviewed (shown in the header)",
            "tier": "presentation"
          },
          {
            "key": "submitLabel",
            "type": "string",
            "default": "Submit review",
            "label": "Submit button",
            "description": "Label on the primary submit-review button",
            "tier": "presentation"
          },
          {
            "key": "writeLabel",
            "type": "string",
            "default": "Write a review",
            "label": "Write CTA",
            "description": "Label on the call-to-action that opens the compose form",
            "tier": "presentation"
          }
        ],
        "capabilities": []
      },
      {
        "name": "RatingReviewSubmit",
        "emittedEvents": [
          "RATE_DRAFT",
          "SUBMIT_REVIEW",
          "CANCEL_REVIEW",
          "RESTART",
          "ReviewSaved",
          "ReviewSaveFailed"
        ],
        "listenedEvents": [],
        "events": [
          {
            "name": "RATE_DRAFT",
            "direction": "emit",
            "description": "Signals a review draft has been created or updated.",
            "synonyms": "draft, save, pending",
            "tier": "customization"
          },
          {
            "name": "SUBMIT_REVIEW",
            "direction": "emit",
            "description": "Signals a review has been successfully submitted.",
            "synonyms": "saved, posted, sent",
            "tier": "essential"
          },
          {
            "name": "CANCEL_REVIEW",
            "direction": "emit",
            "description": "Aborts the review composition process.",
            "synonyms": "discard, abandon, close, revert",
            "tier": "customization"
          },
          {
            "name": "RESTART",
            "direction": "emit",
            "description": "Triggers a refresh of the review data and UI.",
            "synonyms": "refresh, reload, reset",
            "tier": "internal"
          },
          {
            "name": "ReviewSaved",
            "direction": "emit",
            "description": "Indicates a review has been successfully stored.",
            "synonyms": "saved, persisted, updated",
            "tier": "customization"
          },
          {
            "name": "ReviewSaveFailed",
            "direction": "emit",
            "description": "Indicates a review save operation failed.",
            "synonyms": "failed, error, unsuccessful",
            "tier": "internal"
          },
          {
            "name": "INIT",
            "direction": "listen"
          }
        ],
        "overridableConfigKeys": [
          {
            "key": "allowComment",
            "type": "boolean",
            "default": true,
            "label": "Allow comment",
            "description": "Show a free-text comment field below the stars",
            "tier": "presentation"
          },
          {
            "key": "allowPhotos",
            "type": "boolean",
            "default": false,
            "label": "Allow photos",
            "description": "Let the user attach photos to the review",
            "tier": "presentation"
          },
          {
            "key": "cancelLabel",
            "type": "string",
            "default": "Cancel",
            "label": "Cancel button",
            "description": "Label on the cancel button",
            "tier": "presentation"
          },
          {
            "key": "cardLook",
            "type": "string",
            "default": "elevated",
            "label": "Card look",
            "description": "Visual style of the wrapper card. Layer 2 cardLook knob — render-ui references @config.cardLook on the compose card.",
            "tier": "presentation",
            "enumValues": [
              "elevated",
              "flat-bordered",
              "borderless-divider",
              "ticket",
              "invoice",
              "chip",
              "tile-image-first"
            ]
          },
          {
            "key": "maxStars",
            "type": "number",
            "default": 5,
            "label": "Max stars",
            "description": "Top of the rating scale (typically 5)",
            "tier": "domain"
          },
          {
            "key": "submitEvent",
            "type": "string",
            "default": "SUBMIT_REVIEW",
            "label": "Submit event",
            "description": "Event emitted when the user submits the form",
            "tier": "internal"
          },
          {
            "key": "submitLabel",
            "type": "string",
            "default": "Submit review",
            "label": "Submit button",
            "description": "Label on the primary submit button",
            "tier": "presentation"
          },
          {
            "key": "title",
            "type": "string",
            "default": "Write a review",
            "label": "Form title",
            "description": "Heading shown above the review compose form",
            "tier": "presentation"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "RatingReviewPage",
        "defaultPath": "/reviews",
        "primaryEntity": "ReviewView"
      },
      {
        "name": "RatingReviewSubmitPage",
        "defaultPath": "/reviews/new",
        "primaryEntity": "ReviewView"
      }
    ],
    "emittedEvents": [
      "CANCEL_REVIEW",
      "CHANGE_SORT",
      "MARK_HELPFUL",
      "RATE_DRAFT",
      "RESTART",
      "ReviewSaveFailed",
      "ReviewSaved",
      "ReviewsLoadFailed",
      "ReviewsLoaded",
      "SUBMIT_REVIEW",
      "WRITE_REVIEW"
    ],
    "listenedEvents": []
  }
]
