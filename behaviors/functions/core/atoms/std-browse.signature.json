[
  {
    "organism": "std-browse",
    "orbital": "BrowseItemOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-browse.ts",
    "entities": [
      {
        "name": "BrowseItem",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "BrowseItemBrowse",
        "emittedEvents": [
          "BrowseItemLoaded",
          "BrowseItemLoadFailed",
          "VIEW",
          "EDIT",
          "DELETE"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "bodyContent",
            "type": "render-ui",
            "default": {
              "type": "stack",
              "direction": "vertical",
              "children": [
                {
                  "type": "data-grid",
                  "fields": "@config.fields",
                  "imageField": "@config.imageField",
                  "entity": "@payload.data",
                  "itemActions": "@config.itemActions",
                  "cols": "@config.cols",
                  "pageSize": "@config.displayPageSize",
                  "gap": "@config.gap"
                }
              ]
            },
            "label": "Body content tree",
            "description": "Render-ui SExpr rendered after rows load. Default is the canonical data-grid call wrapped in a stack. Layer 3 variants override this with their own tree (composing data-list/data-grid/entity-table + custom renderItem lambdas + filter-group, kbd, card, etc.) to deliver entirely different browse UX while inheriting the same trait, state machine, emits, and listens.",
            "tier": "internal"
          },
          {
            "key": "cols",
            "type": "number",
            "default": 1,
            "label": "Grid columns",
            "description": "Number of columns in the responsive grid layout",
            "tier": "presentation"
          },
          {
            "key": "displayPageSize",
            "type": "number",
            "default": 10,
            "label": "Page size (display)",
            "description": "Rows shown per visible page before pagination",
            "tier": "presentation"
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "variant": "h4",
                "name": "name",
                "label": "Name"
              },
              {
                "variant": "caption",
                "name": "description",
                "label": "Description"
              },
              {
                "name": "status",
                "label": "Status",
                "variant": "badge"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the BrowseItem entity",
            "tier": "presentation",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "gap",
            "type": "string",
            "default": "md",
            "label": "Cell spacing",
            "description": "Gap size between rows (sm, md, lg)",
            "tier": "presentation"
          },
          {
            "key": "imageField",
            "type": "string",
            "default": "",
            "label": "Image field",
            "description": "Entity field that holds the row thumbnail URL",
            "tier": "presentation"
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [],
            "label": "Row actions",
            "description": "Buttons users can click on each row",
            "tier": "presentation",
            "items": {
              "properties": {
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "pageSize",
            "type": "number",
            "default": 10,
            "label": "Page size (fetch)",
            "description": "Rows fetched from the server per page",
            "tier": "presentation"
          },
          {
            "key": "viewPattern",
            "type": "pattern",
            "default": "data-grid",
            "label": "Render pattern",
            "description": "UI pattern used to render the collection. Used by the default bodyContent tree; Layer 3 variants override bodyContent directly instead and may ignore this knob.",
            "tier": "internal"
          }
        ],
        "capabilities": [],
        "entityRebindable": true,
        "entityContract": {
          "requires": [],
          "provides": []
        }
      }
    ],
    "pages": [
      {
        "name": "BrowseItemPage",
        "defaultPath": "/browseitems",
        "primaryEntity": "BrowseItem"
      }
    ],
    "emittedEvents": [
      "BrowseItemLoadFailed",
      "BrowseItemLoaded",
      "DELETE",
      "EDIT",
      "VIEW"
    ],
    "listenedEvents": []
  }
]
