[
  {
    "organism": "std-browse",
    "orbital": "BrowseItemOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-browse.ts",
    "entities": [
      {
        "name": "BrowseItem",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "The item's identifier or title.",
            "synonyms": "title, label, itemName"
          },
          {
            "name": "description",
            "type": "string",
            "required": false,
            "description": "A textual explanation or summary of the item.",
            "synonyms": "summary, details, notes, explanation"
          },
          {
            "name": "status",
            "type": "string",
            "required": false,
            "description": "Indicates the current operational state of the item.",
            "synonyms": "state, condition, flag"
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "BrowseItemBrowse",
        "emittedEvents": [
          "BrowseItemLoaded",
          "BrowseItemLoadFailed",
          "VIEW",
          "EDIT",
          "DELETE"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "assigneeBinding",
            "type": "string",
            "default": "@item.assignee",
            "label": "Assignee binding",
            "description": "Per-row binding string for the assignee/owner slot.",
            "tier": "presentation"
          },
          {
            "key": "badgeBinding",
            "type": "string",
            "default": "@item.status",
            "label": "Badge binding",
            "description": "Per-row binding string for the status/badge slot.",
            "tier": "presentation"
          },
          {
            "key": "bodyContent",
            "type": "render-ui",
            "default": {
              "type": "stack",
              "direction": "vertical",
              "children": [
                {
                  "imageField": "@config.imageField",
                  "entity": "@payload.data",
                  "fields": "@config.fields",
                  "itemActions": "@config.itemActions",
                  "gap": "@config.gap",
                  "pageSize": "@config.displayPageSize",
                  "type": "data-grid",
                  "cols": "@config.cols"
                }
              ]
            },
            "label": "Body content tree",
            "description": "Render-ui SExpr rendered after rows load. Default is the canonical data-grid call wrapped in a stack. Layer 3 variants override this with their own tree (composing data-list/data-grid/entity-table + custom renderItem lambdas + filter-group, kbd, card, etc.) to deliver entirely different browse UX while inheriting the same trait, state machine, emits, and listens.",
            "tier": "internal"
          },
          {
            "key": "categoryBinding",
            "type": "string",
            "default": "@item.category",
            "label": "Category binding",
            "description": "Per-row binding string for the category/tag slot.",
            "tier": "presentation"
          },
          {
            "key": "cols",
            "type": "number",
            "default": 1,
            "label": "Grid columns",
            "description": "Number of columns in the responsive grid layout",
            "tier": "presentation"
          },
          {
            "key": "columns",
            "type": "[ColumnSpec]",
            "default": [
              {
                "weight": "medium",
                "key": "name",
                "field": "name",
                "header": "Name",
                "align": "left"
              },
              {
                "align": "left",
                "key": "description",
                "header": "Detail",
                "field": "description"
              },
              {
                "key": "status",
                "format": "badge",
                "align": "center",
                "field": "status",
                "header": "Status"
              }
            ],
            "label": "Table columns",
            "description": "Column definitions for table-style variants (dense). Each maps an entity field to a column with optional width / align / weight / format.",
            "tier": "presentation",
            "items": {
              "properties": {
                "className": {
                  "name": "className",
                  "required": false,
                  "type": "string"
                },
                "align": {
                  "name": "align",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "weight": {
                  "name": "weight",
                  "required": false,
                  "type": "string"
                },
                "field": {
                  "name": "field",
                  "required": false,
                  "type": "string"
                },
                "width": {
                  "name": "width",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "descriptionBinding",
            "type": "string",
            "default": "@item.description",
            "label": "Description binding",
            "description": "Per-row binding string for the card body/subtitle slot.",
            "tier": "presentation"
          },
          {
            "key": "displayPageSize",
            "type": "number",
            "default": 10,
            "label": "Page size (display)",
            "description": "Rows shown per visible page before pagination",
            "tier": "presentation"
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "variant": "h4",
                "label": "Name",
                "name": "name"
              },
              {
                "name": "description",
                "label": "Description",
                "variant": "caption"
              },
              {
                "variant": "badge",
                "label": "Status",
                "name": "status"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the BrowseItem entity",
            "tier": "presentation",
            "items": {
              "properties": {
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "filters",
            "type": "[FilterSpec]",
            "default": [],
            "label": "Faceted filters",
            "description": "Per-field filter facets ({ field, label, options }); each renders a select that fires REFETCH_FILTER to filter the list by that field. Empty = no filter bar.",
            "tier": "presentation",
            "items": {
              "properties": {
                "field": {
                  "name": "field",
                  "required": true,
                  "type": "string"
                },
                "options": {
                  "name": "options",
                  "required": false,
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "gap",
            "type": "string",
            "default": "md",
            "label": "Cell spacing",
            "description": "Gap size between rows (sm, md, lg)",
            "tier": "presentation"
          },
          {
            "key": "imageField",
            "type": "string",
            "default": "",
            "label": "Image field",
            "description": "Entity field that holds the row thumbnail URL",
            "tier": "presentation"
          },
          {
            "key": "imageLabelBinding",
            "type": "string",
            "default": "@item.thumbnailLabel",
            "label": "Image label binding",
            "description": "Per-row binding string for the image-area label slot (image-first variants).",
            "tier": "presentation"
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [],
            "label": "Row actions",
            "description": "Buttons users can click on each row",
            "tier": "presentation",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "maxInlineActions",
            "type": "number",
            "default": 99,
            "label": "Max inline row actions",
            "description": "Row actions beyond this count collapse into a '⋯' overflow menu. Default 99 = all inline; set 2–3 for dense tables to avoid action overflow.",
            "tier": "presentation"
          },
          {
            "key": "metaBinding",
            "type": "string",
            "default": "@item.createdAt",
            "label": "Meta binding",
            "description": "Per-row binding string for the secondary meta slot (timestamp / category).",
            "tier": "presentation"
          },
          {
            "key": "pageSize",
            "type": "number",
            "default": 10,
            "label": "Page size (fetch)",
            "description": "Rows fetched from the server per page",
            "tier": "presentation"
          },
          {
            "key": "priceBinding",
            "type": "string",
            "default": "@item.price",
            "label": "Price binding",
            "description": "Per-row binding string for the price/amount overlay slot.",
            "tier": "presentation"
          },
          {
            "key": "priorityBinding",
            "type": "string",
            "default": "@item.priority",
            "label": "Priority binding",
            "description": "Per-row binding string for the priority slot (triage / work-queue variants).",
            "tier": "presentation"
          },
          {
            "key": "searchPlaceholder",
            "type": "string",
            "default": "Search…",
            "label": "Search placeholder",
            "description": "Placeholder text in the list's search box. Set per-domain (e.g. 'Search events…') so the box never leaks the variation name.",
            "tier": "presentation"
          },
          {
            "key": "titleBinding",
            "type": "string",
            "default": "@item.name",
            "label": "Title binding",
            "description": "Per-row binding string for the card title slot. Layer 3 variants read this inside their renderItem; consumers override it to point at their entity's field (e.g. \"@item.dishName\").",
            "tier": "presentation"
          },
          {
            "key": "viewPattern",
            "type": "pattern",
            "default": "data-grid",
            "label": "Render pattern",
            "description": "UI pattern used to render the collection. Used by the default bodyContent tree; Layer 3 variants override bodyContent directly instead and may ignore this knob.",
            "tier": "internal"
          }
        ],
        "capabilities": [],
        "entityRebindable": true,
        "entityContract": {
          "requires": [],
          "provides": []
        }
      }
    ],
    "pages": [
      {
        "name": "BrowseItemPage",
        "defaultPath": "/browseitems",
        "primaryEntity": "BrowseItem"
      }
    ],
    "emittedEvents": [
      "BrowseItemLoadFailed",
      "BrowseItemLoaded",
      "DELETE",
      "EDIT",
      "VIEW"
    ],
    "listenedEvents": []
  }
]
