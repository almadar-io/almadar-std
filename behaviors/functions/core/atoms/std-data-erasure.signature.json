[
  {
    "organism": "std-data-erasure",
    "orbital": "DataErasureOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-data-erasure.ts",
    "entities": [
      {
        "name": "ErasureRequest",
        "fields": [
          {
            "name": "subjectId",
            "type": "string",
            "required": false
          },
          {
            "name": "targetEntity",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "requestedAt",
            "type": "number",
            "required": false
          },
          {
            "name": "executesAt",
            "type": "number",
            "required": false
          },
          {
            "name": "executedAt",
            "type": "number",
            "required": false
          },
          {
            "name": "cancelledAt",
            "type": "number",
            "required": false
          },
          {
            "name": "notes",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "ErasureWorkflow",
        "emittedEvents": [
          "CANCEL_ERASURE",
          "ErasureLoaded",
          "ErasureLoadFailed",
          "ErasureSaved",
          "ErasureSaveFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "anonymizeVsDelete",
            "type": "string",
            "default": "anonymize",
            "label": "Mode",
            "description": "anonymize = scrub piiFields and retain row for audit. delete = remove the row entirely.",
            "enumValues": [
              "anonymize",
              "delete"
            ]
          },
          {
            "key": "gracePeriodDays",
            "type": "number",
            "default": 30,
            "label": "Grace period (days)",
            "description": "Days between request and execution. Customer can CANCEL during this window. Default 30 days matches typical GDPR practice."
          },
          {
            "key": "piiFields",
            "type": "[string]",
            "default": [],
            "label": "PII fields to scrub",
            "description": "Fields the target atom should null when anonymizeVsDelete='anonymize'.",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "targetEntity",
            "type": "string",
            "default": "",
            "label": "Target entity",
            "description": "Entity name whose records erasure requests apply to (e.g. 'CustomerAccount')."
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "ErasureWorkflowPage",
        "defaultPath": "/erasure/queue",
        "primaryEntity": "ErasureRequest"
      }
    ],
    "emittedEvents": [
      "CANCEL_ERASURE",
      "ErasureLoadFailed",
      "ErasureLoaded",
      "ErasureSaveFailed",
      "ErasureSaved"
    ],
    "listenedEvents": []
  }
]
