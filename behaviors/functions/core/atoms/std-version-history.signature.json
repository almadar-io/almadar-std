[
  {
    "organism": "std-version-history",
    "orbital": "RevisionOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-version-history.ts",
    "entities": [
      {
        "name": "Revision",
        "fields": [
          {
            "name": "documentId",
            "type": "string",
            "required": true,
            "description": "Unique identifier for the associated document.",
            "synonyms": "reference, identifier, source"
          },
          {
            "name": "documentType",
            "type": "string",
            "required": true,
            "description": "Specifies the kind of document this revision belongs to.",
            "synonyms": "type, kind, category"
          },
          {
            "name": "versionNumber",
            "type": "number",
            "required": true,
            "description": "A sequential identifier representing the revision's order.",
            "synonyms": "sequence, order, iteration"
          },
          {
            "name": "authorId",
            "type": "string",
            "required": false,
            "description": "Unique identifier for the user who made the change.",
            "synonyms": "user identifier, creator, contributor"
          },
          {
            "name": "authorName",
            "type": "string",
            "required": false,
            "description": "The name of the user who made the change.",
            "synonyms": "user, contributor, owner"
          },
          {
            "name": "content",
            "type": "string",
            "required": false,
            "description": "The textual data of the revision.",
            "synonyms": "text, body, data, value"
          },
          {
            "name": "summary",
            "type": "string",
            "required": false,
            "description": "A brief explanation of the revision's changes.",
            "synonyms": "description, note, comment, explanation"
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "RevisionManage",
        "emittedEvents": [
          "OPEN_REVISION",
          "CLOSE_VIEW",
          "COMPARE",
          "ROLLBACK",
          "RevisionLoaded",
          "RevisionLoadFailed",
          "RevisionRolledBack",
          "RevisionRollbackFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "statLook",
            "type": "string",
            "default": "elevated",
            "label": "Stat display look",
            "description": "Layer 2 visual treatment for stat / KPI cards.",
            "tier": "presentation",
            "enumValues": [
              "elevated",
              "flat",
              "progress-backed",
              "gauge",
              "sparkline"
            ]
          },
          {
            "key": "tableLook",
            "type": "string",
            "default": "dense",
            "label": "Table look",
            "description": "Layer 2 visual treatment for the data table rendered by this atom.",
            "tier": "presentation",
            "enumValues": [
              "dense",
              "spacious",
              "striped",
              "borderless",
              "card-rows"
            ]
          },
          {
            "key": "title",
            "type": "string",
            "default": "Version History",
            "label": "Section title",
            "description": "Heading shown above the revision list",
            "tier": "presentation"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "RevisionManagePage",
        "defaultPath": "/revisions/manage",
        "primaryEntity": "Revision"
      }
    ],
    "emittedEvents": [
      "CLOSE_VIEW",
      "COMPARE",
      "OPEN_REVISION",
      "ROLLBACK",
      "RevisionLoadFailed",
      "RevisionLoaded",
      "RevisionRollbackFailed",
      "RevisionRolledBack"
    ],
    "listenedEvents": []
  }
]
