[
  {
    "organism": "std-board",
    "orbital": "BoardOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-board.ts",
    "entities": [
      {
        "name": "BoardView",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "stage",
            "type": "string",
            "required": false
          },
          {
            "name": "notes",
            "type": "string",
            "required": false
          },
          {
            "name": "position",
            "type": "number",
            "required": false
          },
          {
            "name": "boards",
            "type": "array",
            "required": false
          },
          {
            "name": "currentId",
            "type": "string",
            "required": false
          },
          {
            "name": "currentTitle",
            "type": "string",
            "required": false
          },
          {
            "name": "currentDescription",
            "type": "string",
            "required": false
          },
          {
            "name": "currentStage",
            "type": "string",
            "required": false
          },
          {
            "name": "currentNotes",
            "type": "string",
            "required": false
          },
          {
            "name": "errorMessage",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "BoardItemBoard",
        "emittedEvents": [
          "OPEN_CARD",
          "CLOSE_CARD",
          "ADD_CARD",
          "CANCEL_ADD",
          "SAVE_CARD",
          "MOVE_CARD",
          "REORDER_CARD",
          "DELETE_CARD",
          "BoardItemsLoaded",
          "BoardItemsLoadFailed",
          "BoardItemsSaved",
          "BoardItemsSaveFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "bodyContent",
            "type": "render-ui",
            "default": {
              "direction": "vertical",
              "gap": "md",
              "type": "stack",
              "children": [
                {
                  "type": "stack",
                  "direction": "horizontal",
                  "align": "center",
                  "gap": "sm",
                  "children": [
                    {
                      "name": "kanban-square",
                      "type": "icon"
                    },
                    {
                      "type": "typography",
                      "content": "@config.title",
                      "variant": "h3"
                    }
                  ]
                },
                {
                  "type": "divider"
                },
                {
                  "dndRoot": true,
                  "renderItem": [
                    "fn",
                    "col",
                    {
                      "type": "card",
                      "children": [
                        {
                          "children": [
                            {
                              "direction": "horizontal",
                              "type": "stack",
                              "gap": "xs",
                              "children": [
                                {
                                  "type": "icon",
                                  "name": "@col.icon"
                                },
                                {
                                  "variant": "h4",
                                  "content": "@col.label",
                                  "type": "typography"
                                },
                                {
                                  "label": "@col.count",
                                  "type": "badge",
                                  "variant": "@col.variant"
                                }
                              ],
                              "align": "center"
                            },
                            {
                              "dropEvent": "MOVE_CARD",
                              "fields": [],
                              "sortable": true,
                              "reorderEvent": "REORDER_CARD",
                              "positionEvent": "REORDER_POSITION",
                              "renderItem": [
                                "fn",
                                "item",
                                {
                                  "look": "@config.cardLook",
                                  "children": [
                                    {
                                      "type": "stack",
                                      "children": [
                                        {
                                          "type": "typography",
                                          "content": "@item.title",
                                          "variant": "h4"
                                        },
                                        {
                                          "content": "@item.description",
                                          "type": "typography",
                                          "color": "muted",
                                          "variant": "caption"
                                        },
                                        {
                                          "gap": "xs",
                                          "type": "stack",
                                          "direction": "horizontal",
                                          "align": "center",
                                          "children": [
                                            {
                                              "icon": "arrow-right",
                                              "variant": "ghost",
                                              "label": "Open",
                                              "type": "button",
                                              "actionPayload": {
                                                "row": "@item",
                                                "id": "@item.id"
                                              },
                                              "action": "OPEN_CARD"
                                            }
                                          ]
                                        }
                                      ],
                                      "direction": "vertical",
                                      "gap": "xs"
                                    }
                                  ],
                                  "type": "card"
                                }
                              ],
                              "gap": "sm",
                              "accepts": "*",
                              "entity": "@col.items",
                              "type": "data-list",
                              "dragGroup": "@col.key"
                            }
                          ],
                          "type": "stack",
                          "gap": "sm",
                          "direction": "vertical"
                        }
                      ],
                      "look": "@config.cardLook"
                    }
                  ],
                  "cols": "@config.gridCols",
                  "type": "data-grid",
                  "gap": "md",
                  "fields": [],
                  "entity": "@entity.boards"
                },
                {
                  "label": "Add item",
                  "variant": "primary",
                  "type": "floating-action-button",
                  "icon": "plus",
                  "action": "ADD_CARD"
                }
              ]
            },
            "label": "Body content tree",
            "description": "Render-ui SExpr rendered after the board loads. Default is the canonical column data-grid with nested per-column data-lists. Layer 3 variants override this with their own tree (swim-lanes, timeline-roadmap, etc.) while inheriting the same trait, state machine, emits, and listens.",
            "tier": "internal"
          },
          {
            "key": "cardLook",
            "type": "string",
            "default": "elevated",
            "label": "Card look",
            "description": "Layer 2 visual treatment for cards rendered by this board.",
            "tier": "presentation",
            "enumValues": [
              "elevated",
              "flat-bordered",
              "borderless-divider",
              "ticket",
              "invoice",
              "chip",
              "tile-image-first"
            ]
          },
          {
            "key": "columns",
            "type": "[ColumnSpec]",
            "default": [
              {
                "icon": "circle",
                "label": "To Do",
                "key": "todo",
                "variant": "default"
              },
              {
                "key": "doing",
                "label": "In Progress",
                "variant": "primary",
                "icon": "circle-dot"
              },
              {
                "label": "Done",
                "variant": "success",
                "icon": "check-circle",
                "key": "done"
              }
            ],
            "label": "Columns",
            "description": "Board columns; each row's stage maps to a column key",
            "tier": "domain",
            "items": {
              "properties": {
                "key": {
                  "name": "key",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "formFields",
            "type": "[string]",
            "default": [
              "title",
              "description",
              "stage",
              "notes"
            ],
            "label": "New-card fields",
            "description": "Fields shown in the add-card form",
            "tier": "presentation",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "gridCols",
            "type": "number",
            "default": 3,
            "label": "Grid columns",
            "description": "Outer grid column count before the board wraps",
            "tier": "presentation"
          },
          {
            "key": "title",
            "type": "string",
            "default": "Board",
            "label": "Board title",
            "description": "Heading shown above the column board",
            "tier": "presentation"
          }
        ],
        "capabilities": [],
        "entityRebindable": true,
        "entityContract": {
          "requires": [],
          "provides": [
            "boards",
            "currentDescription",
            "currentId",
            "currentNotes",
            "currentStage",
            "currentTitle",
            "errorMessage"
          ]
        }
      }
    ],
    "pages": [
      {
        "name": "BoardPage",
        "defaultPath": "/board",
        "primaryEntity": "BoardView"
      }
    ],
    "emittedEvents": [
      "ADD_CARD",
      "BoardItemsLoadFailed",
      "BoardItemsLoaded",
      "BoardItemsSaveFailed",
      "BoardItemsSaved",
      "CANCEL_ADD",
      "CLOSE_CARD",
      "DELETE_CARD",
      "MOVE_CARD",
      "OPEN_CARD",
      "REORDER_CARD",
      "SAVE_CARD"
    ],
    "listenedEvents": []
  }
]
