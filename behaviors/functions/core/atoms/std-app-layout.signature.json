            "tier": "customization",
            "enumValues": [
              "sidebar",
              "topnav",
              "bottomnav",
              "minimal"
            ]
          },
          {
            "key": "layoutPattern",
            "type": "pattern",
            "default": "dashboard-layout",
            "label": "Layout pattern",
