            "tier": "advanced"
          },
          {
            "key": "navItems",
            "type": "[NavItem]",
            "default": [],
            "label": "Sidebar links",
            "description": "Top-level nav entries on the left rail",
            "tier": "essential",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string",
                  "name": "label",
                  "required": true
                },
                "href": {
                  "type": "string",
                  "name": "href",
                  "required": true
                },
                "icon": {
                  "type": "string",
                  "name": "icon",
                  "required": false
                },
                "badge": {
                  "type": "string",
                  "name": "badge",
                  "required": false
                }
              }
            }
          },
          {
            "key": "notificationClickEvent",
            "type": "string",
            "default": "NOTIFY_CLICK",
            "label": "Notification click event",
            "description": "Event emitted when the user picks a notification",
            "tier": "advanced"
          },
          {
            "key": "notifications",
            "type": "[NotificationSpec]",
            "default": [],
            "label": "Notifications",
            "description": "Items shown in the notifications dropdown",
            "tier": "customization",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "name": "id",
                  "required": false
                },
                "variant": {
                  "type": "string",
                  "name": "variant",
                  "required": false
                },
                "message": {
                  "type": "string",
                  "name": "message",
                  "required": false
                }
              }
            }
          },
          {
            "key": "searchEvent",
            "type": "string",
            "default": "SEARCH",
            "label": "Search event",
            "description": "Event emitted when the user runs a global search",
            "tier": "advanced"
          },
          {
            "key": "topBarActions",
            "type": "[ItemAction]",
            "default": [],
            "label": "Top-bar actions",
            "description": "Icon buttons shown on the right side of the top bar",
            "tier": "customization",
            "items": {
              "type": "object",
              "properties": {
                "event": {
                  "type": "string",
                  "name": "event",
                  "required": true
                },
                "variant": {
                  "type": "string",
                  "name": "variant",
                  "required": false
                },
                "icon": {
                  "type": "string",
                  "name": "icon",
                  "required": false
                },
                "label": {
                  "type": "string",
                  "name": "label",
                  "required": true
                }
              }
            }
          }
