[
  {
    "organism": "std-app-layout",
    "orbital": "AppLayoutOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-app-layout.ts",
    "entities": [
      {
        "name": "AppLayoutState",
        "fields": [],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "AppLayout",
        "emittedEvents": [
          "SEARCH",
          "NOTIFY_CLICK",
          "AppLayoutStateLoaded",
          "AppLayoutStateLoadFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "appName",
            "type": "string",
            "default": "App",
            "label": "App name",
            "description": "Product name shown in the chrome header",
            "tier": "essential"
          },
          {
            "key": "contentTrait",
            "type": "trait",
            "label": "Content trait",
            "description": "Trait rendered inside the app layout content area",
            "tier": "essential"
          },
          {
            "key": "detailSlot",
            "type": "slot",
            "default": "modal",
            "label": "Detail slot",
            "description": "Slot where detail/edit views render",
            "tier": "advanced"
          },
          {
            "key": "layoutMode",
            "type": "string",
            "default": "sidebar",
            "label": "Layout mode",
