[
  {
    "organism": "std-calendar",
    "orbital": "CalendarEventOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-calendar.ts",
    "entities": [
      {
        "name": "CalendarEvent",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "event title shown on the calendar",
            "synonyms": "title, label, summary, subject"
          },
          {
            "name": "description",
            "type": "string",
            "required": false,
            "description": "event details or notes",
            "synonyms": "details, notes, body, summary"
          },
          {
            "name": "status",
            "type": "string",
            "required": false,
            "description": "event lifecycle status",
            "synonyms": "state, stage, phase"
          },
          {
            "name": "date",
            "type": "datetime",
            "required": false,
            "intrinsic": true
          },
          {
            "name": "time",
            "type": "string",
            "required": false,
            "description": "event start time of day",
            "synonyms": "start, scheduled time, begins, when, start time"
          },
          {
            "name": "duration",
            "type": "number",
            "required": false,
            "description": "event length in minutes",
            "synonyms": "minutes, length, span, duration"
          },
          {
            "name": "selectedRange",
            "type": "string",
            "required": false,
            "intrinsic": true
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "CalendarEventCalendar",
        "emittedEvents": [
          "CalendarEventLoaded",
          "CalendarEventLoadFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "badgeBinding",
            "type": "string",
            "default": "@item.status",
            "label": "Badge binding",
            "description": "Per-row binding for the event status/badge slot.",
            "tier": "presentation"
          },
          {
            "key": "bodyContent",
            "type": "render-ui",
            "default": {
              "gap": "lg",
              "direction": "vertical",
              "children": [
                {
                  "type": "stack",
                  "align": "center",
                  "children": [
                    {
                      "direction": "horizontal",
                      "gap": "sm",
                      "align": "center",
                      "type": "stack",
                      "children": [
                        {
                          "type": "icon",
                          "name": "calendar"
                        },
                        {
                          "type": "typography",
                          "variant": "h2",
                          "content": "CalendarEvents Calendar"
                        }
                      ]
                    },
                    {
                      "onSelect": "SELECT_DAY",
                      "type": "date-range-selector",
                      "selected": "@entity.selectedRange"
                    }
                  ],
                  "gap": "md",
                  "justify": "between",
                  "direction": "horizontal"
                },
                {
                  "type": "divider"
                },
                {
                  "type": "calendar-grid"
                },
                {
                  "type": "divider"
                },
                {
                  "content": "Upcoming Events",
                  "type": "typography",
                  "variant": "h4"
                },
                {
                  "fields": [
                    {
                      "name": "name",
                      "label": "Event",
                      "icon": "calendar",
                      "variant": "h4"
                    },
                    {
                      "label": "Time",
                      "variant": "badge",
                      "name": "time"
                    },
                    {
                      "label": "Date",
                      "variant": "caption",
                      "name": "date",
                      "format": "date"
                    },
                    {
                      "label": "Status",
                      "name": "status",
                      "variant": "badge"
                    }
                  ],
                  "itemActions": [
                    {
                      "label": "View",
                      "event": "SELECT_DAY",
                      "icon": "eye"
                    }
                  ],
                  "look": "@config.tableLook",
                  "type": "data-list",
                  "entity": "@payload.data"
                }
              ],
              "type": "stack"
            },
            "label": "Body content tree",
            "description": "Render-ui SExpr rendered after events load. Default is the month-grid + upcoming-events list. Layer 3 variants override this with their own tree (agenda list, week timeline, etc.) to deliver entirely different calendar UX while inheriting the same trait, state machine, emits, and listens.",
            "tier": "internal"
          },
          {
            "key": "descriptionBinding",
            "type": "string",
            "default": "@item.description",
            "label": "Description binding",
            "description": "Per-row binding for the event description slot.",
            "tier": "presentation"
          },
          {
            "key": "tableLook",
            "type": "string",
            "default": "dense",
            "label": "Table look",
            "description": "Layer 2 visual treatment for the data table rendered by this atom.",
            "tier": "presentation",
            "enumValues": [
              "dense",
              "spacious",
              "striped",
              "borderless",
              "card-rows"
            ]
          },
          {
            "key": "timeBinding",
            "type": "string",
            "default": "@item.time",
            "label": "Time binding",
            "description": "Per-row binding for the event time slot.",
            "tier": "presentation"
          },
          {
            "key": "titleBinding",
            "type": "string",
            "default": "@item.name",
            "label": "Title binding",
            "description": "Per-row binding for the event title slot.",
            "tier": "presentation"
          }
        ],
        "capabilities": [],
        "entityRebindable": true,
        "entityContract": {
          "requires": [],
          "provides": [
            "date",
            "selectedRange"
          ]
        }
      }
    ],
    "pages": [
      {
        "name": "CalendarEventCalendarPage",
        "defaultPath": "/calendarevents/calendar",
        "primaryEntity": "CalendarEvent"
      }
    ],
    "emittedEvents": [
      "CalendarEventLoadFailed",
      "CalendarEventLoaded"
    ],
    "listenedEvents": []
  }
]
