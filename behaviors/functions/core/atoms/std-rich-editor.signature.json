[
  {
    "organism": "std-rich-editor",
    "orbital": "DocumentOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-rich-editor.ts",
    "entities": [
      {
        "name": "Document",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true,
            "description": "The human-readable name of the document.",
            "synonyms": "name, heading, label"
          },
          {
            "name": "blocksJson",
            "type": "array",
            "required": false,
            "description": "Serialized representation of the document's content blocks.",
            "synonyms": "content, data, structure, blocks"
          },
          {
            "name": "authorId",
            "type": "string",
            "required": false,
            "description": "Unique identifier of the user who created the document.",
            "synonyms": "creatorId, userId, ownerId"
          },
          {
            "name": "parentId",
            "type": "string",
            "required": false,
            "description": "Reference to the parent document or container.",
            "synonyms": "parent, container, owner"
          },
          {
            "name": "kind",
            "type": "string",
            "required": false,
            "description": "Specifies the document type.",
            "synonyms": "type, documentType, category"
          },
          {
            "name": "status",
            "type": "string",
            "required": false,
            "description": "Indicates the current state of the document.",
            "synonyms": "state, condition, lifecycle"
          },
          {
            "name": "version",
            "type": "number",
            "required": false,
            "description": "Represents the version number of the document.",
            "synonyms": "revision, release, iteration"
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "DocumentEdit",
        "emittedEvents": [
          "OPEN",
          "CLOSE_VIEW",
          "BLOCKS_CHANGE",
          "SAVE",
          "PUBLISH",
          "DocumentLoaded",
          "DocumentLoadFailed",
          "DocumentSaved",
          "DocumentPublished",
          "DocumentSaveFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "statLook",
            "type": "string",
            "default": "elevated",
            "label": "Stat display look",
            "description": "Layer 2 visual treatment for stat / KPI cards.",
            "tier": "presentation",
            "enumValues": [
              "elevated",
              "flat",
              "progress-backed",
              "gauge",
              "sparkline"
            ]
          },
          {
            "key": "tableLook",
            "type": "string",
            "default": "dense",
            "label": "Table look",
            "description": "Layer 2 visual treatment for the data table rendered by this atom.",
            "tier": "presentation",
            "enumValues": [
              "dense",
              "spacious",
              "striped",
              "borderless",
              "card-rows"
            ]
          },
          {
            "key": "title",
            "type": "string",
            "default": "Documents",
            "label": "Section title",
            "description": "Heading shown above the document list",
            "tier": "presentation"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "DocumentEditPage",
        "defaultPath": "/documents/edit",
        "primaryEntity": "Document"
      }
    ],
    "emittedEvents": [
      "BLOCKS_CHANGE",
      "CLOSE_VIEW",
      "DocumentLoadFailed",
      "DocumentLoaded",
      "DocumentPublished",
      "DocumentSaveFailed",
      "DocumentSaved",
      "OPEN",
      "PUBLISH",
      "SAVE"
    ],
    "listenedEvents": []
  }
]
