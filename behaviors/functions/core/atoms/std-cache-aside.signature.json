[
  {
    "organism": "std-cache-aside",
    "orbital": "CacheEntryOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/core/atoms/std-cache-aside.ts",
    "entities": [
      {
        "name": "CacheEntry",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "hitCount",
            "type": "number",
            "required": false
          },
          {
            "name": "cacheAge",
            "type": "number",
            "required": false
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "CacheEntryCacheManager",
        "emittedEvents": [
          "CacheEntryLoaded",
          "CacheEntryLoadFailed",
          "CacheEntryUpdated",
          "CacheEntryUpdateFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "evictionPolicy",
            "type": "string",
            "default": "lru",
            "label": "Eviction policy",
            "description": "How entries are evicted when the cache fills: least-recently-used, least-frequently-used, first-in-first-out, or TTL-only (never evict early).",
            "synonyms": "cache replacement, eviction strategy",
            "tier": "domain",
            "enumValues": [
              "lru",
              "lfu",
              "fifo",
              "ttl-only"
            ]
          },
          {
            "key": "maxCacheSize",
            "type": "number",
            "default": 1000,
            "label": "Max cache entries",
            "description": "Hard cap on cached entries before eviction. 0 = unlimited.",
            "synonyms": "cache capacity, max entries",
            "tier": "domain"
          },
          {
            "key": "staleWhileRevalidate",
            "type": "boolean",
            "default": true,
            "label": "Serve stale while revalidating",
            "description": "When true, serve stale entries to consumers while a background refresh fetches fresh data. Reduces latency at the cost of brief staleness.",
            "synonyms": "SWR, stale serving",
            "tier": "domain"
          },
          {
            "key": "ttlSeconds",
            "type": "number",
            "default": 300,
            "label": "TTL (seconds)",
            "description": "Cache entry time-to-live before it goes stale. Default 5 minutes.",
            "synonyms": "expiration, time to live, cache duration",
            "tier": "domain"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "CacheEntryPage",
        "defaultPath": "/cacheentrys",
        "primaryEntity": "CacheEntry"
      }
    ],
    "emittedEvents": [
      "CacheEntryLoadFailed",
      "CacheEntryLoaded",
      "CacheEntryUpdateFailed",
      "CacheEntryUpdated"
    ],
    "listenedEvents": []
  }
]
