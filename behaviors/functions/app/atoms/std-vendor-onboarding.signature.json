[
  {
    "organism": "std-vendor-onboarding",
    "orbital": "VendorOnboardingOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-vendor-onboarding.ts",
    "entities": [
      {
        "name": "Vendor",
        "fields": [
          {
            "name": "businessName",
            "type": "string",
            "required": true
          },
          {
            "name": "legalName",
            "type": "string",
            "required": false
          },
          {
            "name": "ein",
            "type": "string",
            "required": false
          },
          {
            "name": "bankRoutingMasked",
            "type": "string",
            "required": false
          },
          {
            "name": "bankAcctMasked",
            "type": "string",
            "required": false
          },
          {
            "name": "identityDocUrl",
            "type": "string",
            "required": false
          },
          {
            "name": "currentStep",
            "type": "string",
            "required": false
          },
          {
            "name": "submittedAt",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "VendorOnboard",
        "emittedEvents": [
          "NEXT_STEP",
          "BACK_STEP",
          "SUBMIT",
          "UPLOAD_IDENTITY",
          "VendorLoaded",
          "VendorLoadFailed"
        ],
        "listenedEvents": [
          "VendorUpdated",
          "VendorSubmitted"
        ],
        "overridableConfigKeys": [
          {
            "key": "anonymizeOnRejection",
            "type": "boolean",
            "default": false,
            "label": "Anonymize on rejection",
            "description": "When true, scrub vendor PII on rejected applications. Pair with std-data-erasure."
          },
          {
            "key": "backgroundCheckRequired",
            "type": "boolean",
            "default": true,
            "label": "Background check required",
            "description": "Block SUBMIT until a background check on the vendor is on file."
          },
          {
            "key": "eVerifyRequired",
            "type": "boolean",
            "default": false,
            "label": "E-Verify required",
            "description": "US E-Verify gate. Block SUBMIT until verification passes."
          },
          {
            "key": "equalOpportunityTrackingEnabled",
            "type": "boolean",
            "default": false,
            "label": "Equal opportunity tracking",
            "description": "Capture supplier diversity / EEO data separately (sibling collection)."
          },
          {
            "key": "i9DocumentsRequired",
            "type": "boolean",
            "default": false,
            "label": "I-9 documents required",
            "description": "Require I-9 supporting documents (relevant for sole-proprietor vendors)."
          },
          {
            "key": "retentionAfterRejectionDays",
            "type": "number",
            "default": 1825,
            "label": "Retention after rejection (days)",
            "description": "Days to keep rejected vendor onboarding records. Default 1825 (5 years) typical KYC retention."
          }
        ],
        "capabilities": []
      },
      {
        "name": "VendorPersistor",
        "emittedEvents": [
          "VendorUpdated",
          "VendorUpdateFailed",
          "VendorSubmitted",
          "VendorSubmitFailed"
        ],
        "listenedEvents": [
          "NEXT_STEP",
          "SUBMIT"
        ],
        "overridableConfigKeys": [],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "VendorOnboardingPage",
        "defaultPath": "/vendor-onboarding",
        "primaryEntity": "Vendor"
      }
    ],
    "emittedEvents": [
      "BACK_STEP",
      "NEXT_STEP",
      "SUBMIT",
      "UPLOAD_IDENTITY",
      "VendorLoadFailed",
      "VendorLoaded",
      "VendorSubmitFailed",
      "VendorSubmitted",
      "VendorUpdateFailed",
      "VendorUpdated"
    ],
    "listenedEvents": [
      "NEXT_STEP",
      "SUBMIT",
      "VendorSubmitted",
      "VendorUpdated"
    ]
  }
]
