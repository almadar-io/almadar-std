[
  {
    "organism": "std-applicant",
    "orbital": "ApplicantOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-applicant.ts",
    "entities": [
      {
        "name": "Applicant",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "required": false
          },
          {
            "name": "phone",
            "type": "string",
            "required": false
          },
          {
            "name": "jobId",
            "type": "string",
            "required": false
          },
          {
            "name": "resumeUrl",
            "type": "string",
            "required": false
          },
          {
            "name": "stage",
            "type": "string",
            "required": false
          },
          {
            "name": "notes",
            "type": "string",
            "required": false
          },
          {
            "name": "appliedAt",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "ApplicantPipeline",
        "emittedEvents": [
          "OPEN_APPLICANT",
          "CLOSE_VIEW",
          "ADVANCE_STAGE",
          "REJECT_APPLICANT",
          "ApplicantLoaded",
          "ApplicantLoadFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "anonymizeOnRejection",
            "type": "boolean",
            "default": false,
            "label": "Anonymize on rejection",
            "description": "When true, scrub PII (name, email, phone, resumeUrl) on REJECT_APPLICANT. Pair with std-data-erasure."
          },
          {
            "key": "backgroundCheckRequired",
            "type": "boolean",
            "default": false,
            "label": "Background check required",
            "description": "Block ADVANCE_STAGE to 'hired' until a background check is on file."
          },
          {
            "key": "eVerifyRequired",
            "type": "boolean",
            "default": false,
            "label": "E-Verify required",
            "description": "US I-9 / E-Verify gate. Block ADVANCE_STAGE to 'hired' until verification passes."
          },
          {
            "key": "equalOpportunityTrackingEnabled",
            "type": "boolean",
            "default": false,
            "label": "Equal opportunity tracking",
            "description": "Capture demographic data separately for EEO reporting (sibling collection, not on Applicant entity)."
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "variant": "caption",
                "label": "Name",
                "name": "name"
              },
              {
                "variant": "caption",
                "label": "Email",
                "name": "email"
              },
              {
                "label": "Job",
                "variant": "caption",
                "name": "jobId"
              },
              {
                "variant": "badge",
                "label": "Stage",
                "name": "stage"
              },
              {
                "label": "Applied",
                "name": "appliedAt",
                "variant": "caption"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the Applicant entity",
            "items": {
              "properties": {
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "i9DocumentsRequired",
            "type": "boolean",
            "default": false,
            "label": "I-9 documents required",
            "description": "Require I-9 supporting documents at the hired stage."
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [
              {
                "label": "Open",
                "event": "OPEN_APPLICANT",
                "variant": "primary",
                "icon": "arrow-right"
              },
              {
                "event": "REJECT_APPLICANT",
                "variant": "danger",
                "label": "Reject"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each applicant row",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "retentionAfterRejectionDays",
            "type": "number",
            "default": 730,
            "label": "Retention after rejection (days)",
            "description": "Days to keep rejected applicants. Default 730 (2 years) is typical EEOC retention."
          },
          {
            "key": "title",
            "type": "string",
            "default": "Applicants",
            "label": "Section title",
            "description": "Heading shown above the applicant pipeline"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "ApplicantPage",
        "defaultPath": "/applicants",
        "primaryEntity": "Applicant"
      }
    ],
    "emittedEvents": [
      "ADVANCE_STAGE",
      "ApplicantLoadFailed",
      "ApplicantLoaded",
      "CLOSE_VIEW",
      "OPEN_APPLICANT",
      "REJECT_APPLICANT"
    ],
    "listenedEvents": []
  }
]
