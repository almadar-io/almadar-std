[
  {
    "organism": "std-interview-slot",
    "orbital": "InterviewSlotOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-interview-slot.ts",
    "entities": [
      {
        "name": "InterviewSlot",
        "fields": [
          {
            "name": "applicantId",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantName",
            "type": "string",
            "required": false
          },
          {
            "name": "interviewerName",
            "type": "string",
            "required": false
          },
          {
            "name": "scheduledAt",
            "type": "string",
            "required": true
          },
          {
            "name": "durationMinutes",
            "type": "number",
            "required": false
          },
          {
            "name": "format",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "notes",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "InterviewSlotSchedule",
        "emittedEvents": [
          "OPEN_INTERVIEW",
          "CLOSE_VIEW",
          "COMPLETE_INTERVIEW",
          "CANCEL_INTERVIEW",
          "InterviewSlotLoaded",
          "InterviewSlotLoadFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "anonymizeOnRejection",
            "type": "boolean",
            "default": false,
            "label": "Anonymize on rejection",
            "description": "When true, scrub applicant PII on rejection. Pair with std-data-erasure."
          },
          {
            "key": "backgroundCheckRequired",
            "type": "boolean",
            "default": false,
            "label": "Background check required",
            "description": "Block COMPLETE_INTERVIEW until a background check is on file."
          },
          {
            "key": "blackoutDates",
            "type": "[string]",
            "default": [],
            "label": "Blackout dates",
            "description": "ISO dates blocked from booking (e.g. holidays). Compose std-lifecycle to enforce.",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "bookingHours",
            "type": "string",
            "default": "09:00-17:00",
            "label": "Booking hours",
            "description": "Daily window during which interviews can be scheduled (HH:MM-HH:MM)."
          },
          {
            "key": "bookingWindowDays",
            "type": "number",
            "default": 30,
            "label": "Booking window (days)",
            "description": "How far in advance applicants can schedule interviews."
          },
          {
            "key": "cancellationPolicy",
            "type": "string",
            "default": "free",
            "label": "Cancellation policy",
            "description": "Refund treatment when a slot is cancelled inside the reschedule window.",
            "enumValues": [
              "free",
              "partial-refund",
              "no-refund"
            ]
          },
          {
            "key": "eVerifyRequired",
            "type": "boolean",
            "default": false,
            "label": "E-Verify required",
            "description": "US I-9 / E-Verify gate. Block downstream offer until verification passes."
          },
          {
            "key": "equalOpportunityTrackingEnabled",
            "type": "boolean",
            "default": false,
            "label": "Equal opportunity tracking",
            "description": "Capture demographic data separately for EEO reporting (sibling collection)."
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "label": "Applicant",
                "variant": "caption",
                "name": "applicantName"
              },
              {
                "label": "Interviewer",
                "variant": "caption",
                "name": "interviewerName"
              },
              {
                "name": "scheduledAt",
                "variant": "caption",
                "label": "Scheduled"
              },
              {
                "variant": "badge",
                "name": "format",
                "label": "Format"
              },
              {
                "name": "status",
                "variant": "badge",
                "label": "Status"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the Interview Slot entity",
            "items": {
              "properties": {
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "i9DocumentsRequired",
            "type": "boolean",
            "default": false,
            "label": "I-9 documents required",
            "description": "Require I-9 supporting documents before accepting an offer downstream."
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [
              {
                "label": "Open",
                "icon": "arrow-right",
                "event": "OPEN_INTERVIEW",
                "variant": "primary"
              },
              {
                "label": "Cancel",
                "event": "CANCEL_INTERVIEW",
                "variant": "danger"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each interview row",
            "items": {
              "properties": {
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "leadTimeMinutes",
            "type": "number",
            "default": 60,
            "label": "Lead time (minutes)",
            "description": "Minimum minutes before start time that a new booking is accepted."
          },
          {
            "key": "maxReschedules",
            "type": "number",
            "default": 2,
            "label": "Max reschedules",
            "description": "Hard cap on reschedule count per interview slot."
          },
          {
            "key": "noShowGracePeriodMinutes",
            "type": "number",
            "default": 15,
            "label": "No-show grace (minutes)",
            "description": "Minutes after scheduledAt before the slot auto-marks no_show. Wire via std-lifecycle."
          },
          {
            "key": "rescheduleWindowHours",
            "type": "number",
            "default": 24,
            "label": "Reschedule window (hours)",
            "description": "Hours before scheduledAt during which the applicant can self-reschedule."
          },
          {
            "key": "retentionAfterRejectionDays",
            "type": "number",
            "default": 730,
            "label": "Retention after rejection (days)",
            "description": "Days to keep rejected interview records. Default 730 (2 years) EEOC typical."
          },
          {
            "key": "title",
            "type": "string",
            "default": "Interviews",
            "label": "Section title",
            "description": "Heading shown above the interview schedule"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "InterviewSlotPage",
        "defaultPath": "/interviews",
        "primaryEntity": "InterviewSlot"
      }
    ],
    "emittedEvents": [
      "CANCEL_INTERVIEW",
      "CLOSE_VIEW",
      "COMPLETE_INTERVIEW",
      "InterviewSlotLoadFailed",
      "InterviewSlotLoaded",
      "OPEN_INTERVIEW"
    ],
    "listenedEvents": []
  }
]
