[
  {
    "organism": "std-form-builder",
    "orbital": "FormBuilderOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-form-builder.ts",
    "entities": [
      {
        "name": "Survey",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "questionsJson",
            "type": "string",
            "required": false
          },
          {
            "name": "rulesJson",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "SurveyManage",
        "emittedEvents": [
          "OPEN_SURVEY",
          "CLOSE_VIEW",
          "CREATE",
          "PUBLISH",
          "SurveyLoaded",
          "SurveyLoadFailed",
          "SurveyCreated",
          "SurveyUpdated",
          "SurveyPublished"
        ],
        "listenedEvents": [
          "QuestionsChanged",
          "RulesChanged"
        ],
        "overridableConfigKeys": [
          {
            "key": "allowRollback",
            "type": "boolean",
            "default": true,
            "label": "Allow rollback",
            "description": "Permit reverting a form to a prior retained version.",
            "tier": "customization"
          },
          {
            "key": "defaultLocale",
            "type": "string",
            "default": "en",
            "label": "Default locale",
            "description": "Locale used when no translation exists for the respondent's language.",
            "tier": "customization"
          },
          {
            "key": "draftAutosaveSeconds",
            "type": "number",
            "default": 15,
            "label": "Draft autosave interval (s)",
            "description": "Seconds between draft autosaves in the form builder.",
            "tier": "advanced"
          },
          {
            "key": "enabledLocales",
            "type": "[string]",
            "default": [
              "en"
            ],
            "label": "Enabled locales",
            "description": "Locales the form can be translated into.",
            "tier": "customization",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "label": "Title",
                "variant": "caption",
                "name": "title"
              },
              {
                "label": "Description",
                "variant": "caption",
                "name": "description"
              },
              {
                "label": "Status",
                "name": "status",
                "variant": "badge"
              },
              {
                "variant": "caption",
                "name": "createdAt",
                "label": "Created"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the Survey entity",
            "tier": "customization",
            "items": {
              "properties": {
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [
              {
                "label": "Open",
                "event": "OPEN_SURVEY",
                "variant": "primary",
                "icon": "arrow-right"
              },
              {
                "variant": "secondary",
                "event": "PUBLISH",
                "icon": "send",
                "label": "Publish"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each survey row",
            "tier": "customization",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "keepVersions",
            "type": "number",
            "default": 10,
            "label": "Versions to retain",
            "description": "Number of form revisions to keep.",
            "tier": "customization"
          },
          {
            "key": "scheduledPublishEnabled",
            "type": "boolean",
            "default": false,
            "label": "Scheduled publish",
            "description": "Allow authors to schedule a future publish time. v1.2 declarative.",
            "tier": "customization"
          },
          {
            "key": "seoEnabled",
            "type": "boolean",
            "default": false,
            "label": "SEO meta enabled",
            "description": "Emit canonical + meta tags on the public form page.",
            "tier": "customization"
          },
          {
            "key": "title",
            "type": "string",
            "default": "Survey Builder",
            "label": "Section title",
            "description": "Heading shown above the survey list",
            "tier": "customization"
          },
          {
            "key": "visibilityScope",
            "type": "string",
            "default": "internal",
            "label": "Visibility scope",
            "description": "Who can fill out published forms: public web, internal staff, signed-in customers.",
            "tier": "essential",
            "enumValues": [
              "public",
              "internal",
              "customer"
            ]
          }
        ],
        "capabilities": []
      },
      {
        "name": "SurveyQuestions",
        "emittedEvents": [
          "EDIT_QUESTIONS_JSON",
          "SAVE_QUESTIONS",
          "SurveyHydrated",
          "QuestionsChanged",
          "QuestionsSaveFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "title",
            "type": "string",
            "default": "Survey questions",
            "label": "Editor heading",
            "description": "Heading shown above the questions editor sidebar",
            "tier": "customization"
          }
        ],
        "capabilities": []
      },
      {
        "name": "SurveyBranching",
        "emittedEvents": [
          "EDIT_RULES_JSON",
          "SAVE_RULES",
          "SurveyHydrated",
          "RulesChanged",
          "RulesSaveFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "title",
            "type": "string",
            "default": "Branching rules",
            "label": "Editor heading",
            "description": "Heading shown above the branching rules editor",
            "tier": "customization"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "FormBuilderPage",
        "defaultPath": "/survey-builder",
        "primaryEntity": "Survey"
      }
    ],
    "emittedEvents": [
      "CLOSE_VIEW",
      "CREATE",
      "EDIT_QUESTIONS_JSON",
      "EDIT_RULES_JSON",
      "OPEN_SURVEY",
      "PUBLISH",
      "QuestionsChanged",
      "QuestionsSaveFailed",
      "RulesChanged",
      "RulesSaveFailed",
      "SAVE_QUESTIONS",
      "SAVE_RULES",
      "SurveyCreated",
      "SurveyHydrated",
      "SurveyLoadFailed",
      "SurveyLoaded",
      "SurveyPublished",
      "SurveyUpdated"
    ],
    "listenedEvents": [
      "QuestionsChanged",
      "RulesChanged"
    ]
  }
]
