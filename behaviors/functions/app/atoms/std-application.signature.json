[
  {
    "organism": "std-application",
    "orbital": "ApplicationOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-application.ts",
    "entities": [
      {
        "name": "Application",
        "fields": [
          {
            "name": "applicantName",
            "type": "string",
            "required": true
          },
          {
            "name": "applicantEmail",
            "type": "string",
            "required": true
          },
          {
            "name": "targetId",
            "type": "string",
            "required": true
          },
          {
            "name": "targetType",
            "type": "string",
            "required": true
          },
          {
            "name": "coverLetter",
            "type": "string",
            "required": false
          },
          {
            "name": "attachmentsJson",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "submittedAt",
            "type": "string",
            "required": false
          },
          {
            "name": "reviewedAt",
            "type": "string",
            "required": false
          },
          {
            "name": "notes",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "ApplicationManage",
        "emittedEvents": [
          "CREATE",
          "EDIT",
          "SUBMIT",
          "ACCEPT",
          "REJECT",
          "CREATE_SUBMIT",
          "UPDATE_SUBMIT",
          "CANCEL_EDIT",
          "ApplicationLoaded",
          "ApplicationLoadFailed",
          "ApplicationCreated",
          "ApplicationUpdated",
          "ApplicationSubmitted",
          "ApplicationAccepted",
          "ApplicationRejected"
        ],
        "listenedEvents": [
          "ITEM_CREATED",
          "ITEM_UPDATED"
        ],
        "overridableConfigKeys": [
          {
            "key": "anonymizeOnRejection",
            "type": "boolean",
            "default": false,
            "label": "Anonymize on rejection",
            "description": "When true, scrub PII (applicantName, applicantEmail, coverLetter) on REJECT to retain only the audit row. Pair with sibling std-data-erasure for full Art. 17 compliance."
          },
          {
            "key": "backgroundCheckRequired",
            "type": "boolean",
            "default": false,
            "label": "Background check required",
            "description": "Block ACCEPT transition until a background check is complete."
          },
          {
            "key": "eVerifyRequired",
            "type": "boolean",
            "default": false,
            "label": "E-Verify required",
            "description": "US I-9 / E-Verify gate. Block ACCEPT until verification passes."
          },
          {
            "key": "equalOpportunityTrackingEnabled",
            "type": "boolean",
            "default": false,
            "label": "Equal opportunity tracking",
            "description": "Capture demographic data separately for EEO reporting (stored in a sibling collection, not on the Application entity)."
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "name": "applicantName",
                "icon": "user",
                "label": "Applicant",
                "variant": "caption"
              },
              {
                "name": "applicantEmail",
                "variant": "caption",
                "label": "Email"
              },
              {
                "label": "Target",
                "name": "targetType",
                "variant": "caption"
              },
              {
                "variant": "badge",
                "name": "status",
                "label": "Status"
              },
              {
                "name": "submittedAt",
                "variant": "caption",
                "label": "Submitted"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the Application entity",
            "items": {
              "properties": {
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "i9DocumentsRequired",
            "type": "boolean",
            "default": false,
            "label": "I-9 documents required",
            "description": "Require I-9 supporting documents at the accepted transition."
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [
              {
                "event": "EDIT",
                "variant": "ghost",
                "label": "Edit"
              },
              {
                "label": "Submit",
                "event": "SUBMIT",
                "variant": "primary"
              },
              {
                "label": "Accept",
                "event": "ACCEPT",
                "variant": "primary"
              },
              {
                "variant": "danger",
                "label": "Reject",
                "event": "REJECT"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each application row",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "retentionAfterRejectionDays",
            "type": "number",
            "default": 730,
            "label": "Retention after rejection (days)",
            "description": "Days to keep rejected applications. Default 730 (2 years) is typical EEOC retention. Wire via sibling std-lifecycle delete rule."
          },
          {
            "key": "title",
            "type": "string",
            "default": "Applications",
            "label": "Section title",
            "description": "Heading shown above the application list"
          }
        ],
        "capabilities": []
      },
      {
        "name": "ApplicationPersistor",
        "emittedEvents": [
          "ITEM_CREATED",
          "ITEM_UPDATED"
        ],
        "listenedEvents": [
          "CREATE_SUBMIT",
          "UPDATE_SUBMIT"
        ],
        "overridableConfigKeys": [],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "ApplicationPage",
        "defaultPath": "/applications",
        "primaryEntity": "Application"
      }
    ],
    "emittedEvents": [
      "ACCEPT",
      "ApplicationAccepted",
      "ApplicationCreated",
      "ApplicationLoadFailed",
      "ApplicationLoaded",
      "ApplicationRejected",
      "ApplicationSubmitted",
      "ApplicationUpdated",
      "CANCEL_EDIT",
      "CREATE",
      "CREATE_SUBMIT",
      "EDIT",
      "ITEM_CREATED",
      "ITEM_UPDATED",
      "REJECT",
      "SUBMIT",
      "UPDATE_SUBMIT"
    ],
    "listenedEvents": [
      "CREATE_SUBMIT",
      "ITEM_CREATED",
      "ITEM_UPDATED",
      "UPDATE_SUBMIT"
    ]
  }
]
