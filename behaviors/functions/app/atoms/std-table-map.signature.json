[
  {
    "organism": "std-table-map",
    "orbital": "TableMapOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-table-map.ts",
    "entities": [
      {
        "name": "TableNode",
        "fields": [
          {
            "name": "label",
            "type": "string",
            "required": true
          },
          {
            "name": "x",
            "type": "number",
            "required": false
          },
          {
            "name": "y",
            "type": "number",
            "required": false
          },
          {
            "name": "shape",
            "type": "string",
            "required": false
          },
          {
            "name": "capacity",
            "type": "number",
            "required": true
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "partySize",
            "type": "number",
            "required": false
          },
          {
            "name": "serverName",
            "type": "string",
            "required": false
          },
          {
            "name": "currentOrderId",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "TableManage",
        "emittedEvents": [
          "SELECT_TABLE",
          "MOVE_TABLE",
          "SEAT",
          "CLEAR_TABLE",
          "TableLoaded",
          "TableLoadFailed",
          "TableSelected",
          "TableUpdated",
          "TableWriteFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "allergenWarningsEnabled",
            "type": "boolean",
            "default": true,
            "label": "Allergen warnings",
            "description": "Surface allergen warnings on items selected for a seated table."
          },
          {
            "key": "allowSplitChecks",
            "type": "boolean",
            "default": true,
            "label": "Allow split checks",
            "description": "Permit splitting a table check across multiple payments."
          },
          {
            "key": "canvasHeight",
            "type": "number",
            "default": 600,
            "label": "Canvas height",
            "description": "Floor plan canvas height in pixels"
          },
          {
            "key": "canvasWidth",
            "type": "number",
            "default": 800,
            "label": "Canvas width",
            "description": "Floor plan canvas width in pixels"
          },
          {
            "key": "coursingEnabled",
            "type": "boolean",
            "default": false,
            "label": "Coursing enabled",
            "description": "Track courses for table pacing."
          },
          {
            "key": "kitchenAutoFire",
            "type": "boolean",
            "default": false,
            "label": "Kitchen auto-fire",
            "description": "Auto-fire courses to the kitchen display when a table moves to ordered."
          },
          {
            "key": "serviceCharge",
            "type": "number",
            "default": 0,
            "label": "Service charge (%)",
            "description": "Default service-charge percentage applied to checks for these tables."
          },
          {
            "key": "tableTurnoverTargetMinutes",
            "type": "number",
            "default": 60,
            "label": "Table turnover target (min)",
            "description": "Target minutes between seatings on a single table. v1.1 declarative."
          },
          {
            "key": "tipPresets",
            "type": "[number]",
            "default": [
              15,
              18,
              20,
              25
            ],
            "label": "Tip presets (%)",
            "description": "Quick-select tip percentages shown when closing a table check.",
            "items": {
              "type": "number"
            }
          },
          {
            "key": "title",
            "type": "string",
            "default": "Floor Plan",
            "label": "Section title",
            "description": "Heading shown above the restaurant floor plan"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "TableManagePage",
        "defaultPath": "/tables/manage",
        "primaryEntity": "TableNode"
      }
    ],
    "emittedEvents": [
      "CLEAR_TABLE",
      "MOVE_TABLE",
      "SEAT",
      "SELECT_TABLE",
      "TableLoadFailed",
      "TableLoaded",
      "TableSelected",
      "TableUpdated",
      "TableWriteFailed"
    ],
    "listenedEvents": []
  }
]
