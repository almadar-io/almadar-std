[
  {
    "organism": "std-menu",
    "orbital": "MenuOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-menu.ts",
    "entities": [
      {
        "name": "MenuItem",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "price",
            "type": "number",
            "required": true
          },
          {
            "name": "currency",
            "type": "string",
            "required": false
          },
          {
            "name": "category",
            "type": "string",
            "required": true
          },
          {
            "name": "imageUrl",
            "type": "string",
            "required": false
          },
          {
            "name": "available",
            "type": "boolean",
            "required": false
          },
          {
            "name": "availableFrom",
            "type": "string",
            "required": false
          },
          {
            "name": "availableUntil",
            "type": "string",
            "required": false
          },
          {
            "name": "tags",
            "type": "array",
            "required": false
          },
          {
            "name": "modifierGroupIds",
            "type": "array",
            "required": false
          },
          {
            "name": "prepTimeMinutes",
            "type": "number",
            "required": false
          },
          {
            "name": "order",
            "type": "number",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "MenuItemManage",
        "emittedEvents": [
          "OPEN_ITEM",
          "CLOSE_VIEW",
          "CREATE",
          "UPDATE",
          "TOGGLE_AVAILABLE",
          "DELETE",
          "MenuItemLoaded",
          "MenuItemLoadFailed",
          "MenuItemCreated",
          "MenuItemUpdated",
          "MenuItemDeleted",
          "MenuItemWriteFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "allergenWarningsEnabled",
            "type": "boolean",
            "default": true,
            "label": "Allergen warnings",
            "description": "Surface allergen warnings on menu items with declared allergens."
          },
          {
            "key": "allowSplitChecks",
            "type": "boolean",
            "default": true,
            "label": "Allow split checks",
            "description": "Permit splitting a single table check across multiple payments."
          },
          {
            "key": "coursingEnabled",
            "type": "boolean",
            "default": false,
            "label": "Coursing enabled",
            "description": "Track ordered courses (apps / mains / desserts) for pacing."
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "variant": "caption",
                "label": "Item",
                "name": "name"
              },
              {
                "label": "Category",
                "variant": "badge",
                "name": "category"
              },
              {
                "variant": "caption",
                "name": "price",
                "label": "Price"
              },
              {
                "variant": "badge",
                "name": "currency",
                "label": "Currency"
              },
              {
                "label": "Prep (min)",
                "name": "prepTimeMinutes",
                "variant": "caption"
              },
              {
                "variant": "badge",
                "name": "available",
                "label": "Available"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the Menu Item entity",
            "items": {
              "properties": {
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [
              {
                "variant": "primary",
                "event": "OPEN_ITEM",
                "label": "Open",
                "icon": "arrow-right"
              },
              {
                "event": "DELETE",
                "label": "Delete",
                "icon": "trash",
                "variant": "danger"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each menu item",
            "items": {
              "properties": {
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "kitchenAutoFire",
            "type": "boolean",
            "default": false,
            "label": "Kitchen auto-fire",
            "description": "Auto-send courses to the kitchen display without explicit fire action."
          },
          {
            "key": "serviceCharge",
            "type": "number",
            "default": 0,
            "label": "Service charge (%)",
            "description": "Default service-charge percentage applied to checks. v1.2 declarative."
          },
          {
            "key": "tableTurnoverTargetMinutes",
            "type": "number",
            "default": 60,
            "label": "Table turnover target (min)",
            "description": "Target minutes between seatings on a single table. v1.2 declarative."
          },
          {
            "key": "tipPresets",
            "type": "[number]",
            "default": [
              15,
              18,
              20,
              25
            ],
            "label": "Tip presets (%)",
            "description": "Quick-select tip percentages shown on the checkout terminal.",
            "items": {
              "type": "number"
            }
          },
          {
            "key": "title",
            "type": "string",
            "default": "Menu",
            "label": "Section title",
            "description": "Heading shown above the menu item list"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "MenuItemManagePage",
        "defaultPath": "/menu/manage",
        "primaryEntity": "MenuItem"
      }
    ],
    "emittedEvents": [
      "CLOSE_VIEW",
      "CREATE",
      "DELETE",
      "MenuItemCreated",
      "MenuItemDeleted",
      "MenuItemLoadFailed",
      "MenuItemLoaded",
      "MenuItemUpdated",
      "MenuItemWriteFailed",
      "OPEN_ITEM",
      "TOGGLE_AVAILABLE",
      "UPDATE"
    ],
    "listenedEvents": []
  }
]
