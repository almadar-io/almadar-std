              },
              {
                "label": "Delete",
                "variant": "danger",
                "event": "DELETE_QUESTION"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each question row",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
