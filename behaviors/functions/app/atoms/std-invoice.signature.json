[
  {
    "organism": "std-invoice",
    "orbital": "InvoiceOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-invoice.ts",
    "entities": [
      {
        "name": "InvoiceRecord",
        "fields": [
          {
            "name": "invoiceNumber",
            "type": "string",
            "required": true
          },
          {
            "name": "customerId",
            "type": "string",
            "required": true
          },
          {
            "name": "subscriptionId",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "currency",
            "type": "string",
            "required": false
          },
          {
            "name": "subtotal",
            "type": "number",
            "required": false
          },
          {
            "name": "tax",
            "type": "number",
            "required": false
          },
          {
            "name": "total",
            "type": "number",
            "required": false
          },
          {
            "name": "issuedAt",
            "type": "string",
            "required": false
          },
          {
            "name": "dueAt",
            "type": "string",
            "required": false
          },
          {
            "name": "paidAt",
            "type": "string",
            "required": false
          },
          {
            "name": "lineItemsJson",
            "type": "string",
            "required": false
          },
          {
            "name": "notes",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "InvoiceManage",
        "emittedEvents": [
          "OPEN_INVOICE",
          "CLOSE_VIEW",
          "SEND",
          "MARK_PAID",
          "VOID",
          "REFUND",
          "InvoiceLoaded",
          "InvoiceLoadFailed",
          "InvoiceUpdated",
          "InvoiceUpdateFailed",
          "InvoiceRefunded",
          "InvoiceRefundFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "complianceJurisdiction",
            "type": "string",
            "default": "",
            "label": "Compliance jurisdiction",
            "description": "Drives tax + retention rules per locale: 'US-CA', 'EU-DE', 'UK', etc. v1.2 declarative."
          },
          {
            "key": "currency",
            "type": "string",
            "default": "USD",
            "label": "Default currency",
            "description": "ISO 4217 currency code (USD, EUR, GBP, …) for new invoices."
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "name": "invoiceNumber",
                "variant": "caption",
                "label": "Invoice #"
              },
              {
                "variant": "caption",
                "name": "customerId",
                "label": "Customer"
              },
              {
                "name": "status",
                "label": "Status",
                "variant": "badge"
              },
              {
                "variant": "caption",
                "name": "total",
                "label": "Total"
              },
              {
                "name": "currency",
                "label": "Currency",
                "variant": "badge"
              },
              {
                "label": "Due",
                "name": "dueAt",
                "variant": "caption"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the Invoice entity",
            "items": {
              "properties": {
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "gracePeriodDays",
            "type": "number",
            "default": 30,
            "label": "Grace period (days)",
            "description": "Days after dueAt before an invoice is treated as overdue. Wire via sibling std-lifecycle rule { fromStatus: 'sent', toStatus: 'overdue', condition: { kind: 'ageDays', value: gracePeriodDays, dateField: 'dueAt' } }."
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [
              {
                "event": "OPEN_INVOICE",
                "icon": "arrow-right",
                "label": "Open",
                "variant": "primary"
              },
              {
                "icon": "x",
                "event": "VOID",
                "label": "Void",
                "variant": "danger"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each invoice row",
            "items": {
              "properties": {
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "lateFeeAmount",
            "type": "number",
            "default": 0,
            "label": "Late fee amount",
            "description": "Flat cash amount or percentage (per lateFeePolicy)."
          },
          {
            "key": "lateFeePolicy",
            "type": "string",
            "default": "none",
            "label": "Late fee policy",
            "description": "How late fees compute when overdue: none = no fee; flat = lateFeeAmount as flat cash; percent = lateFeeAmount as % of total. v1.2 declarative; wiring requires a late-fee compute step (gap).",
            "enumValues": [
              "none",
              "flat",
              "percent"
            ]
          },
          {
            "key": "refundTiersJson",
            "type": "string",
            "default": "[]",
            "label": "Refund tiers",
            "description": "JSON list of refund options (e.g. 50% / 100%) shown on the detail view"
          },
          {
            "key": "retentionYears",
            "type": "number",
            "default": 7,
            "label": "Retention (years)",
            "description": "Years to keep invoice records for compliance. Default 7 matches common regimes. Wire via sibling std-lifecycle delete rule when available."
          },
          {
            "key": "roundingMode",
            "type": "string",
            "default": "half-up",
            "label": "Rounding mode",
            "description": "Sub-cent rounding behavior for line items and totals.",
            "enumValues": [
              "bankers",
              "half-up",
              "down"
            ]
          },
          {
            "key": "taxStrategy",
            "type": "string",
            "default": "exclusive",
            "label": "Tax strategy",
            "description": "inclusive = tax baked into the line item totals; exclusive = tax added on top; none = no tax.",
            "enumValues": [
              "inclusive",
              "exclusive",
              "none"
            ]
          },
          {
            "key": "title",
            "type": "string",
            "default": "Invoices",
            "label": "Section title",
            "description": "Heading shown above the invoice list"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "InvoiceManagePage",
        "defaultPath": "/invoices/manage",
        "primaryEntity": "InvoiceRecord"
      }
    ],
    "emittedEvents": [
      "CLOSE_VIEW",
      "InvoiceLoadFailed",
      "InvoiceLoaded",
      "InvoiceRefundFailed",
      "InvoiceRefunded",
      "InvoiceUpdateFailed",
      "InvoiceUpdated",
      "MARK_PAID",
      "OPEN_INVOICE",
      "REFUND",
      "SEND",
      "VOID"
    ],
    "listenedEvents": []
  }
]
