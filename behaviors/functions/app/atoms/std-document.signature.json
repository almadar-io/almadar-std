[
  {
    "organism": "std-document",
    "orbital": "DocumentOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/app/atoms/std-document.ts",
    "entities": [
      {
        "name": "Document",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "mimeType",
            "type": "string",
            "required": false
          },
          {
            "name": "classification",
            "type": "string",
            "required": false
          },
          {
            "name": "lockedBy",
            "type": "string",
            "required": false
          },
          {
            "name": "lockedAt",
            "type": "string",
            "required": false
          },
          {
            "name": "retentionUntil",
            "type": "string",
            "required": false
          },
          {
            "name": "legalHold",
            "type": "boolean",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "DocumentManage",
        "emittedEvents": [
          "OPEN_DOCUMENT",
          "CLOSE_VIEW",
          "LOCK",
          "UNLOCK",
          "DOWNLOAD",
          "REVOKE",
          "DocumentLoaded",
          "DocumentLoadFailed"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "allowedMimeTypes",
            "type": "[string]",
            "default": [
              "application/pdf",
              "application/msword",
              "image/png",
              "image/jpeg"
            ],
            "label": "Allowed MIME types",
            "description": "Upload accepts only these content types. Empty = any.",
            "synonyms": "file types",
            "tier": "domain",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "classificationLevels",
            "type": "[string]",
            "default": [
              "public",
              "internal",
              "confidential",
              "restricted"
            ],
            "label": "Classification levels",
            "description": "Allowed enum for the classification field.",
            "synonyms": "sensitivity, security levels",
            "tier": "domain",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "defaultRetentionYears",
            "type": "number",
            "default": 7,
            "label": "Default retention (years)",
            "description": "Years to keep a document before lifecycle-based deletion. Compose std-lifecycle to enforce.",
            "synonyms": "keep for, archive after",
            "tier": "domain"
          },
          {
            "key": "fields",
            "type": "[FieldSpec]",
            "default": [
              {
                "variant": "caption",
                "name": "title",
                "label": "Title"
              },
              {
                "name": "mimeType",
                "label": "Type",
                "variant": "caption"
              },
              {
                "variant": "badge",
                "name": "classification",
                "label": "Classification"
              },
              {
                "name": "lockedBy",
                "label": "Locked by",
                "variant": "caption"
              },
              {
                "label": "Retention",
                "variant": "caption",
                "name": "retentionUntil"
              }
            ],
            "label": "Columns to show",
            "description": "Each column maps to one field on the Document entity",
            "tier": "presentation",
            "items": {
              "properties": {
                "key": {
                  "name": "key",
                  "required": false,
                  "type": "string"
                },
                "header": {
                  "name": "header",
                  "required": false,
                  "type": "string"
                },
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "name": {
                  "name": "name",
                  "required": true,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": false,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "format": {
                  "name": "format",
                  "required": false,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "itemActions",
            "type": "[ItemAction]",
            "default": [
              {
                "label": "Open",
                "variant": "primary",
                "event": "OPEN_DOCUMENT",
                "icon": "arrow-right"
              },
              {
                "label": "Download",
                "icon": "download",
                "event": "DOWNLOAD",
                "variant": "secondary"
              }
            ],
            "label": "Row actions",
            "description": "Buttons users can click on each document row",
            "tier": "presentation",
            "items": {
              "properties": {
                "icon": {
                  "name": "icon",
                  "required": false,
                  "type": "string"
                },
                "event": {
                  "name": "event",
                  "required": true,
                  "type": "string"
                },
                "variant": {
                  "name": "variant",
                  "required": false,
                  "type": "string"
                },
                "label": {
                  "name": "label",
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          {
            "key": "legalHoldEnabled",
            "type": "boolean",
            "default": true,
            "label": "Honor legal hold",
            "description": "When true, retention policies skip docs marked legalHold=true.",
            "synonyms": "litigation hold",
            "tier": "domain"
          },
          {
            "key": "lockedStatus",
            "type": "string",
            "default": "soft",
            "label": "Lock behavior",
            "description": "soft = block edits w/ override; hard = block edits absolutely; none = informational only.",
            "tier": "domain",
            "enumValues": [
              "none",
              "soft",
              "hard"
            ]
          },
          {
            "key": "requireReasonOnDownload",
            "type": "boolean",
            "default": false,
            "label": "Require reason on download",
            "description": "Prompt the user to enter a justification when downloading restricted docs.",
            "tier": "domain"
          },
          {
            "key": "title",
            "type": "string",
            "default": "Documents",
            "label": "Section title",
            "description": "Heading shown above the documents list",
            "tier": "presentation"
          },
          {
            "key": "versionRetentionCount",
            "type": "number",
            "default": 10,
            "label": "Version retention count",
            "description": "Max prior versions kept per document. 0 = all.",
            "tier": "domain"
          },
          {
            "key": "watermarkPolicy",
            "type": "string",
            "default": "none",
            "label": "Watermark policy",
            "description": "Image overlay when rendering classified docs.",
            "tier": "domain",
            "enumValues": [
              "none",
              "viewer-id",
              "viewer-id-timestamp"
            ]
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "DocumentManagePage",
        "defaultPath": "/documents",
        "primaryEntity": "Document"
      }
    ],
    "emittedEvents": [
      "CLOSE_VIEW",
      "DOWNLOAD",
      "DocumentLoadFailed",
      "DocumentLoaded",
      "LOCK",
      "OPEN_DOCUMENT",
      "REVOKE",
      "UNLOCK"
    ],
    "listenedEvents": []
  }
]
