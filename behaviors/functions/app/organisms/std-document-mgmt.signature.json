      {
        "name": "DocumentStats",
        "emittedEvents": [],
        "listenedEvents": [
          "BrowseItemLoaded"
        ],
        "overridableConfigKeys": [
          {
            "key": "metrics",
            "type": "unknown",
            "default": [
              {
                "aggregation": "count",
                "icon": "file-text",
                "label": "Total",
                "variant": "primary",
                "format": "number"
              },
              {
                "variant": "success",
                "aggregation": "count",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "active"
                  ]
                ],
                "label": "Active",
                "format": "number",
                "icon": "check-circle"
              },
              {
                "aggregation": "count",
                "icon": "clock",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "pending-review"
                  ]
                ],
                "format": "number",
                "variant": "warning",
                "label": "Pending Review"
              },
              {
                "aggregation": "sum",
                "icon": "hard-drive",
                "field": "sizeBytes",
                "label": "Total Size",
                "variant": "primary",
                "format": "number"
              }
            ]
          },
          {
            "key": "title",
            "type": "unknown",
            "default": "Documents"
