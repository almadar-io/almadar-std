          },
          {
            "name": "mimeType",
            "type": "string",
            "required": false
          },
          {
            "name": "sizeBytes",
            "type": "number",
            "required": false
          },
          {
            "name": "owner",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "lastModified",
            "type": "string",
            "required": false
          },
          {
            "name": "pendingId",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
