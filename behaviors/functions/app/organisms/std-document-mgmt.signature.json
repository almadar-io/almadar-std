          {
            "key": "event",
            "type": "unknown",
            "default": "DOCUMENT_FILTER"
          },
          {
            "key": "filters",
            "type": "unknown",
            "default": [
              {
                "label": "Status",
                "options": [
                  "active",
                  "archived",
                  "pending-review"
                ],
                "field": "status",
                "filterType": "select"
              },
              {
                "options": [
                  "pdf",
                  "doc",
                  "text",
                  "image"
                ],
                "field": "mimeType",
                "filterType": "select",
                "label": "Type"
              }
            ]
          }
        ],
        "capabilities": [],
        "ref": "Filter.traits.FilterTargetFilter"
