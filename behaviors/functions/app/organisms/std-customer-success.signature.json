[
  {
    "organism": "std-customer-success",
    "orbital": "CustomerAccountOrbital",
    "tier": "organisms",
    "factoryPath": "behaviors/functions/app/organisms/std-customer-success.ts",
    "entities": [
      {
        "name": "CsAccount",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "plan",
            "type": "string",
            "required": false
          },
          {
            "name": "arrAmount",
            "type": "number",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          },
          {
            "name": "csm",
            "type": "string",
            "required": false
          },
          {
            "name": "renewalDate",
            "type": "string",
            "required": false
          },
          {
            "name": "signedAt",
            "type": "string",
            "required": false
          },
          {
            "name": "pendingId",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "persistent"
      }
    ],
    "traits": [
      {
        "name": "CsAccountAppLayout",
        "emittedEvents": [],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "appName",
            "type": "unknown",
            "default": "Customer Success"
          },
          {
            "key": "contentTrait",
            "type": "unknown",
            "default": "@trait.CsAccountCatalog"
          },
          {
            "key": "navItems",
            "type": "unknown",
            "default": [
              {
                "icon": "users",
                "href": "/cs-accounts",
                "label": "Accounts"
              },
              {
                "icon": "activity",
                "label": "Health Scores",
                "href": "/health-scores"
              },
              {
                "label": "NPS",
                "icon": "message-square",
                "href": "/nps-surveys"
              },
              {
                "href": "/renewal-risks",
                "label": "Renewal Risks",
                "icon": "alert-triangle"
              }
            ]
          },
          {
            "key": "notificationClickEvent",
            "type": "unknown",
            "default": "CS_ACCOUNT_NOTIFICATIONS_OPEN"
          },
          {
            "key": "notifications",
            "type": "unknown",
            "default": []
          },
          {
            "key": "searchEvent",
            "type": "unknown",
            "default": "CS_ACCOUNT_SEARCH"
          }
        ],
        "capabilities": [],
        "ref": "AppShell.traits.AppLayout"
      },
      {
        "name": "CsAccountCatalog",
        "emittedEvents": [
          "CREATE"
        ],
        "listenedEvents": [
          "CS_ACCOUNT_SEARCH",
          "CS_ACCOUNT_NOTIFICATIONS_OPEN"
        ],
        "overridableConfigKeys": [],
        "capabilities": []
      },
      {
        "name": "CsAccountSearch",
        "emittedEvents": [],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "event",
            "type": "unknown",
            "default": "CS_ACCOUNT_SEARCH"
          },
          {
            "key": "placeholder",
            "type": "unknown",
            "default": "Search accounts…"
          }
        ],
        "capabilities": [],
        "ref": "Search.traits.SearchResultSearch"
      },
      {
        "name": "CsAccountFilter",
        "emittedEvents": [],
        "listenedEvents": [],
        "overridableConfigKeys": [
          {
            "key": "event",
            "type": "unknown",
            "default": "CS_ACCOUNT_FILTER"
          },
          {
            "key": "filters",
            "type": "unknown",
            "default": [
              {
                "filterType": "select",
                "field": "plan",
                "options": [
                  "trial",
                  "starter",
                  "growth",
                  "enterprise"
                ],
                "label": "Plan"
              },
              {
                "field": "status",
                "label": "Status",
                "options": [
                  "onboarding",
                  "healthy",
                  "at-risk",
                  "churned",
                  "renewed"
                ],
                "filterType": "select"
              }
            ]
          }
        ],
        "capabilities": [],
        "ref": "Filter.traits.FilterTargetFilter"
      },
      {
        "name": "CsAccountStats",
        "emittedEvents": [],
        "listenedEvents": [
          "BrowseItemLoaded"
        ],
        "overridableConfigKeys": [
          {
            "key": "metrics",
            "type": "unknown",
            "default": [
              {
                "format": "number",
                "icon": "users",
                "aggregation": "count",
                "label": "Total",
                "variant": "primary"
              },
              {
                "format": "number",
                "variant": "success",
                "label": "Healthy",
                "icon": "check-circle",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "healthy"
                  ]
                ],
                "aggregation": "count"
              },
              {
                "icon": "alert-triangle",
                "aggregation": "count",
                "filter": [
                  "fn",
                  "row",
                  [
                    "=",
                    "@row.status",
                    "at-risk"
                  ]
                ],
                "label": "At Risk",
                "variant": "warning",
                "format": "number"
              },
              {
                "aggregation": "sum",
                "label": "Total ARR",
                "format": "number",
                "icon": "dollar-sign",
                "field": "arrAmount",
                "variant": "info"
              }
            ]
          },
          {
            "key": "title",
            "type": "unknown",
            "default": "Customer Success"
          }
        ],
        "capabilities": [],
        "ref": "Stats.traits.StatsItemStats"
      },
