[
  {
    "organism": "std-service-oauth",
    "orbital": "ServiceOauthOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/service/atoms/std-service-oauth.ts",
    "entities": [
      {
        "name": "ServiceOauth",
        "fields": [
          {
            "name": "provider",
            "type": "string",
            "required": false
          },
          {
            "name": "accessToken",
            "type": "string",
            "required": false
          },
          {
            "name": "authStatus",
            "type": "string",
            "required": false
          },
          {
            "name": "error",
            "type": "string",
            "required": false
          },
          {
            "name": "name",
            "type": "string",
            "required": false
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "ServiceOauthDefaultForm",
        "emittedEvents": [
          "LOGIN"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [],
        "capabilities": [
          "identity",
          "oauth"
        ]
      },
      {
        "name": "ServiceOauthOauth",
        "emittedEvents": [
          "ServiceOauthLoaded",
          "ServiceOauthLoadFailed",
          "OAuthLoggedIn",
          "ServiceOauthOauthFailed",
          "FAILED"
        ],
        "listenedEvents": [
          "LOGIN"
        ],
        "overridableConfigKeys": [
          {
            "key": "provider",
            "type": "string",
            "default": "google",
            "label": "Identity provider",
            "description": "Which OAuth vendor handles sign-in (Google, GitHub, Microsoft, Okta)",
            "enumValues": [
              "google",
              "github",
              "microsoft",
              "okta"
            ]
          },
          {
            "key": "redirectUri",
            "type": "string",
            "default": "",
            "label": "Redirect URL",
            "description": "Callback URL the provider returns the user to after sign-in"
          },
          {
            "key": "scopes",
            "type": "[string]",
            "default": [],
            "label": "Requested scopes",
            "description": "Permission scopes requested from the OAuth provider",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "uiTrait",
            "type": "trait",
            "default": "@trait.ServiceOauthDefaultForm",
            "label": "Sign-in form",
            "description": "Trait that renders the OAuth provider button UI"
          }
        ],
        "capabilities": [
          "identity",
          "oauth"
        ]
      }
    ],
    "pages": [
      {
        "name": "ServiceOauthPage",
        "defaultPath": "/serviceoauths",
        "primaryEntity": "ServiceOauth"
      }
    ],
    "emittedEvents": [
      "FAILED",
      "LOGIN",
      "OAuthLoggedIn",
      "ServiceOauthLoadFailed",
      "ServiceOauthLoaded",
      "ServiceOauthOauthFailed"
    ],
    "listenedEvents": [
      "LOGIN"
    ]
  }
]
