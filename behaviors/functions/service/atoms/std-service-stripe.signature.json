            "name": "currency",
            "type": "string",
            "required": false
          },
          {
            "name": "paymentIntentId",
            "type": "string",
            "required": false
          },
          {
            "name": "clientSecret",
            "type": "string",
            "required": false
          },
          {
            "name": "paymentStatus",
            "type": "string",
            "required": false
          },
          {
            "name": "error",
            "type": "string",
            "required": false
          },
          {
            "name": "name",
            "type": "string",
            "required": false
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "ServiceStripeDefaultForm",
        "emittedEvents": [
          "CREATE_PAYMENT"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [],
        "capabilities": []
      },
      {
        "name": "ServiceStripeStripe",
        "emittedEvents": [
          "ServiceStripeLoaded",
          "ServiceStripeLoadFailed",
          "ServiceStripeStripeCompleted",
          "ServiceStripeStripeFailed",
          "PAYMENT_CREATED",
          "PAYMENT_CONFIRMED",
          "FAILED"
        ],
        "listenedEvents": [
          "CREATE_PAYMENT"
        ],
        "overridableConfigKeys": [
          {
            "key": "amount",
            "type": "number",
            "default": 0,
            "label": "Charge amount",
            "description": "Amount to charge in the smallest currency unit (cents for USD)",
            "tier": "customization"
          },
          {
            "key": "currency",
            "type": "string",
            "default": "usd",
            "label": "Currency code",
            "description": "ISO 4217 currency code Stripe should charge in (e.g. usd, eur)",
            "tier": "customization"
          },
          {
            "key": "metadata",
            "type": "StripeMetadata",
            "default": {
              "customerEmail": "",
              "orderId": ""
            },
            "label": "Stripe metadata",
            "description": "Metadata attached to the Stripe charge (orderId for fulfillment correlation, customerEmail for receipt routing). Empty strings are dropped before sending to Stripe.",
            "tier": "advanced",
            "properties": {
              "orderId": {
                "name": "orderId",
                "required": false,
                "type": "string"
              },
              "customerEmail": {
                "name": "customerEmail",
                "required": false,
                "type": "string"
              }
            }
          },
          {
            "key": "uiTrait",
            "type": "trait",
            "default": "@trait.ServiceStripeDefaultForm",
            "label": "Card form",
            "description": "Trait that renders the Stripe Elements card UI",
            "tier": "internal"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "ServiceStripePage",
