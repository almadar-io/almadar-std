[
  {
    "organism": "std-service-storage",
    "orbital": "ServiceStorageOrbital",
    "tier": "atoms",
    "factoryPath": "behaviors/functions/service/atoms/std-service-storage.ts",
    "entities": [
      {
        "name": "ServiceStorage",
        "fields": [
          {
            "name": "bucket",
            "type": "string",
            "required": false
          },
          {
            "name": "fileKey",
            "type": "string",
            "required": false
          },
          {
            "name": "url",
            "type": "string",
            "required": false
          },
          {
            "name": "storageStatus",
            "type": "string",
            "required": false
          },
          {
            "name": "error",
            "type": "string",
            "required": false
          },
          {
            "name": "name",
            "type": "string",
            "required": false
          },
          {
            "name": "description",
            "type": "string",
            "required": false
          },
          {
            "name": "status",
            "type": "string",
            "required": false
          }
        ],
        "persistence": "runtime"
      }
    ],
    "traits": [
      {
        "name": "ServiceStorageDefaultForm",
        "emittedEvents": [
          "UPLOAD"
        ],
        "listenedEvents": [],
        "overridableConfigKeys": [],
        "capabilities": []
      },
      {
        "name": "ServiceStorageStorage",
        "emittedEvents": [
          "ServiceStorageLoaded",
          "ServiceStorageLoadFailed",
          "StorageUploaded",
          "ServiceStorageStorageFailed",
          "FAILED"
        ],
        "listenedEvents": [
          "UPLOAD"
        ],
        "overridableConfigKeys": [
          {
            "key": "acl",
            "type": "string",
            "default": "private",
            "label": "Access level",
            "description": "Whether uploaded files are publicly readable or private",
            "tier": "customization",
            "enumValues": [
              "public",
              "private"
            ]
          },
          {
            "key": "allowedMimeTypes",
            "type": "[string]",
            "default": [],
            "label": "Allowed types",
            "description": "MIME types the upload accepts (empty list = allow all)",
            "tier": "advanced",
            "items": {
              "type": "string"
            }
          },
          {
            "key": "bucket",
            "type": "string",
            "default": "",
            "label": "Bucket name",
            "description": "Object storage bucket files are uploaded into",
            "tier": "customization"
          },
          {
            "key": "maxSize",
            "type": "number",
            "default": 10485760,
            "label": "Max file size",
            "description": "Largest accepted upload size in bytes (default 10 MB)",
            "tier": "advanced"
          },
          {
            "key": "uiTrait",
            "type": "trait",
            "default": "@trait.ServiceStorageDefaultForm",
            "label": "Upload form",
            "description": "Trait that renders the file picker UI",
            "tier": "internal"
          }
        ],
        "capabilities": []
      }
    ],
    "pages": [
      {
        "name": "ServiceStoragePage",
        "defaultPath": "/servicestorages",
        "primaryEntity": "ServiceStorage"
      }
    ],
    "emittedEvents": [
      "FAILED",
      "ServiceStorageLoadFailed",
      "ServiceStorageLoaded",
      "ServiceStorageStorageFailed",
      "StorageUploaded",
      "UPLOAD"
    ],
    "listenedEvents": [
      "UPLOAD"
    ]
  }
]
